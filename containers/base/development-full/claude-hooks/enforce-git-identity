#!/usr/bin/env bash
# Blocks git subcommands that create/rewrite commits (or that precede one, like
# `fetch`) unless git identity and GPG signing are correctly configured.
# The die() helper is intentionally minimal (not the shell-scripts.examples.md
# die()/info() convention) — this script only ever needs a single stderr
# message plus a non-zero exit, matching its sibling enforce-git-dash-c.
# Exit 2 = blocked, 0 = allowed.

die() {
  printf 'Blocked: %s\n' "$*" >&2
  exit 2
}

# Strips heredoc bodies (the part between `<<[-]DELIM` and the closing DELIM
# line) out of a multi-line command string before it's pattern-matched.
# Without this, a Bash call that merely *writes* example/doc/test-script text
# containing a line that starts with "git commit" etc. (e.g. via `cat <<EOF`)
# is indistinguishable from an actual git invocation, and gets blocked (or
# identity-checked) for no reason. Only the common, unescaped-delimiter forms
# (`<<EOF`, `<<'EOF'`, `<<"EOF"`, `<<-EOF`, ...) are recognised; anything more
# exotic (backslash-escaped delimiters, delimiters preceded by other
# redirections on the same line) falls back to the old un-stripped behaviour.
strip_heredocs() {
  local line dash delim="" in_heredoc=0 trimmed
  while IFS= read -r line || [ -n "$line" ]; do
    if [ "$in_heredoc" = "1" ]; then
      if [ "$dash" = "-" ]; then
        trimmed=$(printf '%s' "$line" | sed -E 's/^\t+//')
        [ "$trimmed" = "$delim" ] && in_heredoc=0
      else
        [ "$line" = "$delim" ] && in_heredoc=0
      fi
      continue
    fi
    if [[ "$line" =~ \<\<(-)?[[:space:]]*[\"\']?([A-Za-z_][A-Za-z0-9_]*)[\"\']?[[:space:]]*$ ]]; then
      dash="${BASH_REMATCH[1]}"
      delim="${BASH_REMATCH[2]}"
      in_heredoc=1
    fi
    printf '%s\n' "$line"
  done <<< "$1"
}

# Subcommands that create/rewrite commits, plus `fetch` (checked up front so
# a broken identity is caught before work starts, not after it's done).
SUBCMDS='commit|fetch|pull|rebase|merge|cherry-pick|revert|am'

# A single flag value: a "..."/'...'-quoted token (which may contain spaces),
# or a plain space-free token.
VALTOKEN="(\"[^\"]*\"|'[^']*'|[^[:space:]]+)"

# Zero or more `-C <dir>` / `-c <key>=<value>` global option pairs, in any
# order, before the subcommand — e.g. `git -c core.pager=cat -C /repo commit`.
FLAGS="((-C|-c)[[:space:]]+${VALTOKEN}[[:space:]]+)*"

input=$(cat)
raw_cmd=$(printf '%s' "$input" | jq -r '.tool_input.command // .command // ""')
cmd=$(strip_heredocs "$raw_cmd")

# Only run these checks for commands that actually invoke one of $SUBCMDS.
# Matched against trailing whitespace/end (not \b) so `commit-graph` etc.
# (unrelated plumbing commands) aren't mistaken for `commit`.
GATE="(^|;|&&|\\|\\|)[[:space:]]*git[[:space:]]+${FLAGS}(${SUBCMDS})([[:space:]]|\$)"
printf '%s' "$cmd" | grep -qE "$GATE" || exit 0

# Re-extract the exact matched invocation (same anchored pattern as the gate,
# so this can't drift from — or be tricked by unrelated text elsewhere in the
# command into disagreeing with — what actually triggered the check), then
# pull the `-C` value (if any) out of *that* scoped text only.
invocation=$(printf '%s' "$cmd" | grep -oE "$GATE" | head -1)

git_dir_args=()
repo=$(printf '%s' "$invocation" | grep -oE -- "-C[[:space:]]+${VALTOKEN}" | head -1 \
  | sed -E 's/^-C[[:space:]]+//; s/^"(.*)"$/\1/; s/^'"'"'(.*)'"'"'$/\1/')
[ -n "$repo" ] && git_dir_args=(-C "$repo")

git_cfg() {
  git "${git_dir_args[@]}" config "$1" 2>/dev/null
}

CURRENT_EMAIL=$(git_cfg user.email)

[ -z "$CURRENT_EMAIL" ] && die "git user.email is not set — run: git config --global user.email \"you@example.com\""

[ "$CURRENT_EMAIL" = "andy@nanoclaw.ai" ] && die "git is configured with the wrong identity (${CURRENT_EMAIL}) — aborting"

[ "$(git_cfg commit.gpgsign)" = "true" ] || die "GPG signing is not enabled — run: git config --global commit.gpgsign true"

command -v gpg > /dev/null 2>&1 || die "gpg is not installed — cannot verify signing key"

gpg --list-secret-keys "$CURRENT_EMAIL" > /dev/null 2>&1 \
    || die "no GPG secret key found for ${CURRENT_EMAIL} — run: gpg --gen-key"

SIGNING_KEY=$(git_cfg user.signingkey)
[ -z "$SIGNING_KEY" ] && die "git user.signingkey is not set — run: git config --global user.signingkey <keyid>"

signing_key_info=$(gpg --list-secret-keys "$SIGNING_KEY" 2>/dev/null)
[ -n "$signing_key_info" ] \
    || die "git user.signingkey (${SIGNING_KEY}) not found in GPG keyring"

printf '%s' "$signing_key_info" | grep -qF "$CURRENT_EMAIL" \
    || die "git user.signingkey (${SIGNING_KEY}) is not associated with ${CURRENT_EMAIL}"

exit 0
