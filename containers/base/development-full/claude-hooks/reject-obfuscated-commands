#!/usr/bin/env bash
# Rejects Bash commands whose command-name token isn't a plain, obvious bare
# word, instead of chasing individual bypass techniques through each
# downstream hook's own detection logic (see PR #1105/#1159: six review
# rounds each found a new *obfuscation* technique — quote-splice, escape,
# substitution, separator, brace-expansion, redirection-prefix — because an
# enumerated denylist of "bad shapes" is inherently incomplete). Runs first,
# ahead of every other PreToolUse hook, so obfuscation is refused
# categorically up front.
#
# Design (round 6+): a positive allowlist on the command-name token, not an
# enumeration of bad constructs. The command-name token — the first word of
# a statement, or the first word after a separator (;, &, &&, |, ||, (, {,
# backtick), an `IDENT=value` assignment prefix, or a pass-through wrapper
# (sudo, env, exec, command, time, nice, nohup, doas, stdbuf, builtin, !) —
# must match ^[A-Za-z0-9_./-]+$ once quoting/substitution/brace-expansion
# has been neutralized to a single SENTINEL placeholder char (see
# neutralize_quotes). Any quote-splice ("g""it"), backslash-escape (g\it),
# $()/backtick/$VAR substitution, or brace-expansion group ({git,push})
# leaves a SENTINEL, `$`, or `\` in the token, which the allowlist rejects
# without needing a dedicated check per technique — it also rejects a
# leading redirection operator (`2>/dev/null git push`) for free, since `>`
# isn't in the allowed set. `eval` is rejected outright — indirect string
# execution has no "simple" reading.
#
# Interpreter re-invocation (`bash -c "git push"`, `python3 -c "..."`, ...)
# is a separate, categorical carve-out: the command name (`bash`, `python3`)
# is a perfectly plain bare word, and its inline-code argument is ordinary
# quoted text that neutralize_quotes correctly treats as inert — nothing
# about the *character shape* is wrong, so the allowlist alone can't catch
# it. See is_interpreter/has_inline_code_flag below.
#
# Also rejects any non-printable or non-ASCII byte anywhere in the command
# (control bytes, Unicode homoglyphs of shell metacharacters, zero-width/
# bidi-override characters) — not metacharacters themselves (`;`, `|`, `$`
# etc. all stay legal; segmentation/hardening downstream is what deals with
# those).
#
# Deliberately NOT covered: path-qualified binaries (/usr/bin/git, ./git).
# This container's own mandated workflows invoke hooks via absolute/relative
# path (e.g. `<hooks-path>/pre-commit`, see ai/global/git.instructions.md) —
# a blanket ban on "/" in the command-name token would block that legitimate,
# documented usage. Left to a narrower, path-aware follow-up.
#
# This is a categorical, defense-in-depth guard, not a replacement for
# per-command hooks like enforce-git-dash-c: it says nothing about whether a
# non-obfuscated command is otherwise *allowed* (e.g. `git push` without -C
# is plainly spelled out, not obfuscated, and is still blocked downstream by
# enforce-git-dash-c). Exit 2 = blocked, 0 = allowed.
#
# Deliberately a first pass, not the final word (per credfeto's direction on
# PR #1159): the interpreter list and inline-code-flag list below are small
# and may over-block or under-block at the margins — intended to be relaxed
# once the categorical shape has proven itself, not enumerated exhaustively
# now.

# Strips heredoc bodies out of a multi-line command string before it's
# pattern-matched, so example/doc/test-script text written via `cat <<EOF`
# isn't mistaken for a live command. See enforce-git-dash-c's identical
# helper for the detailed rationale.
strip_heredocs() {
  local line dash delim="" in_heredoc=0 trimmed
  while IFS= read -r line || [ -n "$line" ]; do
    if [ "$in_heredoc" = "1" ]; then
      if [ "$dash" = "-" ]; then
        trimmed=$(printf '%s' "$line" | sed -E 's/^\t+//')
        [ "$trimmed" = "$delim" ] && in_heredoc=0
      else
        [ "$line" = "$delim" ] && in_heredoc=0
      fi
      continue
    fi
    if [[ "$line" =~ \<\<(-)?[[:space:]]*[\"\']?([A-Za-z_][A-Za-z0-9_]*)[\"\']?[[:space:]]*$ ]]; then
      dash="${BASH_REMATCH[1]}"
      delim="${BASH_REMATCH[2]}"
      in_heredoc=1
    fi
    printf '%s\n' "$line"
  done <<< "$1"
}

# A single non-whitespace, non-newline control character used as a
# placeholder for every quoted/substituted span neutralize_quotes blanks
# out. Unlike a literal space, it survives into a segment's first
# whitespace-delimited word, so check_segment can tell "this token had
# quoting/substitution spliced into it" apart from an all-bare token —
# a plain space would make "g""it" indistinguishable from two bare words.
SENTINEL=$'\x01'

# Walks a command string one character at a time and, into the globals
# NEUTRALIZED and EXTRA_SEGMENTS:
#   * blanks out single-quoted text entirely to one SENTINEL char — it is
#     inert in POSIX/bash, so metacharacters inside it must not be treated
#     as statement separators, but its presence must still mark the
#     enclosing word as non-bare;
#   * blanks out double-quoted text the same way, EXCEPT any `$( ... )` or
#     `` ` ` `` command substitution nested inside it, which is queued into
#     EXTRA_SEGMENTS for its own recursive check — that content executes
#     regardless of the quotes around it, e.g. `echo "$(git push)"`;
#   * queues top-level (unquoted) `$( ... )` / backtick substitution the
#     same way, blanking it to one SENTINEL char too — a live substitution
#     used as a command name (e.g. `$(echo git) push`) must not be mistaken
#     for a plain word either;
#   * blanks a top-level brace-expansion group (`{a,b}`, `{1..5}` — see
#     extract_brace_expansion) to one SENTINEL char too, for the same
#     reason: it is only actually dangerous when it lands in the
#     command-name word (`{git,push}`), and blanking rather than an
#     outright whole-command reject means it is correctly left alone, like
#     a quoted argument, when it's just an ordinary argument word (e.g.
#     `mkdir -p dir/{a,b}` must stay allowed — check_segment only ever
#     inspects the command-name word, never the rest of the segment);
#   * leaves every other character untouched so the caller's
#     statement-separator split still applies to real, unquoted operators.
neutralize_quotes() {
  local s="$1" c i=0 len
  NEUTRALIZED=""
  len=${#s}
  while [ "$i" -lt "$len" ]; do
    c="${s:$i:1}"
    case "$c" in
      \')
        i=$((i + 1))
        while [ "$i" -lt "$len" ] && [ "${s:$i:1}" != "'" ]; do
          i=$((i + 1))
        done
        i=$((i + 1))
        NEUTRALIZED+="$SENTINEL"
        ;;
      \")
        i=$((i + 1))
        while [ "$i" -lt "$len" ] && [ "${s:$i:1}" != '"' ]; do
          c="${s:$i:1}"
          if [ "$c" = $'\\' ] && [ $((i + 1)) -lt "$len" ]; then
            i=$((i + 2))
            continue
          fi
          if [ "$c" = '$' ] && [ "${s:$((i + 1)):1}" = '(' ]; then
            extract_substitution "$s" "$i" '(' ')' 2
            i="$SUBST_NEXT_I"
            continue
          fi
          if [ "$c" = '`' ]; then
            extract_substitution "$s" "$i" '`' '`' 1
            i="$SUBST_NEXT_I"
            continue
          fi
          i=$((i + 1))
        done
        i=$((i + 1))
        NEUTRALIZED+="$SENTINEL"
        ;;
      '$')
        if [ "${s:$((i + 1)):1}" = '(' ]; then
          extract_substitution "$s" "$i" '(' ')' 2
          i="$SUBST_NEXT_I"
          NEUTRALIZED+="$SENTINEL"
        else
          NEUTRALIZED+="$c"
          i=$((i + 1))
        fi
        ;;
      '`')
        extract_substitution "$s" "$i" '`' '`' 1
        i="$SUBST_NEXT_I"
        NEUTRALIZED+="$SENTINEL"
        ;;
      '{')
        extract_brace_expansion "$s" "$i"
        if [ "$IS_BRACE_EXPANSION" = "1" ]; then
          i="$BRACE_NEXT_I"
          NEUTRALIZED+="$SENTINEL"
        else
          NEUTRALIZED+="$c"
          i=$((i + 1))
        fi
        ;;
      *)
        NEUTRALIZED+="$c"
        i=$((i + 1))
        ;;
    esac
  done
}

# Extracts the content of a `$( ... )` or `` ` ... ` `` substitution starting
# at index $2 in string $1, honouring nested "open" characters and skipping
# over single-/double-quoted spans (with backslash-escapes) while hunting
# for the matching close character — identical logic to enforce-git-dash-c's
# helper of the same name; see there for the detailed rationale. Appends the
# extracted content to EXTRA_SEGMENTS and sets SUBST_NEXT_I to the index
# just past the closing character.
extract_substitution() {
  local s="$1" start="$2" open="$3" close="$4" head_len="$5" depth=1
  local j=$((start + head_len))
  local len=${#s}
  local c
  while [ "$j" -lt "$len" ] && [ "$depth" -gt 0 ]; do
    c="${s:$j:1}"
    case "$c" in
      \')
        j=$((j + 1))
        while [ "$j" -lt "$len" ] && [ "${s:$j:1}" != "'" ]; do
          j=$((j + 1))
        done
        ;;
      \")
        j=$((j + 1))
        while [ "$j" -lt "$len" ] && [ "${s:$j:1}" != '"' ]; do
          if [ "${s:$j:1}" = $'\\' ] && [ $((j + 1)) -lt "$len" ]; then
            j=$((j + 2))
            continue
          fi
          j=$((j + 1))
        done
        ;;
      "$open") [ "$open" = "$close" ] && depth=$((depth - 1)) || depth=$((depth + 1)) ;;
      "$close") depth=$((depth - 1)) ;;
    esac
    j=$((j + 1))
  done
  local content_len=$((j - start - head_len - 1))
  [ "$content_len" -lt 0 ] && content_len=0
  EXTRA_SEGMENTS+=("${s:$((start + head_len)):${content_len}}")
  SUBST_NEXT_I=$j
}

# Finds the `}` matching the `{` at index $2 in string $1 (simple depth
# counting — braces are not valid inside brace-expansion content, so no
# quote-awareness is needed here, unlike extract_substitution). Sets
# IS_BRACE_EXPANSION=1 and BRACE_NEXT_I (index just past the closing `}`)
# when the content between the braces is expansion syntax — comma-separated
# alternatives or a `..` range, e.g. {a,b}, {a,b,c}, {1..5} — and nothing
# else (in particular, no whitespace anywhere in the content). That
# whitespace exclusion is what tells expansion syntax apart from a
# `{ cmd; }` compound-command group: bash requires whitespace right after
# `{` and right before `}` to parse the reserved-word group form, so its
# absence here means this is expansion, not a group — e.g. `{ git push; }`
# leaves IS_BRACE_EXPANSION=0 so the caller falls through to treating `{`/`}`
# as plain statement separators, same as before this function existed.
# Unmatched braces (no closing `}` found) also leave IS_BRACE_EXPANSION=0.
# Expansion is blanked to a SENTINEL rather than reconstructed and
# re-checked because, unlike $()/backtick substitution, its output can
# splice directly into an adjacent bare word with no quoting, escaping, or
# substitution marker left behind (e.g. {git,push} runtime-expands to the
# two words "git" "push").
extract_brace_expansion() {
  local s="$1" start="$2" depth=1
  local j=$((start + 1))
  local len=${#s}
  IS_BRACE_EXPANSION=0
  while [ "$j" -lt "$len" ] && [ "$depth" -gt 0 ]; do
    case "${s:$j:1}" in
      '{') depth=$((depth + 1)) ;;
      '}') depth=$((depth - 1)) ;;
    esac
    j=$((j + 1))
  done
  [ "$depth" -gt 0 ] && return
  local content_len=$((j - start - 2))
  [ "$content_len" -lt 0 ] && content_len=0
  local content="${s:$((start + 1)):${content_len}}"
  if [[ "$content" =~ ^[^{}[:space:]]*(,|\.\.)[^{}[:space:]]*$ ]]; then
    IS_BRACE_EXPANSION=1
    BRACE_NEXT_I=$j
  fi
}

# Recursively collects every candidate "statement" segment from $1 into the
# global all_segments array: one pass splits the quote-neutralized text on
# statement separators (;, &, && , a bare |, ||, parentheses/subshells,
# brace groups, backtick) — then each live substitution queued by
# neutralize_quotes is checked the same way, recursively.
collect_segments() {
  local text="$1" seg sub
  EXTRA_SEGMENTS=()
  neutralize_quotes "$text"
  while IFS= read -r seg; do
    all_segments+=("$seg")
  done < <(printf '%s\n' "$NEUTRALIZED" | sed -E 's/(;|&&?|\|\|?|\(|\)|\{|\}|`)/\n/g')
  for sub in "${EXTRA_SEGMENTS[@]}"; do
    collect_segments "$sub"
  done
}

WRAPPERS=(sudo env exec command time nice nohup doas stdbuf builtin)

is_wrapper() {
  local w
  for w in "${WRAPPERS[@]}"; do
    [ "$1" = "$w" ] && return 0
  done
  return 1
}

# Interpreters whose inline-code flag lets an arbitrary string be parsed and
# executed as new code, re-invoking a bare command from inside a command
# name that is itself perfectly plain (see the module doc comment). Not
# exhaustive by design — see credfeto's PR #1159 direction to start narrow
# and relax later.
INTERPRETERS=(bash sh dash zsh ksh mksh csh tcsh python python2 python3 perl perl5 ruby irb node nodejs deno php lua lua5.1 lua5.3 tclsh wish osascript)

# Flags that hand one of the interpreters above a string to parse and run as
# code, rather than a script file to read. Deliberately excludes flags like
# ruby's `-E`/node's `-c` that don't execute inline code.
INLINE_CODE_FLAGS=(-c -e --eval --command -ne -pe)

is_interpreter() {
  local w
  for w in "${INTERPRETERS[@]}"; do
    [ "$1" = "$w" ] && return 0
  done
  return 1
}

has_inline_code_flag() {
  local tok flag
  # shellcheck disable=SC2086  # intentional word-splitting to tokenize the rest of the segment
  for tok in $1; do
    for flag in "${INLINE_CODE_FLAGS[@]}"; do
      [ "$tok" = "$flag" ] && return 0
    done
  done
  return 1
}

# Walks the leading words of a segment, stripping `IDENT=value` assignment
# prefixes and pass-through wrappers, until it reaches the actual
# command-name token — then checks that token is a single plain bare word
# via a positive allowlist (^[A-Za-z0-9_./-]+$): anything else (a SENTINEL
# from quoting/substitution/brace-expansion — see
# neutralize_quotes/extract_brace_expansion — a backslash escape, a literal
# `$` from a bare $VAR/${VAR} expansion, a redirection operator, or any
# other non-alphanumeric character) fails the allowlist and is rejected,
# with no need for a dedicated check per obfuscation technique. Finally,
# rejects the segment outright if the (now-validated bare) command name is a
# known interpreter being handed an inline-code flag — see INTERPRETERS /
# INLINE_CODE_FLAGS above.
check_segment() {
  local trimmed first_word rest
  trimmed=$(printf '%s' "$1" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')
  while :; do
    [ -z "$trimmed" ] && return 0
    read -r first_word rest <<< "$trimmed"
    if [[ "$first_word" =~ ^[A-Za-z_][A-Za-z0-9_]*=.*$ ]]; then
      trimmed="$rest"
      continue
    fi
    if [ "$first_word" = "!" ] || is_wrapper "$first_word"; then
      trimmed="$rest"
      continue
    fi
    if [ "$first_word" = "eval" ]; then
      printf 'Blocked: eval used for indirect/obfuscated execution\n' >&2
      exit 2
    fi
    if ! [[ "$first_word" =~ ^[A-Za-z0-9_./-]+$ ]]; then
      printf 'Blocked: command name is quoted, escaped, or dynamically substituted - not a simple, obvious command\n' >&2
      exit 2
    fi
    if is_interpreter "${first_word##*/}" && has_inline_code_flag "$rest"; then
      printf 'Blocked: interpreter re-invocation with inline code is not a simple, obvious command\n' >&2
      exit 2
    fi
    return 0
  done
}

# Rejects the whole (heredoc-stripped) command outright if any byte falls
# outside ordinary printable ASCII (0x20-0x7E) plus tab/newline/CR — see the
# module doc comment for what this catches that character-shape checks on
# individual tokens don't.
NON_PRINTABLE_RE=$'[^ -~\t\n\r]'

reject_non_ascii() {
  if [[ "$1" =~ $NON_PRINTABLE_RE ]]; then
    printf 'Blocked: command contains non-printable or non-ASCII characters\n' >&2
    exit 2
  fi
}

input=$(cat)
raw_cmd=$(printf '%s' "$input" | jq -r '.tool_input.command // .command // ""')
cmd=$(strip_heredocs "$raw_cmd")

reject_non_ascii "$cmd"

all_segments=()
collect_segments "$cmd"

for segment in "${all_segments[@]}"; do
  check_segment "$segment"
done

exit 0
