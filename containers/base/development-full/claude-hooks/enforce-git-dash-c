#!/usr/bin/env bash
# Blocks git commands that don't use `git -C <dir>` format.
# Exit 2 = blocked, 0 = allowed.

# Strips heredoc bodies out of a multi-line command string before it's
# pattern-matched. Without this, a Bash call that merely *writes*
# example/doc/test-script text containing a line that starts with "git ..."
# (e.g. via `cat <<EOF`) is indistinguishable from an actual git invocation,
# and gets blocked for no reason. Only the common, unescaped-delimiter forms
# (`<<EOF`, `<<'EOF'`, `<<"EOF"`, `<<-EOF`, ...) are recognised; anything more
# exotic falls back to the old un-stripped behaviour.
strip_heredocs() {
  local line dash delim="" in_heredoc=0 trimmed
  while IFS= read -r line || [ -n "$line" ]; do
    if [ "$in_heredoc" = "1" ]; then
      if [ "$dash" = "-" ]; then
        trimmed=$(printf '%s' "$line" | sed -E 's/^\t+//')
        [ "$trimmed" = "$delim" ] && in_heredoc=0
      else
        [ "$line" = "$delim" ] && in_heredoc=0
      fi
      continue
    fi
    if [[ "$line" =~ \<\<(-)?[[:space:]]*[\"\']?([A-Za-z_][A-Za-z0-9_]*)[\"\']?[[:space:]]*$ ]]; then
      dash="${BASH_REMATCH[1]}"
      delim="${BASH_REMATCH[2]}"
      in_heredoc=1
    fi
    printf '%s\n' "$line"
  done <<< "$1"
}

# A single flag value: a "..."/'...'-quoted token (which may contain spaces),
# or a plain space-free token.
VALTOKEN="(\"[^\"]*\"|'[^']*'|[^[:space:]]+)"

# Zero or more `-c <key>=<value>` global option pairs that may legitimately
# appear before `-C` — e.g. `git -c core.pager=cat -C /repo status`.
DASH_C_FLAGS="(-c[[:space:]]+${VALTOKEN}[[:space:]]+)*"

input=$(cat)
raw_cmd=$(printf '%s' "$input" | jq -r '.tool_input.command // .command // ""')
cmd=$(strip_heredocs "$raw_cmd")

# Split the command into individual invocations on statement separators
# (;, &&, ||, a bare |), command-substitution/backtick boundaries ($( ` ),
# and parentheses (subshells), so each git invocation is checked on its own.
# A single whole-command check would let one hardened `git -C` earlier in a
# chain satisfy the check while a later bare `git` slips through, e.g.
# `git -C . status && git push --force` or `x=$(git rev-parse HEAD)`.
segments=$(printf '%s' "$cmd" | sed -E 's/(;|&&|\|\|?|\(|\)|`)/\n/g')

while IFS= read -r segment; do
  trimmed=$(printf '%s' "$segment" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')
  [[ "$trimmed" =~ ^git([[:space:]]|$) ]] || continue
  if ! [[ "$trimmed" =~ ^git[[:space:]]+${DASH_C_FLAGS}-C([[:space:]]|$) ]]; then
    printf 'Blocked: git commands must use "git -C <dir>" format\n' >&2
    exit 2
  fi
done <<< "$segments"

exit 0
