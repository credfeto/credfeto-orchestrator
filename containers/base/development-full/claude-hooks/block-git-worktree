#!/usr/bin/env bash
# Blocks `git worktree add` outright — the subcommand that creates a new
# linked worktree. Other worktree subcommands (list/remove/prune/lock/
# unlock/move/repair/...) are inspection or cleanup of worktrees that
# already exist and are left alone.
# Exit 2 = blocked, 0 = allowed.
#
# Git worktrees split repo state across multiple linked checkouts that share
# one object store and one set of refs. That composes badly with this
# project's tooling, which assumes a single checkout per repo directory —
# an errant `git worktree add` has previously left the primary checkout
# registered as bare with no work tree of its own, breaking `git pull`/
# `git status` there until manually repaired.
#
# Parses with shfmt (mvdan/sh) and walks the resulting AST, same approach as
# the sibling enforce-git-dash-c (see that script's header for the full
# rationale) — text/regex scanning for `worktree` would miss obfuscated
# forms and false-positive on unrelated text, so this only inspects the
# subcommand position of an actual git call expression.
#
# Obfuscated command names (quote-splices, substitutions, ${IFS} games) are
# NOT this hook's job — reject-obfuscated-commands rejects those
# categorically before this hook ever runs. Anything here that is not a
# plain literal word is deliberately treated as opaque.
#
# Fails closed: shfmt missing or the command not parsing as shell blocks
# the command.

# Byte-exact pattern semantics regardless of the host locale.
export LC_ALL=C

block() {
  printf 'Blocked: %s\n' "$1" >&2
  exit 2
}

# Known wrapper names for the defense-in-depth `sudo git worktree ...` check
# below — mirrors the "Wrapper commands" section of command-blocklist, which
# is what actually bans these upstream in the normal PreToolUse chain.
WRAPPERS=(env nice command sudo doas exec nohup stdbuf builtin setsid timeout ionice taskset chroot nsenter flock watch time)

is_wrapper() {
  local w
  for w in "${WRAPPERS[@]}"; do
    [ "$1" = "$w" ] && return 0
  done
  return 1
}

input=$(cat)
raw_cmd=$(printf '%s' "$input" | jq -r '.tool_input.command // .command // ""')

[ -z "$raw_cmd" ] && exit 0

command -v shfmt > /dev/null 2>&1 || block 'shfmt is not available to parse the command - failing closed'

ast=$(printf '%s' "$raw_cmd" | shfmt --tojson 2> /dev/null) || block 'command could not be parsed as shell - failing closed'

# One line per CallExpr: every word that is a single plain literal is
# emitted verbatim; anything else (quoted text, substitutions, expansions)
# is represented as a \x01 marker — layer 0 of reject-obfuscated-commands
# (which runs before this hook) already guarantees a real \x01 byte can
# never appear in the input, so the marker is unambiguous, can never equal
# "git"/"worktree"/"-C"/"-c" and so is opaque to the checks below, and —
# unlike an empty string — is never dropped by IFS=<tab> word-splitting's
# collapsing of consecutive whitespace delimiters. Words cannot contain raw
# whitespace, so tab is a safe separator.
calls=$(printf '%s' "$ast" | jq -r '
  .. | objects | select(.Type? == "CallExpr") | select((.Args // [] | length) > 0) |
  [ .Args[] | if (.Parts | length) == 1 and .Parts[0].Type == "Lit" then .Parts[0].Value else "" end ] |
  join("\t")')

while IFS= read -r call_line; do
  [ -z "$call_line" ] && continue
  IFS=$'\t' read -ra words <<< "$call_line"

  # Only the command-name position, and the position immediately after a
  # known wrapper name in the command-name position, are checked — a `git`
  # token appearing anywhere else is an ordinary argument, not a git
  # invocation (e.g. `grep -r git .`, `find . -name git`).
  positions=(0)
  is_wrapper "${words[0]}" && positions+=(1)

  for i in "${positions[@]}"; do
    tok="${words[$i]:-}"
    if [ "$tok" = "git" ] || [[ "$tok" == */git ]]; then
      j=$((i + 1))
      # skip `-C <dir>` / `-c <key>=<value>` global option pairs before the
      # subcommand, in any order — e.g. `git -c core.pager=cat -C . worktree add ...`.
      while [ "${words[$j]:-}" = "-c" ] || [ "${words[$j]:-}" = "-C" ]; do
        j=$((j + 2))
      done
      if [ "${words[$j]:-}" = "worktree" ] && [ "${words[$((j + 1))]:-}" = "add" ]; then
        block 'git worktree add is prohibited in this repo - use a normal branch checkout instead'
      fi
    fi
  done
done <<< "$calls"

exit 0
