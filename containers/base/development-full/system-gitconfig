# Baked into the image at /etc/gitconfig. Owned by root (mode 0444) so the
# unprivileged `node` user the agent runs as cannot modify it. The host's
# ~/.gitconfig is mounted RO on top of this and provides identity
# (user.name / user.email / user.signingkey) for the host operator.
#
# Keep this file in sync with container/CLAUDE.md / startup-check.sh's
# git_eq verifications — those expect every key here to resolve.

[core]
	autocrlf = false
	fscache = true
	ignorecase = false
	preloadIndex = true
	packedGitLimit = 512m
	packedGitWindowSize = 512m
	# Global pre-commit hook wiring. Lives in this file (not in entrypoint
	# env) so every git invocation in the container picks it up regardless
	# of process ancestry — env-var-injected config (GIT_CONFIG_*) doesn't
	# always propagate cleanly through the claude SDK's process tree, and
	# we want hooks active for ALL agent commits, not just the ones whose
	# bash inherited the right env. The startup-check sanity push uses
	# `git commit --no-verify` to bypass per-command (it's a meta-test of
	# git/gpg/auth, not of the hook chain).
	hooksPath = /opt/git-global-hooks

[feature]
	manyFiles = true

[fetch]
	parallel = 16
	prune = true

[merge]
	ff = false

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[rebase]
	autosquash = true

# Rewrite common HTTPS clone URLs to their SSH equivalents so anything the
# agent clones from these hosts uses the mounted ~/.ssh keys rather than
# needing an HTTPS credential helper.
[url "git@github.com:"]
	insteadOf = https://github.com/

[url "git@gitlab.com:"]
	insteadOf = https://gitlab.com/

[url "git@bitbucket.org:"]
	insteadOf = https://bitbucket.org/
