{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [


      "Bash(bun add *)",
      "Bash(bun install *)",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(bun x *)",
      "Bash(cat *)",
      "Bash(docker *)",
      "Bash(dotnet --*)",
      "Bash(dotnet build *)",
      "Bash(dotnet buildcheck *)",
      "Bash(dotnet buildversion *)",
      "Bash(dotnet changelog *)",
      "Bash(dotnet clean *)",
      "Bash(dotnet code-analysis *)",
      "Bash(dotnet cscleanup *)",
      "Bash(dotnet dotnet-script *)",
      "Bash(dotnet nuget *)",
      "Bash(dotnet pack *)",
      "Bash(dotnet publish *)",
      "Bash(dotnet restore *)",
      "Bash(dotnet run *)",
      "Bash(dotnet test *)",
      "Bash(dotnet tool *)",
      "Bash(dotnet tsqllint *)",
      "Bash(find *)",
      "Bash(find * -exec cat *)",
      "Bash(gh api repos/*/releases*)",
      "Bash(gh auth status*)",
      "Bash(gh issue *)",
      "Bash(gh label *)",
      "Bash(gh pr *)",
      "Bash(gh run *)",
      "Bash(git -C * config --get user.email)",
      "Bash(git -C * config --get user.name)",
      "Bash(git -C * config --global --get core.hooks-path)",
      "Bash(git -C * config --global --get user.email)",
      "Bash(git -C * config --global --get user.name)",
      "Bash(git -C * config --local --get core.hooks-path)",
      "Bash(git -C * config --local --get user.email)",
      "Bash(git -C * config --local --get user.name)",
      "Bash(git -C * config --system --get core.hooks-path)",
      "Bash(git -C *)",
      "Bash(git config --get user.email)",
      "Bash(git config --get user.name)",
      "Bash(git config --global --get core.hooks-path)",
      "Bash(git config --global --get user.email)",
      "Bash(git config --global --get user.name)",
      "Bash(git config --local --get core.hooks-path)",
      "Bash(git config --local --get user.email)",
      "Bash(git config --local --get user.name)",
      "Bash(git config --system --get core.hooks-path)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(npm audit *)",
      "Bash(npm ci *)",
      "Bash(npm install *)",
      "Bash(npm list *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npx *)",
      "Bash(podman *)",
      "Bash(pre-commit *)",
      "Bash(python3 *)",
      "Edit",
      "Read",
      "Write"
    ],
    "deny": [
      "Bash(dotnet new tool-manifest*)",
      "Bash(dotnet tool install*)",
      "Bash(gh auth setup-git*)",
      "Bash(git -C * config --add *)",
      "Bash(git -C * config --global commit.gpgsign *)",
      "Bash(git -C * config --global user.email *)",
      "Bash(git -C * config --global user.name *)",
      "Bash(git -C * config --global user.signingkey *)",
      "Bash(git -C * config --replace-all*)",
      "Bash(git -C * config --unset*)",
      "Bash(git config --add *)",
      "Bash(git config --global commit.gpgsign *)",
      "Bash(git config --global user.email *)",
      "Bash(git config --global user.name *)",
      "Bash(git config --global user.signingkey *)",
      "Bash(git config --replace-all*)",
      "Bash(git config --unset*)",
      "Bash(sudo *)"
    ]
  },
  "advisorModel": "opus",
  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/reject-obfuscated-commands"
          },
          {
            "type": "command",
            "command": "block-no-verify"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-git-identity"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/enforce-git-dash-c"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-git-worktree"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/block-dotnet-tool-install"
          }
        ]
      },
      {
        "matcher": "mcp__github__.*",
        "hooks": [
          {
            "type": "command",
            "command": "block-no-verify"
          }
        ]
      }
    ]
  },
  "tui": "default",
  "autoMemoryEnabled": false,
  "theme": "dark",
  "agentPushNotifEnabled": false,
  "autoCompactEnabled": true
}
