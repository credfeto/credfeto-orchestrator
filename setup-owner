#!/bin/bash

# Provisions a system user for the orchestrator on this machine.
# Idempotent: already-done steps are skipped.
# Usage: setup-owner --owner <name>

# Resolve this script's own directory via BASH_SOURCE (not $0), so it works both when run
# directly and when a test harness `source`s it.
SETUP_OWNER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/core disable=SC1091
source "${SETUP_OWNER_DIR}/lib/core" \
    || { printf 'setup-owner: FATAL: failed to source %s/lib/core\n' "${SETUP_OWNER_DIR}" >&2; exit 1; }

REPO_URL="git@github.com:credfeto/credfeto-orchestrator.git"
SOURCE_HOME="${HOME}"
SOURCE_CONFIG="${XDG_CONFIG_HOME:-${HOME}/.config}"
SUDOERS_DIR="${SUDOERS_DIR:-/etc/sudoers.d}"

check_required_tools() {
    local tool
    for tool in id sudo useradd getent git loginctl; do
        command -v "${tool}" >/dev/null 2>&1 || die "Required tool not found: ${tool}"
    done
}

# Validates that all required source config files exist before we touch anything.
# Prints a clear error for each missing file/directory and dies when any are absent.
validate_source_config() {
    local owner="$1"
    local errors=0

    if [ ! -d "${SOURCE_CONFIG}/gh" ] || [ ! -f "${SOURCE_CONFIG}/gh/hosts.yml" ]; then
        printf '\n✗ %s\n' "${SOURCE_CONFIG}/gh/hosts.yml is missing — run 'gh auth login' first" >&2
        errors=$((errors + 1))
    fi

    if [ ! -f "${SOURCE_CONFIG}/orchestrator/.env" ]; then
        printf '\n✗ %s\n' "${SOURCE_CONFIG}/orchestrator/.env is missing" >&2
        printf '  Create it with: GIT_USER_NAME, GIT_USER_EMAIL, GIT_SIGNING_KEY, DISCORD_WEBHOOK\n' >&2
        errors=$((errors + 1))
    fi

    local token_file="${SOURCE_CONFIG}/orchestrator/tokens/${owner}"
    if [ ! -f "${token_file}" ]; then
        printf '\n✗ %s\n' "${token_file} is missing — create it with the Claude OAuth token (chmod 600)" >&2
        errors=$((errors + 1))
    else
        local perms
        perms=$(stat -c '%a' "${token_file}" 2>/dev/null)
        case "${perms}" in
            600|400) ;;
            *) printf '\n✗ %s\n' "${token_file} has permissions ${perms} — must be 600 (run: chmod 600 ${token_file})" >&2
               errors=$((errors + 1)) ;;
        esac
    fi

    [ "${errors}" -eq 0 ] || die "Pre-flight checks failed — fix the above and re-run"
}

get_owner_home() {
    getent passwd "$1" | cut -d: -f6
}

ensure_user_exists() {
    local owner="$1"
    if id "${owner}" >/dev/null 2>&1; then
        info "User ${owner} already exists — skipping"
        return 0
    fi
    info "Creating user ${owner}..."
    sudo useradd -m -s /bin/bash "${owner}" || die "Failed to create user ${owner}"
    sudo passwd -l "${owner}" || die "Failed to lock password for ${owner}"
    success "User ${owner} created"
}

enable_linger() {
    local owner="$1"
    info "Enabling linger for ${owner} (creates persistent systemd user session)..."
    sudo loginctl enable-linger "${owner}" || die "Failed to enable linger for ${owner}"
    success "Linger enabled for ${owner}"
}

revoke_sudoers() {
    local owner="$1"
    local sudoers_file="${SUDOERS_DIR}/${owner}"
    if [ ! -f "${sudoers_file}" ]; then
        info "No sudoers entry for ${owner} — nothing to revoke"
        return 0
    fi
    info "Revoking sudoers entry for ${owner}..."
    sudo rm -f "${sudoers_file}" || die "Failed to remove ${sudoers_file}"
    success "Sudoers entry revoked for ${owner}"
}

# Copies SOURCE_HOME/<name> into the owner's home directory, always refreshing (removing and
# re-copying) rather than skipping when the destination already exists, so a rotated credential
# (e.g. a new SSH key registered with GitHub) is picked up on every run like the other
# credentials copy_config_file/copy_config_dir already refresh (#1104). For ".ssh", a
# destination-only known_hosts (one the source does not ship its own copy of) is backed up
# before the refresh and restored afterwards, since it accumulates independently as the owner
# connects to new git hosts and is not itself rotatable credential material.
copy_dotdir() {
    local owner="$1"
    local owner_home="$2"
    local name="$3"
    local src="${SOURCE_HOME}/${name}"
    local dst="${owner_home}/${name}"

    if [ ! -d "${src}" ]; then
        info "No ${name} in ${SOURCE_HOME} — skipping"
        return 0
    fi

    local known_hosts_backup=""
    if [ "${name}" = ".ssh" ] && [ ! -f "${src}/known_hosts" ] && [ -f "${dst}/known_hosts" ]; then
        known_hosts_backup=$(mktemp) || die "Failed to create temp file for ${dst}/known_hosts backup"
        sudo mv "${dst}/known_hosts" "${known_hosts_backup}" || die "Failed to back up ${dst}/known_hosts"
    fi

    info "Refreshing ${name}..."
    if ! sudo rm -rf "${dst}"; then
        if [ -n "${known_hosts_backup}" ]; then
            die "Failed to remove existing ${dst} - known_hosts backup preserved at ${known_hosts_backup}, restore it manually"
        fi
        die "Failed to remove existing ${dst}"
    fi
    if ! sudo cp -r "${src}" "${dst}"; then
        if [ -n "${known_hosts_backup}" ]; then
            die "Failed to copy ${src} to ${dst} - known_hosts backup preserved at ${known_hosts_backup}, restore it manually"
        fi
        die "Failed to copy ${src} to ${dst}"
    fi

    if [ -n "${known_hosts_backup}" ]; then
        sudo mv "${known_hosts_backup}" "${dst}/known_hosts" \
            || die "Failed to restore known_hosts in ${dst} - backup still at ${known_hosts_backup}, restore it manually"
    fi

    sudo chown -R "${owner}:${owner}" "${dst}" || die "Failed to chown ${dst}"
    sudo chmod 700 "${dst}" || die "Failed to set permissions on ${dst}"
    sudo find "${dst}" -type f -exec chmod 600 {} + || die "Failed to set file permissions in ${dst}"
    if [ "${name}" = ".ssh" ]; then
        sudo find "${dst}" -type f -name "*.pub" -exec chmod 644 {} + \
            || die "Failed to set .pub permissions in ${dst}"
    fi
    success "Refreshed ${name}"
}

copy_dotfile() {
    local owner="$1"
    local owner_home="$2"
    local name="$3"
    local src="${SOURCE_HOME}/${name}"
    local dst="${owner_home}/${name}"

    if [ -f "${dst}" ]; then
        info "${name} already present for ${owner} — skipping"
        return 0
    fi
    if [ ! -f "${src}" ]; then
        info "No ${name} in ${SOURCE_HOME} — skipping"
        return 0
    fi
    info "Copying ${name}..."
    sudo cp "${src}" "${dst}" || die "Failed to copy ${src} to ${dst}"
    sudo chown "${owner}:${owner}" "${dst}" || die "Failed to chown ${dst}"
    sudo chmod 600 "${dst}" || die "Failed to set permissions on ${dst}"
    success "Copied ${name}"
}

copy_dotfiles() {
    local owner="$1"
    local owner_home
    owner_home=$(get_owner_home "${owner}") || die "Failed to look up home directory for ${owner}"
    [ -n "${owner_home}" ] || die "No home directory found for ${owner}"

    copy_dotdir   "${owner}" "${owner_home}" ".ssh"
    sync_gnupg    "${owner}" "${owner_home}"
    configure_git "${owner}" "${owner_home}"
    copy_dotfile  "${owner}" "${owner_home}" ".database"
}

# Copies a single file from SOURCE_CONFIG into the owner's XDG config dir,
# creating parent directories as needed.  Always overwrites so re-runs pick
# up rotated tokens or updated config (analogous to git pull vs clone).
copy_config_file() {
    local owner="$1"
    local owner_home="$2"
    local rel_path="$3"   # path relative to ~/.config/
    local perms="${4:-600}"
    local src="${SOURCE_CONFIG}/${rel_path}"
    local dst_dir owner_config_dir
    owner_config_dir="${owner_home}/.config"
    dst_dir="${owner_config_dir}/$(dirname "${rel_path}")"
    local dst="${owner_config_dir}/${rel_path}"

    if [ ! -f "${src}" ]; then
        die "Expected source file ${src} is missing — this should have been caught by validate_source_config"
    fi
    info "Copying .config/${rel_path}..."
    sudo mkdir -p "${dst_dir}" || die "Failed to create ${dst_dir}"
    sudo chown -R "${owner}:${owner}" "${owner_config_dir}" || die "Failed to chown ${owner_config_dir}"
    sudo chmod 700 "${owner_config_dir}" || die "Failed to set permissions on ${owner_config_dir}"
    sudo chmod 700 "${dst_dir}" || die "Failed to set permissions on ${dst_dir}"
    sudo cp "${src}" "${dst}" || die "Failed to copy ${src} to ${dst}"
    sudo chown "${owner}:${owner}" "${dst}" || die "Failed to chown ${dst}"
    sudo chmod "${perms}" "${dst}" || die "Failed to set permissions on ${dst}"
    success "Copied .config/${rel_path}"
}

# Copies a directory from SOURCE_CONFIG into the owner's XDG config dir.
# Always overwrites so re-runs pick up credential refreshes (analogous to git pull vs clone).
copy_config_dir() {
    local owner="$1"
    local owner_home="$2"
    local rel_path="$3"   # path relative to ~/.config/
    local src="${SOURCE_CONFIG}/${rel_path}"
    local owner_config_dir="${owner_home}/.config"
    local dst="${owner_config_dir}/${rel_path}"

    if [ ! -d "${src}" ]; then
        die "Expected source directory ${src} is missing — this should have been caught by validate_source_config"
    fi
    info "Copying .config/${rel_path}/..."
    sudo mkdir -p "${owner_config_dir}" || die "Failed to create ${owner_config_dir}"
    sudo rm -rf "${dst}" || die "Failed to remove existing ${dst}"
    sudo cp -r "${src}" "${dst}" || die "Failed to copy ${src} to ${dst}"
    sudo chown -R "${owner}:${owner}" "${dst}" || die "Failed to chown ${dst}"
    sudo chmod 700 "${dst}" || die "Failed to set permissions on ${dst}"
    sudo find "${dst}" -type f -exec chmod 600 {} + || die "Failed to set file permissions in ${dst}"
    sudo find "${dst}" -type d -exec chmod 700 {} + || die "Failed to set dir permissions in ${dst}"
    success "Copied .config/${rel_path}/"
}

copy_config_files() {
    local owner="$1"
    local owner_home
    owner_home=$(get_owner_home "${owner}") || die "Failed to look up home directory for ${owner}"
    [ -n "${owner_home}" ] || die "No home directory found for ${owner}"

    copy_config_dir  "${owner}" "${owner_home}" "gh"
    copy_config_file "${owner}" "${owner_home}" "orchestrator/.env" "600"
    copy_config_file "${owner}" "${owner_home}" "orchestrator/tokens/${owner}" "600"
}

sync_gnupg() {
    local owner="$1"
    local owner_home="$2"
    local src="${SOURCE_HOME}/.gnupg"
    local dst="${owner_home}/.gnupg"

    local env_file="${SOURCE_CONFIG}/orchestrator/.env"
    local key_id
    key_id=$(grep '^GIT_SIGNING_KEY=' "${env_file}" 2>/dev/null \
        | cut -d= -f2- | tr -d '"' | tr -d "'" | tr -d '[:space:]')

    if [ -z "${key_id}" ]; then
        info "GIT_SIGNING_KEY not set in .env — skipping GPG keyring sync"
        return 0
    fi

    sudo pkill -KILL -u "${owner}" keyboxd 2>/dev/null || true
    sudo pkill -KILL -u "${owner}" gpg-agent 2>/dev/null || true

    info "Importing GPG key ${key_id} for ${owner}..."
    sudo rm -rf "${dst}" || die "Failed to remove ${dst}"
    sudo mkdir -p "${dst}" || die "Failed to create ${dst}"

    # Empty common.conf ensures classic pubring.kbx mode regardless of system config
    sudo touch "${dst}/common.conf" || die "Failed to create ${dst}/common.conf"

    sudo chown -R "${owner}:${owner}" "${dst}" || die "Failed to chown ${dst}"
    sudo chmod 700 "${dst}" || die "Failed to set permissions on ${dst}"

    # Export secret key (includes public key) and import into owner's fresh keyring
    gpg --batch --no-tty --export-secret-keys "${key_id}" \
        | sudo -u "${owner}" gpg --homedir "${dst}" --batch --no-tty --import \
        || die "Failed to import GPG key ${key_id} for ${owner}"

    if [ -f "${src}/trustdb.gpg" ]; then
        sudo cp "${src}/trustdb.gpg" "${dst}/" || die "Failed to copy trustdb.gpg"
    fi
    if [ -f "${src}/sshcontrol" ]; then
        sudo cp "${src}/sshcontrol" "${dst}/" || die "Failed to copy sshcontrol"
    fi

    sudo chown -R "${owner}:${owner}" "${dst}" || die "Failed to chown ${dst}"
    sudo find "${dst}" -type d -exec chmod 700 {} + || die "Failed to set dir permissions in ${dst}"
    sudo find "${dst}" -type f -exec chmod 600 {} + || die "Failed to set file permissions in ${dst}"

    sudo pkill -KILL -u "${owner}" keyboxd 2>/dev/null || true
    sudo pkill -KILL -u "${owner}" gpg-agent 2>/dev/null || true
    # Remove socket files left behind by SIGKILL so oneshot does not mount a stale
    # socket when gpg-agent has moved to XDG_RUNTIME_DIR on the next service run.
    sudo find "${dst}" -maxdepth 1 -type s -delete 2>/dev/null || true
    success "GPG key ${key_id} imported for ${owner}"
}

configure_git() {
    local owner="$1"
    local owner_home="$2"

    local env_file="${SOURCE_CONFIG}/orchestrator/.env"
    local git_user_name git_user_email git_signing_key
    git_user_name=$(grep '^GIT_USER_NAME=' "${env_file}" 2>/dev/null \
        | cut -d= -f2- | sed "s/^['\"]//;s/['\"]$//")
    git_user_email=$(grep '^GIT_USER_EMAIL=' "${env_file}" 2>/dev/null \
        | cut -d= -f2- | sed "s/^['\"]//;s/['\"]$//")
    git_signing_key=$(grep '^GIT_SIGNING_KEY=' "${env_file}" 2>/dev/null \
        | cut -d= -f2- | tr -d '"' | tr -d "'" | tr -d '[:space:]')

    if [ -z "${git_user_name}" ] || [ -z "${git_user_email}" ]; then
        info "GIT_USER_NAME/GIT_USER_EMAIL not set in .env — skipping git config"
        return 0
    fi

    info "Configuring git for ${owner}..."
    local gitconfig="${owner_home}/.gitconfig"
    # Write .gitconfig directly — sudo git config --global fails when invoked from a
    # directory the owner cannot stat (git safe.directory check rejects non-owner dirs)
    {
        printf '[user]\n'
        printf '\tname = %s\n' "${git_user_name}"
        printf '\temail = %s\n' "${git_user_email}"
        if [ -n "${git_signing_key}" ]; then
            printf '\tsigningkey = %s\n' "${git_signing_key}"
            printf '[commit]\n\tgpgsign = true\n'
            printf '[tag]\n\tgpgSign = true\n'
        fi

        printf '\n[core]\n'
        printf '\tautocrlf = false\n'
        printf '\tfscache = true\n'
        printf '\tignorecase = false\n'
        printf '\tpreloadIndex = true\n'
        printf '\tpackedGitLimit = 512m\n'
        printf '\tpackedGitWindowSize = 512m\n'

        printf '\n[feature]\n'
        printf '\tmanyFiles = true\n'

        printf '\n[fetch]\n'
        printf '\tparallel = 16\n'
        printf '\tprune = true\n'

        printf '\n[init]\n'
        printf '\tdefaultBranch = main\n'

        printf '\n[merge]\n'
        printf '\tff = false\n'

        printf '\n[pull]\n'
        printf '\trebase = true\n'

        printf '\n[push]\n'
        printf '\tautoSetupRemote = true\n'

        printf '\n[rebase]\n'
        printf '\tautosquash = true\n'

        printf '\n'
        # Rewrite common HTTPS clone URLs to their SSH equivalents so anything the
        # agent clones from these hosts uses the mounted ~/.ssh keys rather than
        # needing an HTTPS credential helper.
        printf '[url "git@github.com:"]\n'
        printf '\tinsteadOf = https://github.com/\n'
        printf '\tpushInsteadOf = https://github.com/\n'
        # GH_HOST (github-api.markridgwell.com) is the API/HTTPS proxy only;
        # gh pr checkout also uses it for SSH remote URLs which is wrong.
        printf '\tinsteadOf = git@github-api.markridgwell.com:\n'
        printf '\tpushInsteadOf = git@github-api.markridgwell.com:\n'
        printf '\n'
        printf '[url "git@gitlab.com:"]\n'
        printf '\tinsteadOf = https://gitlab.com/\n'
        printf '\tpushInsteadOf = https://gitlab.com/\n'
        printf '\n'
        printf '[url "git@bitbucket.org:"]\n'
        printf '\tinsteadOf = https://bitbucket.org/\n'
        printf '\tpushInsteadOf = https://bitbucket.org/\n'
    } | sudo tee "${gitconfig}" > /dev/null || die "Failed to write ${gitconfig}"
    sudo chown "${owner}:${owner}" "${gitconfig}" || die "Failed to chown ${gitconfig}"
    sudo chmod 644 "${gitconfig}" || die "Failed to set permissions on ${gitconfig}"
    success "Git configured for ${owner}"
}

configure_podman_storage() {
    local owner="$1"
    local owner_home
    owner_home=$(get_owner_home "${owner}") || die "Failed to look up home directory for ${owner}"
    [ -n "${owner_home}" ] || die "No home directory found for ${owner}"

    local config_dir="${owner_home}/.config/containers"
    local storage_conf="${config_dir}/storage.conf"
    local work_dir="${owner_home}/work"
    local driver="vfs"
    local graphroot=""
    local mount_program=""

    # Use fuse-overlayfs when available: allows the overlay storage driver on any
    # filesystem (btrfs, ext4) without kernel user.overlay xattr support.
    # Otherwise vfs always works but copies entire layers on every pull.
    if command -v fuse-overlayfs >/dev/null 2>&1; then
        driver="overlay"
        mount_program=$(command -v fuse-overlayfs)
    fi

    # Place the graphroot on ~/work when it is a btrfs mount.  This applies
    # to both overlay (via fuse-overlayfs) and vfs: the btrfs volume has much
    # more space than the ext4 home partition, which matters especially for vfs
    # since it copies entire layers rather than sharing them via copy-on-write.
    if [ -d "${work_dir}" ] && command -v findmnt >/dev/null 2>&1; then
        local fstype
        fstype=$(findmnt -T "${work_dir}" -o FSTYPE -n 2>/dev/null | tr -d '[:space:]')
        if [ "${fstype}" = "btrfs" ]; then
            graphroot="${work_dir}/.containers/storage"
        fi
    fi

    info "Configuring Podman storage driver (${driver}) for ${owner}..."
    sudo mkdir -p "${config_dir}" || die "Failed to create ${config_dir}"
    sudo chown "${owner}:${owner}" "${config_dir}" || die "Failed to chown ${config_dir}"
    sudo chmod 700 "${config_dir}" || die "Failed to set permissions on ${config_dir}"
    {
        printf '[storage]\n'
        printf 'driver = "%s"\n' "${driver}"
        [ -n "${graphroot}" ] && printf 'graphroot = "%s"\n' "${graphroot}"
        if [ -n "${mount_program}" ]; then
            printf '[storage.options.overlay]\n'
            printf 'mount_program = "%s"\n' "${mount_program}"
        fi
    } | sudo tee "${storage_conf}" > /dev/null || die "Failed to write ${storage_conf}"
    sudo chown "${owner}:${owner}" "${storage_conf}" || die "Failed to chown ${storage_conf}"
    sudo chmod 600 "${storage_conf}" || die "Failed to set permissions on ${storage_conf}"
    success "Podman storage configured with ${driver} driver for ${owner}"
}

configure_podman_engine() {
    local owner="$1"
    local owner_home
    owner_home=$(get_owner_home "${owner}") || die "Failed to look up home directory for ${owner}"
    [ -n "${owner_home}" ] || die "No home directory found for ${owner}"

    local config_dir="${owner_home}/.config/containers"
    local containers_conf="${config_dir}/containers.conf"

    info "Configuring Podman engine (cgroupfs) for ${owner}..."
    sudo mkdir -p "${config_dir}" || die "Failed to create ${config_dir}"
    sudo chown "${owner}:${owner}" "${config_dir}" || die "Failed to chown ${config_dir}"
    sudo chmod 700 "${config_dir}" || die "Failed to set permissions on ${config_dir}"
    # Use cgroupfs instead of the systemd cgroup manager.  The systemd manager
    # requires runc to create libpod scope units via D-Bus; from inside a system
    # service this is denied even with Delegate=yes.  cgroupfs bypasses D-Bus
    # entirely.  The cgroup parent is NOT set here — oneshot sets it dynamically
    # at runtime by moving itself into a leaf cgroup within the delegated service
    # cgroup subtree, then passing --cgroup-parent to every podman run call.
    {
        printf '[engine]\n'
        printf 'cgroup_manager = "cgroupfs"\n'
    } | sudo tee "${containers_conf}" > /dev/null || die "Failed to write ${containers_conf}"
    sudo chown "${owner}:${owner}" "${containers_conf}" || die "Failed to chown ${containers_conf}"
    sudo chmod 600 "${containers_conf}" || die "Failed to set permissions on ${containers_conf}"
    success "Podman engine configured with cgroupfs for ${owner}"
}

clone_or_pull_repo() {
    local owner="$1"
    local owner_home
    owner_home=$(get_owner_home "${owner}") || die "Failed to look up home directory for ${owner}"
    [ -n "${owner_home}" ] || die "No home directory found for ${owner}"
    local clone_dir="${owner_home}/credfeto-orchestrator"

    if sudo -u "${owner}" test -d "${clone_dir}"; then
        if sudo -u "${owner}" test -d "${clone_dir}/.git"; then
            info "Repository already cloned — pulling..."
            sudo -u "${owner}" git -C "${clone_dir}" pull --ff-only \
                || die "Failed to pull repository in ${clone_dir}"
        else
            die "${clone_dir} exists but is not a git repository — remove it and re-run"
        fi
    else
        info "Cloning orchestrator repository..."
        sudo -u "${owner}" git clone "${REPO_URL}" "${clone_dir}" \
            || die "Failed to clone ${REPO_URL} to ${clone_dir}"
    fi
    success "Repository ready at ${clone_dir}"
}

run_install_timer() {
    local owner="$1"
    local owner_home
    owner_home=$(get_owner_home "${owner}") || die "Failed to look up home directory for ${owner}"
    [ -n "${owner_home}" ] || die "No home directory found for ${owner}"
    local clone_dir="${owner_home}/credfeto-orchestrator"

    info "Running install-timer --owner ${owner}..."
    sudo -u "${owner}" "${clone_dir}/install-timer" --owner "${owner}" \
        || die "install-timer failed"
    success "Timer installed for ${owner}"
}

main() {
    local owner=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --owner)
                shift
                [ -n "${1:-}" ] || die "--owner requires a value"
                [[ "$1" =~ ^[a-z][a-z0-9_-]*$ ]] \
                    || die "--owner value contains invalid characters: $1"
                owner="$1"
                shift
                ;;
            *)
                die "Unknown argument: $1"
                ;;
        esac
    done

    [ -n "${owner}" ] || die "Usage: $(basename "$0") --owner <name>"

    [ "$(id -u)" -ne 0 ] || die "setup-owner must not be run as root — run as yourself; it uses sudo internally"
    is_ai_agent && die "setup-owner must not be run inside a Claude Code session"

    check_required_tools
    validate_source_config "${owner}"

    info "Provisioning orchestrator for owner: ${owner}"

    ensure_user_exists "${owner}"
    enable_linger "${owner}"
    revoke_sudoers "${owner}"
    copy_dotfiles "${owner}"
    copy_config_files "${owner}"
    configure_podman_storage "${owner}"
    configure_podman_engine "${owner}"
    clone_or_pull_repo "${owner}"
    run_install_timer "${owner}"

    success "Setup complete for owner: ${owner}"
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
