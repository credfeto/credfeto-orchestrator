#!/bin/bash

# Continuous loop wrapper: runs ./oneshot then waits 300 seconds, indefinitely.

# Resolve this script's own directory via BASH_SOURCE (not $0), so it works both when run
# directly and when a test harness `source`s it ($0 would then be the test runner, not loop).
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
SLEEP_SECONDS=300

# A failed source must stop the script immediately rather than leaving die/success/info/warn/
# is_ai_agent silently undefined — without this fallback, every call site below degrades to a
# "command not found" no-op instead of the loud failure it depends on (confirmed incident: this
# let a stripped-down test fixture missing lib/ fall through into the real while-loop body
# instead of dying at the oneshot-not-executable check, #1185 review).
# shellcheck source=lib/core disable=SC1091
source "${SCRIPT_DIR}/lib/core" \
    || { printf 'loop: FATAL: failed to source %s/lib/core\n' "${SCRIPT_DIR}" >&2; exit 1; }

# Switches the local checkout to main and pulls the latest commits. A failed switch means the
# checkout is in an unexpected state (dirty tree, detached HEAD, wrong repo), so it dies loudly
# rather than risk running stale or wrong-branch code. A failed or hung pull only warns and
# keeps the existing checkout: a transient network stall must not block the loop indefinitely,
# and unlike the systemd path there is no timer to recover it (#1104).
update_scripts() {
    git -C "${SCRIPT_DIR}" switch main \
        || die "Failed to switch to main branch in ${SCRIPT_DIR} — stopping rather than running stale or wrong-branch code"

    if ! timeout 60 git -C "${SCRIPT_DIR}" pull; then
        warn "git pull failed or timed out in ${SCRIPT_DIR} — continuing with the existing checkout"
    fi
}

main() {
    [ -x "${SCRIPT_DIR}/oneshot" ] || die "oneshot script not found or not executable at ${SCRIPT_DIR}/oneshot"

    is_ai_agent && die "Continuous loop must not be run inside a Claude Code session"

    local iteration=0
    while true; do
        iteration=$((iteration + 1))
        info "Iteration ${iteration} — updating scripts..."
        update_scripts
        info "Iteration ${iteration} — running oneshot..."
        "${SCRIPT_DIR}/oneshot"
        success "Iteration ${iteration} complete — sleeping ${SLEEP_SECONDS}s"
        sleep "${SLEEP_SECONDS}"
    done
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
