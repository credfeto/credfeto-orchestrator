#!/bin/bash
# Build the NanoClaw agent customisation image (thin layer over the base).
#
# The bulk of the image — apt, bun, dotnet, pnpm globals, every static
# binary — lives in container/base.Dockerfile, built and pushed nightly
# by .github/workflows/build-base-image.yml. This script just rebuilds
# the customisation layer (entrypoint scripts, workspace setup, ENTRYPOINT)
# on top of whatever base is in the registry / local cache.
#
# Result: typical local rebuilds finish in seconds rather than ~20 minutes.
#
# Env / .env knobs:
#   NANOCLAW_BASE_REPO   override the base image repo (default:
#                        ghcr.io/dnyw4l3n13/nanoclaw-base)
#   NANOCLAW_BASE_TAG    override the base tag (default: latest)
#   CONTAINER_RUNTIME    docker | podman | etc. (default: docker)
#
# To rebuild the BASE image locally (rare — needed when iterating on
# base.Dockerfile or enabling INSTALL_CJK_FONTS without going through CI),
# run ./container/build-base.sh first, then this script with
# NANOCLAW_BASE_TAG=local-dev (build-base.sh tags it that way).

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$SCRIPT_DIR"

# Derive the image name from the project root so two NanoClaw installs on the
# same host don't overwrite each other's `nanoclaw-agent:latest` tag. Matches
# setup/lib/install-slug.sh + src/install-slug.ts.
# shellcheck source=../setup/lib/install-slug.sh
source "$PROJECT_ROOT/setup/lib/install-slug.sh"
IMAGE_NAME="$(container_image_base)"
TAG="${1:-latest}"
CONTAINER_RUNTIME="${CONTAINER_RUNTIME:-docker}"

BASE_REPO="${NANOCLAW_BASE_REPO:-ghcr.io/dnyw4l3n13/nanoclaw-base}"
BASE_TAG="${NANOCLAW_BASE_TAG:-latest}"

# Pull the base image first. If the registry is unreachable or the tag
# doesn't exist, we fall through to whatever's in the local cache (the
# build will still succeed if a local copy exists). On a truly fresh
# host with no cache, the docker build below will fail with "image not
# found" — that's the right behaviour, surfaces the missing prerequisite.
echo "Resolving base image: ${BASE_REPO}:${BASE_TAG}"
${CONTAINER_RUNTIME} pull "${BASE_REPO}:${BASE_TAG}" || \
    echo "  (pull failed — using local cache if present)"

echo ""
echo "Building NanoClaw agent customisation image..."
echo "Image: ${IMAGE_NAME}:${TAG}"
${CONTAINER_RUNTIME} build \
    --build-arg "BASE_REPO=${BASE_REPO}" \
    --build-arg "BASE_TAG=${BASE_TAG}" \
    -t "${IMAGE_NAME}:${TAG}" .

echo ""
echo "Build complete!"
echo "Image: ${IMAGE_NAME}:${TAG}"

echo ""
echo "Test with:"
echo "  echo '{\"prompt\":\"What is 2+2?\",\"groupFolder\":\"test\",\"chatJid\":\"test@g.us\",\"isMain\":false}' | ${CONTAINER_RUNTIME} run -i ${IMAGE_NAME}:${TAG}"

# ---- Post-build cleanup -----------------------------------------------------
# `image prune` removes dangling (untagged) images. Safe after a successful
# build: anything still tagged with our IMAGE_NAME:TAG points at the new
# image, and the previous image now has its tag detached and is therefore
# dangling. Running containers using the previous image are unaffected —
# they hold their image reference until they exit naturally.
#
# We DO NOT run `builder prune` here. BuildKit's per-layer cache is what
# turns a slow rebuild into a fast one. Pruning it after every build means
# the next rebuild has to re-do everything. Bound cache disk usage with a
# periodic (weekly) `docker buildx prune --keep-storage 5GB` instead.
#
# Best-effort only — pruning failures must not fail the build.
echo ""
echo "Pruning dangling images..."
${CONTAINER_RUNTIME} image prune --force >/dev/null 2>&1 || true
echo "Cleanup complete."
