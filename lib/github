# shellcheck shell=bash
# GitHub trust/collaborators, the priorities feed, and PR/issue discovery: figuring out who is
# trusted, which PR the bot is actually driving, and whether a PR looks human-taken-over.

# Fetches the current repo's collaborator logins (paginated), retrying on transient gh
# failures. Outputs one login per line on success; returns non-zero after
# GH_COLLABORATORS_RETRY_ATTEMPTS failed attempts (#1094).
_fetch_repo_collaborators() {
    local attempt=1 result
    while [ "${attempt}" -le "${GH_COLLABORATORS_RETRY_ATTEMPTS}" ]; do
        if result=$(gh api "repos/${REPO_FULL}/collaborators" --paginate --jq '.[].login' 2>/dev/null); then
            printf '%s' "${result}"
            return 0
        fi
        [ "${attempt}" -lt "${GH_COLLABORATORS_RETRY_ATTEMPTS}" ] && [ "${GH_COLLABORATORS_RETRY_DELAY_SECS}" -gt 0 ] \
            && sleep "${GH_COLLABORATORS_RETRY_DELAY_SECS}"
        attempt=$((attempt + 1))
    done
    return 1
}

# Returns a JSON array of trusted GitHub logins for the current repo context.
# Includes: OWNER, repo collaborators, the GitHub Copilot reviewer bot, and WHITELISTED_USERS.
# The result is cached in _TRUSTED_LOGINS_JSON; cache is cleared by set_repo_context.
# Returns non-zero (and leaves _TRUSTED_LOGINS_JSON empty) if the collaborators list cannot be
# fetched after retrying — callers must skip the item this tick rather than proceed with a
# silently shrunken (and therefore wrong) trust list (#1094): a fingerprint/trust comparison
# using the wrong set of trusted users is worse than doing nothing for one tick.
get_trusted_logins() {
    [ -n "${_TRUSTED_LOGINS_JSON}" ] && { printf '%s' "${_TRUSTED_LOGINS_JSON}"; return 0; }

    local -a logins=()
    [ -n "${OWNER}" ] && logins+=("${OWNER}")

    local login collaborators
    collaborators=$(_fetch_repo_collaborators) || return 1
    while IFS= read -r login; do
        [ -n "${login}" ] && logins+=("${login}")
    done <<< "${collaborators}"

    logins+=("copilot-pull-request-reviewer")

    if [ -n "${WHITELISTED_USERS}" ]; then
        local user remainder="${WHITELISTED_USERS}"
        while [ -n "${remainder}" ]; do
            user="${remainder%%,*}"
            remainder="${remainder#"${user}"}"
            remainder="${remainder#,}"
            user="${user#"${user%%[! ]*}"}"
            user="${user%"${user##*[! ]}"}"
            [ -n "${user}" ] && logins+=("${user}")
        done
    fi

    _TRUSTED_LOGINS_JSON=$(printf '%s\n' "${logins[@]+"${logins[@]}"}" | jq -R -s 'split("\n") | map(select(length > 0)) | unique')
    printf '%s' "${_TRUSTED_LOGINS_JSON}"
}

# Fetches trusted logins for the current repo into the caller's `trusted_logins` variable,
# warning and bumping the caller's `count_error` on failure (#1094 review). Relies on bash's
# dynamic scoping of `local`s: this must only be called from within main()'s per-item loop,
# where both `trusted_logins` and `count_error` are already declared local — `continue` itself
# can't live inside a called function, so callers combine this with `|| continue` to skip the
# item this tick, e.g.: `require_trusted_logins || continue`.
require_trusted_logins() {
    trusted_logins=$(get_trusted_logins) && return 0
    warn "Failed to fetch trusted collaborators for ${item_repo} — skipping this item for now"
    count_error=$((count_error + 1))
    return 1
}

# Outputs all open, non-on-hold priority items as a JSON array sorted by priority.
# Retries transient fetch failures a few times before giving up. Returns 1 (does NOT die,
# does NOT exit the shell) when every attempt fails to connect — the caller must check this
# explicitly and die itself, because a swallowed failure here previously fell through to a "No
# actionable work items found" success report, masking a priorities-API outage as a healthy idle
# run (#1089). Returns 2 when the API answered but the response body failed to parse (a distinct
# condition from unreachability — the caller must not report this as a connectivity outage).
fetch_all_priorities() {
    local priorities_json attempt=1

    while [ "${attempt}" -le "${PRIORITIES_FETCH_RETRY_ATTEMPTS}" ]; do
        if priorities_json=$(curl --silent --fail --connect-timeout 10 --max-time 60 "${PRIORITIES_URL}" 2>/dev/null); then
            printf '%s' "${priorities_json}" | jq -c '[
                .priorities[]
                    | select((.status == "Open" or .status == "Draft") and .isOnHold == false)
            ]' && return 0
            warn "Failed to parse priorities JSON from ${PRIORITIES_URL}"
            return 2
        fi
        [ "${attempt}" -lt "${PRIORITIES_FETCH_RETRY_ATTEMPTS}" ] && [ "${PRIORITIES_FETCH_RETRY_DELAY_SECS}" -gt 0 ] \
            && sleep "${PRIORITIES_FETCH_RETRY_DELAY_SECS}"
        attempt=$((attempt + 1))
    done
    warn "Failed to fetch priorities from ${PRIORITIES_URL} after ${PRIORITIES_FETCH_RETRY_ATTEMPTS} attempt(s)"
    return 1
}

# Resolves the current GitHub login into the cached _GH_ME, retrying a few times on failure.
# Returns 0 with _GH_ME set on success; on ultimate failure warns and returns 1 WITHOUT dying —
# a transient identity-lookup blip should skip the current item, not abort the whole run (#1085).
resolve_gh_me() {
    [ -n "${_GH_ME}" ] && return 0
    local attempt=1 login
    while [ "${attempt}" -le "${GH_USER_RETRY_ATTEMPTS}" ]; do
        if login=$(gh api user --jq '.login' 2>/dev/null) && [ -n "${login}" ]; then
            _GH_ME="${login}"
            return 0
        fi
        [ "${attempt}" -lt "${GH_USER_RETRY_ATTEMPTS}" ] && [ "${GH_USER_RETRY_DELAY_SECS}" -gt 0 ] \
            && sleep "${GH_USER_RETRY_DELAY_SECS}"
        attempt=$((attempt + 1))
    done
    warn "Failed to determine current GitHub user after ${GH_USER_RETRY_ATTEMPTS} attempt(s)"
    return 1
}

# Lists the numbers of open PRs created by the bot (@me) in the given repo, one per line, in
# gh pr list order.  Shared by find_open_nonblocked_pr_for_repo and
# find_human_taken_over_pr_for_issue so the author filter cannot drift between the pivot and
# stand-off paths (#1134).  PRs carrying the Blocked label are excluded unless include_blocked
# is "true" — the pivot must never work a Blocked PR, but the takeover stand-off must still see
# a Blocked human-driven PR, otherwise tagging it Blocked blinds the stand-off and a reopened
# issue gets duplicate work (#1134 review).
# Returns 1 if the identity lookup or the gh call fails.
# Avoids --author @me because gh 2.93.0 broke that flag (exits 1 with "malformed version:").
# Instead, fetches all open PRs with their author field and filters client-side using _GH_ME.
# _GH_ME is resolved lazily (with retries) on the first call and cached for subsequent calls.
list_bot_created_open_prs() {
    local repo_full="$1" include_blocked="${2:-false}"

    resolve_gh_me || return 1

    # --limit raised from gh's default page of 30: in a dependency-bot-heavy repo the bot's own
    # PR can rank past 30, and a truncated list makes the pivot AND the stand-off blind to it —
    # the issue then looks PR-less and gets duplicate work (#1134 review round 3).
    local pr_list
    pr_list=$(gh pr list \
        --repo "${repo_full}" \
        --state open \
        --limit 200 \
        --json number,labels,author \
        2>/dev/null) || return 1
    printf '%s' "${pr_list}" | jq -r --arg me "${_GH_ME}" --argjson incb "${include_blocked}" '
        .[] | select(
            .author.login == $me and
            ($incb or (([(.labels // [])[] | .name | ascii_downcase] | index("blocked")) == null))
        ) | .number
    '
}

# Fetches the given comma-separated --json fields for a PR with the standard retry treatment
# (#1090); single definition shared by every helper that needs a partial PR fetch (#1134).
# Arguments: PR number, field list, repo (defaults to REPO_FULL from the current repo context).
fetch_pr_fields_json() {
    local item_id="$1" fields="$2" repo_full="${3:-${REPO_FULL}}" attempt=1 result
    while [ "${attempt}" -le "${GH_ITEM_FETCH_RETRY_ATTEMPTS}" ]; do
        if result=$(gh pr view "${item_id}" \
            --repo "${repo_full}" \
            --json "${fields}" \
            2>/dev/null); then
            printf '%s' "${result}"
            return 0
        fi
        [ "${attempt}" -lt "${GH_ITEM_FETCH_RETRY_ATTEMPTS}" ] && [ "${GH_ITEM_FETCH_RETRY_DELAY_SECS}" -gt 0 ] \
            && sleep "${GH_ITEM_FETCH_RETRY_DELAY_SECS}"
        attempt=$((attempt + 1))
    done
    return 1
}

# Reads JSON with a .commits array on stdin and succeeds when any commit author or co-author
# login equals the given login.  GitHub maps commit author emails to logins; commits whose
# email maps to no account have no login and are ignored.  Single definition shared by the
# pivot and human-driven predicates so they cannot diverge (#1134).
json_has_commit_author_login() {
    jq -e --arg me "$1" '
        [(.commits // [])[] | (.authors // [])[] | .login // empty] | index($me) != null
    ' > /dev/null 2>&1
}

# Queries GitHub for the first open, non-blocked PR in the given repo that the bot is actually
# driving: created by @me AND containing at least one commit authored by @me (#1131).  PR
# creation authorship alone is not enough — the issue workflow creates the draft PR, but a human
# can take over the branch afterwards (rebasing the bot's placeholder commit away), and such a
# PR must be left alone rather than re-invoked against the human's work.
# Outputs the PR number on stdout, or empty string if no candidate qualifies.
# A candidate whose commits cannot be fetched is scanned past — one broken PR (e.g. from a
# deleted fork) must not block pivoting to a healthy later one (#1134) — but if no bot-driven PR
# is found after such a failure the lookup returns 1, because misreading "could not tell" as
# "PR-less" would let the issue workflow open a duplicate branch.
# Returns 1 if the PR list fetch fails.
find_open_nonblocked_pr_for_repo() {
    local repo_full="$1"

    local candidates candidate commit_rc scan_error=0
    candidates=$(list_bot_created_open_prs "${repo_full}" false) || return 1
    while IFS= read -r candidate; do
        [ -n "${candidate}" ] || continue
        commit_rc=0
        pr_has_bot_authored_commit "${repo_full}" "${candidate}" || commit_rc=$?
        if [ "${commit_rc}" -eq 0 ]; then
            printf '%s' "${candidate}"
            return 0
        fi
        if [ "${commit_rc}" -eq 2 ]; then
            warn "Failed to fetch commits for PR #${candidate} in ${repo_full} — continuing scan"
            scan_error=1
            continue
        fi
        # Diagnosable trail for a systemic misclassification: if GIT_USER_EMAIL stops mapping
        # to the bot account, every bot PR lands here and the orchestrator goes quiet with only
        # a "human-driven" count to show for it (#1134).
        warn "PR #${candidate} in ${repo_full}: created by the bot but has no bot-authored commits — treating as human-driven"
    done <<< "${candidates}"
    [ "${scan_error}" -eq 0 ] || return 1
    return 0
}

# Tests whether the bot (_GH_ME) has authored (or co-authored) at least one commit on the given
# PR — the signal that the bot, not a human, is driving the branch (#1131).
# Returns 0 when a bot-authored commit exists, 1 when none does, and 2 when the gh fetch fails
# after retries — distinct from 1 so callers can propagate a transient error instead of
# misreading it as "human-driven".
pr_has_bot_authored_commit() {
    local repo_full="$1" pr_number="$2" commits_json
    commits_json=$(fetch_pr_fields_json "${pr_number}" commits "${repo_full}") || return 2
    printf '%s' "${commits_json}" | json_has_commit_author_login "${_GH_ME}"
}

# Finds an open, non-blocked PR that the bot created but a human has since taken over (zero
# bot-authored commits) and that belongs to the given issue (#1131).  Such an issue must be
# stood off: it is invisible to the find_open_nonblocked_pr_for_repo pivot (no bot commits), but
# re-working it as a fresh issue would open a duplicate branch/PR alongside the human's work.
# Ownership is matched via closingIssuesReferences; only when a PR declares NO closing
# references at all does the branch-naming convention <type>/<issue>-<name> serve as a fallback
# — a human takeover can edit the "Closes #N" line out of the PR body entirely, and the
# stand-off must not silently vanish with it, but explicit references pointing at a different
# issue must win over a stale branch name (#1134).  Blocked PRs are included: a Blocked
# human-driven PR still owns its issue's work (#1134 review).
# The ownership check runs FIRST, so candidates unrelated to this issue never need a commits
# fetch, and a candidate whose references cannot be read is scanned past (like the pivot) — a
# later matching PR still wins.  Only when the issue's OWN candidate cannot be classified does
# this return 2: a permanently unfetchable candidate that might own the issue keeps its issue
# conservatively parked (close the broken PR to clear it) rather than risking duplicate work
# alongside it (#1134 review round 3).
# Uses REPO_FULL from the current repo context (set_repo_context).
# Outputs the PR number and returns 0 when such a PR exists; returns 1 when none does; returns 2
# on a gh failure after retries (caller should skip the item rather than risk duplicating work).
find_human_taken_over_pr_for_issue() {
    local issue_id="$1"

    local candidates candidate commit_rc refs_json scan_error=0
    candidates=$(list_bot_created_open_prs "${REPO_FULL}" true) || return 2
    while IFS= read -r candidate; do
        [ -n "${candidate}" ] || continue
        if ! refs_json=$(fetch_pr_fields_json "${candidate}" closingIssuesReferences,headRefName); then
            warn "Failed to fetch issue references for PR #${candidate} in ${REPO_FULL} — continuing scan"
            scan_error=1
            continue
        fi
        printf '%s' "${refs_json}" | jq -e --arg n "${issue_id}" '
            ((.closingIssuesReferences // []) | length) > 0
            and ([(.closingIssuesReferences // [])[] | .number | tostring] | index($n) != null)
            or (((.closingIssuesReferences // []) | length) == 0
                and ((.headRefName // "") | test("^[A-Za-z]+/" + $n + "([^0-9]|$)")))
        ' > /dev/null 2>&1 || continue
        # This candidate owns the issue — commit authorship decides who is driving it.
        commit_rc=0
        pr_has_bot_authored_commit "${REPO_FULL}" "${candidate}" || commit_rc=$?
        [ "${commit_rc}" -eq 2 ] && return 2
        # Bot-driven PR — not a takeover; the pivot handles it.
        [ "${commit_rc}" -eq 0 ] && continue
        printf '%s' "${candidate}"
        return 0
    done <<< "${candidates}"
    [ "${scan_error}" -eq 0 ] || return 2
    return 1
}

# Decides whether an open PR from the priorities feed is being driven by a human rather than the
# bot (#1131): the bot has authored no commits on it, AND it is either a PR the bot itself
# created (the issue workflow's draft PR, since taken over) or it contains commits authored by a
# trusted human login.
# Check order matters (#1134): a PR the bot CREATED with zero bot commits is a human takeover
# regardless of its labels — issue-label sync can put a dependencies-ish label on any bot PR, so
# the label must not be consulted first (that was the substring-exemption regression).  Only for
# PRs the bot did NOT create does the "dependencies" label exempt the PR from the stand-off:
# dependency PRs (dependabot and similar) contain no bot commits by design, carry customised
# label variants like "npm dependencies" (hence a case-insensitive substring match), and must
# keep flowing to the CI-verify/auto-merge takeover prompt even after a trusted human pushes a
# conflict fix.
# The external dependency-bump tooling (credfeto-batch-updates) always pushes to a
# "depends/..." branch and normally has its PR opened under "app/github-actions", so it never
# hits the author-check below. It can, rarely, end up opened under the bot's own login instead
# (observed on credfeto-enum-source-generation#118) — with zero bot commits yet (the bot has
# never touched it), that would otherwise look identical to a real human takeover. Unlike a
# label, "depends/" is set once at push time by the bump tooling and is never retroactively
# applied by label-sync, so checking it ahead of the author check cannot reopen the #1134 hole:
# human/bot feature branches use "fix/", "feat/", "perf/", etc., never this prefix.
# Operates entirely on the caller's pr_json — fetch_pr_json already includes author, commits and
# headRefName (#1134) — so the only remote failure mode is the identity lookup.
# Returns 0 (human-driven — stand off), 1 (not human-driven — process normally), or 2 when the
# identity lookup fails (caller should skip the item for this tick).
pr_has_depends_branch() {
    local pr_json="$1"
    printf '%s' "${pr_json}" | jq -e '(.headRefName // "") | test("^depends/")' > /dev/null 2>&1
}

pr_has_dependency_label() {
    local pr_json="$1"
    printf '%s' "${pr_json}" | jq -e '[(.labels // [])[] | .name | ascii_downcase] | any(contains("dependencies"))' > /dev/null 2>&1
}

pr_is_human_driven() {
    local pr_json="$1" trusted_logins="$2"

    resolve_gh_me || return 2

    if printf '%s' "${pr_json}" | json_has_commit_author_login "${_GH_ME}"; then
        return 1
    fi

    if pr_has_depends_branch "${pr_json}"; then
        return 1
    fi

    if printf '%s' "${pr_json}" | jq -e --arg me "${_GH_ME}" '.author.login == $me' > /dev/null 2>&1; then
        return 0
    fi

    if pr_has_dependency_label "${pr_json}"; then
        return 1
    fi

    if printf '%s' "${pr_json}" | jq -e --arg me "${_GH_ME}" --argjson trusted "${trusted_logins}" '
        [(.commits // [])[] | (.authors // [])[] | .login // empty]
        | any(. as $l | $l != $me and (($trusted | index($l)) != null))
    ' > /dev/null 2>&1; then
        return 0
    fi

    return 1
}

# Copies labels from all closing issues linked to a PR onto the PR, adding any that are missing.
# Never removes existing labels. Uses --add-label for each missing one.
# Arguments: pr_id pr_json
sync_pr_labels_from_linked_issues() {
    local pr_id="$1" pr_json="$2"
    local linked_issues
    linked_issues=$(gh pr view "${pr_id}" \
        --repo "${REPO_FULL}" \
        --json closingIssuesReferences \
        --jq '.closingIssuesReferences[].number' 2>/dev/null) || return 0
    [ -n "${linked_issues}" ] || return 0

    local pr_label_list
    pr_label_list=$(printf '%s' "${pr_json}" | jq -c '[(.labels // [])[] | .name]')

    local issue_num issue_label already_present
    while IFS= read -r issue_num; do
        [ -n "${issue_num}" ] || continue
        while IFS= read -r issue_label; do
            [ -n "${issue_label}" ] || continue
            already_present=$(printf '%s' "${pr_label_list}" | jq -r --arg l "${issue_label}" 'map(select(. == $l)) | length')
            if [ "${already_present}" = "0" ]; then
                info "PR #${pr_id}: adding label '${issue_label}' from linked issue #${issue_num}"
                gh pr edit "${pr_id}" --repo "${REPO_FULL}" --add-label "${issue_label}" 2>/dev/null || true
                pr_label_list=$(printf '%s' "${pr_label_list}" | jq -c --arg l "${issue_label}" '. + [$l]')
            fi
        done < <(gh issue view "${issue_num}" \
            --repo "${REPO_FULL}" \
            --json labels \
            --jq '.labels[].name' 2>/dev/null)
    done <<< "${linked_issues}"
}
