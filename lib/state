# shellcheck shell=bash
# File-backed bookkeeping used across ticks: per-item invocation/guard-file counters, the
# runaway backstop and its forgiveness-on-unblock logic, environment-block auto-unblocking,
# rate limiting, and blocked/closed-issue notification markers.

# Shared invocation-guard file path for the runaway backstop, keyed by item type + id. The PR
# and Issue guards below store different shapes (PRs also track an idle counter — see
# load/save_pr_invocation_counts vs. the Issue-only total) so their load/save logic stays
# separate, but the naming/location logic is identical and lives in one place (#1093 review).
invocation_guard_file_path() {
    local item_type="$1" item_id="$2"
    printf '%s/%s_%s.invocations' "${SESSION_BASE_DIR}" "${item_type}" "${item_id}"
}

# Guard-file path for consecutive pre-flight/infra container failures (#1133 review) — separate
# from invocation_guard_file_path's budget, which invoke_claude returning 2 never touches. Also
# doubles as the "have we ever attempted this item" signal for the first-touch board-init check
# below: on a persistently failing container, save_pr_invocation_counts/save_issue_invocation_
# counts (which the normal first-touch check keys off) never run either, so without this the
# board would be reset to "Not Started" on every single retry (#1133 review).
infra_failure_guard_file_path() {
    local item_type="$1" item_id="$2"
    printf '%s/%s_%s.infra-failures' "${SESSION_BASE_DIR}" "${item_type}" "${item_id}"
}

# Reads the saved consecutive-infra-failure count, defaulting a missing/corrupt value to 0.
# Sets global INFRA_FAILURE_COUNT (declared in lib/globals).
load_infra_failure_count() {
    local item_type="$1" item_id="$2" guard_file value
    INFRA_FAILURE_COUNT=0
    guard_file=$(infra_failure_guard_file_path "${item_type}" "${item_id}")
    [ -f "${guard_file}" ] || return 0
    value=$(cat "${guard_file}" 2>/dev/null)
    [[ "${value}" =~ ^[0-9]+$ ]] && INFRA_FAILURE_COUNT="${value}"
    return 0
}

# Persists the consecutive-infra-failure count for an item.
save_infra_failure_count() {
    local item_type="$1" item_id="$2" count="$3" guard_file
    guard_file=$(infra_failure_guard_file_path "${item_type}" "${item_id}")
    mkdir -p "${SESSION_BASE_DIR}" || die "Failed to create session directory: ${SESSION_BASE_DIR}"
    printf '%s\n' "${count}" > "${guard_file}" \
        || die "Failed to write infra-failure guard file: ${guard_file}"
}

# Clears the consecutive-infra-failure guard file — call once a real Claude session has run
# (regardless of outcome), so a one-off pre-flight blip does not count towards a later
# persistent-failure streak.
clear_infra_failure_count() {
    local item_type="$1" item_id="$2"
    rm -f "$(infra_failure_guard_file_path "${item_type}" "${item_id}")" 2>/dev/null || true
}

# Per-PR invocation guard.  Because every run is a fresh session that advances the workflow by
# one phase, a PR is re-invoked repeatedly across ticks until it reaches a terminal state.  The
# guard file holds two space-separated counters, "<total> <idle>":
#   total — every agent invocation ever spent on this PR.  Runaway backstop: at
#           MAX_PR_TOTAL_INVOCATIONS the PR is marked Blocked for a human (catches find-fix
#           churn that keeps pushing new commits but never converges).
#   idle  — consecutive "in-progress" re-invocations where the PR fingerprint had not changed
#           (a phase that advanced the board without pushing, e.g. a clean review).  At
#           MAX_PR_IDLE_INVOCATIONS the PR is parked (skipped) until its state changes again,
#           so a PR that is done but cannot enable auto-merge does not loop forever.
# Absence of the file also signals the first-ever touch of the PR.
pr_invocation_guard_file_path() {
    local item_id="$1"
    invocation_guard_file_path "PullRequest" "${item_id}"
}

# Reads the saved "<total> <idle>" counters for a PR, defaulting missing/corrupt values to 0.
# Sets globals PR_INVOCATION_TOTAL and PR_INVOCATION_IDLE (declared in lib/globals).
load_pr_invocation_counts() {
    local item_id="$1" guard_file line
    PR_INVOCATION_TOTAL=0
    PR_INVOCATION_IDLE=0
    guard_file=$(pr_invocation_guard_file_path "${item_id}")
    [ -f "${guard_file}" ] || return 0
    line=$(cat "${guard_file}" 2>/dev/null)
    # Match both tokens from the whole line at once — extracting total/idle independently via
    # ${line%% *}/${line##* *} would alias a corrupt single-token file ("7") into BOTH counters,
    # letting a bogus total silently exhaust the idle budget (#1103).
    if [[ "${line}" =~ ^([0-9]+)\ ([0-9]+)$ ]]; then
        PR_INVOCATION_TOTAL="${BASH_REMATCH[1]}"
        PR_INVOCATION_IDLE="${BASH_REMATCH[2]}"
    fi
    return 0
}

# Persists the "<total> <idle>" counters for a PR.
save_pr_invocation_counts() {
    local item_id="$1" total="$2" idle="$3" guard_file
    guard_file=$(pr_invocation_guard_file_path "${item_id}")
    mkdir -p "${SESSION_BASE_DIR}" || die "Failed to create session directory: ${SESSION_BASE_DIR}"
    printf '%s %s\n' "${total}" "${idle}" > "${guard_file}" \
        || die "Failed to write invocation guard file: ${guard_file}"
}

# Marks that an item is in (or is about to enter) a Blocked spell while its invocation total is
# already at/above the cap, regardless of which mechanism applied the Blocked label — oneshot's
# own runaway backstop, the code-review workflow's own rules (e.g. "3+ rounds with findings"),
# CI-timeout, or idle-exhaustion. This is the signal the reset_*_invocation_counts_if_capped
# helpers use to tell "the count happens to be at/above the cap while this item sits Blocked"
# apart from "the count just reached the cap this tick and the backstop is about to fire for the
# first time" — only the former should forgive the counter (#1115). Comparing the counter to the
# cap directly, with no marker at all, cannot make that distinction: an unmarked item whose total
# reaches the cap during active (unblocked) work must still let the backstop actually apply the
# block, not get silently forgiven before it ever fires.
runaway_blocked_marker_file_path() {
    local item_type="$1" item_id="$2"
    printf '%s/%s_%s.runaway-blocked' "${SESSION_BASE_DIR}" "${item_type}" "${item_id}"
}

# Writes the marker for an item observed carrying the Blocked label whose invocation total is
# already at/above its cap (#1115) — covers blocks NOT authored by oneshot's own backstop (e.g.
# the code-review workflow's "3+ rounds" rule), which never call this on their own. Without this,
# a human clearing such a Blocked label is a no-op: the total survives untouched, and the very
# next tick that reaches the item reloads the same at-or-over-cap total and re-blocks it before
# any new work happens — turning "unblock" into a silent instant re-block. Best-effort: a failure
# to write only means a future clear-the-label won't auto-reset, not that anything breaks now.
mark_capped_block_for_forgiveness() {
    local item_type="$1" item_id="$2" total cap
    case "${item_type}" in
        PullRequest)
            load_pr_invocation_counts "${item_id}"
            total="${PR_INVOCATION_TOTAL}"
            cap="${MAX_PR_TOTAL_INVOCATIONS}"
            ;;
        Issue)
            load_issue_invocation_counts "${item_id}"
            total="${ISSUE_INVOCATION_TOTAL}"
            cap="${MAX_ISSUE_TOTAL_INVOCATIONS}"
            ;;
        *)
            return 0
            ;;
    esac
    [ "${total}" -ge "${cap}" ] || return 0
    mkdir -p "${SESSION_BASE_DIR}" 2>/dev/null
    touch "$(runaway_blocked_marker_file_path "${item_type}" "${item_id}")" 2>/dev/null \
        || warn "Failed to write runaway-blocked marker for ${item_type} #${item_id} — invocation budget will not auto-reset once a human clears the Blocked label"
}

# Resets a PR's invocation-total counter once it is observed un-blocked, but only when it was
# blocked while already at/over the cap (runaway_blocked_marker_file_path present — written either
# by oneshot's own backstop or by mark_capped_block_for_forgiveness for other block sources).
# Without this, a human clearing the Blocked label on a cap-blocked PR would be a no-op: the guard
# file is never otherwise cleared, so the very next tick reloads the same at-or-over-cap total and
# immediately re-blocks it, turning "unblock" into a silent re-block loop. Blocks for unrelated
# reasons (CI timeout, idle-exhausted review/check) leave the total untouched here — resetting
# those would hand back an undeserved fresh budget instead of preserving the PR's history.
# Call alongside clear_blocked_marker, every place a PR is observed open and un-blocked.
reset_pr_invocation_counts_if_capped() {
    local item_id="$1" marker_file
    marker_file=$(runaway_blocked_marker_file_path "PullRequest" "${item_id}")
    if [ -f "${marker_file}" ]; then
        save_pr_invocation_counts "${item_id}" 0 0
        rm -f "${marker_file}" 2>/dev/null || true
    fi
}

# Guard-file paths for the environment-block auto-unblock feature (#1118). PR-only: Issues have
# no container session to diagnose an environment failure against before a PR exists.
env_unblock_attempts_file_path() {
    local item_id="$1"
    printf '%s/PullRequest_%s.env-unblocks' "${SESSION_BASE_DIR}" "${item_id}"
}

env_unblock_cap_notice_marker_file_path() {
    local item_id="$1"
    printf '%s/PullRequest_%s.env-unblock-cap-notified' "${SESSION_BASE_DIR}" "${item_id}"
}

# Reads how many times oneshot has already auto-cleared Blocked on this PR for an environment
# diagnosis. Sets global ENV_UNBLOCK_ATTEMPTS (declared in lib/globals), defaulting to 0 for a
# missing/corrupt guard file.
load_env_unblock_attempts() {
    local item_id="$1" guard_file total
    ENV_UNBLOCK_ATTEMPTS=0
    guard_file=$(env_unblock_attempts_file_path "${item_id}")
    [ -f "${guard_file}" ] || return 0
    total=$(cat "${guard_file}" 2>/dev/null)
    [[ "${total}" =~ ^[0-9]+$ ]] && ENV_UNBLOCK_ATTEMPTS="${total}"
    return 0
}

save_env_unblock_attempts() {
    local item_id="$1" total="$2" guard_file
    guard_file=$(env_unblock_attempts_file_path "${item_id}")
    mkdir -p "${SESSION_BASE_DIR}" || die "Failed to create session directory: ${SESSION_BASE_DIR}"
    printf '%s\n' "${total}" > "${guard_file}" \
        || die "Failed to write env-unblock-attempts guard file: ${guard_file}"
}

# Clears both the attempts counter and the cap-notice marker. Call alongside
# reset_pr_invocation_counts_if_capped, every place a PR is observed open and un-blocked — once a
# PR is genuinely moving again, any prior environment-block history is stale and should not count
# towards a future MAX_PR_ENV_AUTO_UNBLOCKS budget.
reset_env_unblock_attempts() {
    local item_id="$1"
    rm -f "$(env_unblock_attempts_file_path "${item_id}")" 2>/dev/null || true
    rm -f "$(env_unblock_cap_notice_marker_file_path "${item_id}")" 2>/dev/null || true
}

# Attempts to auto-clear Blocked on a PR the agent itself diagnosed as blocked by an environment/
# infrastructure failure (#1118), once a newer agent image (a different baked-in git SHA) has been
# built since the diagnosis — see pr_json_env_block_image_sha and current_agent_image_sha. Bounded
# by MAX_PR_ENV_AUTO_UNBLOCKS so a wrong "environment" diagnosis (really a code bug) cannot loop
# forever unblocking-and-reblocking itself with no human ever notified; once the cap is hit, posts
# a one-time explanatory comment and leaves Blocked for a human from then on.
#
# Returns 0 if it auto-cleared the label this tick (caller should count it and move to the next
# item — the next tick will observe the PR fresh, no agent work happens in this same tick).
# Returns 1 if there is nothing to do (no environment-block marker, image unchanged, or the cap is
# already hit) — caller falls through to its normal blocked handling.
try_auto_unblock_env_diagnosed_pr() {
    local item_id="$1" item_repo="$2" pr_json="$3"
    local blocked_sha current_sha attempts cap_notice_marker

    blocked_sha=$(pr_json_env_block_image_sha "${pr_json}") || return 1
    current_sha=$(current_agent_image_sha) || return 1
    [ "${current_sha}" != "${blocked_sha}" ] || return 1

    load_env_unblock_attempts "${item_id}"
    if [ "${ENV_UNBLOCK_ATTEMPTS}" -ge "${MAX_PR_ENV_AUTO_UNBLOCKS}" ]; then
        cap_notice_marker=$(env_unblock_cap_notice_marker_file_path "${item_id}")
        if [ ! -f "${cap_notice_marker}" ]; then
            warn "PR #${item_id} in ${item_repo}: environment auto-unblock already attempted ${ENV_UNBLOCK_ATTEMPTS} times without the underlying failure clearing — leaving Blocked for a human"
            gh pr comment "${item_id}" --repo "${item_repo}" --body "$(cat <<COMMENT
This PR has been auto-unblocked ${ENV_UNBLOCK_ATTEMPTS} times after the agent diagnosed an environment/infrastructure failure, but the same failure recurred each time after the container was rebuilt — the diagnosis may be wrong (a real code issue, not an environment one). Leaving Blocked for a human to investigate; no further automatic unblocking will happen for this PR.
COMMENT
            )" 2>/dev/null || true
            mkdir -p "${SESSION_BASE_DIR}" 2>/dev/null
            touch "${cap_notice_marker}" 2>/dev/null || true
        fi
        return 1
    fi

    attempts=$((ENV_UNBLOCK_ATTEMPTS + 1))
    save_env_unblock_attempts "${item_id}" "${attempts}"
    info "PR #${item_id} in ${item_repo}: environment-block image sha ${blocked_sha} superseded by ${current_sha} — auto-clearing Blocked (attempt ${attempts}/${MAX_PR_ENV_AUTO_UNBLOCKS})"
    gh pr edit "${item_id}" --repo "${item_repo}" --remove-label Blocked >/dev/null 2>&1
    gh pr comment "${item_id}" --repo "${item_repo}" --body "$(cat <<COMMENT
Automatically unblocked — this PR was blocked for an environment/infrastructure reason (image sha \`${blocked_sha}\`), and the agent container has since been rebuilt (now \`${current_sha}\`). Resuming automatically.
COMMENT
    )" 2>/dev/null || true
    return 0
}

# Per-Issue invocation guard — same runaway-backstop idea as the PR guard above, but Issues have
# no idle-park case (an unchanged Issue is simply skipped, never re-invoked), so this only tracks
# a single total: every agent invocation ever spent on this Issue while it has no active PR.  At
# MAX_ISSUE_TOTAL_INVOCATIONS the Issue is marked Blocked for a human (#1093) — this closes the
# gap where a non-converging Issue (agent keeps planning/erroring, never opens a PR) re-fires
# every tick forever, since PullRequest_*.invocations only starts counting once a PR exists.
issue_invocation_guard_file_path() {
    local item_id="$1"
    invocation_guard_file_path "Issue" "${item_id}"
}

# Reads the saved total invocation count for an Issue, defaulting missing/corrupt values to 0.
# Sets global ISSUE_INVOCATION_TOTAL (declared in lib/globals).
load_issue_invocation_counts() {
    local item_id="$1" guard_file total
    ISSUE_INVOCATION_TOTAL=0
    guard_file=$(issue_invocation_guard_file_path "${item_id}")
    [ -f "${guard_file}" ] || return 0
    total=$(cat "${guard_file}" 2>/dev/null)
    total="${total%% *}"
    [[ "${total}" =~ ^[0-9]+$ ]] && ISSUE_INVOCATION_TOTAL="${total}"
    return 0
}

# Persists the total invocation count for an Issue.
save_issue_invocation_counts() {
    local item_id="$1" total="$2" guard_file
    guard_file=$(issue_invocation_guard_file_path "${item_id}")
    mkdir -p "${SESSION_BASE_DIR}" || die "Failed to create session directory: ${SESSION_BASE_DIR}"
    printf '%s\n' "${total}" > "${guard_file}" \
        || die "Failed to write invocation guard file: ${guard_file}"
}

# Same reset-on-unblock treatment as reset_pr_invocation_counts_if_capped, for Issues (#1093,
# #1115): only reset when this Issue was blocked while already at/over the cap (marker file
# present), so clearing the Blocked label actually un-sticks it instead of it re-capping on the
# next tick. Call alongside clear_blocked_marker, every place an Issue is observed open and
# un-blocked.
reset_issue_invocation_counts_if_capped() {
    local item_id="$1" marker_file
    marker_file=$(runaway_blocked_marker_file_path "Issue" "${item_id}")
    if [ -f "${marker_file}" ]; then
        save_issue_invocation_counts "${item_id}" 0
        rm -f "${marker_file}" 2>/dev/null || true
    fi
}

# Returns the path to the rate-limit file for the current owner.
owner_rate_limit_file() {
    printf '%s/.orchestrator/%s/rate-limit' "${HOME}" "${OWNER}"
}

# Saves a rate-limit reset unix timestamp for the current owner.
save_rate_limit() {
    local reset_unix="$1"
    local rate_limit_file
    rate_limit_file=$(owner_rate_limit_file)
    mkdir -p "$(dirname "${rate_limit_file}")" \
        || die "Failed to create rate-limit directory for owner ${OWNER}"
    printf '%s\n' "${reset_unix}" > "${rate_limit_file}" \
        || die "Failed to write rate-limit file: ${rate_limit_file}"
}

# Returns 0 (true) if the current owner is still rate-limited.
# Clears the rate-limit file when the reset time has passed.
is_owner_rate_limited() {
    local rate_limit_file reset_unix now_unix
    rate_limit_file=$(owner_rate_limit_file)
    [ -f "${rate_limit_file}" ] || return 1
    reset_unix=$(cat "${rate_limit_file}" 2>/dev/null) || return 1
    [[ "${reset_unix}" =~ ^[0-9]+$ ]] || { rm -f "${rate_limit_file}"; return 1; }
    now_unix=$(date +%s)
    if [ "${now_unix}" -ge "${reset_unix}" ]; then
        rm -f "${rate_limit_file}"
        return 1
    fi
    return 0
}

# Records a raw, unparseable 429 rate-limit message to a tracking issue in the orchestrator
# repo so parse_reset_time can be extended to handle the new format.  Appends a comment to an
# existing OPEN tracking issue; creates a fresh one when none is open.  Closed issues are never
# reopened — a closed tracker means prior formats were handled, so a new sample warrants a new
# issue.  All gh failures are non-fatal (warn only) so the caller's die still fires normally.
report_unparseable_rate_limit() {
    local item_type="$1" item_id="$2" result_text="$3"
    local now_iso existing body

    now_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    # Build the issue/comment body with context and the verbatim raw message.
    # $'...' quoting lets \n expand to real newlines and keeps backticks literal.
    # shellcheck disable=SC2016
    body=$(printf $'parse_reset_time could not parse this Claude 429 rate-limit message. The verbatim message is included below so the parser regex can be extended.\n\n- Owner: `%s`\n- Repo: `%s`\n- Item: `%s #%s`\n- Timestamp (UTC): `%s`\n\nRaw rate-limit message:\n\n```\n%s\n```\n' \
        "${OWNER}" "${REPO_FULL}" "${item_type}" "${item_id}" "${now_iso}" "${result_text}")

    # Find an existing OPEN tracking issue by exact title.
    # The search arg narrows the candidate set; jq then matches exactly so partial-title hits are
    # rejected.  The title is passed via an env var to avoid quoting it inside the jq filter.
    # We use repo: in the search query because --repo + --search is known to fail with
    # "malformed version" in some environments.
    existing=$(RL_TITLE="${RATE_LIMIT_ISSUE_TITLE}" gh issue list \
        --state open \
        --search "repo:${RATE_LIMIT_ISSUE_REPO} ${RATE_LIMIT_ISSUE_TITLE} in:title" \
        --limit 100 \
        --json number,title \
        --jq 'map(select(.title==env.RL_TITLE)) | .[0].number // empty' 2>/dev/null \
        || printf '')

    if [ -n "${existing}" ]; then
        # Check if this exact rate-limit message has already been reported in this issue to avoid spam.
        if { gh issue view "${existing}" --repo "${RATE_LIMIT_ISSUE_REPO}" --json body,comments --jq '.body, .comments[].body' 2>/dev/null || true; } | grep -Fq "${result_text}"; then
            info "Rate-limit message already reported in issue #${existing}"
            return 0
        fi

        gh issue comment "${existing}" --repo "${RATE_LIMIT_ISSUE_REPO}" --body "${body}" 2>/dev/null \
            || warn "Failed to append unparseable rate-limit message to issue #${existing}"
    else
        gh issue create --repo "${RATE_LIMIT_ISSUE_REPO}" \
            --title "${RATE_LIMIT_ISSUE_TITLE}" --label "AI-Work" --body "${body}" 2>/dev/null \
            || warn "Failed to create unparseable rate-limit tracking issue"
    fi
}

# Parses a "resets Hpm (Timezone)" string from a Claude rate-limit error and
# outputs the corresponding unix timestamp on stdout.  If the resolved time is
# already in the past (i.e. the reset is tomorrow), adds 86400 seconds.
# Outputs nothing and returns silently when parsing fails.
parse_reset_time() {
    local result_text="$1"
    local day_month hour minutes ampm tz hour24 reset_unix now_unix
    local regex='resets (([A-Z][a-z]{2} [0-9]+), )?([0-9]+)(:[0-9]+)?(am|pm) \(([^)]+)\)'

    [[ "${result_text}" =~ $regex ]] || return 0

    day_month="${BASH_REMATCH[2]:-today}"
    hour="${BASH_REMATCH[3]}"
    minutes="${BASH_REMATCH[4]:-}"
    ampm="${BASH_REMATCH[5]}"
    tz="${BASH_REMATCH[6]}"

    minutes="${minutes#:}"
    [ -z "${minutes}" ] && minutes="00"

    # Reject timezone strings with dangerous characters.
    case "${tz}" in
        *[!a-zA-Z0-9/_+-]*) return ;;
    esac

    # Convert 12-hour clock to 24-hour.
    if [ "${ampm}" = "pm" ] && [ "${hour}" != "12" ]; then
        hour24=$((hour + 12))
    elif [ "${ampm}" = "am" ] && [ "${hour}" = "12" ]; then
        hour24=0
    else
        hour24="${hour}"
    fi

    reset_unix=$(TZ="${tz}" date -d "${day_month} ${hour24}:${minutes}" +%s 2>/dev/null) || return
    now_unix=$(date +%s)
    if [ "${day_month}" = "today" ] && [ "${reset_unix}" -le "${now_unix}" ]; then
        reset_unix=$(TZ="${tz}" date -d "tomorrow ${hour24}:${minutes}" +%s 2>/dev/null) || return
    fi
    printf '%s' "${reset_unix}"
}

# Returns the path to the per-item blocked-notification marker file.
# The marker records that a blocked notification has already been sent for this
# item so subsequent runs stay silent until the item is observed un-blocked.
blocked_marker_file_path() {
    local item_type="$1" item_id="$2"
    printf '%s/%s_%s.blocked' "${SESSION_BASE_DIR}" "${item_type}" "${item_id}"
}

# Clears the blocked-notification marker for an item, re-arming the notifier so a
# future transition back into the blocked state notifies again. Call on any path
# where the item is observed open and not carrying the Blocked label.
clear_blocked_marker() {
    local item_type="$1" item_id="$2"
    rm -f "$(blocked_marker_file_path "${item_type}" "${item_id}")" 2>/dev/null || true
}

# Re-arms both one-time closed-issue markers (the pivot path's closed-pr-tagged and the
# standoff path's closed-takeover-checked) so a future reopen/re-close cycle is tagged again
# (#1134 review round 3, #1103). Called from both "issue observed open" sites — whichever path
# runs first on a given tick may be the one to observe a reopen, so both must re-arm both
# markers rather than only their own.
rearm_closed_issue_markers() {
    local item_id="$1"
    rm -f "${SESSION_BASE_DIR}/Issue_${item_id}.closed-takeover-checked" 2>/dev/null || true
    rm -f "${SESSION_BASE_DIR}/Issue_${item_id}.closed-pr-tagged" 2>/dev/null || true
}

# Tags an open PR whose linked issue has been closed, and leaves a comment for investigation.
# Labels are added individually so a missing label does not prevent the others from being
# applied.  Returns 0 when at least one action landed on the PR, 1 when every gh call failed
# (e.g. a total outage) — callers that mark the tagging as done must not do so on total failure,
# or the anomaly is silently lost forever (#1134 review round 3).
# Deduplication against repeated calls for the same anomaly is the CALLER's responsibility (a
# marker file, as both call sites now use — #1103) rather than this function's, because "the PR
# already carries Blocked" is not a reliable signal here: the PR may be Blocked for a totally
# unrelated reason (a CI timeout, a human block) and still need the closed-issue investigation
# comment posted for the first time (#1103 review).
tag_pr_closed_issue() {
    local pr_number="$1" issue_id="$2" tagged=1
    gh pr edit "${pr_number}" --repo "${REPO_FULL}" --add-label "Needs Investigation" 2>/dev/null && tagged=0
    gh pr edit "${pr_number}" --repo "${REPO_FULL}" --add-label "Blocked" 2>/dev/null && tagged=0
    gh pr edit "${pr_number}" --repo "${REPO_FULL}" --add-label "On-hold" 2>/dev/null && tagged=0
    gh pr comment "${pr_number}" --repo "${REPO_FULL}" \
        --body "Issue #${issue_id} was found closed while this PR is still open. Automated work has been paused pending manual investigation." \
        2>/dev/null && tagged=0
    return "${tagged}"
}
