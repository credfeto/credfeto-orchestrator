#!/bin/bash

# Installs a systemd system-level service and timer that runs the orchestrator
# on a fixed interval as the current user, even when the user is not logged in.

# How often the timer fires.  Override with ORCHESTRATOR_TIMER_INTERVAL in the
# environment before running install-timer; any value accepted by systemd's
# OnUnitActiveSec is valid (e.g. "30sec", "1min", "5min").
ORCHESTRATOR_TIMER_INTERVAL="${ORCHESTRATOR_TIMER_INTERVAL:-30sec}"

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

success() {
    printf '\n\033[32m✓\033[0m %s\n' "$*"
}

info() {
    printf '\n\033[32m→\033[0m %s\n' "$*"
}

is_ai_agent() {
    [ "${CLAUDECODE}" = "1" ]
}

REPO_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

case "${REPO_DIR}" in
    *$'\n'*) die "install-timer: REPO_DIR contains a newline; aborting." ;;
esac

CURRENT_USER=$(id -un)
case "${CURRENT_USER}" in
    *$'\n'*) die "install-timer: CURRENT_USER contains a newline; aborting." ;;
esac
[[ "${CURRENT_USER}" =~ ^[a-zA-Z0-9._-]+$ ]] || die "install-timer: CURRENT_USER contains invalid characters; aborting."
SERVICE_NAME="credfeto-orchestrator-${CURRENT_USER}"
[[ "${SERVICE_NAME}" =~ ^[a-zA-Z0-9._-]+$ ]] || die "install-timer: SERVICE_NAME contains unsafe characters: ${SERVICE_NAME}"
UNIT_DIR="/etc/systemd/system"

check_required_tools() {
    local tool
    for tool in id sudo systemctl git; do
        command -v "${tool}" >/dev/null 2>&1 || die "Required tool not found: ${tool}"
    done
}

# Writes content to dest via sudo tee.
write_unit_file() {
    local dest="$1"
    local content="$2"
    printf '%s\n' "${content}" | sudo tee "${dest}" > /dev/null || die "Failed to write ${dest}"
}

create_service_unit() {
    local owner_filter="${1:-}"
    local dest="${UNIT_DIR}/${SERVICE_NAME}.service"
    local exec_start="${REPO_DIR}/oneshot"
    [ -n "${owner_filter}" ] && exec_start="${exec_start} --owner ${owner_filter}"
    # RuntimeDirectory creates /run/<name>/ owned by User= before the service
    # starts, providing an isolated location for the ssh-agent socket.
    # XDG_RUNTIME_DIR must point to the user's real session dir (/run/user/<uid>)
    # so that Podman stores container state there instead of a root-owned path.
    # containers.conf sets cgroup_manager=cgroupfs; the systemd manager requires
    # D-Bus access that is denied for non-root users in system services.
    local runtime_dir="${SERVICE_NAME}"
    local ssh_socket="/run/${runtime_dir}/ssh-agent.socket"
    local owner_uid
    owner_uid=$(id -u) || die "Failed to get UID for ${CURRENT_USER}"
    local content
    content="[Unit]
Description=Credfeto Orchestrator for ${CURRENT_USER}
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=${CURRENT_USER}
RuntimeDirectory=${runtime_dir}
RuntimeDirectoryMode=0700
RuntimeDirectoryPreserve=yes
# Delegate=cpu memory pids io grants this service ownership of its cgroup
# subtree so the process can manage subtree_control and child cgroups.  For
# Type=oneshot, systemd does NOT write subtree_control automatically; oneshot
# moves itself to a leaf sub-cgroup then writes the controllers itself so
# container sub-cgroups get pids.max, memory.max etc.  plain Delegate=yes
# grants no specific controllers so the write would be rejected.
Delegate=cpu memory pids io
# XDG_RUNTIME_DIR must be the real user session dir so Podman uses the correct
# runtime state directory for the owner's session.
# DBUS_SESSION_BUS_ADDRESS points at the user session bus; not required for
# cgroupfs but ensures other D-Bus Podman operations find the right socket.
# SSH_AUTH_SOCK is set separately so the ssh-agent socket stays isolated in
# RuntimeDirectory.
Environment=XDG_RUNTIME_DIR=/run/user/${owner_uid}
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/${owner_uid}/bus
Environment=SSH_AUTH_SOCK=${ssh_socket}
WorkingDirectory=${REPO_DIR}
ExecStartPre=/usr/bin/git -C \"${REPO_DIR}\" fetch origin
ExecStartPre=/usr/bin/git -C \"${REPO_DIR}\" merge --ff-only origin/main
ExecStartPre=-/usr/bin/pkill -u %u ssh-agent
ExecStartPre=-/usr/bin/rm -f ${ssh_socket}
ExecStartPre=/usr/bin/ssh-agent -a ${ssh_socket}
# All paths below must be absolute. The %h specifier expands to the home of
# the user that launched systemd (root), not the service User= home directory.
ExecStartPre=-/usr/bin/pkill -u %u gpg-agent
ExecStartPre=/usr/bin/gpgconf --launch gpg-agent
# 0660 = owner + group only. The container gains the owner's primary GID via
# --group-add in oneshot so the developer user can connect without world access.
# Use gpgconf to find the socket path dynamically: with loginctl enable-linger
# the socket lives under XDG_RUNTIME_DIR, not ~/.gnupg.
ExecStartPre=/bin/sh -c '/usr/bin/chmod 0660 \$(/usr/bin/gpgconf --list-dirs agent-extra-socket)'
ExecStart=${exec_start}
# Security hardening — prevent privilege escalation and limit the blast radius
# if the service is compromised.
# NoNewPrivileges prevents setuid/setgid binaries from gaining extra privileges.
# PrivateTmp gives the service its own /tmp so container temp files are isolated.
# ProtectSystem=full makes /usr, /boot, and /etc read-only; the home directory
# and /dev remain writable (rootless Podman needs /dev/fuse for fuse-overlayfs).
# CapabilityBoundingSet= and AmbientCapabilities= remove all Linux capabilities;
# rootless Podman does not require capabilities when running as an unprivileged user.
# LockPersonality prevents changing the execution domain (e.g. via personality(2)).
# MemoryDenyWriteExecute=no is explicit: containers and JIT compilers need pages
# that are both writable and executable, so this restriction must remain off.
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=full
CapabilityBoundingSet=
AmbientCapabilities=
LockPersonality=yes
MemoryDenyWriteExecute=no"
    write_unit_file "${dest}" "${content}"
}

create_timer_unit() {
    local dest="${UNIT_DIR}/${SERVICE_NAME}.timer"
    local content
    content="[Unit]
Description=Credfeto Orchestrator Timer for ${CURRENT_USER}

[Timer]
OnBootSec=${ORCHESTRATOR_TIMER_INTERVAL}
OnUnitActiveSec=${ORCHESTRATOR_TIMER_INTERVAL}
Unit=${SERVICE_NAME}.service

[Install]
WantedBy=timers.target"
    write_unit_file "${dest}" "${content}"
}

main() {
    local owner_filter=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --owner)
                shift
                [ -n "${1:-}" ] || die "--owner requires a value"
                [[ "$1" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]] \
                    || die "--owner value contains invalid characters: $1"
                owner_filter="$1"
                shift
                ;;
            *)
                die "Unknown argument: $1"
                ;;
        esac
    done

    [ "$(id -u)" -ne 0 ] || die "install-timer must not be run as root — run as yourself; it uses sudo internally"
    is_ai_agent && die "install-timer must not be run inside a Claude Code session"

    check_required_tools

    if [ -n "${owner_filter}" ]; then
        SERVICE_NAME="${SERVICE_NAME}-${owner_filter}"
        [[ "${SERVICE_NAME}" =~ ^[a-zA-Z0-9._-]+$ ]] \
            || die "install-timer: resulting SERVICE_NAME contains unsafe characters: ${SERVICE_NAME}"
    fi

    info "Installing Credfeto Orchestrator systemd timer for user ${CURRENT_USER}..."
    info "Repository: ${REPO_DIR}"

    create_service_unit "${owner_filter}"
    info "Service unit written to ${UNIT_DIR}/${SERVICE_NAME}.service"

    create_timer_unit
    info "Timer unit written to ${UNIT_DIR}/${SERVICE_NAME}.timer"

    info "Reloading systemd daemon..."
    sudo systemctl daemon-reload || die "Failed to reload systemd daemon"

    info "Enabling ${SERVICE_NAME}.timer..."
    sudo systemctl enable "${SERVICE_NAME}.timer" || die "Failed to enable ${SERVICE_NAME}.timer"

    info "Starting ${SERVICE_NAME}.timer..."
    sudo systemctl start "${SERVICE_NAME}.timer" || die "Failed to start ${SERVICE_NAME}.timer"

    success "Credfeto Orchestrator timer installed and started for user ${CURRENT_USER}"
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
