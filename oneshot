#!/bin/bash

# Orchestrator oneshot script.
# Fetches all open work items from the priorities API and drives a Claude Code session
# to work on the first actionable item across any repository.  Persists one Claude
# session ID per Issue/PR so subsequent runs resume the correct session.

PRIORITIES_URL="https://git-workflow.markridgwell.com/priorities"
WORK="${XDG_PROJECTS_DIR:-${HOME}/work}"
ORCHESTRATOR_IMAGE="${ORCHESTRATOR_IMAGE:-ghcr.io/credfeto/development-agent:latest}"
CONTAINER_REPO_PATH="/workspace/repo"
CONTAINER_RULES_PATH="/workspace/rules"

# Conservative pre-send guard against grossly oversized prompts.
# The common failure mode is session history overflow in resumed sessions
# (reported as terminal_reason=blocking_limit), which is handled separately in
# invoke_claude by retrying without --resume.  This constant caps only the
# initial prompt text itself.
MAX_PROMPT_CHARS=100000

# Extra buffer added to the token-reset time before resuming agentic work.
# Avoids hitting the limit again immediately after it lifts.
RATE_LIMIT_RESUME_BUFFER_SECS=3600

# Hard limit on how long a single agent container may run. Prevents a stuck
# Monitor loop from holding resources indefinitely.
# Override with AGENT_TIMEOUT_MINUTES in the environment before calling oneshot.
AGENT_TIMEOUT_MINUTES="${AGENT_TIMEOUT_MINUTES:-90}"
AGENT_TIMEOUT_SECS=$(( AGENT_TIMEOUT_MINUTES * 60 ))

# Set by setup_cgroup_leaf; passed as --cgroup-parent to every podman run call.
PODMAN_CGROUP_PARENT=""

# Minimum free disk space in kilobytes required to launch a container (10 GB).
MIN_DISK_SPACE_KB=$(( 10 * 1024 * 1024 ))

die() {
    if [ -t 2 ]; then
        printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    else
        printf '\n✗ %s\n' "$*" >&2
    fi
    exit 1
}

success() {
    if [ -t 1 ]; then
        printf '\n\033[32m✓\033[0m %s\n' "$*"
    else
        printf '\n✓ %s\n' "$*"
    fi
}

info() {
    if [ -t 1 ]; then
        printf '\n\033[32m→\033[0m %s\n' "$*"
    else
        printf '\n→ %s\n' "$*"
    fi
}

warn() {
    if [ -t 2 ]; then
        printf '\n\033[33m!\033[0m %s\n' "$*" >&2
    else
        printf '\n! %s\n' "$*" >&2
    fi
}

# Returns true (0) when running inside a Claude Code Bash-tool session.
# Claude Code sets CLAUDECODE=1 in every shell it spawns via the Bash tool;
# that value is inherited by subprocesses (e.g. git hooks).
# Source: https://docs.anthropic.com/en/docs/claude-code/settings#environment-variables
is_ai_agent() {
    [ "${CLAUDECODE}" = "1" ]
}

# Checks that token_file exists, has safe permissions, and outputs its contents (whitespace stripped).
# Outputs nothing and returns silently if the file is absent or has unsafe permissions.
read_token_if_safe() {
    local token_file="$1"
    local perms
    [ -f "${token_file}" ] || return
    perms=$(stat -c '%a' "${token_file}" 2>/dev/null || stat -f '%Lp' "${token_file}" 2>/dev/null)
    case "${perms}" in
        600|400) ;;
        *) warn "Token file ${token_file} has permissions ${perms} — expected 600; skipping"
           return
           ;;
    esac
    tr -d '[:space:]' < "${token_file}"
}

# Outputs the OAuth token for the given owner, or empty string if not configured.
# Lookup order:
#   1. $XDG_CONFIG_HOME/orchestrator/tokens/<owner>  (preferred XDG location, defaults to ~/.config)
#   2. Empty string — caller falls back to CLAUDE_CODE_OAUTH_TOKEN from the environment.
# Token files must be readable only by the owner (chmod 600).
load_token_for_owner() {
    local owner="$1"
    local token

    case "${owner}" in
        *[!a-zA-Z0-9_-]*) return ;;
    esac

    token=$(read_token_if_safe "${XDG_CONFIG_HOME:-${HOME}/.config}/orchestrator/tokens/${owner}")
    if [ -n "${token}" ]; then
        printf '%s' "${token}"
    fi
}

# Maps a host file path to its container-internal equivalent.
# Paths under REPO_WORK_DIR map to CONTAINER_REPO_PATH; paths under RULES_DIR
# map to CONTAINER_RULES_PATH.  Unrecognised paths are returned unchanged.
host_to_container_path() {
    local host_path="$1"
    local rel
    if [ -n "${REPO_WORK_DIR}" ]; then
        rel="${host_path#"${REPO_WORK_DIR}"}"
        if [ "${rel}" != "${host_path}" ]; then
            printf '%s%s' "${CONTAINER_REPO_PATH}" "${rel}"
            return
        fi
    fi
    if [ -n "${RULES_DIR}" ]; then
        rel="${host_path#"${RULES_DIR}"}"
        if [ "${rel}" != "${host_path}" ]; then
            printf '%s%s' "${CONTAINER_RULES_PATH}" "${rel}"
            return
        fi
    fi
    printf '%s' "${host_path}"
}

# Sets the per-repo globals used by all sub-functions.
# Call once for each repository before invoking any function that reads these globals.
set_repo_context() {
    local repo_full="$1"
    OWNER="${repo_full%%/*}"
    REPO="${repo_full##*/}"
    REPO_FULL="${repo_full}"
    RULES_DIR="${WORK}/${OWNER}/${REPO}/rules"
    REPO_WORK_DIR="${WORK}/${OWNER}/${REPO}/repo"
    SESSION_BASE_DIR="${HOME}/.orchestrator/${OWNER}/${REPO}"
}

ensure_rules_current() {
    if [ -d "${RULES_DIR}/.git" ]; then
        info "Updating rules (cs-template) at ${RULES_DIR}..."
        git -C "${RULES_DIR}" checkout main || die "Failed to switch cs-template to main at ${RULES_DIR}"
        git -C "${RULES_DIR}" pull --ff-only || die "Failed to update cs-template at ${RULES_DIR}"
    else
        info "Cloning rules (cs-template) to ${RULES_DIR}..."
        mkdir -p "$(dirname "${RULES_DIR}")" || die "Failed to create parent directory for ${RULES_DIR}"
        git clone git@github.com:credfeto/cs-template.git "${RULES_DIR}" || die "Failed to clone cs-template to ${RULES_DIR}"
    fi
}

ensure_repo_current() {
    if [ -d "${REPO_WORK_DIR}/.git" ]; then
        # Reset the remote URL to SSH on every iteration. The agent running inside
        # the container may have changed it to HTTPS; that URL is stored in
        # .git/config and would cause the host-side fetch to fail because the
        # service user has no HTTPS credential helper.
        git -C "${REPO_WORK_DIR}" remote set-url origin "git@github.com:${OWNER}/${REPO}.git"
        git -C "${REPO_WORK_DIR}" config --unset remote.origin.pushurl 2>/dev/null || true
        info "Fetching latest changes for ${REPO_FULL}..."
        git -C "${REPO_WORK_DIR}" fetch --prune origin || die "Failed to fetch from origin for ${REPO_FULL}"

        local current_branch
        current_branch=$(git -C "${REPO_WORK_DIR}" branch --show-current)
        if ! git -C "${REPO_WORK_DIR}" diff --quiet || ! git -C "${REPO_WORK_DIR}" diff --cached --quiet; then
            DIRTY_BRANCH="${current_branch}"
            warn "Working tree has uncommitted changes on '${current_branch}' for ${REPO_FULL} — handing off to agent to recover"
            return 1
        fi
        if [ "${current_branch}" != "main" ] \
                && ! git -C "${REPO_WORK_DIR}" rev-parse --verify "refs/remotes/origin/${current_branch}" >/dev/null 2>&1; then
            warn "Branch '${current_branch}' no longer exists on origin for ${REPO_FULL} — returning to main"
            git -C "${REPO_WORK_DIR}" checkout main \
                || die "Failed to switch to main after orphaned branch '${current_branch}' for ${REPO_FULL}"
            current_branch="main"
        fi
        if [ "${current_branch}" = "main" ]; then
            info "Rebasing main with origin/main..."
            git -C "${REPO_WORK_DIR}" rebase origin/main || die "Failed to rebase main with origin/main"
        fi
    else
        info "Cloning ${REPO_FULL} to ${REPO_WORK_DIR}..."
        mkdir -p "$(dirname "${REPO_WORK_DIR}")" || die "Failed to create parent directory for ${REPO_WORK_DIR}"
        git clone "git@github.com:${OWNER}/${REPO}.git" "${REPO_WORK_DIR}" || die "Failed to clone ${REPO_FULL} to ${REPO_WORK_DIR}"
    fi
}

# Returns 0 if the repo was on a branch that no longer exists on origin AND has been
# reset to main; returns 1 in all other cases (repo absent, already on main, branch still
# live on remote, or any git failure).  Performs its own fetch --prune because it is
# called before ensure_repo_current in the fingerprint-skip path.
recover_orphaned_branch() {
    [ -d "${REPO_WORK_DIR}/.git" ] || return 1

    local current_branch
    current_branch=$(git -C "${REPO_WORK_DIR}" branch --show-current 2>/dev/null) || return 1
    [ "${current_branch}" = "main" ] && return 1

    git -C "${REPO_WORK_DIR}" fetch --prune origin 2>/dev/null || return 1

    git -C "${REPO_WORK_DIR}" rev-parse --verify "refs/remotes/origin/${current_branch}" >/dev/null 2>&1 \
        && return 1

    warn "Branch '${current_branch}' no longer exists on origin for ${REPO_FULL} — returning to main"
    git -C "${REPO_WORK_DIR}" checkout -f main \
        || die "Failed to switch to main after orphaned branch '${current_branch}' for ${REPO_FULL}"
    git -C "${REPO_WORK_DIR}" rebase origin/main \
        || die "Failed to rebase origin/main after orphaned branch recovery for ${REPO_FULL}"
    return 0
}

# Attempts a non-agentic rebase of branch_name onto origin/main.
# Returns 0 if the rebase succeeded and changes were force-pushed; 1 if any
# conflict was encountered or if the push failed. Always leaves the working
# tree on main.
try_nonagentic_rebase() {
    local branch_name="$1"

    [ -n "${branch_name}" ] || return 1

    if ! git -C "${REPO_WORK_DIR}" checkout "${branch_name}"; then
        git -C "${REPO_WORK_DIR}" checkout main 2>/dev/null || true
        return 1
    fi

    if ! git -C "${REPO_WORK_DIR}" rebase origin/main; then
        git -C "${REPO_WORK_DIR}" rebase --abort 2>/dev/null || true
        git -C "${REPO_WORK_DIR}" checkout main 2>/dev/null || true
        return 1
    fi

    if ! git -C "${REPO_WORK_DIR}" push --force-with-lease; then
        git -C "${REPO_WORK_DIR}" checkout main 2>/dev/null || true
        return 1
    fi

    git -C "${REPO_WORK_DIR}" checkout main 2>/dev/null || true
    return 0
}

check_required_tools() {
    local tool
    for tool in curl jq podman gh git awk grep flock timeout; do
        command -v "${tool}" >/dev/null 2>&1 || die "Required tool not found: ${tool}"
    done

    if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1; then
        die "Required tool not found: sha256sum or shasum"
    fi
}

# Reads stdin and writes a SHA-256 digest to stdout.
hash_sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum | awk '{ print $1 }'
    else
        shasum -a 256 | awk '{ print $1 }'
    fi
}

# Returns the path to the session file for a given item type and ID.
session_file_path() {
    local item_type="$1" item_id="$2"
    printf '%s/%s_%s.env' "${SESSION_BASE_DIR}" "${item_type}" "${item_id}"
}

# Outputs all open, non-on-hold priority items as a JSON array sorted by priority.
fetch_all_priorities() {
    local priorities_json

    priorities_json=$(curl --silent --fail "${PRIORITIES_URL}") \
        || die "Failed to fetch priorities from ${PRIORITIES_URL}"

    printf '%s' "${priorities_json}" | jq -c '[
        .priorities[]
            | select((.status == "Open" or .status == "Draft") and .isOnHold == false)
    ]' || die "Failed to parse priorities JSON"
}

# Queries GitHub for the first open, non-blocked PR authored by @me in the given repo.
# Outputs the PR number on stdout, or empty string if none found.
# Returns 1 if the gh call fails (caller should treat as an error).
# Avoids --author @me because gh 2.93.0 broke that flag (exits 1 with "malformed version:").
# Instead, fetches all open PRs with their author field and filters client-side using _GH_ME.
# _GH_ME is resolved lazily on the first call and cached for subsequent calls.
find_open_nonblocked_pr_for_repo() {
    local repo_full="$1"

    if [ -z "${_GH_ME}" ]; then
        _GH_ME=$(gh api user --jq '.login' 2>/dev/null) \
            || die "Failed to determine current GitHub user"
    fi

    local pr_list
    pr_list=$(gh pr list \
        --repo "${repo_full}" \
        --state open \
        --json number,labels,author \
        2>/dev/null) || return 1
    printf '%s' "${pr_list}" | jq -r --arg me "${_GH_ME}" '
        [.[] | select(
            .author.login == $me and
            ([(.labels // [])[] | .name | ascii_downcase] | index("blocked")) == null
        )] | first | .number // empty
    '
}

# Sets SESSION_ID for the given item.  For a PullRequest with no session file, falls back
# to the session of a linked closing issue so work already done on the issue is continued.
load_session() {
    local item_type="$1" item_id="$2"
    local session_file linked_issue_id linked_session_file

    SESSION_ID=""

    session_file=$(session_file_path "${item_type}" "${item_id}")
    if [ -f "${session_file}" ]; then
        SESSION_ID=$(cat "${session_file}")
        if ! is_valid_session_id "${SESSION_ID}"; then
            warn "Session file for ${item_type} #${item_id} contains invalid session ID — discarding"
            rm -f "${session_file}"
            SESSION_ID=""
        fi
        return
    fi

    if [ "${item_type}" = "PullRequest" ]; then
        linked_issue_id=$(gh pr view "${item_id}" \
            --repo "${REPO_FULL}" \
            --json closingIssuesReferences \
            --jq '.closingIssuesReferences[0].number // empty' 2>/dev/null)

        if [ -n "${linked_issue_id}" ]; then
            linked_session_file=$(session_file_path "Issue" "${linked_issue_id}")
            if [ -f "${linked_session_file}" ]; then
                info "No session for PR #${item_id} — inheriting session from linked issue #${linked_issue_id}"
                SESSION_ID=$(cat "${linked_session_file}")
                if ! is_valid_session_id "${SESSION_ID}"; then
                    warn "Linked session file for Issue #${linked_issue_id} contains invalid session ID — discarding"
                    rm -f "${linked_session_file}"
                    SESSION_ID=""
                fi
            fi
        fi
    fi
}

# Outputs the path to the .ai-instructions file for the current repo context.
# Returns 1 (with a warning) if neither the repo work dir nor the rules dir has the file.
find_ai_instructions() {
    if [ -f "${REPO_WORK_DIR}/.ai-instructions" ]; then
        printf '%s/.ai-instructions' "${REPO_WORK_DIR}"
    elif [ -f "${RULES_DIR}/.ai-instructions" ]; then
        printf '%s/.ai-instructions' "${RULES_DIR}"
    else
        warn "No .ai-instructions found at ${REPO_WORK_DIR}/.ai-instructions or ${RULES_DIR}/.ai-instructions"
        return 1
    fi
}

build_issue_claude_md() {
    local item_id="$1" ai_instructions="$2" repo_path="${3:-${REPO_WORK_DIR}}"
    cat <<EOF
You are the Orchestrator agent.

Read AI instructions from ${ai_instructions}.

Work on issue #${item_id} in ${REPO_FULL}.
The repository is checked out at ${repo_path}.

Follow all mandatory rules from the AI instructions (GitHub CLI comment bodies, label management).

Steps:
1. Assign yourself: gh issue edit ${item_id} --repo ${REPO_FULL} --add-assignee @me
2. BEFORE writing any code: read the issue and all comments. If the issue contains questions that need answers, or if you have questions, you MUST ask them first in comments on the issue. Mark the issue as blocked and wait for answers: gh issue edit ${item_id} --repo ${REPO_FULL} --add-label Blocked
3. Reply to every issue comment that prompted an action with "<one sentence description>"
4. When ready to start work: create a new branch BEFORE making any changes to the repo, commit a placeholder CHANGELOG.md entry, push upstream, and create a draft pull request that links issue #${item_id}
5. All interaction with humans including status reports must be made as either a comment to the issue or a comment to the pull request if we've opened one.
6. MANDATORY: Never run git commit, git push, or any other bounded git operation as a background task — always run them in the foreground so their exit code is immediately available. If you use the Monitor tool for any background process, never construct the poll pattern from the branch name or branch-type prefix: branch names contain slashes (e.g. perf/my-branch produces git output [perf/my-branch abc1234], not [perf abc1234]), so a pattern like \[perf\] would never match and the loop would hang forever. Use a branch-agnostic string from the command's actual output (see Background Tasks and Monitor Tool rules in the AI instructions for safe poll strings).
EOF
}

build_pr_claude_md() {
    local item_id="$1" ai_instructions="$2" merge_state="${3:-UNKNOWN}" branch_name="${4:-}" repo_path="${5:-${REPO_WORK_DIR}}" dirty_branch="${6:-}" is_dependency_pr="${7:-false}"
    local checkout_step
    local needs_rebase=0
    [ "${merge_state}" = "BEHIND" ] || [ "${merge_state}" = "DIRTY" ] && needs_rebase=1

    if [ -n "${dirty_branch}" ] && [ "${needs_rebase}" = "1" ]; then
        checkout_step="3. The working tree is on branch '${dirty_branch}' with uncommitted changes AND the PR is ${merge_state} — resolve both before any other work:
   a. git -C ${repo_path} status   (inspect what is there)
   b. If changes belong to this PR: git -C ${repo_path} stash && git -C ${repo_path} checkout ${branch_name} && git -C ${repo_path} stash pop
      Otherwise: git -C ${repo_path} checkout -- . && git -C ${repo_path} reset HEAD && git -C ${repo_path} checkout ${branch_name}
   c. git -C ${repo_path} fetch origin && git -C ${repo_path} rebase origin/main
      CHANGELOG.md conflicts: keep entries from both sides. Any other conflict: post the details as a PR comment and stop.
   d. git -C ${repo_path} push --force-with-lease"
    elif [ -n "${dirty_branch}" ]; then
        checkout_step="3. The working tree is on branch '${dirty_branch}' with uncommitted changes — clean up before checking out the PR branch:
   a. git -C ${repo_path} status   (inspect what is there)
   b. If changes belong to this PR: git -C ${repo_path} stash && git -C ${repo_path} checkout ${branch_name} && git -C ${repo_path} stash pop
      Otherwise: git -C ${repo_path} checkout -- . && git -C ${repo_path} reset HEAD && git -C ${repo_path} checkout ${branch_name}"
    elif [ "${needs_rebase}" = "1" ]; then
        checkout_step="3. The PR is ${merge_state} — check out the branch and rebase immediately before any other work:
   git -C ${repo_path} checkout ${branch_name}
   git -C ${repo_path} fetch origin && git -C ${repo_path} rebase origin/main
   CHANGELOG.md conflicts: keep entries from both sides. Any other conflict: post the details as a PR comment and stop.
   git -C ${repo_path} push --force-with-lease"
    else
        checkout_step="3. Check out the PR branch BEFORE making any changes: git -C ${repo_path} checkout ${branch_name}"
    fi

    if [ "${is_dependency_pr}" = "true" ]; then
        cat <<EOF
You are the Orchestrator agent.

Read AI instructions from ${ai_instructions}.

Work on dependency pull request #${item_id} in ${REPO_FULL}.

This is a dependency update PR. Do NOT make any code changes. Your only job is to verify CI and either enable auto-merge or mark as blocked.

Steps:
1. Assign yourself: gh pr edit ${item_id} --repo ${REPO_FULL} --add-assignee @me
2. Sync labels from all linked closing issues — add any label present on a linked issue but missing from this PR (never remove existing labels):
   gh pr view ${item_id} --repo ${REPO_FULL} --json closingIssuesReferences --jq '.closingIssuesReferences[].number' | while IFS= read -r n; do gh issue view "\$n" --repo ${REPO_FULL} --json labels --jq '.labels[].name'; done | sort -u | while IFS= read -r label; do gh pr edit ${item_id} --repo ${REPO_FULL} --add-label "\$label"; done
3. Check CI: gh pr checks ${item_id} --repo ${REPO_FULL}
   - If auto-merge is already enabled (gh pr view ${item_id} --repo ${REPO_FULL} --json autoMergeRequest --jq '.autoMergeRequest != null' returns true): stop — nothing more to do.
   - If ALL required checks have passed: enable auto-merge and stop:
     gh pr merge --auto --merge ${item_id} --repo ${REPO_FULL}
     If that command fails (auto-merge not supported), mark the PR as ready instead:
     gh pr ready ${item_id} --repo ${REPO_FULL}
   - If any required check has FAILED: post a comment on the PR explaining which check failed and why, then add the Blocked label and stop:
     gh pr edit ${item_id} --repo ${REPO_FULL} --add-label Blocked
   - If checks are still PENDING: stop without taking action — the next cycle will re-evaluate.
4. All interaction with humans must be made as a comment to the pull request. Do NOT open issues.
EOF
    else
        cat <<EOF
You are the Orchestrator agent.

Read AI instructions from ${ai_instructions}.

Work on pull request #${item_id} in ${REPO_FULL}.
The repository is checked out at ${repo_path}.

Follow all mandatory rules from the AI instructions (GitHub CLI comment bodies, label management, CI checks).

Steps:
1. Assign yourself: gh pr edit ${item_id} --repo ${REPO_FULL} --add-assignee @me
2. Sync labels from all linked closing issues — add any label present on a linked issue but missing from this PR (never remove existing labels):
   gh pr view ${item_id} --repo ${REPO_FULL} --json closingIssuesReferences --jq '.closingIssuesReferences[].number' | while IFS= read -r n; do gh issue view "\$n" --repo ${REPO_FULL} --json labels --jq '.labels[].name'; done | sort -u | while IFS= read -r label; do gh pr edit ${item_id} --repo ${REPO_FULL} --add-label "\$label"; done
${checkout_step}
4. Check CI once (gh pr checks ${item_id} --repo ${REPO_FULL}); if not all required checks have passed, follow the AI instructions CI policy and stop. Check PR comments and any code reviews. If questions need answers, ask them first and mark the PR as blocked: gh pr edit ${item_id} --repo ${REPO_FULL} --add-label Blocked
5. Reply to every PR comment that prompted an action with "Fixed in <commit-sha> — <one sentence description>"
6. Proceed to address all outstanding work
7. When all work is complete and CI passes: enable auto-merge — run this exact command: gh pr merge --auto --merge ${item_id} --repo ${REPO_FULL}
   If that fails because auto-merge is not supported by the repo, fall back to marking the PR as ready: gh pr ready ${item_id} --repo ${REPO_FULL}
8. All interaction with humans including status reports must be made as a comment to the pull request.
9. MANDATORY: Never run git commit, git push, or any other bounded git operation as a background task — always run them in the foreground so their exit code is immediately available. If you use the Monitor tool for any background process, never construct the poll pattern from the branch name or branch-type prefix: branch names contain slashes (e.g. perf/my-branch produces git output [perf/my-branch abc1234], not [perf abc1234]), so a pattern like \[perf\] would never match and the loop would hang forever. Use a branch-agnostic string from the command's actual output (see Background Tasks and Monitor Tool rules in the AI instructions for safe poll strings).
EOF
    fi
}

build_issue_prompt() {
    local item_id="$1" repo_path="${3:-${REPO_WORK_DIR}}"
    printf 'Work on issue #%s in %s.\nThe repository is checked out at %s.\n' \
        "${item_id}" "${REPO_FULL}" "${repo_path}"
}

build_pr_prompt() {
    local item_id="$1" repo_path="${5:-${REPO_WORK_DIR}}"
    printf 'Work on pull request #%s in %s.\nThe repository is checked out at %s.\n' \
        "${item_id}" "${REPO_FULL}" "${repo_path}"
}

# Returns 0 if the value is a plain UUID (the format Claude returns for a session id).
# Rejecting anything else prevents injecting shell statements into the session file.
is_valid_session_id() {
    [[ "$1" =~ ^[[:xdigit:]]{8}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{12}$ ]]
}

# Prints Claude's error result (if any), removes tmpfile, and dies.
die_claude_failed() {
    local tmpfile="$1"
    jq -r '.result // ""' "${tmpfile}" 2>/dev/null >&2 || true
    rm -f "${tmpfile}"
    die "Claude invocation failed"
}

# Runs a single podman-based claude invocation, writing JSON output to tmpfile.
# On non-zero exit: handles timeout (exit 124), container-name conflict, or general failure.
run_claude_fresh() {
    local tmpfile="$1" item_type="${2:-}" item_id="${3:-}"
    local stderrfile podman_exit=0
    stderrfile=$(mktemp --suffix=.stderr) || die "Failed to create temp file for podman stderr"
    validate_bind_mounts
    info "Starting new Claude session in container ${PODMAN_CONTAINER_NAME}..." >&2
    # tmpfile and stderrfile are created by current user via mktemp, so both redirects are
    # intentionally unprivileged.
    # shellcheck disable=SC2024
    printf '%s' "${CLAUDE_PROMPT}" \
        | timeout --kill-after=60s "${AGENT_TIMEOUT_SECS}" \
            podman "${PODMAN_RUN_ARGS[@]}" "${ORCHESTRATOR_IMAGE}" "${PODMAN_CLAUDE_ARGS[@]}" \
            > "${tmpfile}" 2>"${stderrfile}" \
        || podman_exit=$?
    if [ "${podman_exit}" -ne 0 ]; then
        if [ "${podman_exit}" -eq 124 ]; then
            cat "${stderrfile}" >&2
            rm -f "${stderrfile}"
            podman rm -f "${PODMAN_CONTAINER_NAME}" > /dev/null 2>&1 || true
            notify_discord_claude_error "${item_type}" "${item_id}" \
                "Container ${PODMAN_CONTAINER_NAME} timed out after ${AGENT_TIMEOUT_MINUTES} minutes — killed"
            die "Agent container ${PODMAN_CONTAINER_NAME} timed out after ${AGENT_TIMEOUT_MINUTES} minutes"
        fi
        if grep -qi "name.*already in use" "${stderrfile}" 2>/dev/null; then
            cat "${stderrfile}" >&2
            rm -f "${stderrfile}"
            die "Container ${PODMAN_CONTAINER_NAME} is already in use — another invocation may be running"
        fi
        cat "${stderrfile}" >&2
        rm -f "${stderrfile}"
        # Claude CLI exits non-zero for API-level errors (e.g. 429 rate-limit) even
        # when it has written a valid result JSON to stdout.  Return 0 so invoke_claude
        # can inspect the JSON via handle_claude_is_error rather than losing the context.
        if [ -s "${tmpfile}" ] \
                && jq -e '.type == "result" and .is_error == true' "${tmpfile}" >/dev/null 2>&1; then
            return 0
        fi
        die_claude_failed "${tmpfile}"
    fi
    cat "${stderrfile}" >&2
    rm -f "${stderrfile}"
}

# Runs podman-based claude with --resume, capturing stderr separately to detect the
# "No conversation found" message that Claude writes to stderr on exit 1.
# On timeout (exit 124): kills container, notifies Discord, dies.
# On invalid-session error: logs to console, retries fresh, returns 0.
# On other failure: dies.
# Sets CLAUDE_RESUMED_AS_FRESH=1 if the session was restarted.
CLAUDE_RESUMED_AS_FRESH=0
CLAUDE_MD_TMPFILE=""
GPG_PUBKEY_TMPDIR=""
PODMAN_SECRET_NAME=""
GH_ENTERPRISE_SECRET_NAME=""
run_claude_resumed() {
    local tmpfile="$1" resume_id="$2" item_type="$3" item_id="$4"
    local stderrfile podman_exit=0
    stderrfile=$(mktemp --suffix=.stderr) || die "Failed to create temp file for Claude stderr"
    validate_bind_mounts
    info "Resuming Claude session ${resume_id} in container ${PODMAN_CONTAINER_NAME}..." >&2
    # tmpfile is created by current user via mktemp, so the redirect is intentionally unprivileged.
    # shellcheck disable=SC2024
    printf '%s' "${CLAUDE_PROMPT}" \
        | timeout --kill-after=60s "${AGENT_TIMEOUT_SECS}" \
            podman "${PODMAN_RUN_ARGS[@]}" "${ORCHESTRATOR_IMAGE}" "${PODMAN_CLAUDE_ARGS[@]}" \
            --resume "${resume_id}" > "${tmpfile}" 2>"${stderrfile}" \
        || podman_exit=$?

    if [ "${podman_exit}" -eq 0 ]; then
        cat "${stderrfile}" >&2
        rm -f "${stderrfile}"
        return 0
    fi

    # Timed out — clean up and notify.
    if [ "${podman_exit}" -eq 124 ]; then
        cat "${stderrfile}" >&2
        rm -f "${stderrfile}"
        podman rm -f "${PODMAN_CONTAINER_NAME}" > /dev/null 2>&1 || true
        notify_discord_claude_error "${item_type}" "${item_id}" \
            "Container ${PODMAN_CONTAINER_NAME} timed out after ${AGENT_TIMEOUT_MINUTES} minutes — killed"
        die "Agent container ${PODMAN_CONTAINER_NAME} timed out after ${AGENT_TIMEOUT_MINUTES} minutes"
    fi

    # Non-zero exit — check stderr for the known invalid-session message.
    if grep -q "No conversation found with session ID" "${stderrfile}" "${tmpfile}" 2>/dev/null; then
        cat "${stderrfile}" >&2
        rm -f "${stderrfile}" "${tmpfile}"
        warn "Session ${resume_id} no longer exists — retrying as a new session" >&2
        tmpfile=$(mktemp --suffix=.json) || die "Failed to create temp file for Claude retry"
        run_claude_fresh "${tmpfile}" "${item_type}" "${item_id}"
        CLAUDE_RESUMED_AS_FRESH=1
        # Propagate the new tmpfile path back to the caller via stdout.
        printf '%s' "${tmpfile}"
        return 0
    fi

    if grep -qi "name.*already in use" "${stderrfile}" 2>/dev/null; then
        cat "${stderrfile}" >&2
        rm -f "${stderrfile}"
        die "Container ${PODMAN_CONTAINER_NAME} is already in use — another invocation may be running"
    fi

    cat "${stderrfile}" >&2
    rm -f "${stderrfile}"
    # Claude CLI exits non-zero for API-level errors (e.g. 429 rate-limit) even
    # when it has written a valid result JSON to stdout.  Return 0 so invoke_claude
    # can inspect the JSON via handle_claude_is_error rather than losing the context.
    if [ -s "${tmpfile}" ] \
            && jq -e '.type == "result" and .is_error == true' "${tmpfile}" >/dev/null 2>&1; then
        return 0
    fi
    die_claude_failed "${tmpfile}"
}

# Handles is_error=true in the Claude JSON response.
# On blocking_limit (resumed session): retries fresh, updates tmpfile path via stdout.
# On 429: persists rate limit, notifies Discord, dies.
# On anything else: notifies Discord, dies.
handle_claude_is_error() {
    local tmpfile="$1" resume_session_id="$2" item_type="$3" item_id="$4"
    local terminal_reason api_error_status result_text

    terminal_reason=$(jq -r '.terminal_reason // ""' "${tmpfile}" 2>/dev/null || printf '')
    api_error_status=$(jq -r '.api_error_status // ""' "${tmpfile}" 2>/dev/null || printf '')
    result_text=$(jq -r '.result // "Unknown error"' "${tmpfile}" 2>/dev/null || printf 'Unknown error')
    info "Claude error: ${result_text}" >&2

    if [ "${terminal_reason}" = "blocking_limit" ] && [ -n "${resume_session_id}" ]; then
        warn "Session ${resume_session_id} exceeded context limit — retrying as a new session" >&2
        notify_discord_claude_error "${item_type}" "${item_id}" \
            "Session context too long — restarting session for ${REPO_FULL}"
        rm -f "${tmpfile}"
        local new_tmpfile
        new_tmpfile=$(mktemp --suffix=.json) || die "Failed to create temp file for Claude retry"
        run_claude_fresh "${new_tmpfile}"
        local retry_is_error
        retry_is_error=$(jq -r '.is_error // false' "${new_tmpfile}" 2>/dev/null || printf 'false')
        if [ "${retry_is_error}" = "true" ]; then
            local retry_result
            retry_result=$(jq -r '.result // "Unknown error"' "${new_tmpfile}" 2>/dev/null || printf 'Unknown error')
            notify_discord_claude_error "${item_type}" "${item_id}" "${retry_result}"
            rm -f "${new_tmpfile}"
            die "Claude invocation failed after retry: ${retry_result}"
        fi
        printf '%s' "${new_tmpfile}"
        return 0
    fi

    if [ "${api_error_status}" = "429" ]; then
        local reset_unix resume_unix
        reset_unix=$(parse_reset_time "${result_text}")
        resume_unix=""
        if [ -n "${reset_unix}" ]; then
            resume_unix=$((reset_unix + RATE_LIMIT_RESUME_BUFFER_SECS))
            save_rate_limit "${resume_unix}"
        fi
        notify_discord_rate_limited "${item_type}" "${item_id}" "${result_text}" "${resume_unix}"
        rm -f "${tmpfile}"
        die "Claude rate limited: ${result_text}"
    fi

    notify_discord_claude_error "${item_type}" "${item_id}" "${result_text}"
    rm -f "${tmpfile}"
    die "Claude invocation failed: ${result_text}"
}

# In cgroup v2, the "no-internal-process" constraint forbids a cgroup that
# directly contains processes from having child cgroups with domain controllers
# (memory, cpu, pids).  For Type=oneshot services the process lands directly
# in the service cgroup.  Delegate=cpu memory pids io grants permission to
# write subtree_control but does NOT write it automatically (verified on
# systemd 260); the process must do it itself — but only after moving to a
# leaf, because writing subtree_control while tasks are present fails with EBUSY.
#
# This function handles both cases:
# - If systemd already placed us in a leaf (e.g. on some Type=simple configs),
#   strip the leaf component to get the service cgroup as parent.
# - If we are directly in the service cgroup (Type=oneshot), move ourselves
#   into a leaf sub-cgroup named "init", then write the domain controllers to
#   the service cgroup's subtree_control so container child cgroups get
#   pids.max, memory.max, cpu.max etc.
#
# Sets PODMAN_CGROUP_PARENT so invoke_claude passes --cgroup-parent to every
# podman run call.  No-op when not running from a system service.
setup_cgroup_leaf() {
    local svcgroup leaf_dir cgroupfs_path controller
    svcgroup=$(cut -d: -f3 /proc/self/cgroup 2>/dev/null) || return 0

    case "${svcgroup}" in
        /system.slice/*/*)
            # systemd placed us in a leaf sub-cgroup like
            # /system.slice/<service>.service/0 — strip the last component
            # to get the service cgroup itself as the container parent.
            svcgroup="${svcgroup%/*}"
            ;;
        /system.slice/*)
            # Process is directly in the service cgroup.
            # Step 1: move ALL processes to a leaf so the service cgroup has no
            # direct tasks.  Moving only $$ is insufficient: any left-over
            # processes from an unclean previous run (e.g. ssh-agent) remain in
            # the service cgroup and cause the subtree_control write to fail
            # with EBUSY (cannot enable domain controllers while tasks exist).
            cgroupfs_path="/sys/fs/cgroup${svcgroup}"
            leaf_dir="${cgroupfs_path}/init"
            mkdir -p "${leaf_dir}" 2>/dev/null \
                || { warn "Cannot create leaf cgroup ${leaf_dir} — container resource limits may not apply"; return 0; }
            local pids pid
            pids=$(cat "${cgroupfs_path}/cgroup.procs" 2>/dev/null) || pids=""
            for pid in ${pids}; do
                printf '%s\n' "${pid}" > "${leaf_dir}/cgroup.procs" 2>/dev/null || true
            done
            # Step 2: now that the service cgroup has no direct tasks, enable
            # domain controllers so container child cgroups have pids.max etc.
            for controller in cpu memory pids io; do
                printf '+%s\n' "${controller}" > "${cgroupfs_path}/cgroup.subtree_control" 2>/dev/null \
                    || warn "Cannot enable ${controller} controller in ${svcgroup} — container resource limits may not apply"
            done
            ;;
        *)
            return 0
            ;;
    esac

    PODMAN_CGROUP_PARENT="${svcgroup}"
}

# Loads default SSH keys into the agent if SSH_AUTH_SOCK is set and the agent
# currently holds no keys.  Silent when keys are already loaded (avoids
# redundant re-adds across timer firings); warns rather than dies on failure.
preload_ssh_keys() {
    [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "${SSH_AUTH_SOCK}" ] || return 0
    local ssh_keys_status=0
    ssh-add -l >/dev/null 2>&1 || ssh_keys_status=$?
    [ "${ssh_keys_status}" -eq 1 ] || return 0  # 0 = already loaded; 2 = no agent
    ssh-add -q 2>/dev/null \
        || die "ssh-add: no SSH keys could be loaded — import a key with 'ssh-add <key-file>'"
}

# Posts a comment on the current GitHub work item and adds the Blocked label.
# Silent when item_type or item_id is unset.
notify_github_blocked() {
    local item_type="$1" item_id="$2" message="$3"
    [ -n "${item_type}" ] && [ -n "${item_id}" ] || return 0
    case "${item_type}" in
        Issue)
            gh issue comment "${item_id}" --repo "${REPO_FULL}" --body "${message}" 2>/dev/null || true
            gh issue edit   "${item_id}" --repo "${REPO_FULL}" --add-label "Blocked" 2>/dev/null || true
            ;;
        PullRequest)
            gh pr comment "${item_id}" --repo "${REPO_FULL}" --body "${message}" 2>/dev/null || true
            gh pr edit    "${item_id}" --repo "${REPO_FULL}" --add-label "Blocked" 2>/dev/null || true
            ;;
    esac
}

# Fast-fails if GIT_SIGNING_KEY is set but gpg-agent is not running or the key
# is absent from the keyring.  Posts a GitHub comment and adds Blocked before dying.
verify_gpg_signing_ready() {
    local item_type="$1" item_id="$2"
    [ -n "${GIT_SIGNING_KEY}" ] || return 0

    if ! gpg-connect-agent /bye >/dev/null 2>&1; then
        notify_github_blocked "${item_type}" "${item_id}" \
            "Cannot start agent session: \`gpg-agent\` is not running on the host. Run \`gpgconf --launch gpg-agent\` and retry."
        die "gpg-agent is not running — run 'gpgconf --launch gpg-agent' to start it"
    fi

    if ! gpg --batch --no-tty --list-secret-keys "${GIT_SIGNING_KEY}" >/dev/null 2>&1; then
        notify_github_blocked "${item_type}" "${item_id}" \
            "Cannot start agent session: signing key \`${GIT_SIGNING_KEY}\` is not in the GPG keyring. Import it with \`gpg --import <key-file>\` on the host."
        die "Signing key ${GIT_SIGNING_KEY} not found in GPG keyring — import it with 'gpg --import'"
    fi
}

# Appends GPG volume/socket args to PODMAN_RUN_ARGS.
# Creates a tmpdir containing only the signing public key and forwards the
# gpg-agent extra socket into it — no private key material is exposed to the
# container.  Dies if GIT_SIGNING_KEY is set but the secure path is not available,
# because there is no safe fallback (mounting ~/.gnupg exposes private keys).
add_gpg_podman_args() {
    local extra_socket
    extra_socket=$(gpgconf --list-dirs agent-extra-socket 2>/dev/null) || extra_socket=""

    # When the service runs with XDG_RUNTIME_DIR set, gpg-agent creates its sockets
    # in $XDG_RUNTIME_DIR/gnupg/ rather than ~/.gnupg/.  gpgconf --list-dirs may
    # still return the ~/.gnupg path, which could be a stale socket file left behind
    # when a previous gpg-agent was killed with SIGKILL.  Prefer the live runtime-dir
    # socket when it exists.
    if [ -n "${XDG_RUNTIME_DIR}" ]; then
        local runtime_extra="${XDG_RUNTIME_DIR}/gnupg/S.gpg-agent.extra"
        [ -S "${runtime_extra}" ] && extra_socket="${runtime_extra}"
    fi

    [ -n "${GIT_SIGNING_KEY}" ] || return 0

    [ -S "${extra_socket}" ] \
        || die "GPG agent extra socket not available — run 'gpgconf --launch gpg-agent' and ensure it creates an extra socket"

    GPG_PUBKEY_TMPDIR=$(mktemp -d --suffix=.gnupghome) \
        || die "Failed to create tmpdir for GPG pubkey gnupghome"
    chmod 0700 "${GPG_PUBKEY_TMPDIR}"
    gpg --batch --no-tty --export "${GIT_SIGNING_KEY}" 2>/dev/null \
            | GNUPGHOME="${GPG_PUBKEY_TMPDIR}" gpg --batch --no-tty --import --quiet 2>/dev/null \
        || die "GPG public key export/import failed for ${GIT_SIGNING_KEY} — ensure the key is in the local keyring"
    PODMAN_RUN_ARGS+=( --volume "${GPG_PUBKEY_TMPDIR}:/home/developer/.gnupg:rw" )
    PODMAN_RUN_ARGS+=( --volume "${extra_socket}:/home/developer/.gnupg/S.gpg-agent:ro" )
}

# Verify all --volume source paths in PODMAN_RUN_ARGS exist with the expected
# type before calling podman run.  Podman auto-creates any missing bind-mount
# source as a directory; if that path is later expected to be a socket, the
# directory blocks ssh-agent from binding there on the next run.
validate_bind_mounts() {
    local i=0 take_next=0 src
    local n=${#PODMAN_RUN_ARGS[@]}
    while [ "${i}" -lt "${n}" ]; do
        local arg="${PODMAN_RUN_ARGS[$i]}"
        if [ "${take_next}" = "1" ]; then
            take_next=0
            src="${arg%%:*}"
            case "${src}" in
                *.sock|*/S.gpg-agent|*/S.gpg-agent.extra)
                    [ -S "${src}" ] \
                        || die "Bind-mount source must be a socket but is missing or wrong type: ${src}"
                    ;;
                *)
                    [ -e "${src}" ] \
                        || die "Bind-mount source does not exist: ${src}"
                    ;;
            esac
        elif [ "${arg}" = "--volume" ]; then
            take_next=1
        fi
        i=$(( i + 1 ))
    done
}

# Outputs the Claude session ID on stdout; all user-visible messages go to stderr.
# Claude's text response is written to stderr so the caller can review what was done.
# Runs claude inside a rootless Podman container named orchestrator-<OWNER>.
invoke_claude() {
    local prompt="$1" resume_session_id="$2" item_type="${3:-}" item_id="${4:-}" claude_md_content="${5:-}"
    local tmpfile new_session_id owner_token container_name

    local prompt_len=${#prompt}
    if [ "${prompt_len}" -gt "${MAX_PROMPT_CHARS}" ]; then
        notify_discord_claude_error "${item_type}" "${item_id}" \
            "Prompt is too long: ${prompt_len} characters (max ${MAX_PROMPT_CHARS})"
        die "Prompt is too long: ${prompt_len} characters exceeds limit of ${MAX_PROMPT_CHARS}"
    fi

    owner_token=$(load_token_for_owner "${OWNER}")
    container_name="orchestrator-${OWNER}"

    if podman inspect "${container_name}" >/dev/null 2>&1; then
        die "Container ${container_name} already exists — remove it manually before running"
    fi

    info "Pulling latest image ${ORCHESTRATOR_IMAGE}..." >&2
    podman pull "${ORCHESTRATOR_IMAGE}" >&2 || die "Failed to pull ${ORCHESTRATOR_IMAGE}"

    # CLAUDE.md content is mandatory — every invocation must supply it.
    [ -n "${claude_md_content}" ] || die "claude_md_content is required but was not provided"

    # Mount .claude/ as a host-owned temp directory so the developer user can write
    # session-env and other runtime files inside it.  Mounting only the CLAUDE.md file
    # causes Podman to create the parent directory with wrong ownership, which breaks
    # every Bash tool call with EACCES.
    CLAUDE_MD_TMPFILE=$(mktemp -d --suffix=.claudedir) || die "Failed to create temp dir for .claude"
    printf '%s' "${claude_md_content}" > "${CLAUDE_MD_TMPFILE}/CLAUDE.md"
    PODMAN_SECRET_NAME=""
    GH_ENTERPRISE_SECRET_NAME=""
    trap 'rm -rf "${CLAUDE_MD_TMPFILE}"; rm -rf "${GPG_PUBKEY_TMPDIR}"; [ -n "${PODMAN_SECRET_NAME}" ] && podman secret rm "${PODMAN_SECRET_NAME}" >/dev/null 2>&1 || true; [ -n "${GH_ENTERPRISE_SECRET_NAME}" ] && podman secret rm "${GH_ENTERPRISE_SECRET_NAME}" >/dev/null 2>&1 || true' EXIT

    # Export invocation-scoped globals so helper functions can read them.
    CLAUDE_PROMPT="${prompt}"
    PODMAN_CONTAINER_NAME="${container_name}"
    PODMAN_RUN_ARGS=(
        run
        --name "${container_name}"
        --rm
        --interactive
        # keep-id:uid=1000,gid=1000 maps container developer (UID/GID 1000) to the
        # host user running this service so that bind-mounted sockets and directories
        # owned by the host user appear as owned by the container's developer user,
        # giving it full owner-level access without world-writable permissions.
        "--userns=keep-id:uid=1000,gid=1000"
        --cpus="4"
        --memory="12g"
        --memory-swap="12g"
        --pids-limit=4096
        --volume "${REPO_WORK_DIR}:${CONTAINER_REPO_PATH}:rw"
        --volume "${RULES_DIR}:${CONTAINER_RULES_PATH}:ro"
    )
    [ -n "${PODMAN_CGROUP_PARENT}" ] && PODMAN_RUN_ARGS+=( --cgroup-parent "${PODMAN_CGROUP_PARENT}" )
    if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "${SSH_AUTH_SOCK}" ]; then
        PODMAN_RUN_ARGS+=( --volume "${SSH_AUTH_SOCK}:/tmp/ssh-agent.sock:ro" )
        PODMAN_RUN_ARGS+=( --env "SSH_AUTH_SOCK=/tmp/ssh-agent.sock" )
    else
        warn "SSH_AUTH_SOCK is not set or socket is absent — SSH git operations will not be available in the agent container"
    fi
    verify_gpg_signing_ready "${item_type}" "${item_id}"
    add_gpg_podman_args
    if [ -f "${HOME}/.database" ]; then
        PODMAN_RUN_ARGS+=( --volume "${HOME}/.database:/home/developer/.database:ro" )
    else
        warn "\$HOME/.database not found — database credentials will not be available in the agent container"
    fi
    PODMAN_RUN_ARGS+=( --volume "${CLAUDE_MD_TMPFILE}:/home/developer/.claude:rw" )

    [ -n "${GIT_USER_NAME}" ]  && PODMAN_RUN_ARGS+=( --env "GIT_USER_NAME=${GIT_USER_NAME}" )
    [ -n "${GIT_USER_EMAIL}" ] && PODMAN_RUN_ARGS+=( --env "GIT_USER_EMAIL=${GIT_USER_EMAIL}" )
    [ -n "${GIT_SIGNING_KEY}" ] && PODMAN_RUN_ARGS+=( --env "GIT_SIGNING_KEY=${GIT_SIGNING_KEY}" )

    if [ -n "${owner_token}" ]; then
        PODMAN_SECRET_NAME="claude-oauth-${OWNER}"
        podman secret rm "${PODMAN_SECRET_NAME}" >/dev/null 2>&1 || true
        printf '%s' "${owner_token}" | podman secret create "${PODMAN_SECRET_NAME}" - \
            || die "Failed to create Podman secret for Claude OAuth token"
        PODMAN_RUN_ARGS+=( --secret "${PODMAN_SECRET_NAME},type=env,target=CLAUDE_CODE_OAUTH_TOKEN" )
    fi
    if [ -n "${GH_ENTERPRISE_TOKEN:-}" ]; then
        GH_ENTERPRISE_SECRET_NAME="gh-enterprise-token"
        podman secret rm "${GH_ENTERPRISE_SECRET_NAME}" >/dev/null 2>&1 || true
        printf '%s' "${GH_ENTERPRISE_TOKEN}" | podman secret create "${GH_ENTERPRISE_SECRET_NAME}" - \
            || die "Failed to create Podman secret for GH_ENTERPRISE_TOKEN"
        PODMAN_RUN_ARGS+=( --secret "${GH_ENTERPRISE_SECRET_NAME},type=env,target=GH_ENTERPRISE_TOKEN" )
    fi
    [ -n "${GH_HOST:-}" ]                && PODMAN_RUN_ARGS+=( --env "GH_HOST=${GH_HOST}" )

    PODMAN_CLAUDE_ARGS=(
        --model opusplan
        --print
        --output-format json
        --dangerously-skip-permissions
        --add-dir "${CONTAINER_REPO_PATH}"
    )

    tmpfile=$(mktemp --suffix=.json) || die "Failed to create temp file for Claude output"

    if [ -n "${resume_session_id}" ]; then
        CLAUDE_RESUMED_AS_FRESH=0
        local new_tmpfile resume_status=0
        new_tmpfile=$(run_claude_resumed "${tmpfile}" "${resume_session_id}" "${item_type}" "${item_id}") \
            || resume_status=$?
        if [ "${resume_status}" -ne 0 ]; then
            rm -f "${tmpfile}"
            exit "${resume_status}"
        fi
        # run_claude_resumed returns a new path only when it restarted as a fresh session.
        [ -n "${new_tmpfile}" ] && tmpfile="${new_tmpfile}"
        [ "${CLAUDE_RESUMED_AS_FRESH}" = "1" ] && resume_session_id=""
    else
        run_claude_fresh "${tmpfile}" "${item_type}" "${item_id}"
    fi

    local is_error
    is_error=$(jq -r '.is_error // false' "${tmpfile}" 2>/dev/null || printf 'false')
    if [ "${is_error}" = "true" ]; then
        local new_tmpfile
        new_tmpfile=$(handle_claude_is_error "${tmpfile}" "${resume_session_id}" "${item_type}" "${item_id}")
        # handle_claude_is_error returns a new path only on blocking_limit retry.
        [ -n "${new_tmpfile}" ] && tmpfile="${new_tmpfile}"
    fi

    jq -r '.result // ""' "${tmpfile}" >&2

    new_session_id=$(jq -r '.session_id // empty' "${tmpfile}") \
        || { rm -f "${tmpfile}"; rm -rf "${CLAUDE_MD_TMPFILE}"; CLAUDE_MD_TMPFILE=""; rm -rf "${GPG_PUBKEY_TMPDIR}"; GPG_PUBKEY_TMPDIR=""; die "Failed to parse session_id from Claude output"; }
    rm -f "${tmpfile}"

    [ -n "${new_session_id}" ] || { rm -rf "${CLAUDE_MD_TMPFILE}"; CLAUDE_MD_TMPFILE=""; rm -rf "${GPG_PUBKEY_TMPDIR}"; GPG_PUBKEY_TMPDIR=""; die "No session_id returned by Claude"; }
    is_valid_session_id "${new_session_id}" \
        || { rm -rf "${CLAUDE_MD_TMPFILE}"; CLAUDE_MD_TMPFILE=""; rm -rf "${GPG_PUBKEY_TMPDIR}"; GPG_PUBKEY_TMPDIR=""; die "Unexpected session_id format returned by Claude: ${new_session_id}"; }

    rm -rf "${CLAUDE_MD_TMPFILE}"
    CLAUDE_MD_TMPFILE=""
    rm -rf "${GPG_PUBKEY_TMPDIR}"
    GPG_PUBKEY_TMPDIR=""
    printf '%s' "${new_session_id}"
}

# Returns the path to the rate-limit file for the current owner.
owner_rate_limit_file() {
    printf '%s/.orchestrator/%s/rate-limit' "${HOME}" "${OWNER}"
}

# Saves a rate-limit reset unix timestamp for the current owner.
save_rate_limit() {
    local reset_unix="$1"
    local rate_limit_file
    rate_limit_file=$(owner_rate_limit_file)
    mkdir -p "$(dirname "${rate_limit_file}")" \
        || die "Failed to create rate-limit directory for owner ${OWNER}"
    printf '%s\n' "${reset_unix}" > "${rate_limit_file}" \
        || die "Failed to write rate-limit file: ${rate_limit_file}"
}

# Returns 0 (true) if the current owner is still rate-limited.
# Clears the rate-limit file when the reset time has passed.
is_owner_rate_limited() {
    local rate_limit_file reset_unix now_unix
    rate_limit_file=$(owner_rate_limit_file)
    [ -f "${rate_limit_file}" ] || return 1
    reset_unix=$(cat "${rate_limit_file}" 2>/dev/null) || return 1
    [[ "${reset_unix}" =~ ^[0-9]+$ ]] || { rm -f "${rate_limit_file}"; return 1; }
    now_unix=$(date +%s)
    if [ "${now_unix}" -ge "${reset_unix}" ]; then
        rm -f "${rate_limit_file}"
        return 1
    fi
    return 0
}

# Parses a "resets Hpm (Timezone)" string from a Claude rate-limit error and
# outputs the corresponding unix timestamp on stdout.  If the resolved time is
# already in the past (i.e. the reset is tomorrow), adds 86400 seconds.
# Outputs nothing and returns silently when parsing fails.
parse_reset_time() {
    local result_text="$1"
    local hour ampm tz hour24 reset_unix now_unix
    local regex='resets ([0-9]+)(am|pm) \(([^)]+)\)'

    [[ "${result_text}" =~ $regex ]] || return 0

    hour="${BASH_REMATCH[1]}"
    ampm="${BASH_REMATCH[2]}"
    tz="${BASH_REMATCH[3]}"

    # Reject timezone strings with dangerous characters.
    case "${tz}" in
        *[!a-zA-Z0-9/_+-]*) return ;;
    esac

    # Convert 12-hour clock to 24-hour.
    if [ "${ampm}" = "pm" ] && [ "${hour}" != "12" ]; then
        hour24=$((hour + 12))
    elif [ "${ampm}" = "am" ] && [ "${hour}" = "12" ]; then
        hour24=0
    else
        hour24="${hour}"
    fi

    reset_unix=$(TZ="${tz}" date -d "today ${hour24}:00" +%s 2>/dev/null) || return
    now_unix=$(date +%s)
    if [ "${reset_unix}" -le "${now_unix}" ]; then
        reset_unix=$(TZ="${tz}" date -d "tomorrow ${hour24}:00" +%s 2>/dev/null) || return
    fi
    printf '%s' "${reset_unix}"
}

