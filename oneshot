#!/bin/bash

# Orchestrator oneshot script.
# Fetches all open work items from the priorities API and drives a Claude Code session
# to work on the first actionable item across any repository.  Every invocation runs a
# FRESH Claude session (no --resume): all durable state lives in GitHub (branch, commits,
# PR comments, labels, Workflow board), so each run re-derives its context and does exactly
# ONE workflow phase before stopping.  This bounds a single session's context growth and
# is what keeps runs from hitting the model context window ("Prompt is too long").
# The orchestrator re-invokes the item on the next tick to advance to the next phase.

PRIORITIES_URL="https://git-workflow.markridgwell.com/priorities"
WORK="${XDG_PROJECTS_DIR:-${HOME}/work}"
ORCHESTRATOR_IMAGE="${ORCHESTRATOR_IMAGE:-ghcr.io/credfeto/development-agent:latest}"
CONTAINER_REPO_PATH="/workspace/repo"
CONTAINER_RULES_PATH="/workspace/rules"

# Conservative pre-send guard against grossly oversized prompts.
# The launch prompt is deliberately tiny ("Work on <item> in <repo>") — everything of
# substance lives in the generated CLAUDE.md — so this cap is only a sanity backstop and
# is NOT the mechanism that prevents "Prompt is too long".  That failure comes from
# accumulated conversation over many turns exceeding the model context window; the
# phase-per-invocation design (fresh session, one phase, then stop) is what bounds it.
MAX_PROMPT_CHARS=100000

# Extra buffer added to the token-reset time before resuming agentic work.
# Avoids hitting the limit again immediately after it lifts.
RATE_LIMIT_RESUME_BUFFER_SECS=3600

# Where unparseable 429 rate-limit messages are reported so parse_reset_time can be extended.
RATE_LIMIT_ISSUE_REPO="credfeto/credfeto-orchestrator"
RATE_LIMIT_ISSUE_TITLE="Unparseable Claude rate-limit reset time"

# Title of the issue filed in an affected repo when the orchestrator cannot obtain a
# usable "Workflow" project for it (see report_missing_workflow_project).  A bot account
# cannot create a project under a personal account, so the owner must run create-project.
WF_SETUP_ISSUE_TITLE="Workflow project setup required"

# Hard limit on how long a single agent container may run. Prevents a stuck
# Monitor loop from holding resources indefinitely.
# Override with AGENT_TIMEOUT_MINUTES in the environment before calling oneshot.
AGENT_TIMEOUT_MINUTES="${AGENT_TIMEOUT_MINUTES:-90}"
AGENT_TIMEOUT_SECS=$(( AGENT_TIMEOUT_MINUTES * 60 ))

# Set by setup_cgroup_leaf; passed as --cgroup-parent to every podman run call.
PODMAN_CGROUP_PARENT=""

# Minimum free disk space in kilobytes required to launch a container (10 GB).
MIN_DISK_SPACE_KB=$(( 10 * 1024 * 1024 ))

# Maximum number of review rounds the agent runs per PR.  Each round is now its own
# fresh invocation (one /code-review or /security-review round, then stop), so this cap is
# advisory guidance passed into the prompt rather than an in-session loop counter.
# Override with MAX_REVIEW_ITERATIONS in the environment before calling oneshot.
MAX_REVIEW_ITERATIONS="${MAX_REVIEW_ITERATIONS:-3}"

# Runaway backstop: the maximum number of agent invocations the orchestrator will spend on
# a single PR before marking it Blocked for a human to look at.  Normal end-to-end flow
# (setup, rebase, fix, a few review rounds, finalize) uses well under this; exceeding it
# means the agent is churning without converging.  Override with MAX_PR_TOTAL_INVOCATIONS.
MAX_PR_TOTAL_INVOCATIONS="${MAX_PR_TOTAL_INVOCATIONS:-30}"
[[ "${MAX_PR_TOTAL_INVOCATIONS}" =~ ^[1-9][0-9]*$ ]] || MAX_PR_TOTAL_INVOCATIONS=30

# How many consecutive "in-progress" re-invocations to allow on an unchanged PR fingerprint
# before parking it.  Phases that advance the board without pushing (a clean code/security
# review, or the finalize step on a repo where auto-merge cannot be enabled) do not change the
# fingerprint, so the orchestrator re-invokes an unchanged non-terminal PR to let the next phase
# run — but only up to this many times, so a PR that is genuinely done just goes quiet.
# Override with MAX_PR_IDLE_INVOCATIONS in the environment before calling oneshot.
MAX_PR_IDLE_INVOCATIONS="${MAX_PR_IDLE_INVOCATIONS:-5}"
[[ "${MAX_PR_IDLE_INVOCATIONS}" =~ ^[1-9][0-9]*$ ]] || MAX_PR_IDLE_INVOCATIONS=5

# How long (in minutes) to wait for CI checks to complete before flagging a PR as Blocked.
# Override with CI_CHECK_TIMEOUT_MINUTES in the environment or in .env.
CI_CHECK_TIMEOUT_MINUTES="${CI_CHECK_TIMEOUT_MINUTES:-1440}"
[[ "${CI_CHECK_TIMEOUT_MINUTES}" =~ ^[1-9][0-9]*$ ]] || CI_CHECK_TIMEOUT_MINUTES=120

# Comma-separated list of additional trusted GitHub users, loaded from .env.
WHITELISTED_USERS=""
# Cached JSON array of trusted logins for the current repo context; reset by set_repo_context.
_TRUSTED_LOGINS_JSON=""

die() {
    if [ -t 2 ]; then
        printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    else
        printf '\n✗ %s\n' "$*" >&2
    fi
    exit 1
}

success() {
    if [ -t 1 ]; then
        printf '\n\033[32m✓\033[0m %s\n' "$*"
    else
        printf '\n✓ %s\n' "$*"
    fi
}

info() {
    if [ -t 1 ]; then
        printf '\n\033[32m→\033[0m %s\n' "$*"
    else
        printf '\n→ %s\n' "$*"
    fi
}

warn() {
    if [ -t 2 ]; then
        printf '\n\033[33m!\033[0m %s\n' "$*" >&2
    else
        printf '\n! %s\n' "$*" >&2
    fi
}

# Returns true (0) when running inside a Claude Code Bash-tool session.
# Claude Code sets CLAUDECODE=1 in every shell it spawns via the Bash tool;
# that value is inherited by subprocesses (e.g. git hooks).
# Source: https://docs.anthropic.com/en/docs/claude-code/settings#environment-variables
is_ai_agent() {
    [ "${CLAUDECODE}" = "1" ]
}

# Checks that token_file exists, has safe permissions, and outputs its contents (whitespace stripped).
# Outputs nothing and returns silently if the file is absent or has unsafe permissions.
read_token_if_safe() {
    local token_file="$1"
    local perms
    [ -f "${token_file}" ] || return
    perms=$(stat -c '%a' "${token_file}" 2>/dev/null || stat -f '%Lp' "${token_file}" 2>/dev/null)
    case "${perms}" in
        600|400) ;;
        *) warn "Token file ${token_file} has permissions ${perms} — expected 600; skipping"
           return
           ;;
    esac
    tr -d '[:space:]' < "${token_file}"
}

# Outputs the OAuth token for the given owner, or empty string if not configured.
# Lookup order:
#   1. $XDG_CONFIG_HOME/orchestrator/tokens/<owner>  (preferred XDG location, defaults to ~/.config)
#   2. Empty string — caller falls back to CLAUDE_CODE_OAUTH_TOKEN from the environment.
# Token files must be readable only by the owner (chmod 600).
load_token_for_owner() {
    local owner="$1"
    local token

    case "${owner}" in
        *[!a-zA-Z0-9_-]*) return ;;
    esac

    token=$(read_token_if_safe "${XDG_CONFIG_HOME:-${HOME}/.config}/orchestrator/tokens/${owner}")
    if [ -n "${token}" ]; then
        printf '%s' "${token}"
    fi
}

# Maps a host file path to its container-internal equivalent.
# Paths under REPO_WORK_DIR map to CONTAINER_REPO_PATH; paths under RULES_DIR
# map to CONTAINER_RULES_PATH.  Unrecognised paths are returned unchanged.
host_to_container_path() {
    local host_path="$1"
    local rel
    if [ -n "${REPO_WORK_DIR}" ]; then
        rel="${host_path#"${REPO_WORK_DIR}"}"
        if [ "${rel}" != "${host_path}" ]; then
            printf '%s%s' "${CONTAINER_REPO_PATH}" "${rel}"
            return
        fi
    fi
    if [ -n "${RULES_DIR}" ]; then
        rel="${host_path#"${RULES_DIR}"}"
        if [ "${rel}" != "${host_path}" ]; then
            printf '%s%s' "${CONTAINER_RULES_PATH}" "${rel}"
            return
        fi
    fi
    printf '%s' "${host_path}"
}

# Sets the per-repo globals used by all sub-functions.
# Call once for each repository before invoking any function that reads these globals.
set_repo_context() {
    local repo_full="$1"
    OWNER="${repo_full%%/*}"
    REPO="${repo_full##*/}"
    REPO_FULL="${repo_full}"
    RULES_DIR="${WORK}/${OWNER}/${REPO}/rules"
    REPO_WORK_DIR="${WORK}/${OWNER}/${REPO}/repo"
    SESSION_BASE_DIR="${HOME}/.orchestrator/${OWNER}/${REPO}"
    # Host-side persistent store for the parts of the container's ~/.claude that
    # must survive across invocations (sessions, session-env, plans, cache,
    # backups). Nested under SESSION_BASE_DIR so state stays scoped per-repo,
    # matching how fingerprint/resume-session bookkeeping already works above.
    CLAUDE_STATE_DIR="${SESSION_BASE_DIR}/claude"
    _TRUSTED_LOGINS_JSON=""
}

# Returns a JSON array of trusted GitHub logins for the current repo context.
# Includes: OWNER, repo collaborators, the GitHub Copilot reviewer bot, and WHITELISTED_USERS.
# The result is cached in _TRUSTED_LOGINS_JSON; cache is cleared by set_repo_context.
get_trusted_logins() {
    [ -n "${_TRUSTED_LOGINS_JSON}" ] && { printf '%s' "${_TRUSTED_LOGINS_JSON}"; return; }

    local -a logins=()
    [ -n "${OWNER}" ] && logins+=("${OWNER}")

    local login
    while IFS= read -r login; do
        [ -n "${login}" ] && logins+=("${login}")
    done < <(gh api "repos/${REPO_FULL}/collaborators" --jq '.[].login' 2>/dev/null || true)

    logins+=("copilot-pull-request-reviewer")

    if [ -n "${WHITELISTED_USERS}" ]; then
        local user remainder="${WHITELISTED_USERS}"
        while [ -n "${remainder}" ]; do
            user="${remainder%%,*}"
            remainder="${remainder#"${user}"}"
            remainder="${remainder#,}"
            user="${user#"${user%%[! ]*}"}"
            user="${user%"${user##*[! ]}"}"
            [ -n "${user}" ] && logins+=("${user}")
        done
    fi

    _TRUSTED_LOGINS_JSON=$(printf '%s\n' "${logins[@]+"${logins[@]}"}" | jq -R -s 'split("\n") | map(select(length > 0)) | unique')
    printf '%s' "${_TRUSTED_LOGINS_JSON}"
}

ensure_rules_current() {
    if [ -d "${RULES_DIR}/.git" ]; then
        info "Updating rules (cs-template) at ${RULES_DIR}..."
        git -C "${RULES_DIR}" checkout main || die "Failed to switch cs-template to main at ${RULES_DIR}"
        git -C "${RULES_DIR}" pull --ff-only || die "Failed to update cs-template at ${RULES_DIR}"
    else
        info "Cloning rules (cs-template) to ${RULES_DIR}..."
        mkdir -p "$(dirname "${RULES_DIR}")" || die "Failed to create parent directory for ${RULES_DIR}"
        git clone git@github.com:credfeto/cs-template.git "${RULES_DIR}" || die "Failed to clone cs-template to ${RULES_DIR}"
    fi
}

# Remove any url.*.insteadOf / url.*.pushInsteadOf rules from the local .git/config.
# The agent running inside the container may write these (e.g. via `gh auth setup-git`)
# and they persist across sessions through the bind mount.  The container entrypoint
# rejects them on startup because they are only allowed in the system /etc/gitconfig.
clean_local_git_url_rewrites() {
    local repo_dir="${1:-${REPO_WORK_DIR}}"
    [ -d "${repo_dir}/.git" ] || return 0
    local key
    while IFS= read -r key; do
        [ -z "${key}" ] && continue
        git -C "${repo_dir}" config --local --unset-all "${key}" 2>/dev/null || true
    done < <(git -C "${repo_dir}" config --local --name-only --list 2>/dev/null \
        | grep -iE '\.(insteadof|pushinsteadof)$' || true)
}

ensure_repo_current() {
    if [ -d "${REPO_WORK_DIR}/.git" ]; then
        # Reset the remote URL to SSH on every iteration. The agent running inside
        # the container may have changed the URL or added extra fetch/push URLs.
        # --unset-all removes every entry (--unset silently fails when multiple
        # values exist), then we write exactly one correct URL for each slot.
        clean_local_git_url_rewrites "${REPO_WORK_DIR}"
        git -C "${REPO_WORK_DIR}" config --unset-all remote.origin.url 2>/dev/null || true
        git -C "${REPO_WORK_DIR}" config remote.origin.url "git@github.com:${OWNER}/${REPO}.git"
        git -C "${REPO_WORK_DIR}" config --unset-all remote.origin.pushurl 2>/dev/null || true
        info "Fetching latest changes for ${REPO_FULL}..."
        git -C "${REPO_WORK_DIR}" fetch --prune origin || die "Failed to fetch from origin for ${REPO_FULL}"

        local current_branch
        current_branch=$(git -C "${REPO_WORK_DIR}" branch --show-current)
        if ! git -C "${REPO_WORK_DIR}" diff --quiet || ! git -C "${REPO_WORK_DIR}" diff --cached --quiet; then
            DIRTY_BRANCH="${current_branch}"
            warn "Working tree has uncommitted changes on '${current_branch}' for ${REPO_FULL} — handing off to agent to recover"
            return 1
        fi
        if [ "${current_branch}" != "main" ] \
                && ! git -C "${REPO_WORK_DIR}" rev-parse --verify "refs/remotes/origin/${current_branch}" >/dev/null 2>&1; then
            warn "Branch '${current_branch}' no longer exists on origin for ${REPO_FULL} — returning to main"
            git -C "${REPO_WORK_DIR}" checkout main \
                || die "Failed to switch to main after orphaned branch '${current_branch}' for ${REPO_FULL}"
            current_branch="main"
        fi
        if [ "${current_branch}" = "main" ]; then
            info "Rebasing main with origin/main..."
            git -C "${REPO_WORK_DIR}" rebase origin/main || die "Failed to rebase main with origin/main"
        fi
    else
        info "Cloning ${REPO_FULL} to ${REPO_WORK_DIR}..."
        mkdir -p "$(dirname "${REPO_WORK_DIR}")" || die "Failed to create parent directory for ${REPO_WORK_DIR}"
        git clone "git@github.com:${OWNER}/${REPO}.git" "${REPO_WORK_DIR}" || die "Failed to clone ${REPO_FULL} to ${REPO_WORK_DIR}"
    fi
}

# Returns 0 if the repo was on a branch that no longer exists on origin AND has been
# reset to main; returns 1 in all other cases (repo absent, already on main, branch still
# live on remote, or any git failure).  Performs its own fetch --prune because it is
# called before ensure_repo_current in the fingerprint-skip path.
recover_orphaned_branch() {
    [ -d "${REPO_WORK_DIR}/.git" ] || return 1

    local current_branch
    current_branch=$(git -C "${REPO_WORK_DIR}" branch --show-current 2>/dev/null) || return 1
    [ "${current_branch}" = "main" ] && return 1

    git -C "${REPO_WORK_DIR}" fetch --prune origin 2>/dev/null || return 1

    git -C "${REPO_WORK_DIR}" rev-parse --verify "refs/remotes/origin/${current_branch}" >/dev/null 2>&1 \
        && return 1

    warn "Branch '${current_branch}' no longer exists on origin for ${REPO_FULL} — returning to main"
    git -C "${REPO_WORK_DIR}" checkout -f main \
        || die "Failed to switch to main after orphaned branch '${current_branch}' for ${REPO_FULL}"
    git -C "${REPO_WORK_DIR}" rebase origin/main \
        || die "Failed to rebase origin/main after orphaned branch recovery for ${REPO_FULL}"
    return 0
}

# Attempts a non-agentic rebase of branch_name onto origin/main.
# Returns 0 if the rebase succeeded and changes were force-pushed; 1 if any
# conflict was encountered or if the push failed. Always leaves the working
# tree on main.
try_nonagentic_rebase() {
    local branch_name="$1"

    [ -n "${branch_name}" ] || return 1

    clean_local_git_url_rewrites "${REPO_WORK_DIR}"
    git -C "${REPO_WORK_DIR}" config --unset-all remote.origin.url 2>/dev/null || true
    git -C "${REPO_WORK_DIR}" config remote.origin.url "git@github.com:${OWNER}/${REPO}.git"
    git -C "${REPO_WORK_DIR}" config --unset-all remote.origin.pushurl 2>/dev/null || true

    if ! git -C "${REPO_WORK_DIR}" checkout "${branch_name}"; then
        git -C "${REPO_WORK_DIR}" checkout main 2>/dev/null || true
        return 1
    fi

    if ! git -C "${REPO_WORK_DIR}" rebase origin/main; then
        git -C "${REPO_WORK_DIR}" rebase --abort 2>/dev/null || true
        git -C "${REPO_WORK_DIR}" checkout main 2>/dev/null || true
        return 1
    fi

    if ! git -C "${REPO_WORK_DIR}" push --force-with-lease; then
        git -C "${REPO_WORK_DIR}" checkout main 2>/dev/null || true
        return 1
    fi

    git -C "${REPO_WORK_DIR}" checkout main 2>/dev/null || true
    return 0
}

check_required_tools() {
    local tool
    for tool in curl jq podman gh git awk grep flock timeout; do
        command -v "${tool}" >/dev/null 2>&1 || die "Required tool not found: ${tool}"
    done

    if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1; then
        die "Required tool not found: sha256sum or shasum"
    fi
}

# Reads stdin and writes a SHA-256 digest to stdout.
hash_sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum | awk '{ print $1 }'
    else
        shasum -a 256 | awk '{ print $1 }'
    fi
}

# Outputs all open, non-on-hold priority items as a JSON array sorted by priority.
fetch_all_priorities() {
    local priorities_json

    priorities_json=$(curl --silent --fail "${PRIORITIES_URL}") \
        || die "Failed to fetch priorities from ${PRIORITIES_URL}"

    printf '%s' "${priorities_json}" | jq -c '[
        .priorities[]
            | select((.status == "Open" or .status == "Draft") and .isOnHold == false)
    ]' || die "Failed to parse priorities JSON"
}

# Queries GitHub for the first open, non-blocked PR authored by @me in the given repo.
# Outputs the PR number on stdout, or empty string if none found.
# Returns 1 if the gh call fails (caller should treat as an error).
# Avoids --author @me because gh 2.93.0 broke that flag (exits 1 with "malformed version:").
# Instead, fetches all open PRs with their author field and filters client-side using _GH_ME.
# _GH_ME is resolved lazily on the first call and cached for subsequent calls.
find_open_nonblocked_pr_for_repo() {
    local repo_full="$1"

    if [ -z "${_GH_ME}" ]; then
        _GH_ME=$(gh api user --jq '.login' 2>/dev/null) \
            || die "Failed to determine current GitHub user"
    fi

    local pr_list
    pr_list=$(gh pr list \
        --repo "${repo_full}" \
        --state open \
        --json number,labels,author \
        2>/dev/null) || return 1
    printf '%s' "${pr_list}" | jq -r --arg me "${_GH_ME}" '
        [.[] | select(
            .author.login == $me and
            ([(.labels // [])[] | .name | ascii_downcase] | index("blocked")) == null
        )] | first | .number // empty
    '
}

# Per-PR invocation guard.  Because every run is a fresh session that advances the workflow by
# one phase, a PR is re-invoked repeatedly across ticks until it reaches a terminal state.  The
# guard file holds two space-separated counters, "<total> <idle>":
#   total — every agent invocation ever spent on this PR.  Runaway backstop: at
#           MAX_PR_TOTAL_INVOCATIONS the PR is marked Blocked for a human (catches find-fix
#           churn that keeps pushing new commits but never converges).
#   idle  — consecutive "in-progress" re-invocations where the PR fingerprint had not changed
#           (a phase that advanced the board without pushing, e.g. a clean review).  At
#           MAX_PR_IDLE_INVOCATIONS the PR is parked (skipped) until its state changes again,
#           so a PR that is done but cannot enable auto-merge does not loop forever.
# Absence of the file also signals the first-ever touch of the PR.
pr_invocation_guard_file_path() {
    local item_id="$1"
    printf '%s/PullRequest_%s.invocations' "${SESSION_BASE_DIR}" "${item_id}"
}

# Reads the saved "<total> <idle>" counters for a PR, defaulting missing/corrupt values to 0.
# Sets globals PR_INVOCATION_TOTAL and PR_INVOCATION_IDLE.
PR_INVOCATION_TOTAL=0
PR_INVOCATION_IDLE=0
load_pr_invocation_counts() {
    local item_id="$1" guard_file line total idle
    PR_INVOCATION_TOTAL=0
    PR_INVOCATION_IDLE=0
    guard_file=$(pr_invocation_guard_file_path "${item_id}")
    [ -f "${guard_file}" ] || return 0
    line=$(cat "${guard_file}" 2>/dev/null)
    total="${line%% *}"
    idle="${line##* }"
    [[ "${total}" =~ ^[0-9]+$ ]] && PR_INVOCATION_TOTAL="${total}"
    [[ "${idle}" =~ ^[0-9]+$ ]] && PR_INVOCATION_IDLE="${idle}"
    return 0
}

# Persists the "<total> <idle>" counters for a PR.
save_pr_invocation_counts() {
    local item_id="$1" total="$2" idle="$3" guard_file
    guard_file=$(pr_invocation_guard_file_path "${item_id}")
    mkdir -p "${SESSION_BASE_DIR}" || die "Failed to create session directory: ${SESSION_BASE_DIR}"
    printf '%s %s\n' "${total}" "${idle}" > "${guard_file}" \
        || die "Failed to write invocation guard file: ${guard_file}"
}

# Returns 0 (true) if the PR has reached a terminal state the orchestrator should stop driving:
# auto-merge is enabled and no required check has hard-failed (it will merge once the remaining
# checks/approvals land).  Merged/closed PRs never reach here (filtered earlier as non-OPEN);
# Blocked PRs are filtered by their label.  Auto-merge alone is not enough — it can be enabled
# long before a later push breaks a required check, at which point GitHub will never complete
# the merge and the orchestrator needs to step back in and fix it rather than walk away.  Uses
# the same CheckRun-vs-legacy-StatusContext classification as pr_json_has_pending_ci_checks.
pr_json_is_terminal() {
    local pr_json="$1"
    printf '%s' "${pr_json}" | jq -e '
        .autoMergeRequest != null
        and (
            (.statusCheckRollup // [])
            | all(.[];
                .isRequired == false
                or (
                    if (.status != null)
                    then .conclusion != "FAILURE"
                    else ((.state // "") | . != "FAILURE" and . != "ERROR")
                    end
                )
            )
        )
    ' > /dev/null 2>&1
}

# Decides whether to re-invoke a PR whose fingerprint is UNCHANGED, so the next workflow phase
# can run (phases that only advance the board — e.g. a clean review — leave the fingerprint
# unchanged because the orchestrator re-saves it after each run).  Returns 0 (advance) when the
# PR is non-terminal and still within the idle budget; 1 (park) otherwise.  Read-only: the idle
# counter is persisted at invocation time via save_pr_invocation_counts.
pr_should_advance_unchanged() {
    local item_id="$1" pr_json="$2"
    pr_json_is_terminal "${pr_json}" && return 1
    load_pr_invocation_counts "${item_id}"
    [ "${PR_INVOCATION_IDLE}" -lt "${MAX_PR_IDLE_INVOCATIONS}" ]
}

# Outputs the path to the .ai-instructions file for the current repo context.
# Returns 1 (with a warning) if neither the repo work dir nor the rules dir has the file.
find_ai_instructions() {
    if [ -f "${REPO_WORK_DIR}/.ai-instructions" ]; then
        printf '%s/.ai-instructions' "${REPO_WORK_DIR}"
    elif [ -f "${RULES_DIR}/.ai-instructions" ]; then
        printf '%s/.ai-instructions' "${RULES_DIR}"
    else
        warn "No .ai-instructions found at ${REPO_WORK_DIR}/.ai-instructions or ${RULES_DIR}/.ai-instructions"
        return 1
    fi
}

# Workflow project cache — populated by discover_or_create_workflow_project.
# Empty _WF_PROJECT_ID disables all update_workflow_status calls (no-op mode).
_WF_PROJECT_ID=""
_WF_STATUS_FIELD_ID=""
declare -gA _WF_OPTION_IDS
_WF_CACHED_REPO=""
# Per-repo discovery cache: keys are "REPO_FULL:discovered", "REPO_FULL:project_id",
# "REPO_FULL:field_id", "REPO_FULL:opt_names" (newline-delimited option names), and
# "REPO_FULL:opt:<name>" (one entry per status-field option, avoiding any separator
# character that could collide with characters in option names).
declare -gA _WF_CACHE

# Space-delimited list of repos already issued a Workflow-project setup request this run.
# Prevents report_missing_workflow_project re-filing/re-querying once per item in the same
# failing repo; cross-run de-duplication relies on the open issue itself.
_WF_REPORTED_REPOS=""

# Set to "1" by discover_or_create_workflow_project when _wf_create_project returns non-zero,
# so the call site can distinguish a genuine "cannot create project" failure from other reasons
# _WF_PROJECT_ID might be empty (missing status field, GraphQL auth error, etc.).
_WF_CREATION_FAILED=""

# Board-approved items cache — populated by fetch_board_approved_items.
# Keys are "owner/repo/number"; value is "1" when issue is in Approved status.
declare -gA _WF_APPROVED_ITEMS
# Per-repo fetch guard: value "1" means fetch_board_approved_items has already run for that repo.
declare -gA _WF_APPROVED_FETCHED

# How long (seconds) a disk-persisted project cache entry stays valid before
# discover_or_create_workflow_project falls back to a live re-discovery. Override in the
# environment; the project/field/option IDs are effectively permanent once set up, so the
# default of 1 hour is conservative rather than tightly load-bearing.
PROJECT_CACHE_TTL="${PROJECT_CACHE_TTL:-3600}"

# Returns the path to the disk-persisted Workflow-project discovery cache for the current
# repo. Unlike _WF_CACHE (in-memory, lost at process exit), this file survives across
# oneshot invocations so an already-discovered project/field/option IDs are not re-fetched
# via GraphQL on every run. SESSION_BASE_DIR is already scoped per-repo by set_repo_context.
project_cache_file_path() {
    printf '%s/project-cache.json' "${SESSION_BASE_DIR}"
}

# Attempts to populate _WF_PROJECT_ID, _WF_STATUS_FIELD_ID, _WF_OPTION_IDS, and
# _WF_CACHED_REPO from the on-disk project cache for the current repo, without making any
# network call. Returns 0 (hit) when a fresh (within PROJECT_CACHE_TTL seconds) cache entry
# was found and loaded; returns 1 (miss) when the file is absent, unparseable, incomplete,
# or stale, leaving the caller to perform a live discovery.
load_project_cache() {
    local cache_file cached_json cached_at now_unix
    cache_file=$(project_cache_file_path)
    [ -f "${cache_file}" ] || return 1

    cached_json=$(cat "${cache_file}" 2>/dev/null) || return 1
    [ -n "${cached_json}" ] || return 1

    cached_at=$(printf '%s' "${cached_json}" | jq -r '.cached_at // empty' 2>/dev/null)
    [[ "${cached_at}" =~ ^[0-9]+$ ]] || return 1

    # Defensive check: SESSION_BASE_DIR is expected to already be repo-scoped (set by
    # set_repo_context), so this should always match, but validating the stored repo
    # guards against ever serving one repo's cached IDs for another if that assumption
    # is ever violated (e.g. a future change to SESSION_BASE_DIR's derivation).
    local cached_repo
    cached_repo=$(printf '%s' "${cached_json}" | jq -r '.repo // empty' 2>/dev/null)
    [ "${cached_repo}" = "${REPO_FULL}" ] || return 1

    now_unix=$(date +%s)
    (( now_unix - cached_at <= PROJECT_CACHE_TTL )) || return 1

    local project_id status_field_id
    project_id=$(printf '%s' "${cached_json}" | jq -r '.project_id // empty' 2>/dev/null)
    [ -n "${project_id}" ] || return 1
    status_field_id=$(printf '%s' "${cached_json}" | jq -r '.status_field_id // empty' 2>/dev/null)
    [ -n "${status_field_id}" ] || return 1

    unset _WF_OPTION_IDS
    declare -gA _WF_OPTION_IDS
    local opt_name opt_id
    while IFS=$'\t' read -r opt_name opt_id; do
        [ -z "${opt_name}" ] && continue
        _WF_OPTION_IDS["${opt_name}"]="${opt_id}"
    done < <(printf '%s' "${cached_json}" | jq -r '.option_ids // {} | to_entries[] | "\(.key)\t\(.value)"' 2>/dev/null)

    _WF_PROJECT_ID="${project_id}"
    _WF_STATUS_FIELD_ID="${status_field_id}"
    _WF_CACHED_REPO="${REPO_FULL}"
    _WF_CREATION_FAILED=""
    return 0
}

# Persists the current _WF_PROJECT_ID/_WF_STATUS_FIELD_ID/_WF_OPTION_IDS for the current
# repo to disk so subsequent oneshot invocations can skip live discovery until
# PROJECT_CACHE_TTL elapses. Best-effort: a failure to write just means every run
# re-discovers, which is the pre-existing behaviour, so it only warns rather than dying.
save_project_cache() {
    local cache_file option_ids_json k
    cache_file=$(project_cache_file_path)
    mkdir -p "${SESSION_BASE_DIR}" 2>/dev/null || {
        warn "Workflow project: failed to create ${SESSION_BASE_DIR} for disk cache"
        return 0
    }

    option_ids_json='{}'
    if [ "${#_WF_OPTION_IDS[@]}" -gt 0 ]; then
        option_ids_json=$(
            for k in "${!_WF_OPTION_IDS[@]}"; do
                jq -n --arg k "${k}" --arg v "${_WF_OPTION_IDS[${k}]}" '{($k): $v}'
            done | jq -s 'add // {}'
        ) || option_ids_json='{}'
    fi

    jq -n \
        --arg repo "${REPO_FULL}" \
        --arg project_id "${_WF_PROJECT_ID}" \
        --arg status_field_id "${_WF_STATUS_FIELD_ID}" \
        --argjson option_ids "${option_ids_json}" \
        --argjson cached_at "$(date +%s)" \
        '{repo: $repo, project_id: $project_id, status_field_id: $status_field_id, option_ids: $option_ids, cached_at: $cached_at}' \
        > "${cache_file}" 2>/dev/null \
        || warn "Workflow project: failed to write disk cache ${cache_file}"
}

# Deletes the on-disk project cache for the current repo and clears the in-memory caches
# (_WF_CACHE entry, and the live globals if they belong to this repo) so both this run and
# the next fully re-discover from the API. Called when a board mutation is rejected in a
# way that suggests the cached project/field IDs are stale (e.g. a deleted/recreated
# project) — leaving stale IDs in memory would otherwise keep failing for the rest of this run.
invalidate_project_cache() {
    rm -f "$(project_cache_file_path)" 2>/dev/null || true

    unset "_WF_CACHE[${REPO_FULL}:discovered]" "_WF_CACHE[${REPO_FULL}:project_id]" \
        "_WF_CACHE[${REPO_FULL}:field_id]" "_WF_CACHE[${REPO_FULL}:opt_names]"
    local k
    for k in "${!_WF_OPTION_IDS[@]}"; do
        unset "_WF_CACHE[${REPO_FULL}:opt:${k}]"
    done

    if [ "${_WF_CACHED_REPO}" = "${REPO_FULL}" ]; then
        _WF_CACHED_REPO=""
        _WF_PROJECT_ID=""
        _WF_STATUS_FIELD_ID=""
        unset _WF_OPTION_IDS
        declare -gA _WF_OPTION_IDS
    fi
}

# Outputs the Workflow board data block for embedding in a generated CLAUDE.md.
# Outputs nothing when _WF_PROJECT_ID is empty (project disabled).
_build_wf_section() {
    [ -n "${_WF_PROJECT_ID}" ] || return 0
    printf 'Workflow board (see agent-roles.instructions.md for update commands):\n'
    printf '  WF_PROJECT_ID=%s\n'            "${_WF_PROJECT_ID}"
    printf '  WF_STATUS_FIELD_ID=%s\n'       "${_WF_STATUS_FIELD_ID}"
    printf '  WF_NOT_STARTED=%s\n'           "${_WF_OPTION_IDS["Not Started"]:-}"
    printf '  WF_PLANNING=%s\n'              "${_WF_OPTION_IDS[Planning]:-}"
    printf '  WF_APPROVED=%s\n'              "${_WF_OPTION_IDS[Approved]:-}"
    printf '  WF_DEVELOPMENT=%s\n'           "${_WF_OPTION_IDS[Development]:-}"
    printf '  WF_AI_REVIEW=%s\n'             "${_WF_OPTION_IDS["AI Review"]:-}"
    printf '  WF_AI_SECURITY_REVIEW=%s\n'   "${_WF_OPTION_IDS["AI Security Review"]:-}"
    printf '  WF_HUMAN_REVIEW=%s\n'          "${_WF_OPTION_IDS["Human Review"]:-}"
    printf '  WF_COMPLETE=%s\n'              "${_WF_OPTION_IDS[Complete]:-}"
}

# Discovers or creates a GitHub Projects (v2) board named "Workflow" linked to
# the current repo (OWNER/REPO).  Populates _WF_PROJECT_ID, _WF_STATUS_FIELD_ID,
# and _WF_OPTION_IDS on success.  On any failure, leaves _WF_PROJECT_ID empty so
# all subsequent update_workflow_status calls are silent no-ops.
# Safe to call multiple times — returns immediately when the cache is valid for REPO_FULL.
discover_or_create_workflow_project() {
    [ "${_WF_CACHED_REPO}" = "${REPO_FULL}" ] && return 0

    if [ "${_WF_CACHE["${REPO_FULL}:discovered"]:-}" = "1" ]; then
        _WF_PROJECT_ID="${_WF_CACHE["${REPO_FULL}:project_id"]}"
        _WF_STATUS_FIELD_ID="${_WF_CACHE["${REPO_FULL}:field_id"]}"
        unset _WF_OPTION_IDS
        declare -gA _WF_OPTION_IDS
        local opt_name
        while IFS= read -r opt_name; do
            [ -z "${opt_name}" ] && continue
            _WF_OPTION_IDS["${opt_name}"]="${_WF_CACHE["${REPO_FULL}:opt:${opt_name}"]}"
        done < <(printf '%s' "${_WF_CACHE["${REPO_FULL}:opt_names"]}")
        _WF_CACHED_REPO="${REPO_FULL}"
        _WF_CREATION_FAILED=""
        return 0
    fi

    # Disk cache hit: promote it into the in-memory per-run cache too, so a later call
    # this run takes the cheaper in-memory fast path above instead of re-parsing the
    # cache file, then return without making any network calls.
    if load_project_cache; then
        local k
        for k in "${!_WF_OPTION_IDS[@]}"; do
            _WF_CACHE["${REPO_FULL}:opt:${k}"]="${_WF_OPTION_IDS[${k}]}"
        done
        _WF_CACHE["${REPO_FULL}:project_id"]="${_WF_PROJECT_ID}"
        _WF_CACHE["${REPO_FULL}:field_id"]="${_WF_STATUS_FIELD_ID}"
        _WF_CACHE["${REPO_FULL}:opt_names"]=$(printf '%s\n' "${!_WF_OPTION_IDS[@]}")
        _WF_CACHE["${REPO_FULL}:discovered"]="1"
        return 0
    fi

    _WF_PROJECT_ID=""
    _WF_STATUS_FIELD_ID=""
    _WF_CREATION_FAILED=""
    _WF_CACHED_REPO=""
    unset _WF_OPTION_IDS
    declare -gA _WF_OPTION_IDS

    # If Projects is disabled on the repo, repository.projectsV2 always returns empty, so
    # we would loop trying to create a project every run.  Enable it silently when needed.
    local projects_enabled
    projects_enabled=$(gh repo view "${REPO_FULL}" --json hasProjectsEnabled \
        --jq '.hasProjectsEnabled' 2>/dev/null) || true
    if [ "${projects_enabled}" = "false" ]; then
        info "Workflow project: Projects disabled on ${REPO_FULL} — enabling"
        gh repo edit "${REPO_FULL}" --enable-projects > /dev/null 2>&1 \
            || warn "Workflow project: could not enable Projects on ${REPO_FULL} — discovery may fail"
    fi

    local query="query(\$owner:String!,\$repo:String!){repository(owner:\$owner,name:\$repo){projectsV2(first:20){nodes{id title fields(first:30){nodes{...on ProjectV2SingleSelectField{id name options{id name}}}}}}}}"
    local projects_json graphql_stderr graphql_err_content
    graphql_stderr=$(mktemp --suffix=.stderr) || graphql_stderr=/dev/null
    if ! projects_json=$(gh api graphql \
            -f query="${query}" \
            -f owner="${OWNER}" \
            -f repo="${REPO}" \
            --jq '.data.repository.projectsV2.nodes' 2>"${graphql_stderr}"); then
        graphql_err_content=$(head -3 "${graphql_stderr}" 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//')
        rm -f "${graphql_stderr}"
        if printf '%s' "${graphql_err_content}" | grep -qiE 'scope|permission|authoriz'; then
            warn "Workflow project: GraphQL auth failed for ${REPO_FULL} — run 'gh auth refresh -s project' on the host to enable Projects API access"
        else
            warn "Workflow project: GraphQL query failed for ${REPO_FULL}${graphql_err_content:+ — ${graphql_err_content}} — status updates disabled"
        fi
        return 0
    fi
    rm -f "${graphql_stderr}"

    local project_json
    project_json=$(printf '%s' "${projects_json}" | \
        jq -c 'map(select(.title == "Workflow")) | first // empty' 2>/dev/null)

    if [ -z "${project_json}" ]; then
        info "Workflow project: no 'Workflow' project found for ${REPO_FULL} — creating one"
        project_json=$(_wf_create_project) || {
            warn "Workflow project: creation failed for ${REPO_FULL} — status updates disabled"
            _WF_CREATION_FAILED="1"
            return 0
        }
    fi

    _WF_PROJECT_ID=$(printf '%s' "${project_json}" | jq -r '.id // empty')
    [ -n "${_WF_PROJECT_ID}" ] || {
        warn "Workflow project: could not read project ID — status updates disabled"
        return 0
    }

    _WF_STATUS_FIELD_ID=$(printf '%s' "${project_json}" | \
        jq -r '.fields.nodes[] | select(.name == "Workflow Status") | .id // empty' 2>/dev/null | head -1)
    [ -n "${_WF_STATUS_FIELD_ID}" ] || {
        warn "Workflow project: Workflow Status field not found in project ${_WF_PROJECT_ID} — status updates disabled"
        _WF_PROJECT_ID=""
        return 0
    }

    local opt_name opt_id
    while IFS='|' read -r opt_name opt_id; do
        if [ -z "${opt_name}" ] || [ -z "${opt_id}" ]; then continue; fi
        _WF_OPTION_IDS["${opt_name}"]="${opt_id}"
    done < <(printf '%s' "${project_json}" | \
        jq -r '.fields.nodes[] | select(.name == "Workflow Status") | .options[] | "\(.name)|\(.id)"' 2>/dev/null)

    local cached_opts="" k
    for k in "${!_WF_OPTION_IDS[@]}"; do
        _WF_CACHE["${REPO_FULL}:opt:${k}"]="${_WF_OPTION_IDS[${k}]}"
        cached_opts+="${k}"$'\n'
    done
    _WF_CACHE["${REPO_FULL}:project_id"]="${_WF_PROJECT_ID}"
    _WF_CACHE["${REPO_FULL}:field_id"]="${_WF_STATUS_FIELD_ID}"
    _WF_CACHE["${REPO_FULL}:opt_names"]="${cached_opts}"
    _WF_CACHE["${REPO_FULL}:discovered"]="1"
    save_project_cache

    _WF_CACHED_REPO="${REPO_FULL}"
    info "Workflow project ready for ${REPO_FULL}: ${_WF_PROJECT_ID}"
}

# Files an issue in the affected repo asking the owner to run create-project, used when
# discover_or_create_workflow_project could not obtain a usable "Workflow" project (the bot
# cannot create projects under a personal account).  De-duplicates two ways: an in-process
# guard (_WF_REPORTED_REPOS) avoids re-filing per item within one run, and an existing OPEN
# issue with the same title is left untouched.  All gh failures are non-fatal (warn only).
report_missing_workflow_project() {
    case " ${_WF_REPORTED_REPOS} " in
        *" ${REPO_FULL} "*) return 0 ;;
    esac

    local existing
    # Skip filing if the issue list check itself fails (transient error) — conservative to
    # avoid duplicates on the next successful run.
    # We use repo: in the search query because --repo + --search is known to fail with
    # "malformed version" in some environments.
    if ! existing=$(WF_TITLE="${WF_SETUP_ISSUE_TITLE}" gh issue list \
        --state open \
        --search "repo:${REPO_FULL} ${WF_SETUP_ISSUE_TITLE} in:title" \
        --limit 100 \
        --json number,title \
        --jq 'map(select(.title==env.WF_TITLE)) | .[0].number // empty' 2>/dev/null); then
        return 0
    fi
    if [ -n "${existing}" ]; then
        _WF_REPORTED_REPOS="${_WF_REPORTED_REPOS} ${REPO_FULL}"
        return 0
    fi

    local body
    # shellcheck disable=SC2016
    body=$(printf $'The orchestrator could not obtain a usable "Workflow" GitHub Project for this repository, so workflow board status updates are disabled for it.\n\nA bot account cannot create a project under a personal account, so the project must be set up by the repository owner.\n\nFrom a checkout of `credfeto/credfeto-orchestrator`, authenticated as the repository owner, run:\n\n```\n./create-project --repo %s\n```\n\nThe script is idempotent: it creates the "Workflow" project, adds the "Workflow Status" field, links it to this repository, grants the orchestrator bot (`dnyw4l3n13`) write access, and (on first creation only) seeds the board with all open issues and PRs. Re-running performs only whatever is still missing.\n' \
        "${REPO_FULL}")

    if gh issue create --repo "${REPO_FULL}" \
        --title "${WF_SETUP_ISSUE_TITLE}" --label "AI-Work" --body "${body}" 2>/dev/null; then
        _WF_REPORTED_REPOS="${_WF_REPORTED_REPOS} ${REPO_FULL}"
    else
        warn "Failed to create Workflow-project setup issue for ${REPO_FULL}"
    fi
}

# Invites all trusted logins (excluding the copilot bot) as WRITER collaborators
# on the given GitHub Project V2. Non-fatal: warns and returns 0 on any failure.
# Collapses N+1 sequential GraphQL calls into 2 calls via batched alias lookup.
_wf_invite_trusted_collaborators() {
    local project_id="$1"
    local -a logins=()
    local login

    # Phase 1 — collect logins, skipping the copilot bot (no gh calls yet)
    while IFS= read -r login; do
        [ -z "${login}" ] && continue
        [ "${login}" = "copilot-pull-request-reviewer" ] && continue
        logins+=("${login}")
    done < <(get_trusted_logins | jq -r '.[]' 2>/dev/null)
    [ "${#logins[@]}" -eq 0 ] && return 0

    # Phase 2 — single batched GraphQL user-node lookup using field aliases
    local query="query{" i
    for (( i=0; i<${#logins[@]}; i++ )); do
        query="${query}u${i}:user(login:\"${logins[i]}\"){id}"
    done
    query="${query}}"

    local lookup_result lookup_err
    lookup_err=$(mktemp --suffix=.stderr) || lookup_err=/dev/null
    lookup_result=$(gh api graphql -f query="${query}" 2>"${lookup_err}") || {
        local err_content
        err_content=$(head -3 "${lookup_err}" 2>/dev/null | tr '\n' ' ')
        rm -f "${lookup_err}"
        warn "Workflow project: user-node lookup failed${err_content:+ — ${err_content}}"
        return 0
    }
    rm -f "${lookup_err}"

    # Build collaborators array from resolved IDs
    local collaborators='[]' user_id
    for (( i=0; i<${#logins[@]}; i++ )); do
        user_id=$(printf '%s' "${lookup_result}" | jq -r ".data.u${i}.id" 2>/dev/null) || true
        [ -z "${user_id}" ] || [ "${user_id}" = "null" ] || [[ "${user_id}" == \{* ]] && continue
        collaborators=$(printf '%s' "${collaborators}" | \
            jq -c --arg id "${user_id}" '. + [{"userId":$id,"role":"WRITER"}]')
    done
    [ "${collaborators}" = '[]' ] && return 0

    # shellcheck disable=SC2016
    local mut='mutation($p:ID!,$c:[ProjectV2Collaborator!]!){updateProjectV2Collaborators(input:{projectId:$p,collaborators:$c}){collaborators(first:5){nodes{...on User{login}}}}}'
    local mut_err
    mut_err=$(mktemp --suffix=.stderr) || mut_err=/dev/null
    if ! printf '%s' "${collaborators}" | \
            jq -c --arg p "${project_id}" --arg q "${mut}" \
            '{query:$q,variables:{p:$p,c:.}}' | \
            gh api graphql --input - >/dev/null 2>"${mut_err}"; then
        local err_content
        err_content=$(head -3 "${mut_err}" 2>/dev/null | tr '\n' ' ')
        warn "Workflow project: updateProjectV2Collaborators failed${err_content:+ — ${err_content}} — add collaborators manually at github.com"
    fi
    rm -f "${mut_err}"
}

# Creates a new "Workflow" GitHub Project (v2), adds the Status single-select
# field with all eight options, and links it to the current repo.
# Outputs project JSON (same shape as the discovery query) on stdout.
_wf_create_project() {
    local owner_node_id org_err user_err
    org_err=$(mktemp --suffix=.stderr) || org_err=/dev/null
    user_err=$(mktemp --suffix=.stderr) || user_err=/dev/null
    owner_node_id=$(gh api graphql \
        -f query="query(\$l:String!){organization(login:\$l){id}}" \
        -f l="${OWNER}" \
        --jq '.data.organization.id' 2>"${org_err}") || true
    if [ -z "${owner_node_id}" ] || [ "${owner_node_id}" = "null" ] || [[ "${owner_node_id}" == \{* ]]; then
        owner_node_id=$(gh api graphql \
            -f query="query(\$l:String!){user(login:\$l){id}}" \
            -f l="${OWNER}" \
            --jq '.data.user.id' 2>"${user_err}") || true
    fi
    if [ -z "${owner_node_id}" ] || [ "${owner_node_id}" = "null" ] || [[ "${owner_node_id}" == \{* ]]; then
        local owner_err_content
        owner_err_content=$(head -3 "${org_err}" 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//')
        local user_err_content
        user_err_content=$(head -3 "${user_err}" 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//')
        rm -f "${org_err}" "${user_err}"
        warn "Workflow project: cannot resolve owner node ID for ${OWNER}${owner_err_content:+ — org: ${owner_err_content}}${user_err_content:+ — user: ${user_err_content}}"
        return 1
    fi
    rm -f "${org_err}" "${user_err}"

    # Resolve the repo node ID first so we can pass repositoryId to createProjectV2.
    # This creates a repo-scoped project (sets the default repository and auto-links it)
    # without a separate linkProjectV2ToRepository call — and ensures the project appears
    # in repository.projectsV2 so the next discover run finds it immediately.
    local repo_node_id repo_err repo_err_content
    repo_err=$(mktemp --suffix=.stderr) || repo_err=/dev/null
    repo_node_id=$(gh api graphql \
        -f query="query(\$o:String!,\$r:String!){repository(owner:\$o,name:\$r){id}}" \
        -f o="${OWNER}" -f r="${REPO}" \
        --jq '.data.repository.id' 2>"${repo_err}") || {
        repo_err_content=$(head -3 "${repo_err}" 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//')
        rm -f "${repo_err}"
        warn "Workflow project: cannot resolve repo node ID for ${REPO_FULL}${repo_err_content:+ — ${repo_err_content}}"
        return 1
    }
    rm -f "${repo_err}"

    local project_id project_err
    project_err=$(mktemp --suffix=.stderr) || project_err=/dev/null
    project_id=$(gh api graphql \
        -f query="mutation(\$ownerId:ID!,\$title:String!,\$repoId:ID!){createProjectV2(input:{ownerId:\$ownerId,title:\$title,repositoryId:\$repoId}){projectV2{id}}}" \
        -f ownerId="${owner_node_id}" \
        -f title="Workflow" \
        -f repoId="${repo_node_id}" \
        --jq '.data.createProjectV2.projectV2.id' 2>"${project_err}") \
    || {
        local project_err_content
        project_err_content=$(head -3 "${project_err}" 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//')
        rm -f "${project_err}"
        warn "Workflow project: createProjectV2 failed${project_err_content:+ — ${project_err_content}}"
        return 1
    }
    rm -f "${project_err}"

    local create_field_query="mutation(\$p:ID!){createProjectV2Field(input:{projectId:\$p,dataType:SINGLE_SELECT,name:\"Workflow Status\",singleSelectOptions:[{name:\"Not Started\",color:GRAY,description:\"\"},{name:\"Planning\",color:YELLOW,description:\"\"},{name:\"Approved\",color:BLUE,description:\"\"},{name:\"Development\",color:PURPLE,description:\"\"},{name:\"AI Review\",color:ORANGE,description:\"\"},{name:\"AI Security Review\",color:RED,description:\"\"},{name:\"Human Review\",color:GREEN,description:\"\"},{name:\"Complete\",color:PINK,description:\"\"}]}){projectV2Field{...on ProjectV2SingleSelectField{id name options{id name}}}}}"
    local field_json field_err field_err_content
    field_err=$(mktemp --suffix=.stderr) || field_err=/dev/null
    field_json=$(gh api graphql \
        -f query="${create_field_query}" \
        -f p="${project_id}" 2>"${field_err}") || {
        field_err_content=$(head -3 "${field_err}" 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//')
        rm -f "${field_err}"
        warn "Workflow project: createProjectV2Field failed for project ${project_id}${field_err_content:+ — ${field_err_content}}"
        return 1
    }
    rm -f "${field_err}"

    _wf_invite_trusted_collaborators "${project_id}"

    local status_field_nodes
    status_field_nodes=$(printf '%s' "${field_json}" | \
        jq -c '{nodes: [.data.createProjectV2Field.projectV2Field | {id, name, options}]}' 2>/dev/null)
    printf '{"id":"%s","title":"Workflow","fields":%s}\n' "${project_id}" "${status_field_nodes}"
}

# Updates the Workflow board status for an issue or PR.
# Arguments: item_type ("Issue" or "PullRequest"), item_number, status_name
# No-op when _WF_PROJECT_ID is empty (project disabled or discovery failed).
update_workflow_status() {
    local item_type="$1" item_number="$2" status_name="$3"
    [ -n "${_WF_PROJECT_ID}" ] || return 0

    info "Workflow: adding ${item_type} #${item_number} to board with status '${status_name}'"

    local opt_id="${_WF_OPTION_IDS["${status_name}"]:-}"
    if [ -z "${opt_id}" ]; then
        warn "Workflow: unknown status '${status_name}' — skipping update for ${item_type} #${item_number}"
        return 0
    fi

    local api_path item_node_id
    if [ "${item_type}" = "Issue" ]; then
        api_path="repos/${REPO_FULL}/issues/${item_number}"
    else
        api_path="repos/${REPO_FULL}/pulls/${item_number}"
    fi
    item_node_id=$(gh api "${api_path}" --jq '.node_id' 2>/dev/null) || {
        warn "Workflow: failed to get node ID for ${item_type} #${item_number} — skipping board update"
        return 0
    }

    local project_item_id add_err add_err_content
    add_err=$(mktemp --suffix=.stderr) || add_err=/dev/null
    project_item_id=$(gh api graphql \
        -f query="mutation(\$p:ID!,\$c:ID!){addProjectV2ItemById(input:{projectId:\$p,contentId:\$c}){item{id}}}" \
        -f p="${_WF_PROJECT_ID}" -f c="${item_node_id}" \
        --jq '.data.addProjectV2ItemById.item.id' 2>"${add_err}") || {
        add_err_content=$(head -3 "${add_err}" 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]*$//')
        rm -f "${add_err}"
        warn "Workflow: failed to add ${item_type} #${item_number} to project${add_err_content:+ — ${add_err_content}} — skipping board update"
        # The mutation may be failing because the cached project ID refers to a
        # deleted/recreated project — invalidate so the next run (and any later item this
        # run) re-discovers from the API instead of repeating the same failure silently.
        invalidate_project_cache
        return 0
    }
    rm -f "${add_err}"

    gh api graphql \
        -f query="mutation(\$p:ID!,\$i:ID!,\$f:ID!,\$v:String!){updateProjectV2ItemFieldValue(input:{projectId:\$p,itemId:\$i,fieldId:\$f,value:{singleSelectOptionId:\$v}}){projectV2Item{id}}}" \
        -f p="${_WF_PROJECT_ID}" -f i="${project_item_id}" \
        -f f="${_WF_STATUS_FIELD_ID}" -f v="${opt_id}" \
        > /dev/null 2>&1 \
    || warn "Workflow: failed to set status '${status_name}' for ${item_type} #${item_number}"

    info "Workflow: ${item_type} #${item_number} added to board with status '${status_name}'"
}

# Populate _WF_APPROVED_ITEMS with issue keys ("owner/repo/number") whose
# Workflow board status is "Approved". Results are cached per repo; a no-op
# when the board is not configured or the Approved option ID is unknown.
fetch_board_approved_items() {
    [ -n "${_WF_PROJECT_ID}" ] || return 0
    [ "${_WF_APPROVED_FETCHED["${REPO_FULL}"]:-}" = "1" ] && return 0
    _WF_APPROVED_FETCHED["${REPO_FULL}"]="1"
    local approved_opt_id="${_WF_OPTION_IDS[Approved]:-}"
    [ -n "${approved_opt_id}" ] || return 0
    local query="query(\$p:ID!,\$cursor:String){node(id:\$p){...on ProjectV2{items(first:100,after:\$cursor){pageInfo{endCursor hasNextPage}nodes{content{...on Issue{number repository{nameWithOwner}}}fieldValues(first:50){nodes{...on ProjectV2ItemFieldSingleSelectValue{optionId}}}}}}}}"
    local cursor="" has_next_page="true" entry page_json pagination
    local -a cursor_args
    while true; do
        cursor_args=()
        [ -n "${cursor}" ] && cursor_args=(-f "cursor=${cursor}")
        if ! page_json=$(gh api graphql -f query="${query}" -f p="${_WF_PROJECT_ID}" "${cursor_args[@]}" 2>/dev/null); then
            warn "fetch_board_approved_items: GraphQL request failed for ${REPO_FULL}"
            break
        fi
        while IFS= read -r entry; do
            [ -n "${entry}" ] && _WF_APPROVED_ITEMS["${entry}"]=1
        done < <(printf '%s' "${page_json}" | \
            jq -r --arg opt "${approved_opt_id}" \
            '.data.node.items.nodes[] | select((.content | type) == "object") | select(.content.number? != null) | select(.fieldValues.nodes | map(.optionId? // "") | any(. == $opt)) | "\(.content.repository.nameWithOwner)/\(.content.number)"' \
            2>/dev/null)
        pagination=$(printf '%s' "${page_json}" | \
            jq -r '(.data.node.items.pageInfo.hasNextPage // "false"), (.data.node.items.pageInfo.endCursor // "")' 2>/dev/null)
        has_next_page=$(printf '%s' "${pagination}" | head -1)
        cursor=$(printf '%s' "${pagination}" | tail -1)
        [ "${has_next_page}" = "true" ] || break
        [ -n "${cursor}" ] || break
    done
}

# Output the step-2 approval-check line(s) for build_issue_claude_md.
# With board + board-approved: one-liner directing agent to implementation.
# With board + not approved:   redirect to plan/revision mode.
# No board:                    jq command to detect human approval comment.
_build_plan_approval_check() {
    local item_id="$1" plan_approved="$2"
    if [ "${plan_approved}" = "true" ]; then
        printf '   Result "true"  → plan exists and was approved on the Workflow board by a human — skip to step 5 (Implementation mode).'
    elif [ -n "${_WF_PROJECT_ID}" ]; then
        printf '   Result "true"  → plan exists but has not been approved on the Workflow board yet. Revise or re-post the plan, mark Blocked, and STOP (step 3).'
    else
        local jq_expr="(.comments) as \$c | (first(range(\$c|length)|select(\$c[.].body|test(\"##\\\\s*Implementation Plan\";\"i\"))) // -1) as \$i | if \$i>=0 then \$c[(\$i+1):]|map(.body|test(\"\\\\b(approved|go ahead|looks good|lgtm)\\\\b\";\"i\"))|any else false end"
        printf '   Result "true"  → plan exists. Check for a human approval comment posted AFTER the plan comment\n'
        printf '                    (approved / go ahead / looks good / lgtm — case-insensitive, whole word):\n'
        printf '     gh issue view %s --repo %s --json comments \\\n' "${item_id}" "${REPO_FULL}"
        printf "       --jq '%s'\n" "${jq_expr}"
        printf '   Result "true"  → approved — skip to step 5 (Implementation mode).\n'
        printf '   Result "false" → not yet — revise or re-post the plan, mark Blocked, and STOP (step 3).'
    fi
}

# Output the approval instruction for step 4 of build_issue_claude_md.
_build_plan_approval_instruction() {
    if [ -n "${_WF_PROJECT_ID}" ]; then
        printf 'A human must review the plan, set the Workflow board status to "Approved", and remove the Blocked label to approve it.'
    else
        printf 'A human must review the plan, post an approval comment (approved / go ahead / looks good / lgtm) and remove the Blocked label.'
    fi
}

