# Prints Claude's error result (if any), removes tmpfile, and dies.
die_claude_failed() {
    local tmpfile="$1"
    jq -r '.result // ""' "${tmpfile}" 2>/dev/null >&2 || true
    rm -f "${tmpfile}"
    die "Claude invocation failed"
}

# Runs a single podman-based claude invocation, writing JSON output to tmpfile.
# On non-zero exit: handles timeout (exit 124), container-name conflict, or general failure.
run_claude_fresh() {
    local tmpfile="$1" item_type="${2:-}" item_id="${3:-}"
    local stderrfile podman_exit=0
    stderrfile=$(mktemp --suffix=.stderr) || die "Failed to create temp file for podman stderr"
    [ -n "${CLAUDE_PROMPT}" ] || die "Prompt is empty — refusing to start container"
    [ -s "${CLAUDE_PROMPT_FILE}" ] || die "Prompt file is missing or empty — refusing to start container"
    validate_bind_mounts
    info "Starting new Claude session in container ${PODMAN_CONTAINER_NAME}..." >&2
    # tmpfile and stderrfile are created by current user via mktemp, so both redirects are
    # intentionally unprivileged.
    # shellcheck disable=SC2024
    timeout --kill-after=60s "${AGENT_TIMEOUT_SECS}" \
        podman "${PODMAN_RUN_ARGS[@]}" "${ORCHESTRATOR_IMAGE}" "${PODMAN_CLAUDE_ARGS[@]}" \
        < "${CLAUDE_PROMPT_FILE}" > "${tmpfile}" 2>"${stderrfile}" \
    || podman_exit=$?
    if [ "${podman_exit}" -ne 0 ]; then
        if [ "${podman_exit}" -eq 124 ]; then
            cat "${stderrfile}" >&2
            rm -f "${stderrfile}"
            podman rm -f "${PODMAN_CONTAINER_NAME}" > /dev/null 2>&1 || true
            notify_discord_claude_error "${item_type}" "${item_id}" \
                "Container ${PODMAN_CONTAINER_NAME} timed out after ${AGENT_TIMEOUT_MINUTES} minutes — killed"
            die "Agent container ${PODMAN_CONTAINER_NAME} timed out after ${AGENT_TIMEOUT_MINUTES} minutes"
        fi
        if grep -qi "name.*already in use" "${stderrfile}" 2>/dev/null; then
            cat "${stderrfile}" >&2
            rm -f "${stderrfile}"
            die "Container ${PODMAN_CONTAINER_NAME} is already in use — another invocation may be running"
        fi
        cat "${stderrfile}" >&2
        rm -f "${stderrfile}"
        # Claude CLI exits non-zero for API-level errors (e.g. 429 rate-limit) even
        # when it has written a valid result JSON to stdout.  Return 0 so invoke_claude
        # can inspect the JSON via handle_claude_is_error rather than losing the context.
        if [ -s "${tmpfile}" ] \
                && jq -e '.type == "result" and .is_error == true' "${tmpfile}" >/dev/null 2>&1; then
            return 0
        fi
        die_claude_failed "${tmpfile}"
    fi
    cat "${stderrfile}" >&2
    rm -f "${stderrfile}"
}

# Invocation-scoped globals shared with the podman helpers below and cleaned up on EXIT.
CLAUDE_MD_TMPFILE=""
CLAUDE_PROMPT=""
CLAUDE_PROMPT_FILE=""
GPG_PUBKEY_TMPDIR=""
PODMAN_SECRET_NAME=""
GH_ENTERPRISE_SECRET_NAME=""

# Handles is_error=true in the Claude JSON response.
# On blocking_limit: every run is already a fresh single-phase session, so there is nothing
#   to retry by dropping history — surface it as a hard error for a human to look at.
# On 429: persists rate limit, notifies Discord, dies.
# On anything else: notifies Discord, dies.
handle_claude_is_error() {
    local tmpfile="$1" item_type="$2" item_id="$3"
    local terminal_reason api_error_status result_text

    terminal_reason=$(jq -r '.terminal_reason // ""' "${tmpfile}" 2>/dev/null || printf '')
    api_error_status=$(jq -r '.api_error_status // ""' "${tmpfile}" 2>/dev/null || printf '')
    result_text=$(jq -r '.result // "Unknown error"' "${tmpfile}" 2>/dev/null || printf 'Unknown error')
    info "Claude error: ${result_text}" >&2

    if [ "${terminal_reason}" = "blocking_limit" ]; then
        warn "Fresh single-phase session still exceeded the context window for ${REPO_FULL} — a single phase is too large to fit; a human should split the work" >&2
    fi

    if [ "${api_error_status}" = "429" ]; then
        local reset_unix resume_unix
        reset_unix=$(parse_reset_time "${result_text}")
        resume_unix=""
        if [ -n "${reset_unix}" ]; then
            resume_unix=$((reset_unix + RATE_LIMIT_RESUME_BUFFER_SECS))
            save_rate_limit "${resume_unix}"
        else
            report_unparseable_rate_limit "${item_type}" "${item_id}" "${result_text}"
        fi
        notify_discord_rate_limited "${item_type}" "${item_id}" "${result_text}" "${resume_unix}"
        rm -f "${tmpfile}"
        die "Claude rate limited: ${result_text}"
    fi

    notify_discord_claude_error "${item_type}" "${item_id}" "${result_text}"
    rm -f "${tmpfile}"
    die "Claude invocation failed: ${result_text}"
}

# In cgroup v2, the "no-internal-process" constraint forbids a cgroup that
# directly contains processes from having child cgroups with domain controllers
# (memory, cpu, pids).  For Type=oneshot services the process lands directly
# in the service cgroup.  Delegate=cpu memory pids io grants permission to
# write subtree_control but does NOT write it automatically (verified on
# systemd 260); the process must do it itself — but only after moving to a
# leaf, because writing subtree_control while tasks are present fails with EBUSY.
#
# This function handles both cases:
# - If systemd already placed us in a leaf (e.g. on some Type=simple configs),
#   strip the leaf component to get the service cgroup as parent.
# - If we are directly in the service cgroup (Type=oneshot), move ourselves
#   into a leaf sub-cgroup named "init", then write the domain controllers to
#   the service cgroup's subtree_control so container child cgroups get
#   pids.max, memory.max, cpu.max etc.
#
# Sets PODMAN_CGROUP_PARENT so invoke_claude passes --cgroup-parent to every
# podman run call.  No-op when not running from a system service.
setup_cgroup_leaf() {
    local svcgroup leaf_dir cgroupfs_path controller
    svcgroup=$(cut -d: -f3 /proc/self/cgroup 2>/dev/null) || return 0

    case "${svcgroup}" in
        /system.slice/*/*)
            # systemd placed us in a leaf sub-cgroup like
            # /system.slice/<service>.service/0 — strip the last component
            # to get the service cgroup itself as the container parent.
            svcgroup="${svcgroup%/*}"
            ;;
        /system.slice/*)
            # Process is directly in the service cgroup.
            # Step 1: move ALL processes to a leaf so the service cgroup has no
            # direct tasks.  Moving only $$ is insufficient: any left-over
            # processes from an unclean previous run (e.g. ssh-agent) remain in
            # the service cgroup and cause the subtree_control write to fail
            # with EBUSY (cannot enable domain controllers while tasks exist).
            cgroupfs_path="/sys/fs/cgroup${svcgroup}"
            leaf_dir="${cgroupfs_path}/init"
            mkdir -p "${leaf_dir}" 2>/dev/null \
                || { warn "Cannot create leaf cgroup ${leaf_dir} — container resource limits may not apply"; return 0; }
            local pids pid
            pids=$(cat "${cgroupfs_path}/cgroup.procs" 2>/dev/null) || pids=""
            for pid in ${pids}; do
                printf '%s\n' "${pid}" > "${leaf_dir}/cgroup.procs" 2>/dev/null || true
            done
            # Step 2: now that the service cgroup has no direct tasks, enable
            # domain controllers so container child cgroups have pids.max etc.
            for controller in cpu memory pids io; do
                printf '+%s\n' "${controller}" > "${cgroupfs_path}/cgroup.subtree_control" 2>/dev/null \
                    || warn "Cannot enable ${controller} controller in ${svcgroup} — container resource limits may not apply"
            done
            ;;
        *)
            return 0
            ;;
    esac

    PODMAN_CGROUP_PARENT="${svcgroup}"
}

# Removes dangling (untagged) container images to free disk space.
# Only untagged images are pruned — the current ORCHESTRATOR_IMAGE is always
# tagged and is never removed.  Suppresses errors so that a failure to prune
# (e.g. no images to prune, podman storage not initialised) is never fatal.
cleanup_dangling_images() {
    podman image prune --force > /dev/null 2>&1 || true
}

# Kills the ssh-agent started by the service unit's ExecStartPre so the service
# cgroup is clean when the next timer fires and systemd does not warn about
# left-over processes.  Registered as an EXIT trap by main so it runs on any
# exit — success, die, or signal — regardless of whether invoke_claude was called.
stop_ssh_agent() {
    [ -n "${SSH_AUTH_SOCK:-}" ] || return 0
    pkill ssh-agent 2>/dev/null || true
}

# Loads default SSH keys into the agent if SSH_AUTH_SOCK is set and the agent
# currently holds no keys.  Silent when keys are already loaded (avoids
# redundant re-adds across timer firings); warns rather than dies on failure.
preload_ssh_keys() {
    [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "${SSH_AUTH_SOCK}" ] || return 0
    local ssh_keys_status=0
    ssh-add -l >/dev/null 2>&1 || ssh_keys_status=$?
    [ "${ssh_keys_status}" -eq 1 ] || return 0  # 0 = already loaded; 2 = no agent
    ssh-add -q 2>/dev/null \
        || die "ssh-add: no SSH keys could be loaded — import a key with 'ssh-add <key-file>'"
}

# Posts a comment on the current GitHub work item and adds the Blocked label.
# Silent when item_type or item_id is unset.
notify_github_blocked() {
    local item_type="$1" item_id="$2" message="$3"
    [ -n "${item_type}" ] && [ -n "${item_id}" ] || return 0
    case "${item_type}" in
        Issue)
            gh issue comment "${item_id}" --repo "${REPO_FULL}" --body "${message}" 2>/dev/null || true
            gh issue edit   "${item_id}" --repo "${REPO_FULL}" --add-label "Blocked" 2>/dev/null || true
            ;;
        PullRequest)
            gh pr comment "${item_id}" --repo "${REPO_FULL}" --body "${message}" 2>/dev/null || true
            gh pr edit    "${item_id}" --repo "${REPO_FULL}" --add-label "Blocked" 2>/dev/null || true
            ;;
    esac
}

# Fast-fails if GIT_SIGNING_KEY is set but gpg-agent is not running or the key
# is absent from the keyring.  Posts a GitHub comment and adds Blocked before dying.
verify_gpg_signing_ready() {
    local item_type="$1" item_id="$2"
    [ -n "${GIT_SIGNING_KEY}" ] || return 0

    if ! gpg-connect-agent /bye >/dev/null 2>&1; then
        notify_github_blocked "${item_type}" "${item_id}" \
            "Cannot start agent session: \`gpg-agent\` is not running on the host. Run \`gpgconf --launch gpg-agent\` and retry."
        die "gpg-agent is not running — run 'gpgconf --launch gpg-agent' to start it"
    fi

    if ! gpg --batch --no-tty --list-secret-keys "${GIT_SIGNING_KEY}" >/dev/null 2>&1; then
        notify_github_blocked "${item_type}" "${item_id}" \
            "Cannot start agent session: signing key \`${GIT_SIGNING_KEY}\` is not in the GPG keyring. Import it with \`gpg --import <key-file>\` on the host."
        die "Signing key ${GIT_SIGNING_KEY} not found in GPG keyring — import it with 'gpg --import'"
    fi
}

# Appends GPG volume/socket args to PODMAN_RUN_ARGS.
# Creates a tmpdir containing only the signing public key and forwards the
# gpg-agent extra socket into it — no private key material is exposed to the
# container.  Dies if GIT_SIGNING_KEY is set but the secure path is not available,
# because there is no safe fallback (mounting ~/.gnupg exposes private keys).
add_gpg_podman_args() {
    local extra_socket
    extra_socket=$(gpgconf --list-dirs agent-extra-socket 2>/dev/null) || extra_socket=""

    # When the service runs with XDG_RUNTIME_DIR set, gpg-agent creates its sockets
    # in $XDG_RUNTIME_DIR/gnupg/ rather than ~/.gnupg/.  gpgconf --list-dirs may
    # still return the ~/.gnupg path, which could be a stale socket file left behind
    # when a previous gpg-agent was killed with SIGKILL.  Prefer the live runtime-dir
    # socket when it exists.
    if [ -n "${XDG_RUNTIME_DIR}" ]; then
        local runtime_extra="${XDG_RUNTIME_DIR}/gnupg/S.gpg-agent.extra"
        [ -S "${runtime_extra}" ] && extra_socket="${runtime_extra}"
    fi

    [ -n "${GIT_SIGNING_KEY}" ] || return 0

    [ -S "${extra_socket}" ] \
        || die "GPG agent extra socket not available — run 'gpgconf --launch gpg-agent' and ensure it creates an extra socket"

    GPG_PUBKEY_TMPDIR=$(TMPDIR="${XDG_RUNTIME_DIR:-/tmp}" mktemp -d --suffix=.gnupghome) \
        || die "Failed to create tmpdir for GPG pubkey gnupghome"
    chmod 0700 "${GPG_PUBKEY_TMPDIR}"
    gpg --batch --no-tty --export "${GIT_SIGNING_KEY}" 2>/dev/null \
            | GNUPGHOME="${GPG_PUBKEY_TMPDIR}" gpg --batch --no-tty --import --quiet 2>/dev/null \
        || die "GPG public key export/import failed for ${GIT_SIGNING_KEY} — ensure the key is in the local keyring"
    PODMAN_RUN_ARGS+=( --volume "${GPG_PUBKEY_TMPDIR}:/home/developer/.gnupg:rw" )
    PODMAN_RUN_ARGS+=( --volume "${extra_socket}:/home/developer/.gnupg/S.gpg-agent:ro" )
}

# Verify all --volume source paths in PODMAN_RUN_ARGS exist with the expected
# type before calling podman run.  Podman auto-creates any missing bind-mount
# source as a directory; if that path is later expected to be a socket, the
# directory blocks ssh-agent from binding there on the next run.
validate_bind_mounts() {
    local i=0 take_next=0 src
    local n=${#PODMAN_RUN_ARGS[@]}
    while [ "${i}" -lt "${n}" ]; do
        local arg="${PODMAN_RUN_ARGS[$i]}"
        if [ "${take_next}" = "1" ]; then
            take_next=0
            src="${arg%%:*}"
            case "${src}" in
                *.sock|*/S.gpg-agent|*/S.gpg-agent.extra)
                    [ -S "${src}" ] \
                        || die "Bind-mount source must be a socket but is missing or wrong type: ${src}"
                    ;;
                *)
                    [ -e "${src}" ] \
                        || die "Bind-mount source does not exist: ${src}"
                    ;;
            esac
        elif [ "${arg}" = "--volume" ]; then
            take_next=1
        fi
        i=$(( i + 1 ))
    done
}

# Runs a single FRESH claude session for one workflow phase and returns 0 on success.
# All user-visible messages and Claude's text response go to stderr so the caller can
# review what was done.  No session is persisted — every invocation starts clean.
# Runs claude inside a rootless Podman container named orchestrator-<OWNER>.
invoke_claude() {
    local prompt="$1" item_type="${2:-}" item_id="${3:-}" claude_md_content="${4:-}"
    local tmpfile owner_token container_name

    local prompt_len=${#prompt}
    if [ "${prompt_len}" -gt "${MAX_PROMPT_CHARS}" ]; then
        notify_discord_claude_error "${item_type}" "${item_id}" \
            "Prompt is too long: ${prompt_len} characters (max ${MAX_PROMPT_CHARS})"
        die "Prompt is too long: ${prompt_len} characters exceeds limit of ${MAX_PROMPT_CHARS}"
    fi

    owner_token=$(load_token_for_owner "${OWNER}")
    container_name="orchestrator-${OWNER}"

    if podman inspect "${container_name}" >/dev/null 2>&1; then
        die "Container ${container_name} already exists — remove it manually before running"
    fi

    cleanup_dangling_images
    info "Pulling latest image ${ORCHESTRATOR_IMAGE}..." >&2
    podman pull "${ORCHESTRATOR_IMAGE}" >&2 || die "Failed to pull ${ORCHESTRATOR_IMAGE}"

    # CLAUDE.md content is mandatory — every invocation must supply it.
    [ -n "${claude_md_content}" ] || die "claude_md_content is required but was not provided"

    # Bake settings.json/policy-limits.json/hooks/skills into the image (see
    # containers/base/development-full/Dockerfile) and mount only the pieces of
    # ~/.claude that must vary per invocation or persist across invocations:
    #   - CLAUDE.md: single read-only file mount. Safe now that the image already
    #     creates /home/developer/.claude with correct ownership — the old
    #     whole-directory mount trick existed only to work around Podman creating
    #     an unmounted parent directory with wrong ownership when bind-mounting a
    #     single file into a path whose parent didn't exist yet in the image.
    #   - sessions/, session-env/, plans/, cache/, backups/: read-write, each
    #     backed by a per-owner-per-repo host directory under CLAUDE_STATE_DIR so
    #     they persist across invocations instead of being wiped every run.
    CLAUDE_MD_TMPFILE=$(TMPDIR="${XDG_RUNTIME_DIR:-/tmp}" mktemp --suffix=.claude-md) || die "Failed to create temp file for CLAUDE.md"
    printf '%s' "${claude_md_content}" > "${CLAUDE_MD_TMPFILE}"
    # Write the prompt to its own file (unrelated to the .claude mounts above) so
    # run_claude_fresh/resumed can redirect stdin from it. Using a file avoids any
    # pipe-timing races where printf closes the write end before the container
    # process reads from it. Only ever read by podman on the host side, so it does
    # not need to be mounted into the container at all.
    CLAUDE_PROMPT="${prompt}"
    CLAUDE_PROMPT_FILE=$(TMPDIR="${XDG_RUNTIME_DIR:-/tmp}" mktemp --suffix=.prompt) || die "Failed to create temp file for prompt"
    printf '%s' "${prompt}" > "${CLAUDE_PROMPT_FILE}"
    for d in sessions session-env plans cache backups; do
        mkdir -p "${CLAUDE_STATE_DIR}/${d}" || die "Failed to create persistent Claude state directory: ${CLAUDE_STATE_DIR}/${d}"
    done
    PODMAN_SECRET_NAME=""
    GH_ENTERPRISE_SECRET_NAME=""
    trap 'rm -f "${CLAUDE_MD_TMPFILE}" "${CLAUDE_PROMPT_FILE}"; CLAUDE_MD_TMPFILE=""; CLAUDE_PROMPT_FILE=""; rm -rf "${GPG_PUBKEY_TMPDIR}"; [ -n "${PODMAN_SECRET_NAME}" ] && podman secret rm "${PODMAN_SECRET_NAME}" >/dev/null 2>&1 || true; [ -n "${GH_ENTERPRISE_SECRET_NAME}" ] && podman secret rm "${GH_ENTERPRISE_SECRET_NAME}" >/dev/null 2>&1 || true; stop_ssh_agent' EXIT

    # Export invocation-scoped globals so helper functions can read them.
    CLAUDE_PROMPT="${prompt}"
    PODMAN_CONTAINER_NAME="${container_name}"
    PODMAN_RUN_ARGS=(
        run
        --name "${container_name}"
        --rm
        --interactive
        # keep-id:uid=1000,gid=1000 maps container developer (UID/GID 1000) to the
        # host user running this service so that bind-mounted sockets and directories
        # owned by the host user appear as owned by the container's developer user,
        # giving it full owner-level access without world-writable permissions.
        "--userns=keep-id:uid=1000,gid=1000"
        --cpus="4"
        --memory="12g"
        --memory-swap="12g"
        --pids-limit=4096
        --volume "${REPO_WORK_DIR}:${CONTAINER_REPO_PATH}:rw"
        --volume "${RULES_DIR}:${CONTAINER_RULES_PATH}:ro"
    )
    [ -n "${PODMAN_CGROUP_PARENT}" ] && PODMAN_RUN_ARGS+=( --cgroup-parent "${PODMAN_CGROUP_PARENT}" )
    if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "${SSH_AUTH_SOCK}" ]; then
        PODMAN_RUN_ARGS+=( --volume "${SSH_AUTH_SOCK}:/tmp/ssh-agent.sock:ro" )
        PODMAN_RUN_ARGS+=( --env "SSH_AUTH_SOCK=/tmp/ssh-agent.sock" )
    else
        warn "SSH_AUTH_SOCK is not set or socket is absent — SSH git operations will not be available in the agent container"
    fi
    verify_gpg_signing_ready "${item_type}" "${item_id}"
    add_gpg_podman_args
    if [ -f "${HOME}/.database" ]; then
        PODMAN_RUN_ARGS+=( --volume "${HOME}/.database:/home/developer/.database:ro" )
    else
        warn "\$HOME/.database not found — database credentials will not be available in the agent container"
    fi
    PODMAN_RUN_ARGS+=( --volume "${CLAUDE_MD_TMPFILE}:/home/developer/.claude/CLAUDE.md:ro" )
    for d in sessions session-env plans cache backups; do
        PODMAN_RUN_ARGS+=( --volume "${CLAUDE_STATE_DIR}/${d}:/home/developer/.claude/${d}:rw" )
    done

    [ -n "${GIT_USER_NAME}" ]  && PODMAN_RUN_ARGS+=( --env "GIT_USER_NAME=${GIT_USER_NAME}" )
    [ -n "${GIT_USER_EMAIL}" ] && PODMAN_RUN_ARGS+=( --env "GIT_USER_EMAIL=${GIT_USER_EMAIL}" )
    [ -n "${GIT_SIGNING_KEY}" ] && PODMAN_RUN_ARGS+=( --env "GIT_SIGNING_KEY=${GIT_SIGNING_KEY}" )

    if [ -n "${owner_token}" ]; then
        PODMAN_SECRET_NAME="claude-oauth-${OWNER}"
        podman secret rm "${PODMAN_SECRET_NAME}" >/dev/null 2>&1 || true
        printf '%s' "${owner_token}" | podman secret create "${PODMAN_SECRET_NAME}" - \
            || die "Failed to create Podman secret for Claude OAuth token"
        PODMAN_RUN_ARGS+=( --secret "${PODMAN_SECRET_NAME},type=env,target=CLAUDE_CODE_OAUTH_TOKEN" )
    fi
    if [ -n "${GH_ENTERPRISE_TOKEN:-}" ]; then
        GH_ENTERPRISE_SECRET_NAME="gh-enterprise-token"
        podman secret rm "${GH_ENTERPRISE_SECRET_NAME}" >/dev/null 2>&1 || true
        printf '%s' "${GH_ENTERPRISE_TOKEN}" | podman secret create "${GH_ENTERPRISE_SECRET_NAME}" - \
            || die "Failed to create Podman secret for GH_ENTERPRISE_TOKEN"
        PODMAN_RUN_ARGS+=( --secret "${GH_ENTERPRISE_SECRET_NAME},type=env,target=GH_ENTERPRISE_TOKEN" )
    fi
    [ -n "${GH_HOST:-}" ]                && PODMAN_RUN_ARGS+=( --env "GH_HOST=${GH_HOST}" )

    PODMAN_CLAUDE_ARGS=(
        --model opusplan
        --print
        --output-format json
        --dangerously-skip-permissions
        --add-dir "${CONTAINER_REPO_PATH}"
    )

    tmpfile=$(mktemp --suffix=.json) || die "Failed to create temp file for Claude output"

    run_claude_fresh "${tmpfile}" "${item_type}" "${item_id}"

    local is_error
    is_error=$(jq -r '.is_error // false' "${tmpfile}" 2>/dev/null || printf 'false')
    if [ "${is_error}" = "true" ]; then
        handle_claude_is_error "${tmpfile}" "${item_type}" "${item_id}"
    fi

    jq -r '.result // ""' "${tmpfile}" >&2

    # Sanity check that Claude actually produced a JSON result object rather than empty output
    # or a stream fragment — a fresh run that dies before the final result would otherwise be
    # treated as a silent success.
    jq -e 'type == "object" and (has("result") or has("is_error"))' "${tmpfile}" >/dev/null 2>&1 \
        || { rm -f "${tmpfile}" "${CLAUDE_MD_TMPFILE}" "${CLAUDE_PROMPT_FILE}"; CLAUDE_MD_TMPFILE=""; CLAUDE_PROMPT_FILE=""; rm -rf "${GPG_PUBKEY_TMPDIR}"; GPG_PUBKEY_TMPDIR=""; die "Claude did not return a result object"; }
    rm -f "${tmpfile}"

    rm -f "${CLAUDE_MD_TMPFILE}" "${CLAUDE_PROMPT_FILE}"
    CLAUDE_MD_TMPFILE=""
    CLAUDE_PROMPT_FILE=""
    rm -rf "${GPG_PUBKEY_TMPDIR}"
    GPG_PUBKEY_TMPDIR=""
    cleanup_dangling_images
}

# Returns the path to the rate-limit file for the current owner.
owner_rate_limit_file() {
    printf '%s/.orchestrator/%s/rate-limit' "${HOME}" "${OWNER}"
}

# Saves a rate-limit reset unix timestamp for the current owner.
save_rate_limit() {
    local reset_unix="$1"
    local rate_limit_file
    rate_limit_file=$(owner_rate_limit_file)
    mkdir -p "$(dirname "${rate_limit_file}")" \
        || die "Failed to create rate-limit directory for owner ${OWNER}"
    printf '%s\n' "${reset_unix}" > "${rate_limit_file}" \
        || die "Failed to write rate-limit file: ${rate_limit_file}"
}

# Returns 0 (true) if the current owner is still rate-limited.
# Clears the rate-limit file when the reset time has passed.
is_owner_rate_limited() {
    local rate_limit_file reset_unix now_unix
    rate_limit_file=$(owner_rate_limit_file)
    [ -f "${rate_limit_file}" ] || return 1
    reset_unix=$(cat "${rate_limit_file}" 2>/dev/null) || return 1
    [[ "${reset_unix}" =~ ^[0-9]+$ ]] || { rm -f "${rate_limit_file}"; return 1; }
    now_unix=$(date +%s)
    if [ "${now_unix}" -ge "${reset_unix}" ]; then
        rm -f "${rate_limit_file}"
        return 1
    fi
    return 0
}

# Records a raw, unparseable 429 rate-limit message to a tracking issue in the orchestrator
# repo so parse_reset_time can be extended to handle the new format.  Appends a comment to an
# existing OPEN tracking issue; creates a fresh one when none is open.  Closed issues are never
# reopened — a closed tracker means prior formats were handled, so a new sample warrants a new
# issue.  All gh failures are non-fatal (warn only) so the caller's die still fires normally.
report_unparseable_rate_limit() {
    local item_type="$1" item_id="$2" result_text="$3"
    local now_iso existing body

    now_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    # Build the issue/comment body with context and the verbatim raw message.
    # $'...' quoting lets \n expand to real newlines and keeps backticks literal.
    # shellcheck disable=SC2016
    body=$(printf $'parse_reset_time could not parse this Claude 429 rate-limit message. The verbatim message is included below so the parser regex can be extended.\n\n- Owner: `%s`\n- Repo: `%s`\n- Item: `%s #%s`\n- Timestamp (UTC): `%s`\n\nRaw rate-limit message:\n\n```\n%s\n```\n' \
        "${OWNER}" "${REPO_FULL}" "${item_type}" "${item_id}" "${now_iso}" "${result_text}")

    # Find an existing OPEN tracking issue by exact title.
    # The search arg narrows the candidate set; jq then matches exactly so partial-title hits are
    # rejected.  The title is passed via an env var to avoid quoting it inside the jq filter.
    # We use repo: in the search query because --repo + --search is known to fail with
    # "malformed version" in some environments.
    existing=$(RL_TITLE="${RATE_LIMIT_ISSUE_TITLE}" gh issue list \
        --state open \
        --search "repo:${RATE_LIMIT_ISSUE_REPO} ${RATE_LIMIT_ISSUE_TITLE} in:title" \
        --limit 100 \
        --json number,title \
        --jq 'map(select(.title==env.RL_TITLE)) | .[0].number // empty' 2>/dev/null \
        || printf '')

    if [ -n "${existing}" ]; then
        # Check if this exact rate-limit message has already been reported in this issue to avoid spam.
        if { gh issue view "${existing}" --repo "${RATE_LIMIT_ISSUE_REPO}" --json body,comments --jq '.body, .comments[].body' 2>/dev/null || true; } | grep -Fq "${result_text}"; then
            info "Rate-limit message already reported in issue #${existing}"
            return 0
        fi

        gh issue comment "${existing}" --repo "${RATE_LIMIT_ISSUE_REPO}" --body "${body}" 2>/dev/null \
            || warn "Failed to append unparseable rate-limit message to issue #${existing}"
    else
        gh issue create --repo "${RATE_LIMIT_ISSUE_REPO}" \
            --title "${RATE_LIMIT_ISSUE_TITLE}" --label "AI-Work" --body "${body}" 2>/dev/null \
            || warn "Failed to create unparseable rate-limit tracking issue"
    fi
}

# Parses a "resets Hpm (Timezone)" string from a Claude rate-limit error and
# outputs the corresponding unix timestamp on stdout.  If the resolved time is
# already in the past (i.e. the reset is tomorrow), adds 86400 seconds.
# Outputs nothing and returns silently when parsing fails.
parse_reset_time() {
    local result_text="$1"
    local day_month hour minutes ampm tz hour24 reset_unix now_unix
    local regex='resets (([A-Z][a-z]{2} [0-9]+), )?([0-9]+)(:[0-9]+)?(am|pm) \(([^)]+)\)'

    [[ "${result_text}" =~ $regex ]] || return 0

    day_month="${BASH_REMATCH[2]:-today}"
    hour="${BASH_REMATCH[3]}"
    minutes="${BASH_REMATCH[4]:-}"
    ampm="${BASH_REMATCH[5]}"
    tz="${BASH_REMATCH[6]}"

    minutes="${minutes#:}"
    [ -z "${minutes}" ] && minutes="00"

    # Reject timezone strings with dangerous characters.
    case "${tz}" in
        *[!a-zA-Z0-9/_+-]*) return ;;
    esac

    # Convert 12-hour clock to 24-hour.
    if [ "${ampm}" = "pm" ] && [ "${hour}" != "12" ]; then
        hour24=$((hour + 12))
    elif [ "${ampm}" = "am" ] && [ "${hour}" = "12" ]; then
        hour24=0
    else
        hour24="${hour}"
    fi

    reset_unix=$(TZ="${tz}" date -d "${day_month} ${hour24}:${minutes}" +%s 2>/dev/null) || return
    now_unix=$(date +%s)
    if [ "${day_month}" = "today" ] && [ "${reset_unix}" -le "${now_unix}" ]; then
        reset_unix=$(TZ="${tz}" date -d "tomorrow ${hour24}:${minutes}" +%s 2>/dev/null) || return
    fi
    printf '%s' "${reset_unix}"
}

# Returns the path to the fingerprint file for a given PR ID.
pr_fingerprint_file_path() {
    local item_id="$1"
    printf '%s/PullRequest_%s.fingerprint' "${SESSION_BASE_DIR}" "${item_id}"
}

# Fetches the PR state JSON used for fingerprinting; returns 1 on gh failure.
fetch_pr_json() {
    local item_id="$1"
    gh pr view "${item_id}" \
        --repo "${REPO_FULL}" \
        --json state,title,body,isDraft,labels,headRefOid,headRefName,comments,reviews,statusCheckRollup,mergeable,mergeStateStatus,autoMergeRequest \
        2>/dev/null || return 1
}

# Computes a deterministic fingerprint from pre-fetched PR state JSON.
# Optional second argument: JSON array of trusted logins; when provided, only comments
# and reviews from those users are included so untrusted activity does not trigger re-runs.
# Outputs the hash on stdout; returns non-zero if jq fails.
fingerprint_pr_json() {
    local pr_json="$1"
    local trusted_logins="${2:-null}"
    local canonical

    canonical=$(printf '%s' "${pr_json}" | jq -r --argjson trusted "${trusted_logins}" '
        def tc(cs): if $trusted == null then cs else (cs | map(select(.author.login as $l | ($trusted | index($l)) != null))) end;
        .title,
        (.body // ""),
        (.isDraft | tostring),
        ([((.labels // [])[] | .name)] | sort | .[]),
        .headRefOid,
        (tc(.comments // []) | length | tostring),
        ((tc(.comments // []) | sort_by(.updatedAt) | last | .updatedAt) // "none"),
        ((tc(.reviews // []) | sort_by(.submittedAt // .updatedAt // "") | last | .state) // "none"),
        ((tc(.reviews // []) | sort_by(.submittedAt // .updatedAt // "") | last | (.submittedAt // .updatedAt)) // "none"),
        ([((.statusCheckRollup // [])[]
            | (.name // "unknown") as $n
            | (.conclusion // .status // "none") as $c
            | "\($c):\($n)"
        )] | sort | join(",")),
        (.mergeable // "UNKNOWN"),
        (.mergeStateStatus // "UNKNOWN"),
        (.autoMergeRequest != null | tostring)
    ') || return 1

    printf '%s' "${canonical}" | hash_sha256
}

# Computes a deterministic hash of the PR's current state using a single gh pr view call.
# Outputs the hash on stdout; returns non-zero if the gh call or jq fails.
compute_pr_fingerprint() {
    local item_id="$1"
    local pr_json trusted
    pr_json=$(fetch_pr_json "${item_id}") || return 1
    trusted=$(get_trusted_logins)
    fingerprint_pr_json "${pr_json}" "${trusted}"
}

# Writes the fingerprint to the fingerprint file for a given PR ID.
save_pr_fingerprint() {
    local item_id="$1" fingerprint="$2"
    local fingerprint_file

    fingerprint_file=$(pr_fingerprint_file_path "${item_id}")
    mkdir -p "${SESSION_BASE_DIR}" || die "Failed to create session directory: ${SESSION_BASE_DIR}"
    printf '%s\n' "${fingerprint}" \
        > "${fingerprint_file}" \
        || die "Failed to write fingerprint file: ${fingerprint_file}"
}

# Reads and outputs the saved fingerprint for a given PR ID, or empty string if none exists.
load_pr_fingerprint() {
    local item_id="$1"
    local fingerprint_file

    fingerprint_file=$(pr_fingerprint_file_path "${item_id}")
    if [ -f "${fingerprint_file}" ]; then
        cat "${fingerprint_file}"
    fi
}

# Returns 0 (true) if the pre-fetched PR JSON has at least one required check that is not yet COMPLETED.
# Returns 1 (false) when statusCheckRollup is absent, null, or every required entry has status "COMPLETED".
# Non-required (optional) checks are ignored so they cannot gate agent invocation.
pr_json_has_pending_ci_checks() {
    local pr_json="$1"
    # statusCheckRollup mixes two GraphQL node types: CheckRun (modern GitHub Actions
    # checks, has .status) and StatusContext (legacy commit statuses, has only .state
    # and no .status at all). Treating a StatusContext's absent .status as "not
    # COMPLETED" makes it look pending forever, even once its .state is a terminal
    # SUCCESS/FAILURE/ERROR — so each entry is classified by which field it actually has.
    printf '%s' "${pr_json}" | jq -e '
        (.statusCheckRollup // [])
        | (length > 0) and any(.[];
            .isRequired != false
            and (
                if (.status != null)
                then .status != "COMPLETED"
                else ((.state // "") | . == "PENDING" or . == "EXPECTED")
                end
            )
        )
    ' > /dev/null
}

# Returns the path to the per-PR CI pending state file.
pr_head_oid_file_path() {
    local item_id="$1"
    printf '%s/PullRequest_%s.pending_ci' "${SESSION_BASE_DIR}" "${item_id}"
}

# Writes the current head OID and observation timestamp to the CI pending state file.
save_pr_head_oid() {
    local item_id="$1" oid="$2" timestamp="$3"
    local state_file
    state_file=$(pr_head_oid_file_path "${item_id}")
    mkdir -p "${SESSION_BASE_DIR}" || die "Failed to create session directory: ${SESSION_BASE_DIR}"
    printf '%s %s\n' "${oid}" "${timestamp}" \
        > "${state_file}" \
        || die "Failed to write CI state file: ${state_file}"
}

# Reads and outputs the saved "<oid> <timestamp>" for a given PR, or empty string if absent.
load_pr_head_oid() {
    local item_id="$1"
    local state_file
    state_file=$(pr_head_oid_file_path "${item_id}")
    if [ -f "${state_file}" ]; then
        cat "${state_file}"
    fi
}

# Returns 0 (true) if CI checks for the current head OID have been pending longer than
# CI_CHECK_TIMEOUT_MINUTES.  Resets the clock (returns 1) whenever a new OID is observed.
ci_checks_timed_out() {
    local item_id="$1" pr_json="$2"
    local current_oid current_time
    current_oid=$(printf '%s' "${pr_json}" | jq -r '.headRefOid // empty')
    [ -z "${current_oid}" ] && return 1
    current_time=$(date +%s)

    local saved_state saved_oid saved_timestamp
    saved_state=$(load_pr_head_oid "${item_id}")
    if [ -n "${saved_state}" ]; then
        saved_oid="${saved_state%% *}"
        saved_timestamp="${saved_state##* }"
    fi

    if [ -z "${saved_state}" ] || [ "${current_oid}" != "${saved_oid}" ]; then
        save_pr_head_oid "${item_id}" "${current_oid}" "${current_time}"
        return 1
    fi

    if ! [[ "${saved_timestamp}" =~ ^[0-9]+$ ]]; then
        save_pr_head_oid "${item_id}" "${current_oid}" "${current_time}"
        return 1
    fi

    local elapsed_minutes
    elapsed_minutes=$(( (current_time - saved_timestamp) / 60 ))
    [ "${elapsed_minutes}" -ge "${CI_CHECK_TIMEOUT_MINUTES}" ]
}

# Removes the CI pending state file for a PR, resetting the timeout clock.
# Call after confirming CI checks are all complete so that any future re-trigger starts fresh.
clear_pr_ci_pending_state() {
    local item_id="$1"
    local state_file
    state_file=$(pr_head_oid_file_path "${item_id}")
    rm -f "${state_file}" 2>/dev/null || true
}

# Returns 0 (true) if the pre-fetched PR JSON contains a label named 'blocked' (case-insensitive).
pr_json_has_blocked_label() {
    local pr_json="$1"
    printf '%s' "${pr_json}" | jq -r '.labels[].name' | grep -qi '^blocked$'
}

# Copies labels from all closing issues linked to a PR onto the PR, adding any that are missing.
# Never removes existing labels. Uses --add-label for each missing one.
# Arguments: pr_id pr_json
sync_pr_labels_from_linked_issues() {
    local pr_id="$1" pr_json="$2"
    local linked_issues
    linked_issues=$(gh pr view "${pr_id}" \
        --repo "${REPO_FULL}" \
        --json closingIssuesReferences \
        --jq '.closingIssuesReferences[].number' 2>/dev/null) || return 0
    [ -n "${linked_issues}" ] || return 0

    local pr_label_list
    pr_label_list=$(printf '%s' "${pr_json}" | jq -c '[(.labels // [])[] | .name]')

    local issue_num issue_label already_present
    while IFS= read -r issue_num; do
        [ -n "${issue_num}" ] || continue
        while IFS= read -r issue_label; do
            [ -n "${issue_label}" ] || continue
            already_present=$(printf '%s' "${pr_label_list}" | jq -r --arg l "${issue_label}" 'map(select(. == $l)) | length')
            if [ "${already_present}" = "0" ]; then
                info "PR #${pr_id}: adding label '${issue_label}' from linked issue #${issue_num}"
                gh pr edit "${pr_id}" --repo "${REPO_FULL}" --add-label "${issue_label}" 2>/dev/null || true
                pr_label_list=$(printf '%s' "${pr_label_list}" | jq -c --arg l "${issue_label}" '. + [$l]')
            fi
        done < <(gh issue view "${issue_num}" \
            --repo "${REPO_FULL}" \
            --json labels \
            --jq '.labels[].name' 2>/dev/null)
    done <<< "${linked_issues}"
}

# Returns the path to the fingerprint file for a given Issue ID.
