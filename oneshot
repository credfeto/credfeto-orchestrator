#!/bin/bash
# shellcheck disable=SC2153
# SC2153 ("possible misspelling") false-positives once repo-context globals (OWNER, REPO,
# REPO_FULL, RULES_DIR, REPO_WORK_DIR, ...) are assigned only in the unfollowed lib/git
# source below: shellcheck can no longer see the assignment and flags every use against a
# same-named local parameter (e.g. `local repo_full="$1"`) elsewhere in this file as a typo.

# Orchestrator oneshot script.
# Fetches all open work items from the priorities API and drives a Claude Code session
# to work on the first actionable item across any repository.  Every invocation runs a
# FRESH Claude session (no --resume): all durable state lives in GitHub (branch, commits,
# PR comments, labels, Workflow board), so each run re-derives its context and does exactly
# ONE workflow phase before stopping.  This bounds a single session's context growth and
# is what keeps runs from hitting the model context window ("Prompt is too long").
# The orchestrator re-invokes the item on the next tick to advance to the next phase.

# Resolve this script's own directory via BASH_SOURCE (not $0), so it works both when run
# directly and when a test harness `source`s it ($0 would then be the test runner, not
# oneshot). lib/globals must be sourced first: it declares every associative array and
# config default the other libraries and main() read or write.
ONESHOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/globals disable=SC1091
source "${ONESHOT_DIR}/lib/globals"
# shellcheck source=lib/core disable=SC1091
source "${ONESHOT_DIR}/lib/core"
# shellcheck source=lib/git disable=SC1091
source "${ONESHOT_DIR}/lib/git"
# shellcheck source=lib/github disable=SC1091
source "${ONESHOT_DIR}/lib/github"
# shellcheck source=lib/github-status disable=SC1091
source "${ONESHOT_DIR}/lib/github-status"
# shellcheck source=lib/fingerprints disable=SC1091
source "${ONESHOT_DIR}/lib/fingerprints"
# shellcheck source=lib/state disable=SC1091
source "${ONESHOT_DIR}/lib/state"
# shellcheck source=lib/prompts disable=SC1091
source "${ONESHOT_DIR}/lib/prompts"
# shellcheck source=lib/workflow-board disable=SC1091
source "${ONESHOT_DIR}/lib/workflow-board"
# shellcheck source=lib/discord disable=SC1091
source "${ONESHOT_DIR}/lib/discord"
# shellcheck source=lib/podman disable=SC1091
source "${ONESHOT_DIR}/lib/podman"

# read_token_if_safe and load_token_for_owner are declared in lib/core.
# host_to_container_path and set_repo_context are declared in lib/git.

# _fetch_repo_collaborators, get_trusted_logins, require_trusted_logins, fetch_all_priorities,
# resolve_gh_me, list_bot_created_open_prs, fetch_pr_fields_json, json_has_commit_author_login,
# find_open_nonblocked_pr_for_repo, pr_has_bot_authored_commit, find_human_taken_over_pr_for_issue,
# pr_has_depends_branch, pr_has_dependency_label, and pr_is_human_driven are declared in
# lib/github. ensure_rules_current, clean_local_git_url_rewrites, ensure_repo_current,
# recover_orphaned_branch, and try_nonagentic_rebase are declared in lib/git.
# check_required_tools and hash_sha256 are declared in lib/core.

# invocation_guard_file_path, infra_failure_guard_file_path, load_infra_failure_count,
# save_infra_failure_count, clear_infra_failure_count, pr_invocation_guard_file_path,
# load_pr_invocation_counts, save_pr_invocation_counts, runaway_blocked_marker_file_path,
# mark_capped_block_for_forgiveness, reset_pr_invocation_counts_if_capped,
# env_unblock_attempts_file_path, env_unblock_cap_notice_marker_file_path,
# load_env_unblock_attempts, save_env_unblock_attempts, reset_env_unblock_attempts,
# try_auto_unblock_env_diagnosed_pr, issue_invocation_guard_file_path,
# load_issue_invocation_counts, save_issue_invocation_counts, and
# reset_issue_invocation_counts_if_capped are declared in lib/state.

# pr_json_is_terminal, pr_json_has_failed_required_check, gh_noun_for_item_type,
# apply_blocked_label, apply_blocked_label_with_reason, block_pr_for_idle_exhausted_failure,
# pr_json_has_unaddressed_review_request, block_pr_for_idle_exhausted_review, and
