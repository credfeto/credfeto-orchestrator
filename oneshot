# Reads DISCORD_WEBHOOK, GH_TOKEN, GH_HOST, GIT_USER_NAME, GIT_USER_EMAIL, and
# GIT_SIGNING_KEY from orchestrator/.env.
# Sets DISCORD_WEBHOOK_URL; exports GH_HOST and GH_ENTERPRISE_TOKEN when both are
# present so host-side gh CLI calls use the same proxy as the agent container.
# GIT_USER_NAME, GIT_USER_EMAIL, and GIT_SIGNING_KEY are used by build_minimal_gitconfig.
# Silent when the file is absent or a key is missing.
load_env_config() {
    DISCORD_WEBHOOK_URL=""
    GIT_USER_NAME=""
    GIT_USER_EMAIL=""
    GIT_SIGNING_KEY=""
    local env_file="${XDG_CONFIG_HOME:-${HOME}/.config}/orchestrator/.env"
    [ -f "${env_file}" ] || return 0
    local line val gh_token="" gh_host=""
    while IFS= read -r line || [ -n "${line}" ]; do
        case "${line}" in
            DISCORD_WEBHOOK=*|GH_TOKEN=*|GH_HOST=*|GIT_USER_NAME=*|GIT_USER_EMAIL=*|GIT_SIGNING_KEY=*)
                val="${line#*=}"
                val="${val%$'\r'}"
                case "${val}" in
                    '"'*'"') val="${val#?}"; val="${val%?}" ;;
                    "'"*"'") val="${val#?}"; val="${val%?}" ;;
                esac
                case "${line}" in
                    DISCORD_WEBHOOK=*) DISCORD_WEBHOOK_URL="${val}" ;;
                    GH_TOKEN=*)        gh_token="${val}" ;;
                    GH_HOST=*)         gh_host="${val}" ;;
                    GIT_USER_NAME=*)   GIT_USER_NAME="${val}" ;;
                    GIT_USER_EMAIL=*)  GIT_USER_EMAIL="${val}" ;;
                    GIT_SIGNING_KEY=*) GIT_SIGNING_KEY="${val}" ;;
                esac
                ;;
        esac
    done < "${env_file}"
    if [ -n "${gh_host}" ] && [ -n "${gh_token}" ]; then
        export GH_HOST="${gh_host}"
        export GH_ENTERPRISE_TOKEN="${gh_token}"
    fi
}

# Validates that all required config files exist and are populated correctly.
# Collects all errors and dies once at the end so every problem is visible at once.
# Must be called after load_env_config so GIT_* variables are already populated.
validate_config() {
    local owner_filter="$1"
    local config_dir="${XDG_CONFIG_HOME:-${HOME}/.config}"
    local errors=0

    if [ ! -f "${config_dir}/orchestrator/.env" ]; then
        printf '\n✗ %s\n' "${config_dir}/orchestrator/.env is missing" >&2
        printf '  Create it with: GIT_USER_NAME, GIT_USER_EMAIL, GIT_SIGNING_KEY, DISCORD_WEBHOOK\n' >&2
        errors=$((errors + 1))
    else
        [ -n "${GIT_USER_NAME}" ] || {
            printf '\n✗ %s\n' "GIT_USER_NAME is not set in ${config_dir}/orchestrator/.env" >&2
            errors=$((errors + 1))
        }
        [ -n "${GIT_USER_EMAIL}" ] || {
            printf '\n✗ %s\n' "GIT_USER_EMAIL is not set in ${config_dir}/orchestrator/.env" >&2
            errors=$((errors + 1))
        }
        [ -n "${GIT_SIGNING_KEY}" ] || {
            printf '\n✗ %s\n' "GIT_SIGNING_KEY is not set in ${config_dir}/orchestrator/.env" >&2
            errors=$((errors + 1))
        }
    fi

    # gh needs either the local credential store or a proxy token from .env.
    if [ -z "${GH_HOST:-}" ] || [ -z "${GH_ENTERPRISE_TOKEN:-}" ]; then
        if [ ! -f "${config_dir}/gh/hosts.yml" ]; then
            printf '\n✗ %s\n' "${config_dir}/gh/hosts.yml is missing — run 'gh auth login' first" >&2
            errors=$((errors + 1))
        fi
    fi

    if [ -n "${owner_filter}" ]; then
        local token_file="${config_dir}/orchestrator/tokens/${owner_filter}"
        if [ ! -f "${token_file}" ]; then
            printf '\n✗ %s\n' "${token_file} is missing — create it with the Claude OAuth token (chmod 600)" >&2
            errors=$((errors + 1))
        else
            local perms
            perms=$(stat -c '%a' "${token_file}" 2>/dev/null)
            case "${perms}" in
                600|400) ;;
                *) printf '\n✗ %s\n' "${token_file} has permissions ${perms} — must be 600 (run: chmod 600 ${token_file})" >&2
                   errors=$((errors + 1)) ;;
            esac
        fi
    fi

    [ "${errors}" -eq 0 ] || die "Config validation failed — fix the above and re-run"
}

# Sends a Discord embed notification when starting or resuming work on an item.
# Arguments: msg_type (start|resume), item_type, item_id, item_title
# Silent when DISCORD_WEBHOOK_URL is unset; logs a warning on curl failure.
notify_discord_work_item() {
    [ -n "${DISCORD_WEBHOOK_URL}" ] || return 0
    local msg_type="$1" item_type="$2" item_id="$3" item_title="$4"
    local url color status_label payload

    case "${msg_type}" in
        start|resume) ;;
        *) warn "Discord: unknown notification type '${msg_type}'"; return 0 ;;
    esac

    case "${item_type}" in
        Issue)       url="https://github.com/${REPO_FULL}/issues/${item_id}" ;;
        PullRequest) url="https://github.com/${REPO_FULL}/pull/${item_id}" ;;
        *)           url="https://github.com/${REPO_FULL}" ;;
    esac

    if [ "${msg_type}" = "start" ]; then
        color=3066993    # green  (#2ECC71)
        status_label="New"
    else
        color=15844367   # gold   (#F1C40F)
        status_label="Resume"
    fi

    payload=$(jq --null-input \
        --argjson color "${color}" \
        --arg title "${item_title}" \
        --arg url "${url}" \
        --arg repo "${REPO_FULL}" \
        --arg type "${item_type}" \
        --arg status "${status_label}" \
        '{embeds:[{title:$title,url:$url,color:$color,fields:[
            {name:"Repository",value:$repo,inline:true},
            {name:"Type",value:$type,inline:true},
            {name:"Status",value:$status,inline:true}
        ]}]}') \
        || { warn "Discord: failed to build payload for ${item_type} #${item_id}"; return 0; }

    curl --silent --fail --max-time 5 \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        "${DISCORD_WEBHOOK_URL}" > /dev/null 2>&1 \
        || warn "Discord webhook notification failed"
}

# Sends a Discord notification when no actionable work items are found.
# Arguments: owner (optional), count_blocked, count_unchanged, count_active_repo, count_not_open
# Silent when DISCORD_WEBHOOK_URL is unset; logs a warning on curl failure.
# Suppresses duplicate messages: if the same message was sent within the last hour, it is
# silently dropped.  A changed message is always sent immediately.  At most one send per hour
# per owner even when the message is identical.
notify_discord_no_work() {
    [ -n "${DISCORD_WEBHOOK_URL}" ] || return 0
    local owner="${1:-}"
    local count_blocked="${2:-0}"
    local count_unchanged="${3:-0}"
    local count_active_repo="${4:-0}"
    local count_not_open="${5:-0}"
    local prefix message detail payload
    if [ -n "${owner}" ]; then
        prefix="[${owner}] "
    else
        prefix=""
    fi
    message="${prefix}No actionable work items found."
    detail=""
    [ "${count_blocked}" -gt 0 ]     && detail="${detail:+${detail}, }blocked: ${count_blocked}"
    [ "${count_unchanged}" -gt 0 ]   && detail="${detail:+${detail}, }unchanged: ${count_unchanged}"
    [ "${count_active_repo}" -gt 0 ] && detail="${detail:+${detail}, }repo-active: ${count_active_repo}"
    [ "${count_not_open}" -gt 0 ]    && detail="${detail:+${detail}, }not-open: ${count_not_open}"
    [ -n "${detail}" ] && message="${message} (${detail})"

    # Dedup: suppress if the same message was sent within the last hour.
    local owner_slug state_file now last_message last_sent elapsed
    owner_slug="${owner:-_global}"
    owner_slug="${owner_slug//\//_}"
    state_file="${HOME}/.orchestrator/.no_work_${owner_slug}.state"
    now=$(date +%s)
    if [ -f "${state_file}" ]; then
        last_message=$(sed -n '1p' "${state_file}" 2>/dev/null || true)
        last_sent=$(sed -n '2p' "${state_file}" 2>/dev/null || true)
        if [ "${last_message}" = "${message}" ] && \
           printf '%s' "${last_sent}" | grep -qE '^[0-9]+$'; then
            elapsed=$(( now - last_sent ))
            [ "${elapsed}" -lt 3600 ] && return 0
        fi
    fi

    payload=$(jq --null-input --arg msg "${message}" '{"content":$msg}') \
        || { warn "Discord: failed to build no-work payload"; return 0; }
    curl --silent --fail --max-time 5 \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        "${DISCORD_WEBHOOK_URL}" > /dev/null 2>&1 \
        || warn "Discord webhook notification failed"

    mkdir -p "${HOME}/.orchestrator" 2>/dev/null || true
    printf '%s\n%s\n' "${message}" "${now}" > "${state_file}"
}

# Outputs available disk space in kilobytes for the filesystem containing WORK (or HOME).
# Outputs nothing when df output cannot be parsed.
disk_space_available_kb() {
    local check_path="${WORK:-${HOME}}"
    [ -d "${check_path}" ] || check_path="${HOME}"
    df -k "${check_path}" 2>/dev/null | awk 'NR==2{print $4}'
}

# Returns 0 when sufficient disk space is available (>= MIN_DISK_SPACE_KB).
# Returns 1 when space is below the threshold.
# Warns and returns 0 when available space cannot be determined.
check_disk_space() {
    local available_kb
    available_kb=$(disk_space_available_kb)
    if ! [[ "${available_kb}" =~ ^[0-9]+$ ]]; then
        warn "Could not determine available disk space — proceeding"
        return 0
    fi
    [ "${available_kb}" -ge "${MIN_DISK_SPACE_KB}" ]
}

# Sends a Discord embed notification when disk space is below MIN_DISK_SPACE_KB.
# Deduplicates: at most one notification per hour per owner.
# Silent when DISCORD_WEBHOOK_URL is unset; logs a warning on curl failure.
notify_discord_low_disk_space() {
    [ -n "${DISCORD_WEBHOOK_URL}" ] || return 0
    local owner="${1:-}"

    local available_kb available_gb threshold_gb
    available_kb=$(disk_space_available_kb)
    available_gb=$(( ${available_kb:-0} / 1024 / 1024 ))
    threshold_gb=$(( MIN_DISK_SPACE_KB / 1024 / 1024 ))

    local owner_slug state_file now last_sent elapsed
    owner_slug="${owner:-_global}"
    owner_slug="${owner_slug//\//_}"
    state_file="${HOME}/.orchestrator/.low_disk_space_${owner_slug}.state"
    now=$(date +%s)
    if [ -f "${state_file}" ]; then
        last_sent=$(cat "${state_file}" 2>/dev/null || printf '0')
        if printf '%s' "${last_sent}" | grep -qE '^[0-9]+$'; then
            elapsed=$(( now - last_sent ))
            [ "${elapsed}" -lt 3600 ] && return 0
        fi
    fi

    local payload
    payload=$(jq --null-input \
        --argjson color 15158332 \
        --arg title "Low Disk Space${owner:+ [${owner}]}" \
        --argjson available_gb "${available_gb}" \
        --argjson threshold_gb "${threshold_gb}" \
        '{embeds:[{title:$title,color:$color,fields:[
            {name:"Available",value:("\($available_gb) GB"),inline:true},
            {name:"Minimum Required",value:("\($threshold_gb) GB"),inline:true}
        ]}]}') \
        || { warn "Discord: failed to build low disk space payload"; return 0; }

    curl --silent --fail --max-time 5 \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        "${DISCORD_WEBHOOK_URL}" > /dev/null 2>&1 \
        || warn "Discord webhook notification failed"

    mkdir -p "${HOME}/.orchestrator" 2>/dev/null || true
    printf '%s\n' "${now}" > "${state_file}"
}

