# Runs a single podman-based claude invocation, writing JSON output to tmpfile.
# On non-zero exit: handles timeout (exit 124), container-name conflict, or general failure.
# Returns 0 on success (including a valid is_error=true result — the caller inspects that).
# Returns 2 when the container exited before Claude ever produced a result at all — most
# commonly an entrypoint.sh pre-flight check dying before `exec claude` runs (e.g. #1133's
# workspace-trust guard). Claude never started, so this is an infra/pre-flight failure, not a
# Claude-level one; the caller must not count it against the item's invocation budget and must
# not die the whole run over it — return a distinguishable code instead so main() can skip just
# this item and retry it next tick (#1133).
run_claude_fresh() {
    local tmpfile="$1" item_type="${2:-}" item_id="${3:-}"
    local stderrfile podman_exit=0
    stderrfile=$(mktemp --suffix=.stderr) || die "Failed to create temp file for podman stderr"
    [ -n "${CLAUDE_PROMPT}" ] || die "Prompt is empty — refusing to start container"
    validate_bind_mounts
    info "Starting new Claude session in container ${PODMAN_CONTAINER_NAME}..." >&2
    # The prompt is passed as a positional argument in PODMAN_CLAUDE_ARGS, not via
    # stdin, so stdin is redirected from /dev/null explicitly rather than left to
    # inherit whatever this process happens to have — closing off the host<->
    # container stdin-attach race that caused #281, #288, and #1062.
    # tmpfile and stderrfile are created by current user via mktemp, so both redirects are
    # intentionally unprivileged.
    # shellcheck disable=SC2024
    timeout --kill-after=60s "${AGENT_TIMEOUT_SECS}" \
        podman "${PODMAN_RUN_ARGS[@]}" "${ORCHESTRATOR_IMAGE}" "${PODMAN_CLAUDE_ARGS[@]}" \
        < /dev/null > "${tmpfile}" 2>"${stderrfile}" \
    || podman_exit=$?
    if [ "${podman_exit}" -ne 0 ]; then
        if [ "${podman_exit}" -eq 124 ]; then
            cat "${stderrfile}" >&2
            rm -f "${stderrfile}"
            podman rm -f "${PODMAN_CONTAINER_NAME}" > /dev/null 2>&1 || true
            notify_discord_claude_error "${item_type}" "${item_id}" \
                "Container ${PODMAN_CONTAINER_NAME} timed out after ${AGENT_TIMEOUT_MINUTES} minutes — killed"
            die "Agent container ${PODMAN_CONTAINER_NAME} timed out after ${AGENT_TIMEOUT_MINUTES} minutes"
        fi
        if grep -qi "name.*already in use" "${stderrfile}" 2>/dev/null; then
            cat "${stderrfile}" >&2
            rm -f "${stderrfile}"
            die "Container ${PODMAN_CONTAINER_NAME} is already in use — another invocation may be running"
        fi
        cat "${stderrfile}" >&2
        rm -f "${stderrfile}"
        # Claude CLI exits non-zero for API-level errors (e.g. 429 rate-limit) even
        # when it has written a valid result JSON to stdout.  Return 0 whenever a valid
        # result object exists AT ALL — not only when is_error is true — so invoke_claude's
        # own is_error inspection (which already handles both true and false correctly) does
        # the classification. Requiring is_error==true here would misclassify the narrow but
        # real case of podman exiting non-zero (e.g. an OOM-kill racing a clean exit) AFTER
        # Claude had already written a genuinely successful (is_error:false) result: that
        # completed work would be treated as a pre-flight infra failure — not counted, and
        # silently re-invoked next tick, risking duplicated agent actions (#1133 review).
        if [ -s "${tmpfile}" ] \
                && jq -e '.type == "result"' "${tmpfile}" >/dev/null 2>&1; then
            return 0
        fi
        jq -r '.result // ""' "${tmpfile}" 2>/dev/null >&2 || true
        rm -f "${tmpfile}"
        return 2
    fi
    cat "${stderrfile}" >&2
    rm -f "${stderrfile}"
}

# Invocation-scoped globals shared with the podman helpers below and cleaned up on EXIT.
CLAUDE_MD_TMPFILE=""
CLAUDE_PROMPT=""
GPG_PUBKEY_TMPDIR=""
PODMAN_SECRET_NAME=""
GH_ENTERPRISE_SECRET_NAME=""

# Handles is_error=true in the Claude JSON response.
# On blocking_limit: every run is already a fresh single-phase session, so there is nothing
#   to retry by dropping history — surface it as a hard error for a human to look at.
# On 429: persists rate limit, notifies Discord, dies.
# On anything else: notifies Discord, dies.
handle_claude_is_error() {
    local tmpfile="$1" item_type="$2" item_id="$3"
    local terminal_reason api_error_status result_text

    terminal_reason=$(jq -r '.terminal_reason // ""' "${tmpfile}" 2>/dev/null || printf '')
    api_error_status=$(jq -r '.api_error_status // ""' "${tmpfile}" 2>/dev/null || printf '')
    result_text=$(jq -r '.result // "Unknown error"' "${tmpfile}" 2>/dev/null || printf 'Unknown error')
    info "Claude error: ${result_text}" >&2

    if [ "${terminal_reason}" = "blocking_limit" ]; then
        warn "Fresh single-phase session still exceeded the context window for ${REPO_FULL} — a single phase is too large to fit; a human should split the work" >&2
    fi

    if [ "${api_error_status}" = "429" ]; then
        local reset_unix resume_unix
        reset_unix=$(parse_reset_time "${result_text}")
        resume_unix=""
        if [ -n "${reset_unix}" ]; then
            resume_unix=$((reset_unix + RATE_LIMIT_RESUME_BUFFER_SECS))
            save_rate_limit "${resume_unix}"
        else
            report_unparseable_rate_limit "${item_type}" "${item_id}" "${result_text}"
        fi
        notify_discord_rate_limited "${item_type}" "${item_id}" "${result_text}" "${resume_unix}"
        rm -f "${tmpfile}"
        die "Claude rate limited: ${result_text}"
    fi

    notify_discord_claude_error "${item_type}" "${item_id}" "${result_text}"
    rm -f "${tmpfile}"
    die "Claude invocation failed: ${result_text}"
}

# In cgroup v2, the "no-internal-process" constraint forbids a cgroup that
# directly contains processes from having child cgroups with domain controllers
# (memory, cpu, pids).  For Type=oneshot services the process lands directly
# in the service cgroup.  Delegate=cpu memory pids io grants permission to
# write subtree_control but does NOT write it automatically (verified on
# systemd 260); the process must do it itself — but only after moving to a
# leaf, because writing subtree_control while tasks are present fails with EBUSY.
#
# This function handles both cases:
# - If systemd already placed us in a leaf (e.g. on some Type=simple configs),
#   strip the leaf component to get the service cgroup as parent.
# - If we are directly in the service cgroup (Type=oneshot), move ourselves
#   into a leaf sub-cgroup named "init", then write the domain controllers to
#   the service cgroup's subtree_control so container child cgroups get
#   pids.max, memory.max, cpu.max etc.
#
# Sets PODMAN_CGROUP_PARENT so invoke_claude passes --cgroup-parent to every
# podman run call.  No-op when not running from a system service.
setup_cgroup_leaf() {
    local svcgroup leaf_dir cgroupfs_path controller
    svcgroup=$(cut -d: -f3 /proc/self/cgroup 2>/dev/null) || return 0

    case "${svcgroup}" in
        /system.slice/*/*)
            # systemd placed us in a leaf sub-cgroup like
            # /system.slice/<service>.service/0 — strip the last component
            # to get the service cgroup itself as the container parent.
            svcgroup="${svcgroup%/*}"
            ;;
        /system.slice/*)
            # Process is directly in the service cgroup.
            # Step 1: move ALL processes to a leaf so the service cgroup has no
            # direct tasks.  Moving only $$ is insufficient: any left-over
            # processes from an unclean previous run (e.g. ssh-agent) remain in
            # the service cgroup and cause the subtree_control write to fail
            # with EBUSY (cannot enable domain controllers while tasks exist).
            cgroupfs_path="/sys/fs/cgroup${svcgroup}"
            leaf_dir="${cgroupfs_path}/init"
            mkdir -p "${leaf_dir}" 2>/dev/null \
                || { warn "Cannot create leaf cgroup ${leaf_dir} — container resource limits may not apply"; return 0; }
            local pids pid
            pids=$(cat "${cgroupfs_path}/cgroup.procs" 2>/dev/null) || pids=""
            for pid in ${pids}; do
                printf '%s\n' "${pid}" > "${leaf_dir}/cgroup.procs" 2>/dev/null || true
            done
            # Step 2: now that the service cgroup has no direct tasks, enable
            # domain controllers so container child cgroups have pids.max etc.
            for controller in cpu memory pids io; do
                printf '+%s\n' "${controller}" > "${cgroupfs_path}/cgroup.subtree_control" 2>/dev/null \
                    || warn "Cannot enable ${controller} controller in ${svcgroup} — container resource limits may not apply"
            done
            ;;
        *)
            return 0
            ;;
    esac

    PODMAN_CGROUP_PARENT="${svcgroup}"
}

# Removes dangling (untagged) container images to free disk space.
# Only untagged images are pruned — the current ORCHESTRATOR_IMAGE is always
# tagged and is never removed.  Suppresses errors so that a failure to prune
# (e.g. no images to prune, podman storage not initialised) is never fatal.
cleanup_dangling_images() {
    podman image prune --force > /dev/null 2>&1 || true
}

# Kills the ssh-agent started by the service unit's ExecStartPre so the service
# cgroup is clean when the next timer fires and systemd does not warn about
# left-over processes.  Registered as an EXIT trap by main so it runs on any
# exit — success, die, or signal — regardless of whether invoke_claude was called.
# Scoped to the agent bound to SSH_AUTH_SOCK's own socket (mirroring install-timer's
# ExecStartPre pkill) — an unscoped 'pkill ssh-agent' matches any process with that
# name system-wide, including an unrelated interactive login agent (#1122).
stop_ssh_agent() {
    [ -n "${SSH_AUTH_SOCK:-}" ] || return 0
    pkill -u "$(id -un)" -f "ssh-agent -a ${SSH_AUTH_SOCK}" 2>/dev/null || true
}

# Loads default SSH keys into the agent if SSH_AUTH_SOCK is set and the agent
# currently holds no keys.  Silent when keys are already loaded (avoids
# redundant re-adds across timer firings) or when SSH_AUTH_SOCK is entirely
# absent.  Dies (host-health path, same as the gpg-agent check beside it in
# main) when the socket exists but nothing answers on it — a dead/stale agent
# would otherwise pass silently, get mounted into every agent container, and
# fail every push inside it instead of failing fast here (#1103).
preload_ssh_keys() {
    [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "${SSH_AUTH_SOCK}" ] || return 0
    local ssh_keys_status=0
    ssh-add -l >/dev/null 2>&1 || ssh_keys_status=$?
    case "${ssh_keys_status}" in
        0) return 0 ;;  # already loaded
        1) ;;           # agent reachable but empty — fall through to load keys
        2) die "ssh-add: cannot connect to the agent at ${SSH_AUTH_SOCK} — the socket exists but nothing is listening on it" ;;
        *) return 0 ;;
    esac
    ssh-add -q 2>/dev/null \
        || die "ssh-add: no SSH keys could be loaded — import a key with 'ssh-add <key-file>'"
}

# notify_github_blocked is declared in lib/github-status.

# Fast-fails if GIT_SIGNING_KEY is set but gpg-agent is not running or the key
# is absent from the keyring.  Posts a GitHub comment and adds Blocked before dying.
verify_gpg_signing_ready() {
    local item_type="$1" item_id="$2"
    [ -n "${GIT_SIGNING_KEY}" ] || return 0

    if ! gpg-connect-agent /bye >/dev/null 2>&1; then
        notify_github_blocked "${item_type}" "${item_id}" \
            "Cannot start agent session: \`gpg-agent\` is not running on the host. Run \`gpgconf --launch gpg-agent\` and retry."
        die "gpg-agent is not running — run 'gpgconf --launch gpg-agent' to start it"
    fi

    if ! gpg --batch --no-tty --list-secret-keys "${GIT_SIGNING_KEY}" >/dev/null 2>&1; then
        notify_github_blocked "${item_type}" "${item_id}" \
            "Cannot start agent session: signing key \`${GIT_SIGNING_KEY}\` is not in the GPG keyring. Import it with \`gpg --import <key-file>\` on the host."
        die "Signing key ${GIT_SIGNING_KEY} not found in GPG keyring — import it with 'gpg --import'"
    fi
}

# Appends GPG volume/socket args to PODMAN_RUN_ARGS.
# Creates a tmpdir containing only the signing public key and forwards the
# gpg-agent extra socket into it — no private key material is exposed to the
# container.  Dies if GIT_SIGNING_KEY is set but the secure path is not available,
# because there is no safe fallback (mounting ~/.gnupg exposes private keys).
add_gpg_podman_args() {
    local extra_socket
    extra_socket=$(gpgconf --list-dirs agent-extra-socket 2>/dev/null) || extra_socket=""

    # When the service runs with XDG_RUNTIME_DIR set, gpg-agent creates its sockets
    # in $XDG_RUNTIME_DIR/gnupg/ rather than ~/.gnupg/.  gpgconf --list-dirs may
    # still return the ~/.gnupg path, which could be a stale socket file left behind
    # when a previous gpg-agent was killed with SIGKILL.  Prefer the live runtime-dir
    # socket when it exists.
    if [ -n "${XDG_RUNTIME_DIR}" ]; then
        local runtime_extra="${XDG_RUNTIME_DIR}/gnupg/S.gpg-agent.extra"
        [ -S "${runtime_extra}" ] && extra_socket="${runtime_extra}"
    fi

    [ -n "${GIT_SIGNING_KEY}" ] || return 0

    [ -S "${extra_socket}" ] \
        || die "GPG agent extra socket not available — run 'gpgconf --launch gpg-agent' and ensure it creates an extra socket"

    GPG_PUBKEY_TMPDIR=$(TMPDIR="${XDG_RUNTIME_DIR:-/tmp}" mktemp -d --suffix=.gnupghome) \
        || die "Failed to create tmpdir for GPG pubkey gnupghome"
    chmod 0700 "${GPG_PUBKEY_TMPDIR}"
    gpg --batch --no-tty --export "${GIT_SIGNING_KEY}" 2>/dev/null \
            | GNUPGHOME="${GPG_PUBKEY_TMPDIR}" gpg --batch --no-tty --import --quiet 2>/dev/null \
        || die "GPG public key export/import failed for ${GIT_SIGNING_KEY} — ensure the key is in the local keyring"
    PODMAN_RUN_ARGS+=( --volume "${GPG_PUBKEY_TMPDIR}:/home/developer/.gnupg:rw" )
    PODMAN_RUN_ARGS+=( --volume "${extra_socket}:/home/developer/.gnupg/S.gpg-agent:ro" )
}

# Verify all --volume source paths in PODMAN_RUN_ARGS exist with the expected
# type before calling podman run.  Podman auto-creates any missing bind-mount
# source as a directory; if that path is later expected to be a socket, the
# directory blocks ssh-agent from binding there on the next run.
validate_bind_mounts() {
    local i=0 take_next=0 src
    local n=${#PODMAN_RUN_ARGS[@]}
    while [ "${i}" -lt "${n}" ]; do
        local arg="${PODMAN_RUN_ARGS[$i]}"
        if [ "${take_next}" = "1" ]; then
            take_next=0
            src="${arg%%:*}"
            case "${src}" in
                *.sock|*/S.gpg-agent|*/S.gpg-agent.extra)
                    [ -S "${src}" ] \
                        || die "Bind-mount source must be a socket but is missing or wrong type: ${src}"
                    ;;
                *)
                    [ -e "${src}" ] \
                        || die "Bind-mount source does not exist: ${src}"
                    ;;
            esac
        elif [ "${arg}" = "--volume" ]; then
            take_next=1
        fi
        i=$(( i + 1 ))
    done
}

# Removes the per-invocation CLAUDE.md tempfile and GPG pubkey tempdir and resets their
# globals. Shared by every invoke_claude exit path (success, infra-failure early-return, and
# the "no result object" die) so cleanup cannot drift between them (#1133).
# Removes the per-invocation CLAUDE.md tempfile, GPG pubkey tempdir, and any podman secrets
# created for this invocation (Claude OAuth / GH Enterprise tokens), resetting their globals.
# Shared by every invoke_claude exit path (success, infra-failure early-return, and the "no
# result object" die) so cleanup cannot drift between them, AND by the EXIT trap — which used
# to be the ONLY thing that removed the podman secrets, firing only when the whole oneshot
# process exits. That was fine while every invocation was followed by an immediate process
# exit, but the #1133 infra-failure path uses `continue` to keep the main loop scanning other
# items in the same run, so a secret created for a failed item could sit in the podman secret
# store — readable by anything else with local podman access — for the rest of the run instead
# of being removed immediately (#1133 review). Calling this explicitly on every path closes
# that gap regardless of how long the caller's process keeps running afterwards.
cleanup_claude_invocation_tmpfiles() {
    if [ -n "${CLAUDE_MD_TMPFILE}" ]; then
        rm -f "${CLAUDE_MD_TMPFILE}"
        CLAUDE_MD_TMPFILE=""
    fi
    if [ -n "${GPG_PUBKEY_TMPDIR}" ]; then
        rm -rf "${GPG_PUBKEY_TMPDIR}"
        GPG_PUBKEY_TMPDIR=""
    fi
    if [ -n "${PODMAN_SECRET_NAME}" ]; then
        podman secret rm "${PODMAN_SECRET_NAME}" >/dev/null 2>&1 || true
        PODMAN_SECRET_NAME=""
    fi
    if [ -n "${GH_ENTERPRISE_SECRET_NAME}" ]; then
        podman secret rm "${GH_ENTERPRISE_SECRET_NAME}" >/dev/null 2>&1 || true
        GH_ENTERPRISE_SECRET_NAME=""
    fi
}

# Runs a single FRESH claude session for one workflow phase and returns 0 on success.
# All user-visible messages and Claude's text response go to stderr so the caller can
# review what was done.  No session is persisted — every invocation starts clean.
# Runs claude inside a rootless Podman container named orchestrator-<OWNER>.
# Returns 2 when the container failed before Claude ever ran (see run_claude_fresh) — the
# caller (main) must skip this item without counting it against the invocation budget (#1133).
invoke_claude() {
    local prompt="$1" item_type="${2:-}" item_id="${3:-}" claude_md_content="${4:-}"
    local tmpfile owner_token container_name

    local prompt_len=${#prompt}
    if [ "${prompt_len}" -gt "${MAX_PROMPT_CHARS}" ]; then
        notify_discord_claude_error "${item_type}" "${item_id}" \
            "Prompt is too long: ${prompt_len} characters (max ${MAX_PROMPT_CHARS})"
        die "Prompt is too long: ${prompt_len} characters exceeds limit of ${MAX_PROMPT_CHARS}"
    fi

    owner_token=$(load_token_for_owner "${OWNER}")
    container_name="orchestrator-${OWNER}"

    if podman inspect "${container_name}" >/dev/null 2>&1; then
        # A container left behind by a hard host crash (despite --rm) previously made every
        # subsequent run die permanently until a human removed it manually (#1090). If it is not
        # actively running, it is safe to assume it is such a leftover and remove it ourselves;
        # only die if it is genuinely running, which means something else is actively using it.
        if [ "$(podman inspect --format '{{.State.Running}}' "${container_name}" 2>/dev/null)" = "true" ]; then
            notify_discord_claude_error "${item_type}" "${item_id}" \
                "Container ${container_name} already exists and is running — remove it manually before running"
            die "Container ${container_name} already exists and is running — remove it manually before running"
        fi
        warn "Removing leftover (non-running) container ${container_name} from a previous run"
        podman rm -f "${container_name}" >&2 \
            || { notify_discord_claude_error "${item_type}" "${item_id}" "Failed to remove leftover container ${container_name}"; die "Failed to remove leftover container ${container_name}"; }
    fi

    cleanup_dangling_images
    info "Pulling latest image ${ORCHESTRATOR_IMAGE}..." >&2
    if ! podman pull "${ORCHESTRATOR_IMAGE}" >&2; then
        # A registry hiccup should not fail the run when a usable cached image already exists
        # locally — fall back to it instead of dying outright (#1090). Only die if there is truly
        # no image to run at all.
        if podman image exists "${ORCHESTRATOR_IMAGE}"; then
            warn "Failed to pull ${ORCHESTRATOR_IMAGE} — falling back to the cached local image"
        else
            notify_discord_claude_error "${item_type}" "${item_id}" \
                "Failed to pull ${ORCHESTRATOR_IMAGE} and no cached local image is available"
            die "Failed to pull ${ORCHESTRATOR_IMAGE} and no cached local image is available"
        fi
    fi

    # CLAUDE.md content is mandatory — every invocation must supply it.
    if [ -z "${claude_md_content}" ]; then
        notify_discord_claude_error "${item_type}" "${item_id}" "claude_md_content is required but was not provided"
        die "claude_md_content is required but was not provided"
    fi

    # Bake settings.json/policy-limits.json/hooks/skills into the image (see
    # containers/base/development-full/Dockerfile) and mount only the pieces of
    # ~/.claude that must vary per invocation or persist across invocations:
    #   - CLAUDE.md: single read-only file mount. Safe now that the image already
    #     creates /home/developer/.claude with correct ownership — the old
    #     whole-directory mount trick existed only to work around Podman creating
    #     an unmounted parent directory with wrong ownership when bind-mounting a
    #     single file into a path whose parent didn't exist yet in the image.
    #   - sessions/, session-env/, plans/, cache/, backups/: read-write, each
    #     backed by a per-owner-per-repo host directory under CLAUDE_STATE_DIR so
    #     they persist across invocations instead of being wiped every run.
    CLAUDE_MD_TMPFILE=$(TMPDIR="${XDG_RUNTIME_DIR:-/tmp}" mktemp --suffix=.claude-md) || die "Failed to create temp file for CLAUDE.md"
    printf '%s' "${claude_md_content}" > "${CLAUDE_MD_TMPFILE}"
    PODMAN_SECRET_NAME=""
    GH_ENTERPRISE_SECRET_NAME=""
    # Registered immediately after CLAUDE_MD_TMPFILE is populated — not after the mkdir loop
    # below — so a die() from that loop (or anything else between here and the container run)
    # cannot leak the tmpfile before anything is tracking it (#1103). Backstop only: every
    # normal exit path below now calls cleanup_claude_invocation_tmpfiles itself (#1133
    # review), so by the time this trap fires those globals are usually already empty and its
    # cleanup calls are no-ops — it only does real work if invoke_claude is interrupted
    # somewhere that skips its own cleanup (a signal, an unexpected die() elsewhere).
    trap 'cleanup_claude_invocation_tmpfiles; stop_ssh_agent' EXIT
    # The prompt travels as a trailing positional argument to claude (see
    # PODMAN_CLAUDE_ARGS below), not via stdin — passing it as an argv element
    # sidesteps the host<->container stdin-attach race entirely (#281, #288, #1062
    # were all variations of that race). MAX_PROMPT_CHARS (100000) keeps it well
    # under any argv-length limit.
    CLAUDE_PROMPT="${prompt}"
    for d in sessions session-env plans cache backups; do
        mkdir -p "${CLAUDE_STATE_DIR}/${d}" || die "Failed to create persistent Claude state directory: ${CLAUDE_STATE_DIR}/${d}"
    done

    # Export invocation-scoped globals so helper functions can read them.
    CLAUDE_PROMPT="${prompt}"
    PODMAN_CONTAINER_NAME="${container_name}"
    PODMAN_RUN_ARGS=(
        run
        --name "${container_name}"
        --rm
        --interactive
        # keep-id:uid=1000,gid=1000 maps container developer (UID/GID 1000) to the
        # host user running this service so that bind-mounted sockets and directories
        # owned by the host user appear as owned by the container's developer user,
        # giving it full owner-level access without world-writable permissions.
        "--userns=keep-id:uid=1000,gid=1000"
        --cpus="4"
        --memory="12g"
        --memory-swap="12g"
        --pids-limit=4096
        --volume "${REPO_WORK_DIR}:${CONTAINER_REPO_PATH}:rw"
        --volume "${RULES_DIR}:${CONTAINER_RULES_PATH}:ro"
    )
    [ -n "${PODMAN_CGROUP_PARENT}" ] && PODMAN_RUN_ARGS+=( --cgroup-parent "${PODMAN_CGROUP_PARENT}" )
    if [ -n "${SSH_AUTH_SOCK:-}" ] && [ -S "${SSH_AUTH_SOCK}" ]; then
        PODMAN_RUN_ARGS+=( --volume "${SSH_AUTH_SOCK}:/tmp/ssh-agent.sock:ro" )
        PODMAN_RUN_ARGS+=( --env "SSH_AUTH_SOCK=/tmp/ssh-agent.sock" )
    else
        warn "SSH_AUTH_SOCK is not set or socket is absent — SSH git operations will not be available in the agent container"
    fi
    verify_gpg_signing_ready "${item_type}" "${item_id}"
    add_gpg_podman_args
    if [ -f "${HOME}/.database" ]; then
        PODMAN_RUN_ARGS+=( --volume "${HOME}/.database:/home/developer/.database:ro" )
    else
        warn "\$HOME/.database not found — database credentials will not be available in the agent container"
    fi
    PODMAN_RUN_ARGS+=( --volume "${CLAUDE_MD_TMPFILE}:/home/developer/.claude/CLAUDE.md:ro" )
    for d in sessions session-env plans cache backups; do
        PODMAN_RUN_ARGS+=( --volume "${CLAUDE_STATE_DIR}/${d}:/home/developer/.claude/${d}:rw" )
    done

    [ -n "${GIT_USER_NAME}" ]  && PODMAN_RUN_ARGS+=( --env "GIT_USER_NAME=${GIT_USER_NAME}" )
    [ -n "${GIT_USER_EMAIL}" ] && PODMAN_RUN_ARGS+=( --env "GIT_USER_EMAIL=${GIT_USER_EMAIL}" )
    [ -n "${GIT_SIGNING_KEY}" ] && PODMAN_RUN_ARGS+=( --env "GIT_SIGNING_KEY=${GIT_SIGNING_KEY}" )

    # Lets the agent container announce what it's working on at startup. Only
    # set when both are known — most callers (tests, ad-hoc invocations) pass
    # empty item_type/item_id and simply won't get this env var.
    if [ -n "${item_type}" ] && [ -n "${item_id}" ]; then
        PODMAN_RUN_ARGS+=( --env "WORK_ITEM_URL=$(build_item_url "${item_type}" "${item_id}")" )
    fi

    if [ -n "${owner_token}" ]; then
        PODMAN_SECRET_NAME="claude-oauth-${OWNER}"
        podman secret rm "${PODMAN_SECRET_NAME}" >/dev/null 2>&1 || true
        printf '%s' "${owner_token}" | podman secret create "${PODMAN_SECRET_NAME}" - \
            || { notify_discord_claude_error "${item_type}" "${item_id}" "Failed to create Podman secret for Claude OAuth token"; die "Failed to create Podman secret for Claude OAuth token"; }
        PODMAN_RUN_ARGS+=( --secret "${PODMAN_SECRET_NAME},type=env,target=CLAUDE_CODE_OAUTH_TOKEN" )
    fi
    if [ -n "${GH_ENTERPRISE_TOKEN:-}" ]; then
        GH_ENTERPRISE_SECRET_NAME="gh-enterprise-token"
        podman secret rm "${GH_ENTERPRISE_SECRET_NAME}" >/dev/null 2>&1 || true
        printf '%s' "${GH_ENTERPRISE_TOKEN}" | podman secret create "${GH_ENTERPRISE_SECRET_NAME}" - \
            || { notify_discord_claude_error "${item_type}" "${item_id}" "Failed to create Podman secret for GH_ENTERPRISE_TOKEN"; die "Failed to create Podman secret for GH_ENTERPRISE_TOKEN"; }
        PODMAN_RUN_ARGS+=( --secret "${GH_ENTERPRISE_SECRET_NAME},type=env,target=GH_ENTERPRISE_TOKEN" )
    fi
    [ -n "${GH_HOST:-}" ]                && PODMAN_RUN_ARGS+=( --env "GH_HOST=${GH_HOST}" )
    PODMAN_RUN_ARGS+=( --env "CLAUDE_CODE_AUTO_COMPACT_WINDOW=${CLAUDE_CODE_AUTO_COMPACT_WINDOW}" )

    PODMAN_CLAUDE_ARGS=(
        --model opusplan
        --print
        --output-format json
        --dangerously-skip-permissions
        --add-dir "${CONTAINER_REPO_PATH}"
        # -- terminates option/variadic parsing before the positional prompt.
        # --add-dir takes <directories...> (variadic) — without this separator the
        # CLI parser greedily swallows the prompt as an extra --add-dir value
        # instead of recognizing it as the [prompt] argument, which then dies with
        # "Input must be provided either through stdin or as a prompt argument"
        # despite a real prompt being passed (#1062 recurrence after #1077).
        --
        "${CLAUDE_PROMPT}"
    )

    tmpfile=$(mktemp --suffix=.json) || die "Failed to create temp file for Claude output"

    run_claude_fresh "${tmpfile}" "${item_type}" "${item_id}"
    local run_claude_exit=$?
    if [ "${run_claude_exit}" -eq 2 ]; then
        # Infra/pre-flight failure — Claude never started (#1133). run_claude_fresh already
        # removed tmpfile; propagate the distinguishable code so main() skips just this item
        # instead of dying the whole run and counting it against the invocation budget.
        cleanup_claude_invocation_tmpfiles
        cleanup_dangling_images
        return 2
    fi

    local is_error
    is_error=$(jq -r '.is_error // false' "${tmpfile}" 2>/dev/null || printf 'false')
    if [ "${is_error}" = "true" ]; then
        handle_claude_is_error "${tmpfile}" "${item_type}" "${item_id}"
    fi

    jq -r '.result // ""' "${tmpfile}" >&2

    # Sanity check that Claude actually produced a JSON result object rather than empty output
    # or a stream fragment — a fresh run that dies before the final result would otherwise be
    # treated as a silent success.
    jq -e 'type == "object" and (has("result") or has("is_error"))' "${tmpfile}" >/dev/null 2>&1 \
        || { rm -f "${tmpfile}"; cleanup_claude_invocation_tmpfiles; die "Claude did not return a result object"; }
    rm -f "${tmpfile}"

    cleanup_claude_invocation_tmpfiles
    cleanup_dangling_images
}

# owner_rate_limit_file, save_rate_limit, is_owner_rate_limited, report_unparseable_rate_limit,
# and parse_reset_time are declared in lib/state.

# pr_fingerprint_file_path, fetch_pr_json, fetch_pr_review_comments, fingerprint_pr_json,
# compute_pr_fingerprint, save_pr_fingerprint, load_pr_fingerprint, pr_head_oid_file_path,
# save_pr_head_oid, load_pr_head_oid, ci_checks_timed_out, and clear_pr_ci_pending_state are
# declared in lib/fingerprints.
# pr_json_has_pending_ci_checks, block_pr_for_ci_timeout, pr_json_has_blocked_label, and
# pr_json_env_block_image_sha are declared in lib/github-status.

# Reads the git SHA baked into the agent image's IMAGE_SHA_DEVELOPMENT_AGENT env var (set at build
# time — see containers/agent/Dockerfile) directly off the image config, without running a
# container (#1118). Assumes invoke_claude has already pulled the current ${ORCHESTRATOR_IMAGE}
# tag. Best-effort: prints nothing and returns non-zero on any inspect failure — a failure here
# only means the auto-unblock check below is skipped for this tick, never that anything breaks.
current_agent_image_sha() {
    local sha
    sha=$(podman inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "${ORCHESTRATOR_IMAGE}" 2>/dev/null \
        | sed -n 's/^IMAGE_SHA_DEVELOPMENT_AGENT=//p')
    [ -n "${sha}" ] || return 1
    printf '%s' "${sha}"
}

# sync_pr_labels_from_linked_issues is declared in lib/github.

# issue_fingerprint_file_path, fetch_issue_json, fingerprint_issue_json,
# compute_issue_fingerprint, save_issue_fingerprint, and load_issue_fingerprint are declared in
# lib/fingerprints.

# issue_json_has_blocked_label is declared in lib/github-status.

# load_env_config and validate_config are declared in lib/core.

# build_item_url, notify_discord_work_item, notify_discord_no_work,
# notify_discord_low_disk_space, notify_discord_blocked_item, notify_discord_claude_error, and
# notify_discord_rate_limited are declared in lib/discord.

# rearm_closed_issue_markers and tag_pr_closed_issue are declared in lib/state.

main() {
    local owner_filter=""

    # Registered first, before any die-capable step below, so an early failure
    # (bad argument, missing tool, invalid config, missing signing key) still
    # cleans up the ssh-agent the service unit's ExecStartPre already started
    # before oneshot ran — otherwise it leaks and systemd logs "Found
    # left-over process ... in control group" on the next timer firing (#1103).
    trap stop_ssh_agent EXIT

    while [ $# -gt 0 ]; do
        case "$1" in
            --owner)
                shift
                [ -n "${1:-}" ] || die "--owner requires a value"
                [[ "$1" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]] \
                    || die "--owner value contains invalid characters: $1"
                owner_filter="$1"
                shift
                ;;
            *)
                die "Unknown argument: $1"
                ;;
        esac
    done

    check_required_tools
    load_env_config
    validate_config "${owner_filter}"
    if [ -n "${GIT_SIGNING_KEY}" ]; then
        gpg --batch --no-tty --list-secret-keys "${GIT_SIGNING_KEY}" >/dev/null 2>&1 \
            || die "Signing key ${GIT_SIGNING_KEY} is set in .env but not found in the GPG keyring — import it with 'gpg --import <key-file>'"
    fi
    preload_ssh_keys
    setup_cgroup_leaf

    if ! check_disk_space; then
        notify_discord_low_disk_space "${owner_filter}"
        warn "Insufficient disk space — skipping all work this cycle"
        exit 0
    fi

    local head_sha
    head_sha=$(git -C "$(dirname "$(realpath "$0")")" rev-parse --short HEAD 2>/dev/null || printf 'unknown')
    info "oneshot version: ${head_sha}"

    # Acquire an exclusive per-owner lock so concurrent invocations (e.g. two
    # systemd timer firings) do not race on the same git working directories.
    local lock_dir="${HOME}/.orchestrator/locks"
    mkdir -p "${lock_dir}" || die "Failed to create lock directory at ${lock_dir}"
    # fd 9 stays open (and lock held) until the process exits.
    exec 9>"${lock_dir}/${owner_filter:-_global}.lock"
    if ! flock --exclusive --nonblock 9; then
        info "Another oneshot instance is already running for '${owner_filter:-global}' — exiting cleanly"
        exit 0
    fi

    local items_json item_count
    info "Fetching priorities from ${PRIORITIES_URL}..."
    items_json=$(fetch_all_priorities) || die "Failed to fetch priorities from ${PRIORITIES_URL}"

    if [ -n "${owner_filter}" ]; then
        items_json=$(printf '%s' "${items_json}" | jq -c --arg owner "${owner_filter}" \
            '[.[] | select(.repository | startswith($owner + "/"))]') \
            || die "Failed to filter priorities by owner"
    fi

    item_count=$(printf '%s' "${items_json}" | jq 'length')
    [[ "${item_count}" =~ ^[0-9]+$ ]] || die "Failed to determine item count from priorities JSON"
    if [ "${item_count}" -eq 0 ]; then
        success "No open work items found in priorities"
        notify_discord_no_work "${owner_filter}"
        exit 0
    fi

    info "Found ${item_count} open work item(s) — scanning for actionable work..."

    local -a skip_repos=()
    declare -gA reported_rate_limited=()
    local count_blocked=0
    local count_unchanged=0
    local count_active_repo=0
    local count_not_open=0
    local count_error=0
    local count_human_driven=0
    local item_index=0
    # Declare all loop-body variables here so they are function-scoped.
    # 'local' inside a while loop is a no-op after the first iteration in bash,
    # so initialising them here (and resetting where needed at the top of each
    # iteration) avoids stale-value bugs.
    local item item_repo item_id item_type item_priority item_title
    local skip_repo is_skipped original_issue_id pr_idle_advance
    local open_pr pr_json pr_state pr_fp saved_fp merge_state branch_name pr_review_comments
    local issue_json issue_state issue_fp saved_issue_fp
    local ai_instructions container_ai_instructions prompt claude_md_content post_fp
    local post_pr_fp_ok post_issue_fp_ok post_issue_fp
    local ensure_repo_current_status trusted_logins
    local standoff_pr standoff_rc human_driven_rc closed_takeover_marker closed_pr_tagged_marker
    local -a _filtered_repos

    while [ "${item_index}" -lt "${item_count}" ]; do
        item=$(printf '%s' "${items_json}" | jq -c --argjson idx "${item_index}" '.[$idx]')
        item_index=$((item_index + 1))

        item_repo=$(printf '%s' "${item}" | jq -r '.repository')
        item_id=$(printf '%s' "${item}" | jq -r '.id')
        item_type=$(printf '%s' "${item}" | jq -r '.itemType')
        item_priority=$(printf '%s' "${item}" | jq -r '.priority')

        # A single malformed entry from the priorities API must not brick every future cycle by
        # dying on the same bad item every tick (#1090) — warn and skip just this one instead.
        if [[ ! "${item_id}" =~ ^[0-9]+$ ]]; then
            warn "Non-numeric id from priorities API: ${item_id} — skipping this item"
            count_error=$((count_error + 1))
            continue
        fi
        case "${item_type}" in
            Issue|PullRequest) ;;
            *)
                warn "Unexpected itemType from priorities API: ${item_type} — skipping this item"
                count_error=$((count_error + 1))
                continue
                ;;
        esac
        if [[ ! "${item_repo}" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*/[a-zA-Z0-9_][a-zA-Z0-9._-]*$ ]]; then
            warn "Malformed repository from priorities API: ${item_repo} — skipping this item"
            count_error=$((count_error + 1))
            continue
        fi

        # Skip Issue items in repos that already have an active (non-blocked) PR.
        # PullRequests are always evaluated regardless of skip_repos — the guard
        # only prevents starting brand-new work from an Issue in an active repo.
        # Explicit reset — the 'local' initialiser above only fires once.
        is_skipped=false
        original_issue_id=""
        # Set when an unchanged non-terminal PR is re-invoked only to advance its next phase
        # (no external change); consumed when persisting the PR idle counter before invocation.
        pr_idle_advance=0
        if [ "${item_type}" = "Issue" ]; then
            for skip_repo in "${skip_repos[@]+"${skip_repos[@]}"}"; do
                if [ "${skip_repo}" = "${item_repo}" ]; then
                    is_skipped=true
                    break
                fi
            done
        fi
        if [ "${is_skipped}" = true ]; then
            info "Skipping Issue #${item_id} in ${item_repo} — repo already has active work"
            count_active_repo=$((count_active_repo + 1))
            continue
        fi

        info "Checking ${item_type} #${item_id} in ${item_repo} (priority ${item_priority})..."

        # Configure per-repo globals for all sub-functions.
        set_repo_context "${item_repo}"

        if [ "${item_type}" = "Issue" ]; then
            # Lazy check: does this repo already have an open non-blocked PR that we are actually
            # driving (created by us AND containing at least one commit we authored — #1131)?
            # A transient gh failure here (identity lookup or PR list) should skip just this item,
            # not abort the whole cycle and throw away every other priority item (#1085).
            if ! open_pr=$(find_open_nonblocked_pr_for_repo "${item_repo}"); then
                warn "Failed to query open PRs for ${item_repo} — skipping this item for now"
                count_error=$((count_error + 1))
                continue
            fi

            if [ -n "${open_pr}" ]; then
                if [[ ! "${open_pr}" =~ ^[0-9]+$ ]]; then
                    warn "Non-numeric open PR number from GitHub: ${open_pr} — skipping this item"
                    count_error=$((count_error + 1))
                    continue
                fi

                # Before pivoting to the PR workflow, verify the issue is still open and
                # unblocked — a PR can outlive its issue if the issue was closed as not planned.
                # A transient fetch failure here skips just this item rather than the whole
                # run (#1090) — fetch_issue_json already retries before giving up.
                if ! issue_json=$(fetch_issue_json "${item_id}"); then
                    warn "Failed to fetch state for Issue #${item_id} in ${item_repo} — skipping this item for now"
                    count_error=$((count_error + 1))
                    continue
                fi
                issue_state=$(printf '%s' "${issue_json}" | jq -r '.state')
                if [ "${issue_state}" != "OPEN" ]; then
                    # The marker file makes this a one-time tagging per closed issue — without
                    # it, a feed that retains closed issues would re-post the investigation
                    # comment and re-add labels on the PR every tick (#1103). Deliberately keyed
                    # on the Issue, not on the PR's own Blocked label — the PR can be Blocked for
                    # a totally unrelated reason and still need this tagging done for the first
                    # time (#1103 review). Best-effort: only a total tagging failure leaves the
                    # marker unwritten so the check retries.
                    closed_pr_tagged_marker="${SESSION_BASE_DIR}/Issue_${item_id}.closed-pr-tagged"
                    if [ ! -f "${closed_pr_tagged_marker}" ]; then
                        info "Issue #${item_id} in ${item_repo} is no longer open — tagging PR #${open_pr} for investigation and skipping"
                        if tag_pr_closed_issue "${open_pr}" "${item_id}"; then
                            mkdir -p "${SESSION_BASE_DIR}" 2>/dev/null
                            touch "${closed_pr_tagged_marker}" 2>/dev/null \
                                || warn "Failed to write closed-pr-tagged marker for Issue #${item_id} — the check will repeat next tick"
                        else
                            warn "Failed to tag PR #${open_pr} in ${item_repo} for closed Issue #${item_id} — will retry next tick"
                        fi
                    fi
                    count_not_open=$((count_not_open + 1))
                    continue
                fi
                if issue_json_has_blocked_label "${issue_json}"; then
                    info "Issue #${item_id} in ${item_repo} is blocked — skipping"
                    mark_capped_block_for_forgiveness "Issue" "${item_id}"
                    notify_discord_blocked_item "Issue" "${item_id}"
                    count_blocked=$((count_blocked + 1))
                    continue
                fi
                # Issue observed open and un-blocked — re-arm its blocked notifier and, if the
                # Blocked label was applied while already at/over the cap, reset its budget
                # (#1093, #1115).
                clear_blocked_marker "Issue" "${item_id}"
                reset_issue_invocation_counts_if_capped "${item_id}"
                # Issue observed open — re-arm the one-time closed-issue checks so a future
                # reopen/re-close cycle is tagged again (#1134 review round 3, #1103).
                rearm_closed_issue_markers "${item_id}"

                info "Issue #${item_id} in ${item_repo}: found open non-blocked PR #${open_pr} — switching to PR workflow"

                if ! pr_json=$(fetch_pr_json "${open_pr}"); then
                    warn "Failed to fetch state for PR #${open_pr} in ${item_repo} — skipping this item for now"
                    count_error=$((count_error + 1))
                    # The pivot has already confirmed a bot-driven PR exists here — serialize
                    # the repo even though this tick cannot work it (#1134 review round 3).
                    skip_repos+=("${item_repo}")
                    continue
                fi

                pr_state=$(printf '%s' "${pr_json}" | jq -r '.state')
                if [ "${pr_state}" != "OPEN" ]; then
                    info "PR #${open_pr} in ${item_repo} is no longer open — skipping"
                    count_not_open=$((count_not_open + 1))
                    continue
                fi

                if pr_json_has_blocked_label "${pr_json}"; then
                    if try_auto_unblock_env_diagnosed_pr "${open_pr}" "${item_repo}" "${pr_json}"; then
                        count_blocked=$((count_blocked + 1))
                        continue
                    fi
                    info "PR #${open_pr} in ${item_repo} is blocked — skipping (not counting as active work)"
                    mark_capped_block_for_forgiveness "PullRequest" "${open_pr}"
                    notify_discord_blocked_item "PullRequest" "${open_pr}"
                    count_blocked=$((count_blocked + 1))
                    continue
                fi
                # PR observed open and un-blocked — re-arm its blocked notifier and, if the
                # Blocked label was applied while already at/over the cap, reset its budget
                # (#1093, #1115); also clear any environment-auto-unblock history (#1118).
                clear_blocked_marker "PullRequest" "${open_pr}"
                reset_pr_invocation_counts_if_capped "${open_pr}"
                reset_env_unblock_attempts "${open_pr}"

                # PR is confirmed open, non-blocked — mark repo as having active work.
                skip_repos+=("${item_repo}")

                require_trusted_logins || continue
                if ! pr_review_comments=$(fetch_pr_review_comments "${open_pr}"); then
                    warn "Failed to fetch review comments for PR #${open_pr} in ${item_repo} — skipping this item for now"
                    count_error=$((count_error + 1))
                    continue
                fi
                pr_fp=$(fingerprint_pr_json "${pr_json}" "${trusted_logins}" "${pr_review_comments}") \
                    || die "Failed to compute fingerprint for PR #${open_pr} in ${item_repo}"
                saved_fp=$(load_pr_fingerprint "${open_pr}")
                pr_is_draft=$(printf '%s' "${pr_json}" | jq -r '.isDraft // false')

                if [ -n "${saved_fp}" ] && [ "${pr_fp}" = "${saved_fp}" ]; then
                    if pr_json_has_pending_ci_checks "${pr_json}"; then
                        if ci_checks_timed_out "${open_pr}" "${pr_json}"; then
                            block_pr_for_ci_timeout "${open_pr}" "${item_repo}"
                        else
                            info "PR #${open_pr} in ${item_repo}: CI checks pending — deferring"
                        fi
                        count_unchanged=$((count_unchanged + 1))
                        continue
                    fi
                    clear_pr_ci_pending_state "${open_pr}"
                    if [ "${pr_is_draft}" != "true" ]; then
                        # PR unchanged — also check whether the linked issue has new comments.
                        require_trusted_logins || continue
                        issue_fp=$(fingerprint_issue_json "${issue_json}" "${trusted_logins}") \
                            || die "Failed to compute fingerprint for Issue #${item_id} in ${item_repo}"
                        saved_issue_fp=$(load_issue_fingerprint "${item_id}")
                        if [ -n "${saved_issue_fp}" ] && [ "${issue_fp}" = "${saved_issue_fp}" ]; then
                            if pr_should_advance_unchanged "${open_pr}" "${pr_json}"; then
                                info "PR #${open_pr} in ${item_repo} unchanged — re-invoking to advance the next workflow phase"
                                pr_idle_advance=1
                            else
                                if pr_json_has_failed_required_check "${pr_json}"; then
                                    info "PR #${open_pr} in ${item_repo}: idle budget exhausted with a failed required check — blocking"
                                    block_pr_for_idle_exhausted_failure "${open_pr}" "${item_repo}"
                                elif pr_json_has_unaddressed_review_request "${pr_json}"; then
                                    info "PR #${open_pr} in ${item_repo}: idle budget exhausted with an unaddressed review request — blocking"
                                    block_pr_for_idle_exhausted_review "${open_pr}" "${item_repo}"
                                else
                                    info "PR #${open_pr} in ${item_repo} unchanged — skipping repo"
                                fi
                                count_unchanged=$((count_unchanged + 1))
                                continue
                            fi
                        else
                            info "Issue #${item_id} in ${item_repo} changed — re-running against PR #${open_pr}"
                        fi
                    else
                        info "PR #${open_pr} in ${item_repo} unchanged but still in draft — re-running"
                    fi
                fi

                # PR has changed (or issue changed, or still in draft) — work on it.
                original_issue_id="${item_id}"
                item_id="${open_pr}"
                item_type="PullRequest"

            else
                # No active PR — check the issue itself.
                if ! issue_json=$(fetch_issue_json "${item_id}"); then
                    warn "Failed to fetch state for Issue #${item_id} in ${item_repo} — skipping this item for now"
                    count_error=$((count_error + 1))
                    continue
                fi

                issue_state=$(printf '%s' "${issue_json}" | jq -r '.state')
                if [ "${issue_state}" != "OPEN" ]; then
                    # A taken-over PR is invisible to the pivot above, so the closed-issue-
                    # with-open-PR anomaly tagging the pivot performs must also happen here
                    # (#1134).  The marker file makes this a one-time check per closed issue:
                    # without it, a feed that retains closed issues would pay the PR-list and
                    # per-candidate commits fetches every tick AND re-post the investigation
                    # comment on the human's PR every tick (#1134 review).  Best-effort: only a
                    # transient lookup failure leaves the marker unwritten so the check retries.
                    closed_takeover_marker="${SESSION_BASE_DIR}/Issue_${item_id}.closed-takeover-checked"
                    if [ ! -f "${closed_takeover_marker}" ]; then
                        standoff_rc=0
                        standoff_pr=$(find_human_taken_over_pr_for_issue "${item_id}") || standoff_rc=$?
                        if [ "${standoff_rc}" -eq 0 ]; then
                            info "Issue #${item_id} in ${item_repo} is closed but human-driven PR #${standoff_pr} is still open — tagging for investigation"
                            if ! tag_pr_closed_issue "${standoff_pr}" "${item_id}"; then
                                # Nothing landed on the PR (total gh failure) — leave the marker
                                # unwritten so the tagging retries next tick instead of being
                                # silently lost forever (#1134 review round 3).
                                warn "Failed to tag PR #${standoff_pr} in ${item_repo} for closed Issue #${item_id} — will retry next tick"
                                standoff_rc=2
                            fi
                        fi
                        if [ "${standoff_rc}" -ne 2 ]; then
                            mkdir -p "${SESSION_BASE_DIR}" 2>/dev/null
                            touch "${closed_takeover_marker}" 2>/dev/null \
                                || warn "Failed to write closed-takeover marker for Issue #${item_id} — the check will repeat next tick"
                        fi
                    fi
                    info "Issue #${item_id} in ${item_repo} is no longer open — skipping"
                    count_not_open=$((count_not_open + 1))
                    continue
                fi

                if issue_json_has_blocked_label "${issue_json}"; then
                    info "Issue #${item_id} in ${item_repo} is blocked — skipping"
                    mark_capped_block_for_forgiveness "Issue" "${item_id}"
                    notify_discord_blocked_item "Issue" "${item_id}"
                    count_blocked=$((count_blocked + 1))
                    continue
                fi
                # Issue observed open and un-blocked — re-arm its blocked notifier and, if the
                # Blocked label was applied while already at/over the cap, reset its budget
                # (#1093, #1115).
                clear_blocked_marker "Issue" "${item_id}"
                reset_issue_invocation_counts_if_capped "${item_id}"
                # Issue observed open — re-arm the one-time closed-issue checks so a future
                # reopen/re-close cycle is tagged again (#1134 review round 3, #1103).
                rearm_closed_issue_markers "${item_id}"

                # Stand off if this issue is assigned to someone other than us — prevents
                # duplicate work when a human owns the item (#1142).
                if ! resolve_gh_me; then
                    warn "Failed to determine current GitHub user for Issue #${item_id} in ${item_repo} — skipping this item for now"
                    count_error=$((count_error + 1))
                    continue
                fi
                if printf '%s' "${issue_json}" | jq -e --arg me "${_GH_ME}" \
                    '((.assignees // []) | length > 0) and ([(.assignees // [])[].login] | index($me) == null)' \
                    > /dev/null 2>&1; then
                    info "Issue #${item_id} in ${item_repo} is assigned to another user — standing off"
                    count_human_driven=$((count_human_driven + 1))
                    continue
                fi

                require_trusted_logins || continue
                issue_fp=$(fingerprint_issue_json "${issue_json}" "${trusted_logins}") \
                    || die "Failed to compute fingerprint for Issue #${item_id} in ${item_repo}"
                saved_fp=$(load_issue_fingerprint "${item_id}")

                if [ -n "${saved_fp}" ] && [ "${issue_fp}" = "${saved_fp}" ]; then
                    if ! recover_orphaned_branch; then
                        info "Issue #${item_id} in ${item_repo} unchanged — skipping"
                        count_unchanged=$((count_unchanged + 1))
                        continue
                    fi
                    info "Issue #${item_id} in ${item_repo}: fingerprint unchanged but repo was on an orphaned branch — re-running"
                fi

                # A bot-created PR that a human has taken over (zero bot-authored commits) is
                # invisible to the pivot above, which makes this issue look PR-less — but
                # re-working it would open a duplicate branch/PR alongside the human's work.
                # Stand the issue off; other issues in the repo remain workable, so the repo is
                # deliberately NOT added to skip_repos (#1131).  Checked after the fingerprint
                # short-circuit so idle issues do not pay the PR-list and per-candidate commits
                # fetches every tick (#1134).
                standoff_rc=0
                standoff_pr=$(find_human_taken_over_pr_for_issue "${item_id}") || standoff_rc=$?
                if [ "${standoff_rc}" -eq 0 ]; then
                    info "Issue #${item_id} in ${item_repo}: PR #${standoff_pr} is being developed by a human — standing off"
                    count_human_driven=$((count_human_driven + 1))
                    continue
                elif [ "${standoff_rc}" -eq 2 ]; then
                    warn "Failed to check for a human-driven PR for Issue #${item_id} in ${item_repo} — skipping this item for now"
                    count_error=$((count_error + 1))
                    continue
                fi
                # Fall through to work block (item_type remains "Issue").
            fi

        else
            # PullRequest appearing directly in the priorities list.
            if ! pr_json=$(fetch_pr_json "${item_id}"); then
                warn "Failed to fetch state for PR #${item_id} in ${item_repo} — skipping this item for now"
                count_error=$((count_error + 1))
                # An open PR whose state cannot be fetched must still serialize its repo, like
                # every other unknown-status path (#1134 review round 3).
                skip_repos+=("${item_repo}")
                continue
            fi

            pr_state=$(printf '%s' "${pr_json}" | jq -r '.state')
            if [ "${pr_state}" != "OPEN" ]; then
                info "PR #${item_id} in ${item_repo} is no longer open — skipping"
                count_not_open=$((count_not_open + 1))
                continue
            fi

            if pr_json_has_blocked_label "${pr_json}"; then
                if try_auto_unblock_env_diagnosed_pr "${item_id}" "${item_repo}" "${pr_json}"; then
                    count_blocked=$((count_blocked + 1))
                    continue
                fi
                info "PR #${item_id} in ${item_repo} is blocked — skipping (not counting as active work)"
                mark_capped_block_for_forgiveness "PullRequest" "${item_id}"
                notify_discord_blocked_item "PullRequest" "${item_id}"
                count_blocked=$((count_blocked + 1))
                continue
            fi
            # PR observed open and un-blocked — re-arm its blocked notifier and, if the
            # Blocked label was applied while already at/over the cap, reset its budget
            # (#1093, #1115); also clear any environment-auto-unblock history (#1118).
            clear_blocked_marker "PullRequest" "${item_id}"
            reset_pr_invocation_counts_if_capped "${item_id}"
            reset_env_unblock_attempts "${item_id}"

            # An open non-blocked PR whose status cannot be determined must still serialize its
            # repo (#1134) — a transient failure here must not let a lower-priority issue start
            # concurrent work alongside this PR.
            if ! require_trusted_logins; then
                skip_repos+=("${item_repo}")
                continue
            fi

            # Stand off PRs a human is driving (zero bot-authored commits on a bot-created or
            # trusted-human-committed PR) — the human's session owns the branch.  Dependency PRs
            # are exempt inside pr_is_human_driven and keep flowing to the takeover prompt.  The
            # repo is deliberately NOT marked active, so its other issues stay workable (#1131).
            human_driven_rc=0
            pr_is_human_driven "${pr_json}" "${trusted_logins}" || human_driven_rc=$?
            if [ "${human_driven_rc}" -eq 0 ]; then
                info "PR #${item_id} in ${item_repo} is being developed by a human — standing off"
                count_human_driven=$((count_human_driven + 1))
                continue
            elif [ "${human_driven_rc}" -eq 2 ]; then
                warn "Failed to determine commit authorship for PR #${item_id} in ${item_repo} — skipping this item for now"
                count_error=$((count_error + 1))
                skip_repos+=("${item_repo}")
                continue
            fi

            # Stand off if this PR is assigned to someone other than us — prevents
            # duplicate work when a human owns the item (#1142).  _GH_ME was resolved
            # above by pr_is_human_driven; resolve_gh_me is a no-op if already set.
            # Dependency PRs are exempt here too, for the same reason pr_is_human_driven
            # exempts them above: dependabot.yml-style `assignees:` config (or a human
            # self-assigning to review) must not permanently block the CI-verify/auto-merge
            # takeover prompt (observed on funfair-server-ethereum#1028).
            if ! resolve_gh_me; then
                warn "Failed to determine current GitHub user for PR #${item_id} in ${item_repo} — skipping this item for now"
                count_error=$((count_error + 1))
                skip_repos+=("${item_repo}")
                continue
            fi
            if ! pr_has_depends_branch "${pr_json}" && ! pr_has_dependency_label "${pr_json}"; then
                if printf '%s' "${pr_json}" | jq -e --arg me "${_GH_ME}" \
                    '((.assignees // []) | length > 0) and ([(.assignees // [])[].login] | index($me) == null)' \
                    > /dev/null 2>&1; then
                    info "PR #${item_id} in ${item_repo} is assigned to another user — standing off"
                    count_human_driven=$((count_human_driven + 1))
                    continue
                fi
            fi

            # Non-blocked, open PR = active work for this repo.
            skip_repos+=("${item_repo}")

            if ! pr_review_comments=$(fetch_pr_review_comments "${item_id}"); then
                warn "Failed to fetch review comments for PR #${item_id} in ${item_repo} — skipping this item for now"
                count_error=$((count_error + 1))
                continue
            fi
            pr_fp=$(fingerprint_pr_json "${pr_json}" "${trusted_logins}" "${pr_review_comments}") \
                || die "Failed to compute fingerprint for PR #${item_id} in ${item_repo}"
            saved_fp=$(load_pr_fingerprint "${item_id}")
            pr_is_draft=$(printf '%s' "${pr_json}" | jq -r '.isDraft // false')

            if [ -n "${saved_fp}" ] && [ "${pr_fp}" = "${saved_fp}" ]; then
                if pr_json_has_pending_ci_checks "${pr_json}"; then
                    if ci_checks_timed_out "${item_id}" "${pr_json}"; then
                        block_pr_for_ci_timeout "${item_id}" "${item_repo}"
                    else
                        info "PR #${item_id} in ${item_repo}: CI checks pending — deferring"
                    fi
                    count_unchanged=$((count_unchanged + 1))
                    continue
                fi
                clear_pr_ci_pending_state "${item_id}"
                pr_merge_state=$(printf '%s' "${pr_json}" | jq -r '.mergeStateStatus // "UNKNOWN"')
                if [ "${pr_is_draft}" = "true" ]; then
                    info "PR #${item_id} in ${item_repo} unchanged but still in draft — re-running"
                elif [ "${pr_merge_state}" = "BEHIND" ] || [ "${pr_merge_state}" = "DIRTY" ]; then
                    info "PR #${item_id} in ${item_repo} unchanged but ${pr_merge_state} — re-running"
                elif pr_should_advance_unchanged "${item_id}" "${pr_json}"; then
                    info "PR #${item_id} in ${item_repo} unchanged — re-invoking to advance the next workflow phase"
                    pr_idle_advance=1
                else
                    if pr_json_has_failed_required_check "${pr_json}"; then
                        info "PR #${item_id} in ${item_repo}: idle budget exhausted with a failed required check — blocking"
                        block_pr_for_idle_exhausted_failure "${item_id}" "${item_repo}"
                    elif pr_json_has_unaddressed_review_request "${pr_json}"; then
                        info "PR #${item_id} in ${item_repo}: idle budget exhausted with an unaddressed review request — blocking"
                        block_pr_for_idle_exhausted_review "${item_id}" "${item_repo}"
                    else
                        info "PR #${item_id} in ${item_repo} unchanged — skipping"
                    fi
                    count_unchanged=$((count_unchanged + 1))
                    continue
                fi
            fi
            # Fall through to work block (item_type remains "PullRequest").
        fi

        # ---- Work block: item_type and item_id are resolved ----
        info "Found actionable ${item_type} #${item_id} in ${item_repo} — preparing..."

        merge_state=""
        branch_name=""
        DIRTY_BRANCH=""
        if [ "${item_type}" = "PullRequest" ]; then
            merge_state=$(printf '%s' "${pr_json}" | jq -r '.mergeStateStatus // "UNKNOWN"')
            branch_name=$(printf '%s' "${pr_json}" | jq -r '.headRefName // empty')

            if pr_json_has_pending_ci_checks "${pr_json}"; then
                if ci_checks_timed_out "${item_id}" "${pr_json}"; then
                    block_pr_for_ci_timeout "${item_id}" "${item_repo}"
                else
                    info "PR #${item_id} in ${item_repo}: CI checks pending — deferring agent invocation"
                    save_pr_fingerprint "${item_id}" "${pr_fp}"
                fi
                continue
            fi
            clear_pr_ci_pending_state "${item_id}"
            sync_pr_labels_from_linked_issues "${item_id}" "${pr_json}"
        fi

        ensure_repo_current
        ensure_repo_current_status=$?
        if [ "${ensure_repo_current_status}" -eq 2 ]; then
            count_error=$((count_error + 1))
            continue
        elif [ "${ensure_repo_current_status}" -ne 0 ]; then
            info "Repo not clean for ${item_repo} — handing off to agent to recover"
        elif [ "${item_type}" = "PullRequest" ]; then
            if [ "${merge_state}" = "BEHIND" ] || [ "${merge_state}" = "DIRTY" ]; then
                if try_nonagentic_rebase "${branch_name}"; then
                    info "PR #${item_id} in ${item_repo} rebased non-agentically — updating fingerprint"
                    # The rebase itself already succeeded and was force-pushed — that work is
                    # durable in GitHub regardless of what happens next. A transient gh blip here
                    # should not fail the whole run (#1090): worst case of skipping the
                    # fingerprint update is one redundant re-evaluation on the next tick, once
                    # fetch_pr_json's own retries (see #1090) are also exhausted.
                    if post_fp=$(compute_pr_fingerprint "${item_id}"); then
                        save_pr_fingerprint "${item_id}" "${post_fp}"
                    else
                        warn "Failed to compute post-rebase fingerprint for PR #${item_id} in ${item_repo} — will re-evaluate next tick"
                        count_error=$((count_error + 1))
                    fi
                    # A free non-agentic rebase must not block other same-repo Issues from
                    # being picked up in the same tick (#1114).
                    _filtered_repos=()
                    for skip_repo in "${skip_repos[@]+"${skip_repos[@]}"}"; do
                        if [ "${skip_repo}" != "${item_repo}" ]; then
                            _filtered_repos+=("${skip_repo}")
                        fi
                    done
                    skip_repos=("${_filtered_repos[@]+"${_filtered_repos[@]}"}")
                    continue
                fi
                info "Non-agentic rebase of PR #${item_id} in ${item_repo} had conflicts — handing off to agent"
            fi
        fi

        if is_owner_rate_limited; then
            if [ -z "${reported_rate_limited["${OWNER}"]:-}" ]; then
                info "Owner ${OWNER} is rate-limited — skipping all actionable items"
                reported_rate_limited["${OWNER}"]=1
            fi
            continue
        fi

        ensure_rules_current

        if ! ai_instructions=$(find_ai_instructions); then
            local no_ai_instructions_reason="No .ai-instructions file was found for this repository (checked both the repo checkout and the rules clone), so the automation cannot determine what rules to follow. Blocking until this is resolved."
            warn "Skipping ${item_type} #${item_id} in ${item_repo}: no .ai-instructions found — marking as blocked"
            apply_blocked_label_with_reason "${item_type}" "${item_id}" "${item_repo}" "${no_ai_instructions_reason}"
            continue
        fi

        # Moved ahead of notify_discord_work_item (was originally right before build_issue_prompt/
        # build_pr_prompt below) so _WF_PROJECT_ID is populated before ANY Discord notification
        # for this item fires this tick — otherwise board_substatus_for_item would always report
        # "Unknown" for the very first item touched per repo (#1136). Idempotent/cached, so
        # nothing downstream that still expects it at its old position is affected.
        discover_or_create_workflow_project
        [ -n "${_WF_CREATION_FAILED}" ] && report_missing_workflow_project

        local item_labels_json
        if [ "${item_type}" = "Issue" ]; then
            item_title=$(printf '%s' "${issue_json}" | jq -r '.title // empty')
            item_labels_json=$(printf '%s' "${issue_json}" | jq -c '.labels // []')
        else
            item_title=$(printf '%s' "${pr_json}" | jq -r '.title // empty')
            item_labels_json=$(printf '%s' "${pr_json}" | jq -c '.labels // []')
        fi

        # Every run is a fresh single-phase session (no resume): the agent re-derives its
        # context from GitHub, does one workflow phase, and stops.  The orchestrator re-invokes
        # on later ticks to advance through the remaining phases.
        info "Starting fresh single-phase session for ${item_type} #${item_id} in ${item_repo}"
        notify_discord_work_item "start" "${item_type}" "${item_id}" "${item_title}" "${item_labels_json}"

        # Runaway backstop (PRs): cap the total number of agent invocations spent on one PR so a
        # non-converging PR cannot loop forever.  Absence of the guard file also tells us this is
        # the first time we have ever worked this PR (used to initialise the board below) — OR
        # that every past attempt was a pre-flight/infra failure (#1133 review): those never
        # write the invocation-count guard file, so the infra-failure guard file is also checked
        # here to avoid re-declaring "first touch" (and re-resetting the board to "Not Started")
        # on every single retry of a persistently failing container.
        local pr_first_touch="false"
        if [ "${item_type}" = "PullRequest" ]; then
            if [ ! -f "$(pr_invocation_guard_file_path "${item_id}")" ] \
                && [ ! -f "$(infra_failure_guard_file_path "PullRequest" "${item_id}")" ]; then
                pr_first_touch="true"
            fi
            load_pr_invocation_counts "${item_id}"
            if [ "${PR_INVOCATION_TOTAL}" -ge "${MAX_PR_TOTAL_INVOCATIONS}" ]; then
                local pr_runaway_reason="This PR has been worked ${PR_INVOCATION_TOTAL} times by the automation without reaching a mergeable state. Blocking for a human to investigate."
                warn "PR #${item_id} in ${item_repo} used ${PR_INVOCATION_TOTAL} agent invocations without converging — marking Blocked"
                if apply_blocked_label_with_reason "PullRequest" "${item_id}" "${item_repo}" "${pr_runaway_reason}"; then
                    mkdir -p "${SESSION_BASE_DIR}" 2>/dev/null
                    if ! touch "$(runaway_blocked_marker_file_path "PullRequest" "${item_id}")" 2>/dev/null; then
                        warn "Failed to write runaway-blocked marker for PR #${item_id} in ${item_repo} — invocation budget will not auto-reset once a human clears the Blocked label"
                    fi
                fi
                count_blocked=$((count_blocked + 1))
                continue
            fi
        elif [ "${item_type}" = "Issue" ]; then
            # Runaway backstop (Issues): same idea as the PR backstop above, for the
            # Issue-stays-Issue path (an Issue with no active PR that keeps being worked without
            # ever producing one). Once a PR exists the item pivots to "PullRequest" above and
            # the PR backstop takes over (#1093).
            load_issue_invocation_counts "${item_id}"
            if [ "${ISSUE_INVOCATION_TOTAL}" -ge "${MAX_ISSUE_TOTAL_INVOCATIONS}" ]; then
                local issue_runaway_reason="This issue has been worked ${ISSUE_INVOCATION_TOTAL} times by the automation without producing a mergeable pull request. Blocking for a human to investigate."
                warn "Issue #${item_id} in ${item_repo} used ${ISSUE_INVOCATION_TOTAL} agent invocations without converging — marking Blocked"
                if apply_blocked_label_with_reason "Issue" "${item_id}" "${item_repo}" "${issue_runaway_reason}"; then
                    mkdir -p "${SESSION_BASE_DIR}" 2>/dev/null
                    if ! touch "$(runaway_blocked_marker_file_path "Issue" "${item_id}")" 2>/dev/null; then
                        warn "Failed to write runaway-blocked marker for Issue #${item_id} in ${item_repo} — invocation budget will not auto-reset once a human clears the Blocked label"
                    fi
                fi
                count_blocked=$((count_blocked + 1))
                continue
            fi
        fi

        container_ai_instructions=$(host_to_container_path "${ai_instructions}")

        # discover_or_create_workflow_project already ran earlier this iteration (moved ahead
        # of notify_discord_work_item, #1136) — no need to call it again here.

        require_trusted_logins || continue
        if [ "${item_type}" = "Issue" ]; then
            fetch_board_approved_items
            local plan_approved="false"
            [ "${_WF_APPROVED_ITEMS["${item_repo}/${item_id}"]:-}" = "1" ] && plan_approved="true"
            prompt=$(build_issue_prompt "${item_id}" "${container_ai_instructions}" "${CONTAINER_REPO_PATH}")
            claude_md_content=$(build_issue_claude_md "${item_id}" "${container_ai_instructions}" "${CONTAINER_REPO_PATH}" "${plan_approved}" "${trusted_logins}" "${DIRTY_BRANCH}")
        else
            local is_dependency_pr
            is_dependency_pr=$(printf '%s' "${pr_json}" | jq -r '[.labels[].name] | contains(["dependencies"])')
            prompt=$(build_pr_prompt "${item_id}" "${container_ai_instructions}" "${merge_state}" "${branch_name}" "${CONTAINER_REPO_PATH}")
            claude_md_content=$(build_pr_claude_md "${item_id}" "${container_ai_instructions}" "${merge_state}" "${branch_name}" "${CONTAINER_REPO_PATH}" "${DIRTY_BRANCH}" "${is_dependency_pr}" "${trusted_logins}")
        fi

        [ -n "${prompt}" ] || die "prompt is empty for ${item_type} #${item_id} in ${item_repo}"

        # Initialise the board to "Not Started" only on the first-ever touch of the item, so
        # re-invocations never clobber a phase the agent has already advanced the board to. This
        # must happen BEFORE invoke_claude — the agent's own session can move the board forward
        # during this very invocation, and setting it afterwards would clobber that.
        if [ "${item_type}" = "PullRequest" ]; then
            [ "${pr_first_touch}" = "true" ] && update_workflow_status "${item_type}" "${item_id}" "Not Started"
        elif [ "${item_type}" = "Issue" ]; then
            if [ -z "$(load_issue_fingerprint "${item_id}")" ] \
                && [ ! -f "$(infra_failure_guard_file_path "Issue" "${item_id}")" ]; then
                update_workflow_status "${item_type}" "${item_id}" "Not Started"
            fi
        fi

        invoke_claude "${prompt}" "${item_type}" "${item_id}" "${claude_md_content}"
        invoke_claude_exit=$?
        git -C "${REPO_WORK_DIR}" clean -fdX

        if [ "${invoke_claude_exit}" -eq 2 ]; then
            # Container failed before Claude ever ran (e.g. an entrypoint.sh pre-flight check —
            # #1133). Nothing agentic happened, so this attempt must not count against the
            # item's normal invocation budget — but it must still escalate on repeated
            # occurrence, tracked via a SEPARATE consecutive-failure counter, or a persistently
            # broken container would retry silently forever with no human ever notified (#1133
            # review) — the die()-kills-the-whole-run behaviour this replaced was accidentally
            # the only thing providing that signal.
            load_infra_failure_count "${item_type}" "${item_id}"
            local new_infra_failures=$(( INFRA_FAILURE_COUNT + 1 ))
            save_infra_failure_count "${item_type}" "${item_id}" "${new_infra_failures}"
            if [ "${new_infra_failures}" -ge "${MAX_CONSECUTIVE_INFRA_FAILURES}" ]; then
                local infra_block_reason="This item's agent container has failed ${new_infra_failures} times in a row before Claude could even start (a pre-flight/infra failure, not a Claude-level one — e.g. a workspace-trust or environment check in entrypoint.sh). Blocking for a human to investigate the container/image rather than retrying forever."
                warn "${item_type} #${item_id} in ${item_repo}: agent container failed ${new_infra_failures} times in a row before Claude could even start — marking Blocked"
                apply_blocked_label_with_reason "${item_type}" "${item_id}" "${item_repo}" "${infra_block_reason}"
                count_blocked=$((count_blocked + 1))
                continue
            fi
            warn "${item_type} #${item_id} in ${item_repo}: agent container failed before Claude started (pre-flight/infra failure, ${new_infra_failures}/${MAX_CONSECUTIVE_INFRA_FAILURES}) — not counted against the invocation budget"
            count_error=$((count_error + 1))
            continue
        fi
        # No other invoke_claude_exit value is reachable here: invoke_claude either dies
        # internally on any real failure (terminating the whole process) or falls through to a
        # normal return (0) — see invoke_claude's own header comment (#1103).

        # Record this invocation against the budget now that Claude has actually run a session
        # (a pre-flight/infra failure above never reaches here — #1133): always bump the total;
        # for PRs, bump the idle counter only when this run is a no-external-change phase
        # advance, and reset it to 0 otherwise (a push, a new comment, or CI change is real
        # progress). A real session running — regardless of how it ends — also clears the
        # consecutive-infra-failure streak: the container is demonstrably working again.
        clear_infra_failure_count "${item_type}" "${item_id}"
        if [ "${item_type}" = "PullRequest" ]; then
            local pr_new_idle=0
            [ "${pr_idle_advance}" = "1" ] && pr_new_idle=$(( PR_INVOCATION_IDLE + 1 ))
            save_pr_invocation_counts "${item_id}" "$(( PR_INVOCATION_TOTAL + 1 ))" "${pr_new_idle}"
        elif [ "${item_type}" = "Issue" ]; then
            save_issue_invocation_counts "${item_id}" "$(( ISSUE_INVOCATION_TOTAL + 1 ))"
        fi

        success "Completed one workflow phase for ${item_type} #${item_id} in ${item_repo}"

        # The agent's work (commits, comments, board moves) is already durable in GitHub at this
        # point — a transient gh failure computing the post-run fingerprint must not fail the run
        # (#1091): the fingerprint would be missing, the same phase would be re-invoked next tick
        # (potentially duplicating agent actions), and PR_INVOCATION_TOTAL — already incremented
        # above — would be charged twice for one phase of real work. Both fingerprints (PR + its
        # linked issue, when pivoting) are computed FIRST and only saved once BOTH succeed, so a
        # failure on one side never leaves the pair half-written (which would itself guarantee a
        # spurious re-invocation via the "PR unchanged, issue changed" branch next tick).
        if [ "${item_type}" = "PullRequest" ]; then
            post_pr_fp_ok=1
            post_issue_fp_ok=1
            post_issue_fp=""
            post_fp=$(compute_pr_fingerprint "${item_id}") && post_pr_fp_ok=0
            if [ -n "${original_issue_id}" ]; then
                post_issue_fp=$(compute_issue_fingerprint "${original_issue_id}") && post_issue_fp_ok=0
            else
                post_issue_fp_ok=0
            fi
            if [ "${post_pr_fp_ok}" -eq 0 ] && [ "${post_issue_fp_ok}" -eq 0 ]; then
                save_pr_fingerprint "${item_id}" "${post_fp}"
                [ -n "${original_issue_id}" ] && save_issue_fingerprint "${original_issue_id}" "${post_issue_fp}"
            else
                warn "Failed to compute post-run fingerprint(s) for ${item_type} #${item_id} in ${item_repo} — skipping save, will re-evaluate next tick"
            fi
        elif [ "${item_type}" = "Issue" ]; then
            if post_fp=$(compute_issue_fingerprint "${item_id}"); then
                save_issue_fingerprint "${item_id}" "${post_fp}"
            else
                warn "Failed to compute post-run fingerprint for Issue #${item_id} in ${item_repo} — skipping save, will re-evaluate next tick"
            fi
        fi

        exit 0
    done

    notify_discord_no_work "${owner_filter}" "${count_blocked}" "${count_unchanged}" "${count_active_repo}" "${count_not_open}" "${count_error}" "${count_human_driven}"
    success "No actionable work items found across all priorities (blocked: ${count_blocked}, unchanged: ${count_unchanged}, repo-active: ${count_active_repo}, not-open: ${count_not_open}, errors: ${count_error}, human-driven: ${count_human_driven})"
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
