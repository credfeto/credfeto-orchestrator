# Reads DISCORD_WEBHOOK, GH_TOKEN, GH_HOST, GIT_USER_NAME, GIT_USER_EMAIL, and
# GIT_SIGNING_KEY from orchestrator/.env.
# Sets DISCORD_WEBHOOK_URL; exports GH_HOST and GH_ENTERPRISE_TOKEN when both are
# present so host-side gh CLI calls use the same proxy as the agent container.
# GIT_USER_NAME, GIT_USER_EMAIL, and GIT_SIGNING_KEY are used by build_minimal_gitconfig.
# Silent when the file is absent or a key is missing.
load_env_config() {
    DISCORD_WEBHOOK_URL=""
    GIT_USER_NAME=""
    GIT_USER_EMAIL=""
    GIT_SIGNING_KEY=""
    WHITELISTED_USERS=""
    local env_file="${XDG_CONFIG_HOME:-${HOME}/.config}/orchestrator/.env"
    [ -f "${env_file}" ] || return 0
    local line val gh_token="" gh_host=""
    while IFS= read -r line || [ -n "${line}" ]; do
        case "${line}" in
            DISCORD_WEBHOOK=*|GH_TOKEN=*|GH_HOST=*|GIT_USER_NAME=*|GIT_USER_EMAIL=*|GIT_SIGNING_KEY=*|WHITELISTED_USERS=*|CI_CHECK_TIMEOUT_MINUTES=*)
                val="${line#*=}"
                val="${val%$'\r'}"
                case "${val}" in
                    '"'*'"') val="${val#?}"; val="${val%?}" ;;
                    "'"*"'") val="${val#?}"; val="${val%?}" ;;
                esac
                case "${line}" in
                    DISCORD_WEBHOOK=*)          DISCORD_WEBHOOK_URL="${val}" ;;
                    GH_TOKEN=*)                 gh_token="${val}" ;;
                    GH_HOST=*)                  gh_host="${val}" ;;
                    GIT_USER_NAME=*)            GIT_USER_NAME="${val}" ;;
                    GIT_USER_EMAIL=*)           GIT_USER_EMAIL="${val}" ;;
                    GIT_SIGNING_KEY=*)          GIT_SIGNING_KEY="${val}" ;;
                    WHITELISTED_USERS=*)        WHITELISTED_USERS="${val}" ;;
                    CI_CHECK_TIMEOUT_MINUTES=*) if [[ "${val}" =~ ^[1-9][0-9]*$ ]]; then CI_CHECK_TIMEOUT_MINUTES="${val}"; else warn "CI_CHECK_TIMEOUT_MINUTES must be a positive integer; ignoring '${val}'"; fi ;;
                esac
                ;;
        esac
    done < "${env_file}"
    if [ -n "${gh_host}" ] && [ -n "${gh_token}" ]; then
        export GH_HOST="${gh_host}"
        export GH_ENTERPRISE_TOKEN="${gh_token}"
    fi
}

# Validates that all required config files exist and are populated correctly.
# Collects all errors and dies once at the end so every problem is visible at once.
# Must be called after load_env_config so GIT_* variables are already populated.
validate_config() {
    local owner_filter="$1"
    local config_dir="${XDG_CONFIG_HOME:-${HOME}/.config}"
    local errors=0

    if [ ! -f "${config_dir}/orchestrator/.env" ]; then
        printf '\n✗ %s\n' "${config_dir}/orchestrator/.env is missing" >&2
        printf '  Create it with: GIT_USER_NAME, GIT_USER_EMAIL, GIT_SIGNING_KEY, DISCORD_WEBHOOK\n' >&2
        errors=$((errors + 1))
    else
        [ -n "${GIT_USER_NAME}" ] || {
            printf '\n✗ %s\n' "GIT_USER_NAME is not set in ${config_dir}/orchestrator/.env" >&2
            errors=$((errors + 1))
        }
        [ -n "${GIT_USER_EMAIL}" ] || {
            printf '\n✗ %s\n' "GIT_USER_EMAIL is not set in ${config_dir}/orchestrator/.env" >&2
            errors=$((errors + 1))
        }
        [ -n "${GIT_SIGNING_KEY}" ] || {
            printf '\n✗ %s\n' "GIT_SIGNING_KEY is not set in ${config_dir}/orchestrator/.env" >&2
            errors=$((errors + 1))
        }
    fi

    # gh needs either the local credential store or a proxy token from .env.
    if [ -z "${GH_HOST:-}" ] || [ -z "${GH_ENTERPRISE_TOKEN:-}" ]; then
        if [ ! -f "${config_dir}/gh/hosts.yml" ]; then
            printf '\n✗ %s\n' "${config_dir}/gh/hosts.yml is missing — run 'gh auth login' first" >&2
            errors=$((errors + 1))
        fi
    fi

    if [ -n "${owner_filter}" ]; then
        local token_file="${config_dir}/orchestrator/tokens/${owner_filter}"
        if [ ! -f "${token_file}" ]; then
            printf '\n✗ %s\n' "${token_file} is missing — create it with the Claude OAuth token (chmod 600)" >&2
            errors=$((errors + 1))
        else
            local perms
            perms=$(stat -c '%a' "${token_file}" 2>/dev/null)
            case "${perms}" in
                600|400) ;;
                *) printf '\n✗ %s\n' "${token_file} has permissions ${perms} — must be 600 (run: chmod 600 ${token_file})" >&2
                   errors=$((errors + 1)) ;;
            esac
        fi
    fi

    [ "${errors}" -eq 0 ] || die "Config validation failed — fix the above and re-run"
}

# Sends a Discord embed notification when starting or resuming work on an item.
# Arguments: msg_type (start|resume), item_type, item_id, item_title
# Silent when DISCORD_WEBHOOK_URL is unset; logs a warning on curl failure.
notify_discord_work_item() {
    [ -n "${DISCORD_WEBHOOK_URL}" ] || return 0
    local msg_type="$1" item_type="$2" item_id="$3" item_title="$4"
    local url color status_label payload

    case "${msg_type}" in
        start|resume) ;;
        *) warn "Discord: unknown notification type '${msg_type}'"; return 0 ;;
    esac

    case "${item_type}" in
        Issue)       url="https://github.com/${REPO_FULL}/issues/${item_id}" ;;
        PullRequest) url="https://github.com/${REPO_FULL}/pull/${item_id}" ;;
        *)           url="https://github.com/${REPO_FULL}" ;;
    esac

    if [ "${msg_type}" = "start" ]; then
        color=3066993    # green  (#2ECC71)
        status_label="New"
    else
        color=15844367   # gold   (#F1C40F)
        status_label="Resume"
    fi

    payload=$(jq --null-input \
        --argjson color "${color}" \
        --arg title "${item_title}" \
        --arg url "${url}" \
        --arg repo "${REPO_FULL}" \
        --arg type "${item_type}" \
        --arg status "${status_label}" \
        '{embeds:[{title:$title,url:$url,color:$color,fields:[
            {name:"Repository",value:$repo,inline:true},
            {name:"Type",value:$type,inline:true},
            {name:"Status",value:$status,inline:true}
        ]}]}') \
        || { warn "Discord: failed to build payload for ${item_type} #${item_id}"; return 0; }

    curl --silent --fail --max-time 5 \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        "${DISCORD_WEBHOOK_URL}" > /dev/null 2>&1 \
        || warn "Discord webhook notification failed"
}

# Sends a Discord notification when no actionable work items are found.
# Arguments: owner (optional), count_blocked, count_unchanged, count_active_repo, count_not_open
# Silent when DISCORD_WEBHOOK_URL is unset; logs a warning on curl failure.
# Suppresses duplicate messages: if the same message was sent within the last hour, it is
# silently dropped.  A changed message is always sent immediately.  At most one send per hour
# per owner even when the message is identical.
notify_discord_no_work() {
    [ -n "${DISCORD_WEBHOOK_URL}" ] || return 0
    local owner="${1:-}"
    local count_blocked="${2:-0}"
    local count_unchanged="${3:-0}"
    local count_active_repo="${4:-0}"
    local count_not_open="${5:-0}"
    local prefix message detail payload
    if [ -n "${owner}" ]; then
        prefix="[${owner}] "
    else
        prefix=""
    fi
    message="${prefix}No actionable work items found."
    detail=""
    [ "${count_blocked}" -gt 0 ]     && detail="${detail:+${detail}, }blocked: ${count_blocked}"
    [ "${count_unchanged}" -gt 0 ]   && detail="${detail:+${detail}, }unchanged: ${count_unchanged}"
    [ "${count_active_repo}" -gt 0 ] && detail="${detail:+${detail}, }repo-active: ${count_active_repo}"
    [ "${count_not_open}" -gt 0 ]    && detail="${detail:+${detail}, }not-open: ${count_not_open}"
    [ -n "${detail}" ] && message="${message} (${detail})"

    # Dedup: suppress if the same message was sent within the last hour.
    local owner_slug state_file now last_message last_sent elapsed
    owner_slug="${owner:-_global}"
    owner_slug="${owner_slug//\//_}"
    state_file="${HOME}/.orchestrator/.no_work_${owner_slug}.state"
    now=$(date +%s)
    if [ -f "${state_file}" ]; then
        last_message=$(sed -n '1p' "${state_file}" 2>/dev/null || true)
        last_sent=$(sed -n '2p' "${state_file}" 2>/dev/null || true)
        if [ "${last_message}" = "${message}" ] && \
           printf '%s' "${last_sent}" | grep -qE '^[0-9]+$'; then
            elapsed=$(( now - last_sent ))
            [ "${elapsed}" -lt 3600 ] && return 0
        fi
    fi

    payload=$(jq --null-input --arg msg "${message}" '{"content":$msg}') \
        || { warn "Discord: failed to build no-work payload"; return 0; }
    curl --silent --fail --max-time 5 \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        "${DISCORD_WEBHOOK_URL}" > /dev/null 2>&1 \
        || warn "Discord webhook notification failed"

    mkdir -p "${HOME}/.orchestrator" 2>/dev/null || true
    printf '%s\n%s\n' "${message}" "${now}" > "${state_file}"
}

# Outputs available disk space in kilobytes for the filesystem containing WORK (or HOME).
# Outputs nothing when df output cannot be parsed.
disk_space_available_kb() {
    local check_path="${WORK:-${HOME}}"
    [ -d "${check_path}" ] || check_path="${HOME}"
    df -k "${check_path}" 2>/dev/null | awk 'NR==2{print $4}'
}

# Returns 0 when sufficient disk space is available (>= MIN_DISK_SPACE_KB).
# Returns 1 when space is below the threshold.
# Warns and returns 0 when available space cannot be determined.
check_disk_space() {
    local available_kb
    available_kb=$(disk_space_available_kb)
    if ! [[ "${available_kb}" =~ ^[0-9]+$ ]]; then
        warn "Could not determine available disk space — proceeding"
        return 0
    fi
    [ "${available_kb}" -ge "${MIN_DISK_SPACE_KB}" ]
}

# Sends a Discord embed notification when disk space is below MIN_DISK_SPACE_KB.
# Deduplicates: at most one notification per hour per owner.
# Silent when DISCORD_WEBHOOK_URL is unset; logs a warning on curl failure.
notify_discord_low_disk_space() {
    [ -n "${DISCORD_WEBHOOK_URL}" ] || return 0
    local owner="${1:-}"

    local available_kb available_gb threshold_gb
    available_kb=$(disk_space_available_kb)
    available_gb=$(( ${available_kb:-0} / 1024 / 1024 ))
    threshold_gb=$(( MIN_DISK_SPACE_KB / 1024 / 1024 ))

    local owner_slug state_file now last_sent elapsed
    owner_slug="${owner:-_global}"
    owner_slug="${owner_slug//\//_}"
    state_file="${HOME}/.orchestrator/.low_disk_space_${owner_slug}.state"
    now=$(date +%s)
    if [ -f "${state_file}" ]; then
        last_sent=$(cat "${state_file}" 2>/dev/null || printf '0')
        if printf '%s' "${last_sent}" | grep -qE '^[0-9]+$'; then
            elapsed=$(( now - last_sent ))
            [ "${elapsed}" -lt 3600 ] && return 0
        fi
    fi

    local payload
    payload=$(jq --null-input \
        --argjson color 15158332 \
        --arg title "Low Disk Space${owner:+ [${owner}]}" \
        --argjson available_gb "${available_gb}" \
        --argjson threshold_gb "${threshold_gb}" \
        '{embeds:[{title:$title,color:$color,fields:[
            {name:"Available",value:("\($available_gb) GB"),inline:true},
            {name:"Minimum Required",value:("\($threshold_gb) GB"),inline:true}
        ]}]}') \
        || { warn "Discord: failed to build low disk space payload"; return 0; }

    curl --silent --fail --max-time 5 \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        "${DISCORD_WEBHOOK_URL}" > /dev/null 2>&1 \
        || warn "Discord webhook notification failed"

    mkdir -p "${HOME}/.orchestrator" 2>/dev/null || true
    printf '%s\n' "${now}" > "${state_file}"
}

# Returns the path to the per-item blocked-notification marker file.
# The marker records that a blocked notification has already been sent for this
# item so subsequent runs stay silent until the item is observed un-blocked.
blocked_marker_file_path() {
    local item_type="$1" item_id="$2"
    printf '%s/%s_%s.blocked' "${SESSION_BASE_DIR}" "${item_type}" "${item_id}"
}

# Clears the blocked-notification marker for an item, re-arming the notifier so a
# future transition back into the blocked state notifies again. Call on any path
# where the item is observed open and not carrying the Blocked label.
clear_blocked_marker() {
    local item_type="$1" item_id="$2"
    rm -f "$(blocked_marker_file_path "${item_type}" "${item_id}")" 2>/dev/null || true
}

# Sends a Discord embed notification when an item is found to be blocked.
# Arguments: item_type (Issue|PullRequest), item_id
# Notifies only on the transition into the blocked state: a per-item marker file
# suppresses repeat notifications while the item stays blocked. clear_blocked_marker
# re-arms it once the item is observed un-blocked.
# Silent when DISCORD_WEBHOOK_URL is unset; logs a warning on curl failure.
notify_discord_blocked_item() {
    [ -n "${DISCORD_WEBHOOK_URL}" ] || return 0
    local item_type="$1" item_id="$2"
    local url payload marker_file

    marker_file=$(blocked_marker_file_path "${item_type}" "${item_id}")
    # Already notified for this blocked spell — stay silent until re-armed.
    [ -f "${marker_file}" ] && return 0

    case "${item_type}" in
        Issue)       url="https://github.com/${REPO_FULL}/issues/${item_id}" ;;
        PullRequest) url="https://github.com/${REPO_FULL}/pull/${item_id}" ;;
        *)           url="https://github.com/${REPO_FULL}" ;;
    esac

    payload=$(jq --null-input \
        --argjson color 15158332 \
        --arg title "Blocked: ${item_type} #${item_id}" \
        --arg url "${url}" \
        --arg repo "${REPO_FULL}" \
        --arg type "${item_type}" \
        '{embeds:[{title:$title,url:$url,color:$color,fields:[
            {name:"Repository",value:$repo,inline:true},
            {name:"Type",value:$type,inline:true}
        ]}]}') \
        || { warn "Discord: failed to build blocked payload for ${item_type} #${item_id}"; return 0; }

    curl --silent --fail --max-time 5 \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        "${DISCORD_WEBHOOK_URL}" > /dev/null 2>&1 \
        || warn "Discord webhook notification failed"

    # Record that this blocked spell has been notified, so the next run is silent.
    mkdir -p "${SESSION_BASE_DIR}" 2>/dev/null || true
    printf '%s\n' "blocked" > "${marker_file}" 2>/dev/null || true
}

# Sends a Discord embed notification when Claude returns an application-level error.
# Arguments: item_type (Issue|PullRequest|empty), item_id (numeric|empty), error_message
# Silent when DISCORD_WEBHOOK_URL is unset; logs a warning on curl failure.
notify_discord_claude_error() {
    [ -n "${DISCORD_WEBHOOK_URL}" ] || return 0
    local item_type="${1:-}" item_id="${2:-}" error_message="$3"
    local url payload

    case "${item_type}" in
        Issue)       url="https://github.com/${REPO_FULL}/issues/${item_id}" ;;
        PullRequest) url="https://github.com/${REPO_FULL}/pull/${item_id}" ;;
        *)           url="https://github.com/${REPO_FULL}" ;;
    esac

    # Truncate to stay within Discord's 1024-character field limit.
    local truncated_error="${error_message:0:900}"

    payload=$(jq --null-input \
        --argjson color 15158332 \
        --arg title "Claude Error: ${REPO_FULL}" \
        --arg url "${url}" \
        --arg error "${truncated_error}" \
        '{embeds:[{title:$title,url:$url,color:$color,fields:[
            {name:"Error",value:$error,inline:false}
        ]}]}') \
        || { warn "Discord: failed to build claude error payload"; return 0; }

    curl --silent --fail --max-time 5 \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        "${DISCORD_WEBHOOK_URL}" > /dev/null 2>&1 \
        || warn "Discord webhook notification failed"
}

# Sends a Discord embed notification when Claude returns a rate-limit error (HTTP 429).
# Arguments: item_type (Issue|PullRequest|empty), item_id (numeric|empty),
#            error_message, reset_unix (unix timestamp, may be empty)
# When reset_unix is provided, includes a Discord timestamp field showing when
# the limit resets in the user's local timezone.
# Silent when DISCORD_WEBHOOK_URL is unset; logs a warning on curl failure.
notify_discord_rate_limited() {
    [ -n "${DISCORD_WEBHOOK_URL}" ] || return 0
    local item_type="${1:-}" item_id="${2:-}" error_message="$3" reset_unix="${4:-}"
    local url payload reset_display truncated_error

    case "${item_type}" in
        Issue)       url="https://github.com/${REPO_FULL}/issues/${item_id}" ;;
        PullRequest) url="https://github.com/${REPO_FULL}/pull/${item_id}" ;;
        *)           url="https://github.com/${REPO_FULL}" ;;
    esac

    truncated_error="${error_message:0:900}"

    # Discord timestamp markup: <t:UNIX:t> = local time, <t:UNIX:R> = relative
    if [ -n "${reset_unix}" ]; then
        reset_display="<t:${reset_unix}:t> (<t:${reset_unix}:R>)"
    else
        reset_display=""
    fi

    payload=$(jq --null-input \
        --argjson color 16776960 \
        --arg title "Rate Limited: ${REPO_FULL}" \
        --arg url "${url}" \
        --arg error "${truncated_error}" \
        --arg reset "${reset_display}" \
        '{embeds:[{title:$title,url:$url,color:$color,fields:(
            [{name:"Error",value:$error,inline:false}] +
            (if $reset != "" then [{name:"Resets",value:$reset,inline:true}] else [] end)
        )}]}') \
        || { warn "Discord: failed to build rate-limit payload"; return 0; }

    curl --silent --fail --max-time 5 \
        -H "Content-Type: application/json" \
        -d "${payload}" \
        "${DISCORD_WEBHOOK_URL}" > /dev/null 2>&1 \
        || warn "Discord webhook notification failed"
}

# Tags an open PR whose linked issue has been closed, and leaves a comment for investigation.
# Labels are added individually so a missing label does not prevent the others from being applied.
tag_pr_closed_issue() {
    local pr_number="$1" issue_id="$2"
    gh pr edit "${pr_number}" --repo "${REPO_FULL}" --add-label "Needs Investigation" 2>/dev/null || true
    gh pr edit "${pr_number}" --repo "${REPO_FULL}" --add-label "Blocked" 2>/dev/null || true
    gh pr edit "${pr_number}" --repo "${REPO_FULL}" --add-label "On-hold" 2>/dev/null || true
    gh pr comment "${pr_number}" --repo "${REPO_FULL}" \
        --body "Issue #${issue_id} was found closed while this PR is still open. Automated work has been paused pending manual investigation." \
        2>/dev/null || true
}

main() {
    local owner_filter=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --owner)
                shift
                [ -n "${1:-}" ] || die "--owner requires a value"
                [[ "$1" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*$ ]] \
                    || die "--owner value contains invalid characters: $1"
                owner_filter="$1"
                shift
                ;;
            *)
                die "Unknown argument: $1"
                ;;
        esac
    done

    check_required_tools
    load_env_config
    validate_config "${owner_filter}"
    if [ -n "${GIT_SIGNING_KEY}" ]; then
        gpg --batch --no-tty --list-secret-keys "${GIT_SIGNING_KEY}" >/dev/null 2>&1 \
            || die "Signing key ${GIT_SIGNING_KEY} is set in .env but not found in the GPG keyring — import it with 'gpg --import <key-file>'"
    fi
    preload_ssh_keys
    setup_cgroup_leaf
    trap stop_ssh_agent EXIT

    if ! check_disk_space; then
        notify_discord_low_disk_space "${owner_filter}"
        warn "Insufficient disk space — skipping all work this cycle"
        exit 0
    fi

    local head_sha
    head_sha=$(git -C "$(dirname "$(realpath "$0")")" rev-parse --short HEAD 2>/dev/null || printf 'unknown')
    info "oneshot version: ${head_sha}"

    # Acquire an exclusive per-owner lock so concurrent invocations (e.g. two
    # systemd timer firings) do not race on the same git working directories.
    local lock_dir="${HOME}/.orchestrator/locks"
    mkdir -p "${lock_dir}" || die "Failed to create lock directory at ${lock_dir}"
    # fd 9 stays open (and lock held) until the process exits.
    exec 9>"${lock_dir}/${owner_filter:-_global}.lock"
    if ! flock --exclusive --nonblock 9; then
        info "Another oneshot instance is already running for '${owner_filter:-global}' — exiting cleanly"
        exit 0
    fi

    local items_json item_count
    info "Fetching priorities from ${PRIORITIES_URL}..."
    items_json=$(fetch_all_priorities)

    if [ -n "${owner_filter}" ]; then
        items_json=$(printf '%s' "${items_json}" | jq -c --arg owner "${owner_filter}" \
            '[.[] | select(.repository | startswith($owner + "/"))]') \
            || die "Failed to filter priorities by owner"
    fi

    item_count=$(printf '%s' "${items_json}" | jq 'length')
    if [ "${item_count}" -eq 0 ]; then
        success "No open work items found in priorities"
        notify_discord_no_work "${owner_filter}"
        exit 0
    fi

    info "Found ${item_count} open work item(s) — scanning for actionable work..."

    local -a skip_repos=()
    declare -gA reported_rate_limited=()
    local count_blocked=0
    local count_unchanged=0
    local count_active_repo=0
    local count_not_open=0
    local item_index=0
    # Declare all loop-body variables here so they are function-scoped.
    # 'local' inside a while loop is a no-op after the first iteration in bash,
    # so initialising them here (and resetting where needed at the top of each
    # iteration) avoids stale-value bugs.
    local item item_repo item_id item_type item_priority item_title
    local skip_repo is_skipped original_issue_id pr_idle_advance
    local open_pr pr_json pr_state pr_fp saved_fp merge_state branch_name
    local issue_json issue_state issue_fp saved_issue_fp
    local ai_instructions container_ai_instructions prompt claude_md_content post_fp

    while [ "${item_index}" -lt "${item_count}" ]; do
        item=$(printf '%s' "${items_json}" | jq -c --argjson idx "${item_index}" '.[$idx]')
        item_index=$((item_index + 1))

        item_repo=$(printf '%s' "${item}" | jq -r '.repository')
        item_id=$(printf '%s' "${item}" | jq -r '.id')
        item_type=$(printf '%s' "${item}" | jq -r '.itemType')
        item_priority=$(printf '%s' "${item}" | jq -r '.priority')

        [[ "${item_id}" =~ ^[0-9]+$ ]] \
            || die "Non-numeric id from priorities API: ${item_id}"
        case "${item_type}" in
            Issue|PullRequest) ;;
            *) die "Unexpected itemType from priorities API: ${item_type}" ;;
        esac
        [[ "${item_repo}" =~ ^[a-zA-Z0-9][a-zA-Z0-9._-]*/[a-zA-Z0-9_][a-zA-Z0-9._-]*$ ]] \
            || die "Malformed repository from priorities API: ${item_repo}"

        # Skip Issue items in repos that already have an active (non-blocked) PR.
        # PullRequests are always evaluated regardless of skip_repos — the guard
        # only prevents starting brand-new work from an Issue in an active repo.
        # Explicit reset — the 'local' initialiser above only fires once.
        is_skipped=false
        original_issue_id=""
        # Set when an unchanged non-terminal PR is re-invoked only to advance its next phase
        # (no external change); consumed when persisting the PR idle counter before invocation.
        pr_idle_advance=0
        if [ "${item_type}" = "Issue" ]; then
            for skip_repo in "${skip_repos[@]+"${skip_repos[@]}"}"; do
                if [ "${skip_repo}" = "${item_repo}" ]; then
                    is_skipped=true
                    break
                fi
            done
        fi
        if [ "${is_skipped}" = true ]; then
            info "Skipping Issue #${item_id} in ${item_repo} — repo already has active work"
            count_active_repo=$((count_active_repo + 1))
            continue
        fi

        info "Checking ${item_type} #${item_id} in ${item_repo} (priority ${item_priority})..."

        # Configure per-repo globals for all sub-functions.
        set_repo_context "${item_repo}"

        if [ "${item_type}" = "Issue" ]; then
            # Lazy check: does this repo already have an open non-blocked PR that we authored?
            open_pr=$(find_open_nonblocked_pr_for_repo "${item_repo}") \
                || die "Failed to query open PRs for ${item_repo}"

            if [ -n "${open_pr}" ]; then
                [[ "${open_pr}" =~ ^[0-9]+$ ]] \
                    || die "Non-numeric open PR number from GitHub: ${open_pr}"

                # Before pivoting to the PR workflow, verify the issue is still open and
                # unblocked — a PR can outlive its issue if the issue was closed as not planned.
                issue_json=$(fetch_issue_json "${item_id}") \
                    || die "Failed to fetch state for Issue #${item_id} in ${item_repo}"
                issue_state=$(printf '%s' "${issue_json}" | jq -r '.state')
                if [ "${issue_state}" != "OPEN" ]; then
                    info "Issue #${item_id} in ${item_repo} is no longer open — tagging PR #${open_pr} for investigation and skipping"
                    tag_pr_closed_issue "${open_pr}" "${item_id}"
                    count_not_open=$((count_not_open + 1))
                    continue
                fi
                if issue_json_has_blocked_label "${issue_json}"; then
                    info "Issue #${item_id} in ${item_repo} is blocked — skipping"
                    notify_discord_blocked_item "Issue" "${item_id}"
                    count_blocked=$((count_blocked + 1))
                    continue
                fi
                # Issue observed open and un-blocked — re-arm its blocked notifier.
                clear_blocked_marker "Issue" "${item_id}"

                info "Issue #${item_id} in ${item_repo}: found open non-blocked PR #${open_pr} — switching to PR workflow"

                pr_json=$(fetch_pr_json "${open_pr}") \
                    || die "Failed to fetch state for PR #${open_pr} in ${item_repo}"

                pr_state=$(printf '%s' "${pr_json}" | jq -r '.state')
                if [ "${pr_state}" != "OPEN" ]; then
                    info "PR #${open_pr} in ${item_repo} is no longer open — skipping"
                    count_not_open=$((count_not_open + 1))
                    continue
                fi

                if pr_json_has_blocked_label "${pr_json}"; then
                    info "PR #${open_pr} in ${item_repo} is blocked — skipping (not counting as active work)"
                    notify_discord_blocked_item "PullRequest" "${open_pr}"
                    count_blocked=$((count_blocked + 1))
                    continue
                fi
                # PR observed open and un-blocked — re-arm its blocked notifier.
                clear_blocked_marker "PullRequest" "${open_pr}"

                # PR is confirmed open, non-blocked — mark repo as having active work.
                skip_repos+=("${item_repo}")

                pr_fp=$(fingerprint_pr_json "${pr_json}" "$(get_trusted_logins)") \
                    || die "Failed to compute fingerprint for PR #${open_pr} in ${item_repo}"
                saved_fp=$(load_pr_fingerprint "${open_pr}")
                pr_is_draft=$(printf '%s' "${pr_json}" | jq -r '.isDraft // false')

                if [ -n "${saved_fp}" ] && [ "${pr_fp}" = "${saved_fp}" ]; then
                    if pr_json_has_pending_ci_checks "${pr_json}"; then
                        if ci_checks_timed_out "${open_pr}" "${pr_json}"; then
                            info "PR #${open_pr} in ${item_repo}: CI checks pending past ${CI_CHECK_TIMEOUT_MINUTES}-minute timeout — blocking"
                            gh pr comment "${open_pr}" --repo "${item_repo}" --body "$(cat <<COMMENT
CI checks have been pending for over ${CI_CHECK_TIMEOUT_MINUTES} minutes. Blocking this PR until a human investigates.
COMMENT
                            )" 2>/dev/null || true
                            gh pr edit "${open_pr}" --repo "${item_repo}" --add-label Blocked 2>/dev/null || true
                            clear_pr_ci_pending_state "${open_pr}"
                        else
                            info "PR #${open_pr} in ${item_repo}: CI checks pending — deferring"
                        fi
                        count_unchanged=$((count_unchanged + 1))
                        continue
                    fi
                    clear_pr_ci_pending_state "${open_pr}"
                    if [ "${pr_is_draft}" != "true" ]; then
                        # PR unchanged — also check whether the linked issue has new comments.
                        issue_fp=$(fingerprint_issue_json "${issue_json}" "$(get_trusted_logins)") \
                            || die "Failed to compute fingerprint for Issue #${item_id} in ${item_repo}"
                        saved_issue_fp=$(load_issue_fingerprint "${item_id}")
                        if [ -n "${saved_issue_fp}" ] && [ "${issue_fp}" = "${saved_issue_fp}" ]; then
                            if pr_should_advance_unchanged "${open_pr}" "${pr_json}"; then
                                info "PR #${open_pr} in ${item_repo} unchanged — re-invoking to advance the next workflow phase"
                                pr_idle_advance=1
                            else
                                info "PR #${open_pr} in ${item_repo} unchanged — skipping repo"
                                count_unchanged=$((count_unchanged + 1))
                                continue
                            fi
                        else
                            info "Issue #${item_id} in ${item_repo} changed — re-running against PR #${open_pr}"
                        fi
                    else
                        info "PR #${open_pr} in ${item_repo} unchanged but still in draft — re-running"
                    fi
                fi

                # PR has changed (or issue changed, or still in draft) — work on it.
                original_issue_id="${item_id}"
                item_id="${open_pr}"
                item_type="PullRequest"

            else
                # No active PR — check the issue itself.
                issue_json=$(fetch_issue_json "${item_id}") \
                    || die "Failed to fetch state for Issue #${item_id} in ${item_repo}"

                issue_state=$(printf '%s' "${issue_json}" | jq -r '.state')
                if [ "${issue_state}" != "OPEN" ]; then
                    info "Issue #${item_id} in ${item_repo} is no longer open — skipping"
                    count_not_open=$((count_not_open + 1))
                    continue
                fi

                if issue_json_has_blocked_label "${issue_json}"; then
                    info "Issue #${item_id} in ${item_repo} is blocked — skipping"
                    notify_discord_blocked_item "Issue" "${item_id}"
                    count_blocked=$((count_blocked + 1))
                    continue
                fi
                # Issue observed open and un-blocked — re-arm its blocked notifier.
                clear_blocked_marker "Issue" "${item_id}"

                issue_fp=$(fingerprint_issue_json "${issue_json}" "$(get_trusted_logins)") \
                    || die "Failed to compute fingerprint for Issue #${item_id} in ${item_repo}"
                saved_fp=$(load_issue_fingerprint "${item_id}")

                if [ -n "${saved_fp}" ] && [ "${issue_fp}" = "${saved_fp}" ]; then
                    if ! recover_orphaned_branch; then
                        info "Issue #${item_id} in ${item_repo} unchanged — skipping"
                        count_unchanged=$((count_unchanged + 1))
                        continue
                    fi
                    info "Issue #${item_id} in ${item_repo}: fingerprint unchanged but repo was on an orphaned branch — re-running"
                fi
                # Fall through to work block (item_type remains "Issue").
            fi

        else
            # PullRequest appearing directly in the priorities list.
            pr_json=$(fetch_pr_json "${item_id}") \
                || die "Failed to fetch state for PR #${item_id} in ${item_repo}"

            pr_state=$(printf '%s' "${pr_json}" | jq -r '.state')
            if [ "${pr_state}" != "OPEN" ]; then
                info "PR #${item_id} in ${item_repo} is no longer open — skipping"
                count_not_open=$((count_not_open + 1))
                continue
            fi

            if pr_json_has_blocked_label "${pr_json}"; then
                info "PR #${item_id} in ${item_repo} is blocked — skipping (not counting as active work)"
                notify_discord_blocked_item "PullRequest" "${item_id}"
                count_blocked=$((count_blocked + 1))
                continue
            fi
            # PR observed open and un-blocked — re-arm its blocked notifier.
            clear_blocked_marker "PullRequest" "${item_id}"

            # Non-blocked, open PR = active work for this repo.
            skip_repos+=("${item_repo}")

            pr_fp=$(fingerprint_pr_json "${pr_json}" "$(get_trusted_logins)") \
                || die "Failed to compute fingerprint for PR #${item_id} in ${item_repo}"
            saved_fp=$(load_pr_fingerprint "${item_id}")
            pr_is_draft=$(printf '%s' "${pr_json}" | jq -r '.isDraft // false')

            if [ -n "${saved_fp}" ] && [ "${pr_fp}" = "${saved_fp}" ]; then
                if pr_json_has_pending_ci_checks "${pr_json}"; then
                    if ci_checks_timed_out "${item_id}" "${pr_json}"; then
                        info "PR #${item_id} in ${item_repo}: CI checks pending past ${CI_CHECK_TIMEOUT_MINUTES}-minute timeout — blocking"
                        gh pr comment "${item_id}" --repo "${item_repo}" --body "$(cat <<COMMENT
CI checks have been pending for over ${CI_CHECK_TIMEOUT_MINUTES} minutes. Blocking this PR until a human investigates.
COMMENT
                        )" 2>/dev/null || true
                        gh pr edit "${item_id}" --repo "${item_repo}" --add-label Blocked 2>/dev/null || true
                        clear_pr_ci_pending_state "${item_id}"
                    else
                        info "PR #${item_id} in ${item_repo}: CI checks pending — deferring"
                    fi
                    count_unchanged=$((count_unchanged + 1))
                    continue
                fi
                clear_pr_ci_pending_state "${item_id}"
                pr_merge_state=$(printf '%s' "${pr_json}" | jq -r '.mergeStateStatus // "UNKNOWN"')
                if [ "${pr_is_draft}" = "true" ]; then
                    info "PR #${item_id} in ${item_repo} unchanged but still in draft — re-running"
                elif [ "${pr_merge_state}" = "BEHIND" ] || [ "${pr_merge_state}" = "DIRTY" ]; then
                    info "PR #${item_id} in ${item_repo} unchanged but ${pr_merge_state} — re-running"
                elif pr_should_advance_unchanged "${item_id}" "${pr_json}"; then
                    info "PR #${item_id} in ${item_repo} unchanged — re-invoking to advance the next workflow phase"
                    pr_idle_advance=1
                else
                    info "PR #${item_id} in ${item_repo} unchanged — skipping"
                    count_unchanged=$((count_unchanged + 1))
                    continue
                fi
            fi
            # Fall through to work block (item_type remains "PullRequest").
        fi

        # ---- Work block: item_type and item_id are resolved ----
        info "Found actionable ${item_type} #${item_id} in ${item_repo} — preparing..."

        merge_state=""
        branch_name=""
        DIRTY_BRANCH=""
        if [ "${item_type}" = "PullRequest" ]; then
            merge_state=$(printf '%s' "${pr_json}" | jq -r '.mergeStateStatus // "UNKNOWN"')
            branch_name=$(printf '%s' "${pr_json}" | jq -r '.headRefName // empty')

            if pr_json_has_pending_ci_checks "${pr_json}"; then
                if ci_checks_timed_out "${item_id}" "${pr_json}"; then
                    info "PR #${item_id} in ${item_repo}: CI checks pending past ${CI_CHECK_TIMEOUT_MINUTES}-minute timeout — blocking"
                    gh pr comment "${item_id}" --repo "${item_repo}" --body "$(cat <<COMMENT
CI checks have been pending for over ${CI_CHECK_TIMEOUT_MINUTES} minutes. Blocking this PR until a human investigates.
COMMENT
                    )" 2>/dev/null || true
                    gh pr edit "${item_id}" --repo "${item_repo}" --add-label Blocked 2>/dev/null || true
                    clear_pr_ci_pending_state "${item_id}"
                else
                    info "PR #${item_id} in ${item_repo}: CI checks pending — deferring agent invocation"
                    save_pr_fingerprint "${item_id}" "${pr_fp}"
                fi
                continue
            fi
            clear_pr_ci_pending_state "${item_id}"
            sync_pr_labels_from_linked_issues "${item_id}" "${pr_json}"
        fi

        if ! ensure_repo_current; then
            info "Repo not clean for ${item_repo} — handing off to agent to recover"
        elif [ "${item_type}" = "PullRequest" ]; then
            if [ "${merge_state}" = "BEHIND" ] || [ "${merge_state}" = "DIRTY" ]; then
                if try_nonagentic_rebase "${branch_name}"; then
                    info "PR #${item_id} in ${item_repo} rebased non-agentically — updating fingerprint"
                    post_fp=$(compute_pr_fingerprint "${item_id}") \
                        || die "Failed to compute post-rebase fingerprint for PR #${item_id} in ${item_repo}"
                    save_pr_fingerprint "${item_id}" "${post_fp}"
                    continue
                fi
                info "Non-agentic rebase of PR #${item_id} in ${item_repo} had conflicts — handing off to agent"
            fi
        fi

        if is_owner_rate_limited; then
            if [ -z "${reported_rate_limited["${OWNER}"]:-}" ]; then
                info "Owner ${OWNER} is rate-limited — skipping all actionable items"
                reported_rate_limited["${OWNER}"]=1
            fi
            continue
        fi

        ensure_rules_current

        if ! ai_instructions=$(find_ai_instructions); then
            warn "Skipping ${item_type} #${item_id} in ${item_repo}: no .ai-instructions found — marking as blocked"
            if [ "${item_type}" = "Issue" ]; then
                gh issue edit "${item_id}" --repo "${item_repo}" --add-label Blocked 2>/dev/null || true
            else
                gh pr edit "${item_id}" --repo "${item_repo}" --add-label Blocked 2>/dev/null || true
            fi
            continue
        fi

        if [ "${item_type}" = "Issue" ]; then
            item_title=$(printf '%s' "${issue_json}" | jq -r '.title // empty')
        else
            item_title=$(printf '%s' "${pr_json}" | jq -r '.title // empty')
        fi

        # Every run is a fresh single-phase session (no resume): the agent re-derives its
        # context from GitHub, does one workflow phase, and stops.  The orchestrator re-invokes
        # on later ticks to advance through the remaining phases.
        info "Starting fresh single-phase session for ${item_type} #${item_id} in ${item_repo}"
        notify_discord_work_item "start" "${item_type}" "${item_id}" "${item_title}"

        # Runaway backstop (PRs): cap the total number of agent invocations spent on one PR so a
        # non-converging PR cannot loop forever.  Absence of the guard file also tells us this is
        # the first time we have ever worked this PR (used to initialise the board below).
        local pr_first_touch="false"
        if [ "${item_type}" = "PullRequest" ]; then
            [ -f "$(pr_invocation_guard_file_path "${item_id}")" ] || pr_first_touch="true"
            load_pr_invocation_counts "${item_id}"
            if [ "${PR_INVOCATION_TOTAL}" -ge "${MAX_PR_TOTAL_INVOCATIONS}" ]; then
                warn "PR #${item_id} in ${item_repo} used ${PR_INVOCATION_TOTAL} agent invocations without converging — marking Blocked"
                gh pr comment "${item_id}" --repo "${item_repo}" --body "$(cat <<COMMENT
This PR has been worked ${PR_INVOCATION_TOTAL} times by the automation without reaching a mergeable state. Blocking for a human to investigate.
COMMENT
                )" 2>/dev/null || true
                gh pr edit "${item_id}" --repo "${item_repo}" --add-label Blocked 2>/dev/null || true
                notify_discord_blocked_item "PullRequest" "${item_id}"
                count_blocked=$((count_blocked + 1))
                continue
            fi
        fi

        container_ai_instructions=$(host_to_container_path "${ai_instructions}")

        discover_or_create_workflow_project
        [ -n "${_WF_CREATION_FAILED}" ] && report_missing_workflow_project

        local trusted_logins
        trusted_logins=$(get_trusted_logins)
        if [ "${item_type}" = "Issue" ]; then
            fetch_board_approved_items
            local plan_approved="false"
            [ "${_WF_APPROVED_ITEMS["${item_repo}/${item_id}"]:-}" = "1" ] && plan_approved="true"
            prompt=$(build_issue_prompt "${item_id}" "${container_ai_instructions}" "${CONTAINER_REPO_PATH}")
            claude_md_content=$(build_issue_claude_md "${item_id}" "${container_ai_instructions}" "${CONTAINER_REPO_PATH}" "${plan_approved}" "${trusted_logins}")
        else
            local is_dependency_pr
            is_dependency_pr=$(printf '%s' "${pr_json}" | jq -r '[.labels[].name] | contains(["dependencies"])')
            prompt=$(build_pr_prompt "${item_id}" "${container_ai_instructions}" "${merge_state}" "${branch_name}" "${CONTAINER_REPO_PATH}")
            claude_md_content=$(build_pr_claude_md "${item_id}" "${container_ai_instructions}" "${merge_state}" "${branch_name}" "${CONTAINER_REPO_PATH}" "${DIRTY_BRANCH}" "${is_dependency_pr}" "${trusted_logins}")
        fi

        [ -n "${prompt}" ] || die "prompt is empty for ${item_type} #${item_id} in ${item_repo}"

        # Initialise the board to "Not Started" only on the first-ever touch of the item, so
        # re-invocations never clobber a phase the agent has already advanced the board to.
        # Also record this invocation against the PR budgets: always bump the total; bump the
        # idle counter only when this run is a no-external-change phase advance, and reset it to
        # 0 otherwise (a push, a new comment, or CI change is real progress).
        if [ "${item_type}" = "PullRequest" ]; then
            [ "${pr_first_touch}" = "true" ] && update_workflow_status "${item_type}" "${item_id}" "Not Started"
            local pr_new_idle=0
            [ "${pr_idle_advance}" = "1" ] && pr_new_idle=$(( PR_INVOCATION_IDLE + 1 ))
            save_pr_invocation_counts "${item_id}" "$(( PR_INVOCATION_TOTAL + 1 ))" "${pr_new_idle}"
        elif [ "${item_type}" = "Issue" ] && [ -z "$(load_issue_fingerprint "${item_id}")" ]; then
            update_workflow_status "${item_type}" "${item_id}" "Not Started"
        fi

        invoke_claude "${prompt}" "${item_type}" "${item_id}" "${claude_md_content}"
        invoke_claude_exit=$?
        git -C "${REPO_WORK_DIR}" clean -fdX
        [ "${invoke_claude_exit}" -eq 0 ] || die "Failed to invoke Claude for ${item_type} #${item_id} in ${item_repo}"

        success "Completed one workflow phase for ${item_type} #${item_id} in ${item_repo}"

        if [ "${item_type}" = "PullRequest" ]; then
            post_fp=$(compute_pr_fingerprint "${item_id}") \
                || die "Failed to compute post-run fingerprint for PR #${item_id} in ${item_repo}"
            save_pr_fingerprint "${item_id}" "${post_fp}"
            if [ -n "${original_issue_id}" ]; then
                post_fp=$(compute_issue_fingerprint "${original_issue_id}") \
                    || die "Failed to compute post-run fingerprint for Issue #${original_issue_id} in ${item_repo}"
                save_issue_fingerprint "${original_issue_id}" "${post_fp}"
            fi
        elif [ "${item_type}" = "Issue" ]; then
            post_fp=$(compute_issue_fingerprint "${item_id}") \
                || die "Failed to compute post-run fingerprint for Issue #${item_id} in ${item_repo}"
            save_issue_fingerprint "${item_id}" "${post_fp}"
        fi

        exit 0
    done

    notify_discord_no_work "${owner_filter}" "${count_blocked}" "${count_unchanged}" "${count_active_repo}" "${count_not_open}"
    success "No actionable work items found across all priorities (blocked: ${count_blocked}, unchanged: ${count_unchanged}, repo-active: ${count_active_repo}, not-open: ${count_not_open})"
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
