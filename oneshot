#!/bin/bash
# shellcheck disable=SC2153
# SC2153 ("possible misspelling") false-positives once repo-context globals (OWNER, REPO,
# REPO_FULL, RULES_DIR, REPO_WORK_DIR, ...) are assigned only in the unfollowed lib/git
# source below: shellcheck can no longer see the assignment and flags every use against a
# same-named local parameter (e.g. `local repo_full="$1"`) elsewhere in this file as a typo.

# Orchestrator oneshot script.
# Fetches all open work items from the priorities API and drives a Claude Code session
# to work on the first actionable item across any repository.  Every invocation runs a
# FRESH Claude session (no --resume): all durable state lives in GitHub (branch, commits,
# PR comments, labels, Workflow board), so each run re-derives its context and does exactly
# ONE workflow phase before stopping.  This bounds a single session's context growth and
# is what keeps runs from hitting the model context window ("Prompt is too long").
# The orchestrator re-invokes the item on the next tick to advance to the next phase.

# Resolve this script's own directory via BASH_SOURCE (not $0), so it works both when run
# directly and when a test harness `source`s it ($0 would then be the test runner, not
# oneshot). lib/globals must be sourced first: it declares every associative array and
# config default the other libraries and main() read or write.
ONESHOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/globals disable=SC1091
source "${ONESHOT_DIR}/lib/globals"
# shellcheck source=lib/core disable=SC1091
source "${ONESHOT_DIR}/lib/core"
# shellcheck source=lib/git disable=SC1091
source "${ONESHOT_DIR}/lib/git"
# shellcheck source=lib/github disable=SC1091
source "${ONESHOT_DIR}/lib/github"
# shellcheck source=lib/github-status disable=SC1091
source "${ONESHOT_DIR}/lib/github-status"
# shellcheck source=lib/fingerprints disable=SC1091
source "${ONESHOT_DIR}/lib/fingerprints"
# shellcheck source=lib/state disable=SC1091
source "${ONESHOT_DIR}/lib/state"

