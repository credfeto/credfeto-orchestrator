#!/bin/bash

# Orchestrator oneshot script.
# Fetches the top-priority open work item for credfeto/credfeto-orchestrator from the
# priorities API and drives a Claude Code session to work on it.  Persists one Claude
# session ID per Issue/PR so subsequent runs resume the correct session.

OWNER="credfeto"
REPO="credfeto-orchestrator"
REPO_FULL="${OWNER}/${REPO}"
PRIORITIES_URL="https://git-workflow.markridgwell.com/priorities"
SESSION_BASE_DIR="${HOME}/.orchestrator/${OWNER}/${REPO}"
WORK="${XDG_PROJECTS_DIR:-${HOME}/work}"
RULES_DIR="${WORK}/${OWNER}/${REPO}/rules"
REPO_WORK_DIR="${WORK}/${OWNER}/${REPO}/repo"

die() {
    printf '\n\033[31m✗\033[0m %s\n' "$*" >&2
    exit 1
}

success() {
    printf '\n\033[32m✓\033[0m %s\n' "$*"
}

info() {
    printf '\n\033[32m→\033[0m %s\n' "$*"
}

warn() {
    printf '\n\033[33m!\033[0m %s\n' "$*" >&2
}

# Returns true (0) when running inside a Claude Code Bash-tool session.
# Claude Code sets CLAUDECODE=1 in every shell it spawns via the Bash tool;
# that value is inherited by subprocesses (e.g. git hooks).
# Source: https://docs.anthropic.com/en/docs/claude-code/settings#environment-variables
is_ai_agent() {
    [ "${CLAUDECODE}" = "1" ]
}

# Checks that token_file exists, has safe permissions, and outputs its contents (whitespace stripped).
# Outputs nothing and returns silently if the file is absent or has unsafe permissions.
read_token_if_safe() {
    local token_file="$1"
    local perms
    [ -f "${token_file}" ] || return
    perms=$(stat -c '%a' "${token_file}" 2>/dev/null || stat -f '%Lp' "${token_file}" 2>/dev/null)
    case "${perms}" in
        600|400) ;;
        *) warn "Token file ${token_file} has permissions ${perms} — expected 600; skipping"
           return
           ;;
    esac
    tr -d '[:space:]' < "${token_file}"
}

# Outputs the OAuth token for the given owner, or empty string if not configured.
# Lookup order:
#   1. $XDG_CONFIG_HOME/orchestrator/tokens/<owner>  (preferred XDG location, defaults to ~/.config)
#   2. Empty string — caller falls back to CLAUDE_CODE_OAUTH_TOKEN from the environment.
# Token files must be readable only by the owner (chmod 600).
load_token_for_owner() {
    local owner="$1"
    local token

    case "${owner}" in
        *[!a-zA-Z0-9_-]*) return ;;
    esac

    token=$(read_token_if_safe "${XDG_CONFIG_HOME:-${HOME}/.config}/orchestrator/tokens/${owner}")
    [ -n "${token}" ] && printf '%s' "${token}"
}

ensure_rules_current() {
    if [ -d "${RULES_DIR}/.git" ]; then
        info "Updating rules (cs-template) at ${RULES_DIR}..."
        git -C "${RULES_DIR}" checkout main || die "Failed to switch cs-template to main at ${RULES_DIR}"
        git -C "${RULES_DIR}" pull --ff-only || die "Failed to update cs-template at ${RULES_DIR}"
    else
        info "Cloning rules (cs-template) to ${RULES_DIR}..."
        mkdir -p "$(dirname "${RULES_DIR}")" || die "Failed to create parent directory for ${RULES_DIR}"
        git clone git@github.com:credfeto/cs-template.git "${RULES_DIR}" || die "Failed to clone cs-template to ${RULES_DIR}"
    fi
}

ensure_repo_current() {
    if [ -d "${REPO_WORK_DIR}/.git" ]; then
        info "Fetching latest changes for ${REPO_FULL}..."
        git -C "${REPO_WORK_DIR}" fetch origin || die "Failed to fetch from origin for ${REPO_FULL}"

        local current_branch
        current_branch=$(git -C "${REPO_WORK_DIR}" branch --show-current)
        if [ "${current_branch}" = "main" ]; then
            if ! git -C "${REPO_WORK_DIR}" diff --quiet || ! git -C "${REPO_WORK_DIR}" diff --cached --quiet; then
                die "Working tree has uncommitted changes on main — cannot rebase ${REPO_FULL}"
            fi
            info "Rebasing main with origin/main..."
            git -C "${REPO_WORK_DIR}" rebase origin/main || die "Failed to rebase main with origin/main"
        fi
    else
        info "Cloning ${REPO_FULL} to ${REPO_WORK_DIR}..."
        mkdir -p "$(dirname "${REPO_WORK_DIR}")" || die "Failed to create parent directory for ${REPO_WORK_DIR}"
        git clone "git@github.com:${OWNER}/${REPO}.git" "${REPO_WORK_DIR}" || die "Failed to clone ${REPO_FULL} to ${REPO_WORK_DIR}"
    fi
}

check_required_tools() {
    local tool
    for tool in curl jq claude gh git awk grep; do
        command -v "${tool}" >/dev/null 2>&1 || die "Required tool not found: ${tool}"
    done

    if ! command -v sha256sum >/dev/null 2>&1 && ! command -v shasum >/dev/null 2>&1; then
        die "Required tool not found: sha256sum or shasum"
    fi
}

# Reads stdin and writes a SHA-256 digest to stdout.
hash_sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum | awk '{ print $1 }'
    else
        shasum -a 256 | awk '{ print $1 }'
    fi
}

# Returns the path to the session file for a given item type and ID.
session_file_path() {
    local item_type="$1" item_id="$2"
    printf '%s/%s_%s.env' "${SESSION_BASE_DIR}" "${item_type}" "${item_id}"
}

# Outputs the top-priority item JSON for this repo; caller announces progress.
fetch_top_priority() {
    local priorities_json top_item

    priorities_json=$(curl --silent --fail "${PRIORITIES_URL}") \
        || die "Failed to fetch priorities from ${PRIORITIES_URL}"

    top_item=$(printf '%s' "${priorities_json}" | jq -c --arg repo "${REPO_FULL}" '
        .priorities
            | map(select(.repository == $repo and .status == "Open" and .isOnHold == false))
            | sort_by(.priority)
            | first
    ') || die "Failed to parse priorities JSON"

    printf '%s' "${top_item}"
}

# Sets SESSION_ID for the given item.  For a PullRequest with no session file, falls back
# to the session of a linked closing issue so work already done on the issue is continued.
load_session() {
    local item_type="$1" item_id="$2"
    local session_file linked_issue_id linked_session_file

    SESSION_ID=""

    session_file=$(session_file_path "${item_type}" "${item_id}")
    if [ -f "${session_file}" ]; then
        SESSION_ID=$(cat "${session_file}")
        return
    fi

    if [ "${item_type}" = "PullRequest" ]; then
        linked_issue_id=$(gh pr view "${item_id}" \
            --repo "${REPO_FULL}" \
            --json closingIssuesReferences \
            --jq '.closingIssuesReferences[0].number // empty' 2>/dev/null)

        if [ -n "${linked_issue_id}" ]; then
            linked_session_file=$(session_file_path "Issue" "${linked_issue_id}")
            if [ -f "${linked_session_file}" ]; then
                info "No session for PR #${item_id} — inheriting session from linked issue #${linked_issue_id}"
                SESSION_ID=$(cat "${linked_session_file}")
            fi
        fi
    fi
}

find_ai_instructions() {
    if [ -f "${REPO_WORK_DIR}/.ai-instructions" ]; then
        printf '%s/.ai-instructions' "${REPO_WORK_DIR}"
    elif [ -f "${RULES_DIR}/.ai-instructions" ]; then
        printf '%s/.ai-instructions' "${RULES_DIR}"
    else
        die "No .ai-instructions found at ${REPO_WORK_DIR}/.ai-instructions or ${RULES_DIR}/.ai-instructions"
    fi
}

build_issue_prompt() {
    local item_id="$1" ai_instructions="$2"
    cat <<EOF
You are the Orchestrator agent.

Read AI instructions from ${ai_instructions}.

Work on issue #${item_id} in ${REPO_FULL}.
The repository is checked out at ${REPO_WORK_DIR}.

Steps:
1. Assign yourself: gh issue edit ${item_id} --repo ${REPO_FULL} --add-assignee @me
2. BEFORE writing any code: read the issue and all comments. If the issue contains questions that need answers, or if you have questions, you MUST ask them first in comments on the issue. Mark the issue as blocked and wait for answers: gh issue edit ${item_id} --repo ${REPO_FULL} --add-label Blocked
3. Reply to every issue comment that prompted an action with "<one sentence description>"
4. When ready to start work: create a new branch, commit a placeholder CHANGELOG.md entry, push upstream, and create a draft pull request that links issue #${item_id}
EOF
}

build_pr_prompt() {
    local item_id="$1" ai_instructions="$2"
    cat <<EOF
You are the Orchestrator agent.

Read AI instructions from ${ai_instructions}.

Work on pull request #${item_id} in ${REPO_FULL}.
The repository is checked out at ${REPO_WORK_DIR}.

Steps:
1. Assign yourself: gh pr edit ${item_id} --repo ${REPO_FULL} --add-assignee @me
2. Check the PR comments, any code reviews, and CI workflow runs. If the PR or comments contain questions that need answers, or if you have questions, ask them first in PR Comment replies and mark the PR as blocked: gh pr edit ${item_id} --repo ${REPO_FULL} --add-label Blocked
3. Reply to every PR comment that prompted an action with "Fixed in <commit-sha> — <one sentence description>"
4. Proceed to address all outstanding work
EOF
}

# Queries GitHub for an open PR whose closing issues include the given issue ID.
# Outputs the PR number on stdout, or empty string if none found.
# Returns 1 if the gh call fails (caller should treat as "no linked PR found").
find_linked_pr_on_github() {
    local issue_id="$1"
    local pr_list
    pr_list=$(gh pr list \
        --repo "${REPO_FULL}" \
        --state open \
        --json number,closingIssuesReferences \
        2>/dev/null) || return 1
    printf '%s' "${pr_list}" | jq -r --argjson issue "${issue_id}" \
        '[.[] | select(.closingIssuesReferences[]?.number == $issue)] | first | .number // empty'
}

# Checks whether the given item is still open on GitHub.
# Return codes: 0 = open; 1 = closed or merged; 2 = gh call failed (state unknown).
# The priorities API may be stale — always verify against the live GitHub state.
check_item_open() {
    local item_type="$1" item_id="$2"
    local state

    if [ "${item_type}" = "Issue" ]; then
        state=$(gh issue view "${item_id}" \
            --repo "${REPO_FULL}" \
            --json state \
            --jq '.state' 2>/dev/null) || return 2
    else
        state=$(gh pr view "${item_id}" \
            --repo "${REPO_FULL}" \
            --json state \
            --jq '.state' 2>/dev/null) || return 2
    fi

    if [ "${state}" = "OPEN" ]; then
        return 0
    fi
    return 1
}

# Returns 0 if the value is a plain UUID (the format Claude returns for a session id).
# Rejecting anything else prevents injecting shell statements into the session file.
is_valid_session_id() {
    [[ "$1" =~ ^[[:xdigit:]]{8}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{4}-[[:xdigit:]]{12}$ ]]
}

# Outputs the Claude session ID on stdout; all user-visible messages go to stderr.
# Claude's text response is written to stderr so the caller can review what was done.
invoke_claude() {
    local prompt="$1" resume_session_id="$2"
    local tmpfile new_session_id owner_token

    tmpfile=$(mktemp --suffix=.json) || die "Failed to create temp file for Claude output"

    # Load the per-owner OAuth token (if configured) and scope it to this invocation only.
    # The token is never logged — use [REDACTED] in any diagnostic messages that reference it.
    owner_token=$(load_token_for_owner "${OWNER}")

    local -a claude_env_prefix=()
    [ -n "${owner_token}" ] && claude_env_prefix=( env "CLAUDE_CODE_OAUTH_TOKEN=${owner_token}" )

    if [ -n "${resume_session_id}" ]; then
        info "Resuming Claude session ${resume_session_id}..." >&2
        printf '%s' "${prompt}" | "${claude_env_prefix[@]}" claude \
            --resume "${resume_session_id}" \
            --print \
            --output-format json \
            --dangerously-skip-permissions \
            --add-dir "${REPO_WORK_DIR}" > "${tmpfile}" \
            || { rm -f "${tmpfile}"; die "Claude invocation failed"; }
    else
        info "Starting new Claude session..." >&2
        printf '%s' "${prompt}" | "${claude_env_prefix[@]}" claude \
            --print \
            --output-format json \
            --dangerously-skip-permissions \
            --add-dir "${REPO_WORK_DIR}" > "${tmpfile}" \
            || { rm -f "${tmpfile}"; die "Claude invocation failed"; }
    fi

    # Show Claude's text response so the caller can review what was done
    jq -r '.result // ""' "${tmpfile}" >&2

    new_session_id=$(jq -r '.session_id // empty' "${tmpfile}") \
        || { rm -f "${tmpfile}"; die "Failed to parse session_id from Claude output"; }

    rm -f "${tmpfile}"

    [ -n "${new_session_id}" ] || die "No session_id returned by Claude"

    # Reject anything that is not a plain UUID to prevent injecting shell statements
    # into the session file that is read on the next run.
    is_valid_session_id "${new_session_id}" \
        || die "Unexpected session_id format returned by Claude: ${new_session_id}"

    printf '%s' "${new_session_id}"
}

save_session() {
    local item_type="$1" item_id="$2" new_session_id="$3"
    local session_file

    session_file=$(session_file_path "${item_type}" "${item_id}")
    mkdir -p "${SESSION_BASE_DIR}" || die "Failed to create session directory: ${SESSION_BASE_DIR}"
    printf '%s\n' "${new_session_id}" \
        > "${session_file}" \
        || die "Failed to write session file: ${session_file}"
}

# Returns the path to the fingerprint file for a given PR ID.
pr_fingerprint_file_path() {
    local item_id="$1"
    printf '%s/PullRequest_%s.fingerprint' "${SESSION_BASE_DIR}" "${item_id}"
}

# Fetches the PR state JSON used for fingerprinting; returns 1 on gh failure.
fetch_pr_json() {
    local item_id="$1"
    gh pr view "${item_id}" \
        --repo "${REPO_FULL}" \
        --json title,body,isDraft,labels,headRefOid,comments,reviews,statusCheckRollup \
        2>/dev/null || return 1
}

# Computes a deterministic fingerprint from pre-fetched PR state JSON.
# Outputs the hash on stdout; returns non-zero if jq fails.
fingerprint_pr_json() {
    local pr_json="$1"
    local canonical

    canonical=$(printf '%s' "${pr_json}" | jq -r '
        .title,
        (.body // ""),
        (.isDraft | tostring),
        ([((.labels // [])[] | .name)] | sort | .[]),
        .headRefOid,
        ((.comments // []) | length | tostring),
        (((.comments // []) | sort_by(.updatedAt) | last | .updatedAt) // "none"),
        (((.reviews // []) | sort_by(.submittedAt // .updatedAt // "") | last | .state) // "none"),
        (((.reviews // []) | sort_by(.submittedAt // .updatedAt // "") | last | (.submittedAt // .updatedAt)) // "none"),
        ([((.statusCheckRollup // [])[]
            | (.name // "unknown") as $n
            | (.conclusion // .status // "none") as $c
            | "\($c):\($n)"
        )] | sort | join(","))
    ') || return 1

    printf '%s' "${canonical}" | hash_sha256
}

# Computes a deterministic hash of the PR's current state using a single gh pr view call.
# Outputs the hash on stdout; returns non-zero if the gh call or jq fails.
compute_pr_fingerprint() {
    local item_id="$1"
    local pr_json
    pr_json=$(fetch_pr_json "${item_id}") || return 1
    fingerprint_pr_json "${pr_json}"
}

# Writes the fingerprint to the fingerprint file for a given PR ID.
save_pr_fingerprint() {
    local item_id="$1" fingerprint="$2"
    local fingerprint_file

    fingerprint_file=$(pr_fingerprint_file_path "${item_id}")
    mkdir -p "${SESSION_BASE_DIR}" || die "Failed to create session directory: ${SESSION_BASE_DIR}"
    printf '%s\n' "${fingerprint}" \
        > "${fingerprint_file}" \
        || die "Failed to write fingerprint file: ${fingerprint_file}"
}

# Reads and outputs the saved fingerprint for a given PR ID, or empty string if none exists.
load_pr_fingerprint() {
    local item_id="$1"
    local fingerprint_file

    fingerprint_file=$(pr_fingerprint_file_path "${item_id}")
    if [ -f "${fingerprint_file}" ]; then
        cat "${fingerprint_file}"
    fi
}

# Returns 0 (true) if the pre-fetched PR JSON contains a label named 'blocked' (case-insensitive).
pr_json_has_blocked_label() {
    local pr_json="$1"
    printf '%s' "${pr_json}" | jq -r '.labels[].name' | grep -qi '^blocked$'
}

# Returns the path to the fingerprint file for a given Issue ID.
issue_fingerprint_file_path() {
    local item_id="$1"
    printf '%s/Issue_%s.fingerprint' "${SESSION_BASE_DIR}" "${item_id}"
}

# Fetches the Issue state JSON used for fingerprinting; returns 1 on gh failure.
fetch_issue_json() {
    local item_id="$1"
    gh issue view "${item_id}" \
        --repo "${REPO_FULL}" \
        --json title,body,state,labels,comments,assignees,milestone || return 1
}

# Computes a deterministic fingerprint from pre-fetched Issue state JSON.
# Outputs the hash on stdout; returns non-zero if jq fails.
fingerprint_issue_json() {
    local issue_json="$1"
    printf '%s' "${issue_json}" | jq -r '
        .title,
        (.body // ""),
        .state,
        ([((.labels // [])[] | .name)] | sort | .[]),
        ((.comments // []) | length | tostring),
        ([((.comments // [])[] | [(.updatedAt // "none"), (.body // "")] | @tsv)] | sort | join("\n")),
        ([((.assignees // [])[] | .login)] | sort | join(",")),
        (.milestone.title // "none")
    ' | hash_sha256
}

# Computes a deterministic hash of the Issue's current state using a single gh issue view call.
# Outputs the hash on stdout; returns non-zero if the gh call or jq fails.
compute_issue_fingerprint() {
    local item_id="$1"
    local issue_json
    issue_json=$(fetch_issue_json "${item_id}") || return 1
    fingerprint_issue_json "${issue_json}"
}

# Writes the fingerprint to the fingerprint file for a given Issue ID.
save_issue_fingerprint() {
    local item_id="$1" fingerprint="$2"
    local fingerprint_file

    fingerprint_file=$(issue_fingerprint_file_path "${item_id}")
    mkdir -p "${SESSION_BASE_DIR}" || die "Failed to create session directory: ${SESSION_BASE_DIR}"
    printf '%s\n' "${fingerprint}" \
        > "${fingerprint_file}" \
        || die "Failed to write fingerprint file: ${fingerprint_file}"
}

# Reads and outputs the saved fingerprint for a given Issue ID, or empty string if none exists.
load_issue_fingerprint() {
    local item_id="$1"
    local fingerprint_file

    fingerprint_file=$(issue_fingerprint_file_path "${item_id}")
    if [ -f "${fingerprint_file}" ]; then
        cat "${fingerprint_file}"
    fi
}

# Returns 0 (true) if the pre-fetched Issue JSON contains a label named 'blocked' (case-insensitive).
issue_json_has_blocked_label() {
    local issue_json="$1"
    printf '%s' "${issue_json}" | jq -r '.labels[].name' | grep -qi '^blocked$'
}

main() {
    check_required_tools

    ensure_rules_current
    ensure_repo_current

    local top_item item_id item_type item_priority linked_pr prompt new_session_id

    info "Fetching priorities from ${PRIORITIES_URL}..."
    top_item=$(fetch_top_priority)

    if [ -z "${top_item}" ] || [ "${top_item}" = "null" ]; then
        success "No open work items for ${REPO_FULL}"
        exit 0
    fi

    item_id=$(printf '%s' "${top_item}" | jq -r '.id')
    item_type=$(printf '%s' "${top_item}" | jq -r '.itemType')
    item_priority=$(printf '%s' "${top_item}" | jq -r '.priority')

    [[ "${item_id}" =~ ^[0-9]+$ ]] || die "Non-numeric id from priorities API: ${item_id}"
    case "${item_type}" in
        Issue|PullRequest) ;;
        *) die "Unexpected itemType from priorities API: ${item_type}" ;;
    esac

    info "Top priority item: ${item_type} #${item_id} (priority level ${item_priority})"

    # When an issue already has a linked pull request, work on the PR directly.
    # First check the priorities API (cheap), then fall back to a live GitHub query.
    if [ "${item_type}" = "Issue" ]; then
        linked_pr=$(printf '%s' "${top_item}" | jq -r '(.linkedPrNumbers // []) | first // empty')
        if [ -z "${linked_pr}" ]; then
            info "No linked PR in priorities API for Issue #${item_id} — querying GitHub directly..."
            linked_pr=$(find_linked_pr_on_github "${item_id}") \
                || info "GitHub PR lookup failed for Issue #${item_id} — proceeding as issue"
        fi
        if [ -n "${linked_pr}" ]; then
            [[ "${linked_pr}" =~ ^[0-9]+$ ]] || die "Non-numeric linked PR number: ${linked_pr}"
            info "Issue #${item_id} has linked PR #${linked_pr} — switching to PR workflow"
            item_id="${linked_pr}"
            item_type="PullRequest"
        fi
    fi

    if [ "${item_type}" = "Issue" ]; then
        local issue_json issue_state current_fingerprint saved_fingerprint
        issue_json=$(fetch_issue_json "${item_id}") \
            || die "Failed to fetch state for Issue #${item_id} from GitHub"

        issue_state=$(printf '%s' "${issue_json}" | jq -r '.state')
        if [ "${issue_state}" != "OPEN" ]; then
            success "Issue #${item_id} is no longer open on GitHub — skipping"
            exit 0
        fi

        if issue_json_has_blocked_label "${issue_json}"; then
            info "Issue #${item_id} has the 'blocked' label — skipping"
            exit 0
        fi

        current_fingerprint=$(fingerprint_issue_json "${issue_json}") \
            || die "Failed to compute fingerprint for Issue #${item_id}"
        saved_fingerprint=$(load_issue_fingerprint "${item_id}")

        if [ -n "${saved_fingerprint}" ] && [ "${current_fingerprint}" = "${saved_fingerprint}" ]; then
            info "Issue #${item_id} state unchanged since last run — skipping"
            exit 0
        fi
    else
        info "Verifying ${item_type} #${item_id} is still open on GitHub..."
        check_item_open "${item_type}" "${item_id}"
        case $? in
            0) ;;
            1) success "${item_type} #${item_id} is no longer open on GitHub — skipping"
               exit 0 ;;
            *) die "Failed to determine GitHub state of ${item_type} #${item_id} — aborting to avoid skipping valid work" ;;
        esac
    fi

    if [ "${item_type}" = "PullRequest" ]; then
        local pr_json current_fingerprint saved_fingerprint
        pr_json=$(fetch_pr_json "${item_id}") \
            || die "Failed to fetch state for PR #${item_id} from GitHub"

        if pr_json_has_blocked_label "${pr_json}"; then
            info "PR #${item_id} has the 'blocked' label — skipping"
            exit 0
        fi

        current_fingerprint=$(fingerprint_pr_json "${pr_json}") \
            || die "Failed to compute fingerprint for PR #${item_id}"
        saved_fingerprint=$(load_pr_fingerprint "${item_id}")

        if [ -n "${saved_fingerprint}" ] && [ "${current_fingerprint}" = "${saved_fingerprint}" ]; then
            info "PR #${item_id} state unchanged since last run — skipping"
            exit 0
        fi
    fi

    load_session "${item_type}" "${item_id}"

    if [ -n "${SESSION_ID}" ]; then
        info "Resuming existing session for ${item_type} #${item_id}"
    else
        info "No existing session — starting fresh for ${item_type} #${item_id}"
    fi

    local ai_instructions
    ai_instructions=$(find_ai_instructions) || exit 1

    if [ "${item_type}" = "Issue" ]; then
        prompt=$(build_issue_prompt "${item_id}" "${ai_instructions}")
    else
        prompt=$(build_pr_prompt "${item_id}" "${ai_instructions}")
    fi

    [ -n "${prompt}" ] || die "prompt is empty for ${item_type} #${item_id}"

    new_session_id=$(invoke_claude "${prompt}" "${SESSION_ID}") \
        || die "Failed to invoke Claude"

    save_session "${item_type}" "${item_id}" "${new_session_id}"
    success "Session ${new_session_id} saved for ${item_type} #${item_id}"

    if [ "${item_type}" = "PullRequest" ]; then
        local current_fingerprint
        current_fingerprint=$(compute_pr_fingerprint "${item_id}") \
            || die "Failed to compute fingerprint for PR #${item_id}"
        save_pr_fingerprint "${item_id}" "${current_fingerprint}"
    elif [ "${item_type}" = "Issue" ]; then
        local post_run_fingerprint
        post_run_fingerprint=$(compute_issue_fingerprint "${item_id}") \
            || die "Failed to compute fingerprint for Issue #${item_id}"
        save_issue_fingerprint "${item_id}" "${post_run_fingerprint}"
    fi
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
